---
import Header from '../components/Header.astro';
import SearchPalette from '../components/SearchPalette.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Manifesto from '../components/Manifesto.astro';
import AmbientForest from '../components/AmbientForest.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

// Préchargement des 2 polices critiques above-the-fold — ?url résout vers le fichier hashé final
import loraDisplayUrl from '@fontsource/lora/files/lora-latin-400-normal.woff2?url';
import dmSansBodyUrl from '@fontsource-variable/dm-sans/files/dm-sans-latin-opsz-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const {
  title,
  description,
  image = '/og-image.jpg',
  canonical,
  noindex = false,
  schema,
} = Astro.props;

const siteUrl     = 'https://caelestis.fr';
// Toujours pointer vers le domaine principal — évite les doublons si le site
// est accessible sur plusieurs domaines (Vercel preview, www, etc.)
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImage      = image.startsWith('http') ? image : `${siteUrl}${image}`;

// JSON-LD — accepte un objet unique ou un tableau
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <!-- minimum-scale=1 : empêche le dézoom sous 100 % sur mobile (page toujours pleine),
         SANS bloquer le zoom-avant (accessibilité WCAG 1.4.4 préservée, pas de user-scalable=no) -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, viewport-fit=cover" />
    <!-- ── Reveal tactile — anti-flash + failsafe ──
         Sur pointeur grossier (mobile), GSAP n'est pas chargé : on pose .reveal-js
         AVANT le paint pour que les apparitions soient gérées en CSS/IO. Le failsafe
         garantit que le contenu devient visible même si le module d'animation échoue. -->
    <script is:inline>
    (function(){
      try{
        var coarse = matchMedia('(hover: none) and (pointer: coarse)').matches;
        var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if(!coarse || reduce) return;
        document.documentElement.classList.add('reveal-js');
        window.__caelRevealFailsafe = setTimeout(function(){
          if(window.__caelRevealActive) return;
          var els = document.querySelectorAll('[data-reveal]:not(.is-visible)');
          for(var i=0;i<els.length;i++) els[i].classList.add('is-visible');
        }, 2600);
      }catch(_){}
    })();
    </script>
    <!-- ── GA4 — chargé uniquement après consentement CNIL ── -->
    <script is:inline>
    (function(){
      var GA='G-CE8L11103N';var loaded=false;
      /* Helper de tracking global — no-op tant que le consentement n'est pas donné (CNIL) */
      window.caelTrack=function(name,params){try{if(typeof window.gtag==='function')window.gtag('event',name,params||{});}catch(e){}};
      function load(){
        if(loaded)return;loaded=true;
        window.dataLayer=window.dataLayer||[];
        window.gtag=function(){window.dataLayer.push(arguments);};
        window.gtag('js',new Date());
        window.gtag('config',GA,{send_page_view:false,anonymize_ip:true});
        var s=document.createElement('script');s.async=true;
        s.src='https://www.googletagmanager.com/gtag/js?id='+GA;
        document.head.appendChild(s);
      }
      function consent(){
        try{var d=JSON.parse(localStorage.getItem('caelestis-cookies')||'null');
          return d&&d.exp&&Date.now()<d.exp?d.value:null;}catch(e){return null;}
      }
      if(consent()==='accepted')load();
      window.addEventListener('caelestis:consent-accepted',load);
      document.addEventListener('astro:page-load',function(){
        if(!loaded)return;
        window.gtag('event','page_view',{page_location:location.href,page_title:document.title});
      });
    })();
    </script>
    <!-- ── SEO de base ── -->
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <meta name="author" content="Célestin Fruleux, Caelestis" />
    <meta name="theme-color" content="#3d4f28" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonicalUrl} />
    {!noindex && <link rel="alternate" hreflang="fr" href={canonicalUrl} />}
    {!noindex && <link rel="alternate" hreflang="x-default" href={canonicalUrl} />}

    <!-- ── Géolocalisation — SEO local Drôme ── -->
    <meta name="geo.region"   content="FR-26" />
    <meta name="geo.placename" content="Crest, Drôme, France" />
    <meta name="geo.position" content="44.7308;5.0197" />
    <meta name="ICBM"         content="44.7308, 5.0197" />

    <!-- ── PWA / mobile ── -->
    <meta name="mobile-web-app-capable"                content="yes" />
    <meta name="apple-mobile-web-app-capable"          content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title"            content="Caelestis" />

    <!-- ── Open Graph ── -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={canonicalUrl} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={ogImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={title} />
    <meta property="og:locale"       content="fr_FR" />
    <meta property="og:site_name"    content="Caelestis" />

    <!-- ── Twitter / X Card ── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- ── Fonts — auto-hébergées via fontsource (pas de requête externe) ── -->
    <!-- Preload des 2 polices critiques above-the-fold (titres Lora + corps DM Sans) → LCP plus rapide -->
    <link rel="preload" href={loraDisplayUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={dmSansBodyUrl} as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- ── Icônes ── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=9" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=9" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=9" />
    <link rel="icon" type="image/png" href="/favicon.png?v=9" />
    <link rel="icon" type="image/x-icon"  href="/favicon.ico?v=9" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=9" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>
    <ClientRouter />

    <!-- ── Slot pour les preloads / ressources spécifiques à une page ── -->
    <slot name="head" />

    <!-- ── JSON-LD Structured Data ── -->
    <!-- Échappement de < > / pour éviter l'injection via </script> dans une valeur JSON -->
    {schemas.map((s) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/\//g, '\\u002f')} />
    ))}
  </head>
  <body>
    <!-- ── Lien "Aller au contenu" — WCAG 2.4.1 (A) ── -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[99999] focus:bg-cream focus:text-brun focus:px-5 focus:py-2.5 focus:rounded-full focus:font-body focus:text-sm focus:font-medium focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-sauge"
    >
      Aller au contenu principal
    </a>

<Header />
    <SearchPalette />

    <!-- ── Bannière consentement audio ── -->
    <div
      id="audio-banner"
      role="region"
      aria-label="Activation du son ambiant"
      class="fixed top-16 left-0 right-0 z-[51] flex items-center justify-center py-3 bg-cream/96 backdrop-blur-md border-b border-cream-dark/50"
      style="transform: translateY(-110%); opacity: 0; pointer-events: none;"
    >
      <div class="flex items-center gap-5">

      <!-- Icône + texte -->
      <div class="flex items-center gap-3">
        <svg viewBox="0 0 26 22" width="18" height="15" fill="none" aria-hidden="true" class="text-sauge flex-shrink-0">
          <path d="M13 12 C10 10 6 11 2 9"  stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M13 12 C16 10 20 11 24 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <ellipse cx="13" cy="13.5" rx="2.8" ry="2" fill="currentColor"/>
          <circle cx="15.5" cy="11.5" r="2" fill="currentColor"/>
          <path d="M17.2 11 L20.5 10.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        <p class="font-body text-xs text-brun-mid">
          Activer les <span class="text-[#5A653A] font-medium">sons de forêt</span> en fond ?
        </p>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <button
          id="audio-yes"
          class="font-body text-[11px] font-medium tracking-wide text-cream bg-[#5A653A] px-4 py-1.5 rounded-full hover:bg-brun transition-colors duration-200 cursor-pointer"
        >
          Activer
        </button>
        <button
          id="audio-no"
          class="font-body text-[11px] text-brun-mid/75 hover:text-brun transition-colors duration-200 px-3 py-1.5 cursor-pointer"
        >
          Non merci
        </button>
      </div>

      </div> <!-- fin wrapper centré -->
    </div>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <Cursor />
    <Manifesto />
    <AmbientForest />
    <CookieBanner />

    <!-- ── Oiseau fixe bas-droite — même sync que navbar ── -->
    <button
      class="sound-btn fixed-bird"
      aria-label="Activer le son de la forêt"
      title="Sons de la forêt"
    >
      <span class="bird-wrap">
        <span class="b-notes" aria-hidden="true">
          <span class="b-note-1">♪</span>
          <span class="b-note-2">♫</span>
          <span class="b-note-3">♩</span>
        </span>
        <svg class="bird-icon" viewBox="0 0 26 22" width="40" height="33" fill="none" aria-hidden="true">
          <path class="b-wing-l" d="M13 12 C10 10 6 11 2 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path class="b-wing-r" d="M13 12 C16 10 20 11 24 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <ellipse cx="13" cy="13.5" rx="2.8" ry="2" fill="currentColor"/>
          <circle cx="15.5" cy="11.5" r="2" fill="currentColor"/>
          <path d="M17.2 11 L20.5 10.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line class="b-mute-line" x1="2" y1="1" x2="24" y2="21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" opacity="0"/>
        </svg>
      </span>
    </button>

    <style is:global>
      .fixed-bird {
        position: fixed;
        bottom: 1.8rem;
        right: 1.25rem;
        z-index: 9985;
        padding: 12px;
        border-radius: 50%;
        background: rgba(237, 227, 212, 0.84);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(76, 61, 25, 0.14);
        box-shadow: 0 4px 18px rgba(76, 61, 25, 0.09);
        transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
        color: rgba(136, 112, 64, 0.60);
      }
      .fixed-bird:hover {
        background: rgba(237, 227, 212, 0.97);
        box-shadow: 0 6px 24px rgba(76, 61, 25, 0.14);
        transform: translateY(-2px);
        color: #354024;
      }
      .fixed-bird .b-notes {
        top: -10px;
        font-size: 11px;
        gap: 4px;
      }
    </style>
  </body>
</html>

<script>
  /* ═══════════════════════════════════════════════════════
     Bannière consentement audio — vanilla, sans GSAP
  ═══════════════════════════════════════════════════════ */
  (function initAudioBanner() {
    const banner = document.getElementById('audio-banner') as HTMLElement | null;
    const btnYes = document.getElementById('audio-yes')   as HTMLButtonElement | null;
    const btnNo  = document.getElementById('audio-no')    as HTMLButtonElement | null;

    if (!banner) return;

    /* Affiche la bannière une seule fois par session de navigation */
    if (sessionStorage.getItem('caelestis-audio-seen')) return;
    sessionStorage.setItem('caelestis-audio-seen', '1');

    /* Affiche la bannière après 2s avec CSS transition */
    setTimeout(() => {
      banner.style.pointerEvents = 'auto';
      banner.style.transition = 'transform 0.55s cubic-bezier(0.22,1,0.36,1), opacity 0.55s ease';
      banner.style.transform  = 'translateY(0)';
      banner.style.opacity    = '1';
    }, 2000);

    function hideBanner(accepted: boolean) {
      banner!.style.transition = 'transform 0.4s ease-in, opacity 0.4s ease-in';
      banner!.style.transform  = 'translateY(-110%)';
      banner!.style.opacity    = '0';
      banner!.style.pointerEvents = 'none';
      if (accepted) {
        window.dispatchEvent(new CustomEvent('caelestis:audio-enable'));
      }
    }

    btnYes?.addEventListener('click', () => hideBanner(true));
    btnNo?.addEventListener('click',  () => hideBanner(false));
  })();

  /* ═══════════════════════════════════════════════════════
     GSAP + Lenis — chargement asynchrone après le rendu
  ═══════════════════════════════════════════════════════ */
  type GsapType = typeof import('gsap')['default'];
  type StType   = typeof import('gsap/ScrollTrigger')['ScrollTrigger'];

  /** Interface minimale de l'instance Lenis dont on se sert */
  interface LenisInstance {
    raf(time: number): void;
    destroy(): void;
    on(event: string, callback: () => void): void;
  }

  let gsap: GsapType;
  let ScrollTrigger: StType;
  let Lenis: (new(opts?: { duration?: number; easing?: (t: number) => number; smoothWheel?: boolean; smoothTouch?: boolean; touchMultiplier?: number }) => LenisInstance) | undefined;
  let lenis: LenisInstance | null = null;
  let gsapReady = false;

  /* Tactile (pointeur grossier) : pas de smooth-scroll JS — détecté une seule fois */
  const prefersCoarse = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

  /* Référence au ticker pour pouvoir le retirer avant d'en ajouter un nouveau.
     Sans ça, chaque navigation empile un callback supplémentaire → scroll
     2×, 3×, N× trop rapide après plusieurs changements de page. */
  let lenisTicker: ((time: number) => void) | null = null;

  async function loadGsap() {
    if (gsapReady) return;
    const [gsapMod, stMod] = await Promise.all([
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]);
    gsap          = gsapMod.default;
    ScrollTrigger = stMod.ScrollTrigger;
    gsap.registerPlugin(ScrollTrigger);
    /* Lenis (smooth scroll) : desktop à pointeur fin uniquement.
       Sur tactile, le scroll natif est déjà fluide — on évite ~17 Ko de JS. */
    if (!prefersCoarse) {
      const lenisMod = await import('lenis');
      Lenis = lenisMod.default;
    }
    gsapReady = true;
  }

  function initLenis() {
    /* Nettoie l'ancienne instance et son ticker avant tout */
    if (lenisTicker) { gsap.ticker.remove(lenisTicker); lenisTicker = null; }
    if (lenis) { lenis.destroy(); lenis = null; }

    /* Sur écrans tactiles purs (mobile), Lenis n'est même pas chargé :
       le scroll natif iOS/Android est déjà parfaitement fluide et
       Lenis peut introduire de la latence tactile. */
    if (prefersCoarse || !Lenis) return;

    lenis = new Lenis({
      duration:       1.1,   /* réduit vs 1.4 → moins "swimmy" */
      easing:         (t: number) => 1 - Math.pow(1 - t, 4),  /* quartic ease-out : départ vif, fin douce */
      smoothWheel:    true,
      smoothTouch:    false, /* touch natif sur mobiles hybrides */
      touchMultiplier: 1.5,
    });
    lenis.on('scroll', ScrollTrigger.update);

    lenisTicker = (time: number) => { lenis!.raf(time * 1000); };
    gsap.ticker.add(lenisTicker);
    gsap.ticker.lagSmoothing(500, 33); /* laisse GSAP compenser les frames longues */
  }

  function initAnimations(isFirstLoad = true) {
    ScrollTrigger.getAll().forEach((t) => t.kill());

    /* Respect prefers-reduced-motion — WCAG 2.3.3 (AAA) / bonne pratique AA */
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      /* Rend tous les éléments visibles sans animation */
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      document.querySelectorAll<HTMLElement>('.sl > *').forEach(el => {
        (el as HTMLElement).style.transform = 'translateY(0%)';
      });
      return;
    }

    /* ── 1. Scroll reveal — apparition élégante, lente ── */
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      /* Navigation (pas le 1er chargement) : on affiche directement, sans rejouer
         l'apparition — sinon le contenu repasse par opacity:0 et « flashe » par
         dessus la transition de page (même symptôme que celui corrigé sur mobile). */
      if (!isFirstLoad) { gsap.set(el, { opacity: 1, y: 0 }); return; }
      const delayMap: Record<string, number> = { '0': 0, '1': 0.1, '2': 0.2, '3': 0.32, '4': 0.45, '5': 0.58 };
      const delay = delayMap[el.dataset.delay ?? ''] ?? 0;
      const inlineDelay = el.style.transitionDelay
        ? parseFloat(el.style.transitionDelay)
        : 0;
      gsap.fromTo(el,
        { opacity: 0, y: 34 },
        {
          opacity: 1, y: 0,
          duration: 1.0,
          delay: delay + inlineDelay,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 91%',
            toggleActions: 'play none none none',
          },
        }
      );
    });

    /* ── 2. Split text — éditorial, power4 pour décélération luxe ── */
    document.querySelectorAll<HTMLElement>('[data-split], [data-split-hero]').forEach((el) => {
      const isHero = el.hasAttribute('data-split-hero');
      const baseDelay = isHero ? 0.04 : 0.03;
      el.querySelectorAll<HTMLElement>('.sl > *').forEach((line, i) => {
        gsap.fromTo(line,
          { y: '110%' },
          {
            y: '0%',
            duration: 1.15,
            delay: baseDelay + i * 0.11,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 95%',
              toggleActions: 'play none none none',
            },
          }
        );
      });
    });

    /* ── 3. Parallax GSAP scrub doux ── */
    document.querySelectorAll<HTMLElement>('[data-parallax]').forEach((el) => {
      gsap.fromTo(el,
        { yPercent: -8 },
        {
          yPercent: 8,
          ease: 'none',
          scrollTrigger: {
            trigger: el.parentElement ?? el,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2,
          },
        }
      );
    });

    /* ── 4. Light blobs — dérive très lente au scroll ── */
    document.querySelectorAll<HTMLElement>('.light-blob').forEach((blob, i) => {
      const dir = i % 2 === 0 ? -1 : 1;
      gsap.to(blob, {
        yPercent: dir * 18,
        xPercent: dir * 5,
        ease: 'none',
        scrollTrigger: {
          trigger: blob.parentElement ?? blob,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 2,
        },
      });
    });

    /* ── 5. Image zoom GSAP au survol ── */
    document.querySelectorAll<HTMLElement>('.img-zoom').forEach((container) => {
      const img = container.querySelector<HTMLElement>('img');
      if (!img) return;
      container.addEventListener('mouseenter', () => {
        gsap.to(img, { scale: 1.055, duration: 0.9, ease: 'power2.out', overwrite: 'auto' });
      });
      container.addEventListener('mouseleave', () => {
        gsap.to(img, { scale: 1, duration: 0.9, ease: 'power2.inOut', overwrite: 'auto' });
      });
    });

    /* ── 6. Boutons magnétiques ── */
    document.querySelectorAll<HTMLElement>('.btn-magnetic').forEach((btn) => {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width  / 2) * 0.28;
        const y = (e.clientY - rect.top  - rect.height / 2) * 0.36;
        gsap.to(btn, { x, y, duration: 0.18, ease: 'power2.out' });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.7, ease: 'elastic.out(1, 0.38)' });
      });
    });

    /* ── 7. Compteurs animés (data-counter) ── */
    document.querySelectorAll<HTMLElement>('[data-counter]').forEach((el) => {
      const target = parseFloat(el.dataset.counter ?? '0');
      const suffix = el.dataset.suffix ?? '';
      gsap.fromTo({ val: 0 }, { val: target },
        {
          duration: 2.0,
          ease: 'power2.out',
          onUpdate: function() { el.textContent = Math.round(this.targets()[0].val) + suffix; },
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        }
      );
    });

    /* ── 8. Fil botanique — se trace au scroll ── */
    const vinePath = document.getElementById('vine-path');
    if (vinePath instanceof SVGGeometryElement) {
      const len = vinePath.getTotalLength();
      gsap.set(vinePath, { strokeDasharray: len, strokeDashoffset: len });
      gsap.to(vinePath, {
        strokeDashoffset: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: 'main',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 2.5,
        },
      });
    }

    /* ── 9. Scroll indicator — respiration douce ── */
    const scrollIndicator = document.querySelector<HTMLElement>('.scroll-indicator');
    if (scrollIndicator) {
      gsap.to(scrollIndicator, {
        y: -6,
        opacity: 0.6,
        duration: 2.2,
        ease: 'power1.inOut',
        yoyo: true,
        repeat: -1,
      });
    }
  }

  /* ── Reveal léger sur tactile — remplace GSAP/ScrollTrigger sur mobile ──
     IntersectionObserver vanilla : 0 dépendance, ~110 Ko de JS en moins. */
  type CaelWindow = Window & { __caelRevealActive?: boolean; __caelRevealFailsafe?: number };
  function initRevealMobile() {
    const w = window as CaelWindow;
    w.__caelRevealActive = true;                 /* neutralise le failsafe inline */
    if (w.__caelRevealFailsafe) { clearTimeout(w.__caelRevealFailsafe); w.__caelRevealFailsafe = undefined; }

    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.05, rootMargin: '0px 0px -7% 0px' });
    els.forEach((el) => io.observe(el));
  }

  /* ── Boot : sur tactile, reveal natif sans GSAP ; sur desktop, GSAP complet ── */
  async function boot() {
    if (prefersCoarse) { initRevealMobile(); return; }
    await loadGsap();
    initLenis();
    initAnimations();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  /* ── View Transitions sur tactile : on AFFICHE directement le contenu de la
     nouvelle page, sans rejouer l'animation d'entrée. Rejouer le reveal à
     chaque navigation provoquait un flash / « double affichage » (le contenu
     repassait à opacity:0 puis ré-apparaissait par-dessus la transition de
     page). L'effet d'apparition ne joue donc qu'au tout premier chargement.
     On retire .reveal-js (plus de masquage) et on marque tout comme visible,
     AVANT le paint — donc sans aucun flash. ── */
  document.addEventListener('astro:after-swap', () => {
    if (prefersCoarse) {
      /* Tactile : retire le masquage et marque tout visible. */
      document.documentElement.classList.remove('reveal-js');
      document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-visible'));
    } else {
      /* Desktop : révèle directement, AVANT le paint, pour qu'aucune frame ne
         passe par opacity:0 (GSAP, chargé en async, prend la main ensuite mais
         seulement pour les effets de scroll — plus pour l'apparition). */
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });

  /* ── Relance après chaque navigation View Transitions ── */
  document.addEventListener('astro:page-load', async () => {
    if (prefersCoarse) return;   /* tactile : déjà géré dans astro:after-swap */
    await loadGsap();
    initLenis();
    initAnimations(false);   /* navigation : pas de ré-animation d'entrée (anti-flash) */
  });
</script>
