---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: extraClass = '' } = Astro.props;

const base = 'inline-block font-body font-medium text-sm tracking-[0.04em] transition-all duration-300';
const variants = {
  primary: 'btn-primary-pulse bg-ocre text-cream px-8 py-4 rounded-full hover:bg-ocre-dark btn-magnetic',
  outline: 'border border-brun/70 text-brun px-8 py-4 rounded-full hover:bg-brun hover:text-cream hover:border-brun btn-magnetic',
  ghost:   'text-ocre underline-offset-4 hover:underline opacity-80 hover:opacity-100',
};
---
<a href={href} class={`${base} ${variants[variant]} ${extraClass}`}>
  <slot />
</a>
