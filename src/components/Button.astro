---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: extraClass = '' } = Astro.props;

const base = 'inline-block font-body font-medium text-sm transition-colors duration-200';
const variants = {
  primary: 'bg-ocre text-cream px-8 py-4 hover:bg-ocre-dark',
  outline: 'border border-brun text-brun px-8 py-4 hover:bg-brun hover:text-cream',
  ghost:   'text-ocre underline-offset-4 hover:underline',
};
---
<a href={href} class={`${base} ${variants[variant]} ${extraClass}`}>
  <slot />
</a>
