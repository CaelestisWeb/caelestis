---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: extraClass = '' } = Astro.props;

const base = 'inline-flex items-center justify-center font-body font-medium text-sm tracking-[0.04em] transition-all duration-300 min-h-[44px]';
const variants = {
  primary: 'btn-primary-pulse bg-sauge text-cream px-8 py-3 rounded-full hover:opacity-85 btn-magnetic',
  outline: 'border border-sauge/70 text-sauge px-8 py-3 rounded-full hover:bg-sauge hover:text-cream hover:border-sauge btn-magnetic',
  ghost:   'text-ocre underline-offset-4 hover:underline opacity-80 hover:opacity-100',
};
---
<a href={href} class={`${base} ${variants[variant]} ${extraClass}`}>
  <slot />
</a>
