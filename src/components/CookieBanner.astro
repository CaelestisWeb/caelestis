<!-- ─── Bandeau consentement cookies — conforme CNIL lignes directrices 2020 ─── -->
<div
  id="cookie-banner"
  role="dialog"
  aria-label="Consentement aux cookies"
  aria-modal="false"
  aria-describedby="cookie-banner-desc"
  class="fixed bottom-0 left-0 right-0 z-[9990] translate-y-full opacity-0 pointer-events-none"
>
  <div class="bg-cream/97 backdrop-blur-md border-t border-cream-dark/40 shadow-[0_-8px_32px_rgba(53,64,36,0.10)]">
    <div class="max-w-5xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-8">

      <!-- Texte -->
      <div class="flex-1 min-w-0">
        <div>
          <p id="cookie-banner-desc" class="font-body text-[13px] text-brun leading-relaxed">
            <strong class="font-semibold">Ce site Caelestis</strong> utilise des cookies techniques nécessaires
            à son fonctionnement et, avec votre accord, Google Analytics pour mesurer la fréquentation. Aucune publicité, aucune donnée revendue.
            <a href="/politique-confidentialite" class="text-[#5A653A] underline underline-offset-2 hover:text-brun transition-colors ml-1">En savoir plus →</a>
          </p>
        </div>
      </div>

      <!-- Boutons — refus aussi accessible que l'acceptation (CNIL) -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <button
          id="cookie-decline"
          class="font-body text-[12px] font-medium text-brun-mid border border-cream-dark hover:border-brun hover:text-brun transition-colors duration-200 px-4 py-2 rounded-full cursor-pointer"
        >
          Refuser
        </button>
        <button
          id="cookie-accept"
          class="font-body text-[12px] font-medium text-cream bg-[#5A653A] hover:bg-brun transition-colors duration-200 px-5 py-2 rounded-full cursor-pointer"
        >
          Accepter
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  /* ── Durée maximale CNIL : 13 mois ── */
  const CONSENT_TTL_MS = 13 * 30 * 24 * 60 * 60 * 1000;
  const STORAGE_KEY    = 'caelestis-cookies';

  interface ConsentData {
    value: 'accepted' | 'declined';
    exp: number;
  }

  /** Lit le consentement stocké — retourne null si absent ou expiré */
  function readConsent(): ConsentData | null {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return null;
    try {
      const data = JSON.parse(raw) as ConsentData;
      if (data.exp && Date.now() < data.exp) return data;
      /* Expiré — on supprime */
      localStorage.removeItem(STORAGE_KEY);
      return null;
    } catch {
      /* Ancien format (string simple) ou JSON invalide — on supprime */
      localStorage.removeItem(STORAGE_KEY);
      return null;
    }
  }

  /** Enregistre le choix avec timestamp d'expiration (13 mois) */
  function saveConsent(value: 'accepted' | 'declined') {
    const data: ConsentData = { value, exp: Date.now() + CONSENT_TTL_MS };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  (function initCookieBanner() {
    const banner = document.getElementById('cookie-banner') as HTMLElement | null;
    if (!banner) return;

    /* Ne rien afficher si consentement valide déjà donné */
    if (readConsent() !== null) return;

    /* Affiche le bandeau après 10s — pas de focus automatique (WCAG 2.4.3 : ne pas déplacer
       le focus de façon inattendue ; l'utilisateur accède aux boutons via Tab si nécessaire) */
    setTimeout(() => {
      banner.style.transition = 'transform 0.45s cubic-bezier(0.22,1,0.36,1), opacity 0.45s ease';
      banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
      banner.classList.add('translate-y-0', 'opacity-100');
    }, 10000);

    function hideBanner() {
      banner!.style.transition = 'transform 0.35s ease-in, opacity 0.35s ease-in';
      banner!.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
      banner!.classList.remove('translate-y-0', 'opacity-100');
    }

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      saveConsent('accepted');
      hideBanner();
      window.dispatchEvent(new CustomEvent('caelestis:consent-accepted'));
    });

    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      saveConsent('declined');
      hideBanner();
    });
  })();

  /**
   * Expose une fonction globale pour réouvrir le bandeau depuis le footer.
   * Utilisé par le lien "Gérer mes préférences cookies".
   */
  (window as Window & { caelestisResetCookies?: () => void }).caelestisResetCookies = function() {
    localStorage.removeItem(STORAGE_KEY);
    /* Réinitialise la bannière */
    const banner = document.getElementById('cookie-banner') as HTMLElement | null;
    if (!banner) return;
    banner.style.transition = 'none';
    banner.classList.remove('translate-y-0', 'opacity-100');
    banner.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
    /* Réaffiche après court délai */
    setTimeout(() => {
      banner.style.transition = 'transform 0.45s cubic-bezier(0.22,1,0.36,1), opacity 0.45s ease';
      banner.style.pointerEvents = 'auto';
      banner.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
      banner.classList.add('translate-y-0', 'opacity-100');
    }, 100);
  };
</script>
