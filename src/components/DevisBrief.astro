---
---

<div class="brief-root">

  <div id="restore-banner" class="restore-banner hidden" role="alert">
    <div class="restore-inner">
      <span class="restore-dot" aria-hidden="true"></span>
      <p class="restore-msg">Réponses sauvegardées. Souhaitez-vous reprendre là où vous en étiez&nbsp;?</p>
      <div class="restore-actions">
        <button id="restore-btn" class="restore-yes">Reprendre</button>
        <button id="discard-btn" class="restore-no" aria-label="Ignorer">✕</button>
      </div>
    </div>
  </div>

  <div id="form-container" class="brief-container">

    <header class="brief-header">
      <p class="brief-overline">Caelestis. Demande de devis</p>
      <h1 class="brief-title">Parlez-moi<br>de votre projet.</h1>
      <p class="brief-subtitle">Ces questions me permettent de comprendre votre projet en détail. Avec vos réponses, je vous prépare un devis précis et personnalisé, livré sous 48h.</p>
      <div class="brief-divider" aria-hidden="true"></div>
    </header>

    <div aria-live="polite" style="display:none;">
      <span id="save-indicator" aria-label="Formulaire sauvegardé"><span id="save-time"></span></span>
    </div>

    <form id="brief-form" novalidate>

      <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>

      <!-- 01 · À propos de vous -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">01</span>
          <div>
            <p class="b-overline">Pour commencer</p>
            <h2 class="b-title">À propos de vous</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="nom_entreprise">Nom de l'entreprise</label>
              <input id="nom_entreprise" type="text" name="nom_entreprise" placeholder="Ex : Jardins Dupont" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="nom_dirigeant">Votre prénom et nom</label>
              <input id="nom_dirigeant" type="text" name="nom_dirigeant" placeholder="Ex : Jean Dupont" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="activite">Activité principale</label>
              <input id="activite" type="text" name="activite" placeholder="Ex : Artisan, producteur, thérapeute…" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="ville">Ville et département</label>
              <input id="ville" type="text" name="ville" placeholder="Ex : Valence (26)" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="email_contact">
                Email <span class="b-required" aria-label="champ obligatoire">*</span>
              </label>
              <input id="email_contact" type="email" name="email_contact" placeholder="votre@email.fr" class="b-input" required>
            </div>
            <div class="b-field">
              <label class="b-label" for="telephone">Téléphone</label>
              <input id="telephone" type="tel" name="telephone" placeholder="07 xx xx xx xx" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="site_actuel">Site internet actuel <span class="b-hint">(si vous en avez un)</span></label>
              <input id="site_actuel" type="text" name="site_actuel" placeholder="https://…" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="domaine_souhaite">Nom de domaine souhaité</label>
              <input id="domaine_souhaite" type="text" name="domaine_souhaite" placeholder="Ex : jardins-dupont.fr" class="b-input">
            </div>
          </div>
        </div>
      </section>

      <!-- 02 · Votre activité -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">02</span>
          <div>
            <p class="b-overline">Votre histoire</p>
            <h2 class="b-title">Votre activité</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <label class="b-label" for="description_activite">Décrivez votre activité en quelques phrases</label>
            <textarea id="description_activite" name="description_activite" rows="4" placeholder="Ce que vous faites, depuis combien de temps, ce qui vous tient à cœur dans ce métier…" class="b-textarea"></textarea>
          </div>
          <div class="b-field">
            <label class="b-label" for="ce_qui_vous_differencie">Ce qui vous différencie de vos concurrents</label>
            <textarea id="ce_qui_vous_differencie" name="ce_qui_vous_differencie" rows="3" placeholder="Votre approche, votre expérience, votre façon de travailler…" class="b-textarea"></textarea>
          </div>
          <div class="b-field">
            <span class="b-label" id="type-client-legend">Clientèle ciblée</span>
            <div class="b-chips b-chips-wrap" role="group" aria-labelledby="type-client-legend">
              <label class="b-chip"><input type="checkbox" name="type_client" value="particuliers" class="b-chip-input"><span>Particuliers</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="professionnels" class="b-chip-input"><span>Professionnels (B2B)</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="collectivites" class="b-chip-input"><span>Collectivités</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="associations" class="b-chip-input"><span>Associations</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="autre" class="b-chip-input"><span>Autre</span></label>
            </div>
            <div id="type_client-autre" class="b-reveal hidden">
              <input type="text" name="type_client_autre" aria-label="Précisez votre clientèle" placeholder="Précisez votre clientèle…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="zone_geo">Zone géographique desservie</label>
            <input id="zone_geo" type="text" name="zone_geo" placeholder="Ex : Drôme et Ardèche, toute la France, international…" class="b-input">
          </div>
        </div>
      </section>

      <!-- 03 · Vos services -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">03</span>
          <div>
            <p class="b-overline">Ce que vous proposez</p>
            <h2 class="b-title">Vos services</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label">Vos principales prestations</span>
            <div class="b-services">
              <div class="b-service-row"><span class="b-service-num" aria-hidden="true">1</span><input type="text" name="service_1" aria-label="Prestation 1" placeholder="Ex : Création et aménagement de jardins" class="b-input"></div>
              <div class="b-service-row"><span class="b-service-num" aria-hidden="true">2</span><input type="text" name="service_2" aria-label="Prestation 2" placeholder="Ex : Entretien régulier" class="b-input"></div>
              <div class="b-service-row"><span class="b-service-num" aria-hidden="true">3</span><input type="text" name="service_3" aria-label="Prestation 3 (optionnelle)" placeholder="Prestation 3 (optionnelle)" class="b-input"></div>
              <div class="b-service-row"><span class="b-service-num" aria-hidden="true">4</span><input type="text" name="service_4" aria-label="Prestation 4 (optionnelle)" placeholder="Prestation 4 (optionnelle)" class="b-input"></div>
              <div class="b-service-row"><span class="b-service-num" aria-hidden="true">5</span><input type="text" name="service_5" aria-label="Prestation 5 (optionnelle)" placeholder="Prestation 5 (optionnelle)" class="b-input"></div>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="tarifs-legend">Afficher les tarifs sur le site ?</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="tarifs-legend">
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="oui" class="b-chip-input"><span>Oui, mes prix</span></label>
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="sur_demande" class="b-chip-input"><span>Sur demande uniquement</span></label>
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="non" class="b-chip-input"><span>Non</span></label>
            </div>
          </div>
        </div>
      </section>

      <!-- 04 · Votre futur site -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">04</span>
          <div>
            <p class="b-overline">Votre vision</p>
            <h2 class="b-title">Votre futur site</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="type-site-legend">Type de site</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="type-site-legend">
              <label class="b-chip"><input type="radio" name="type_site" value="vitrine" class="b-chip-input"><span>Site vitrine</span></label>
              <label class="b-chip"><input type="radio" name="type_site" value="boutique_en_ligne" class="b-chip-input"><span>Boutique en ligne</span></label>
              <label class="b-chip"><input type="radio" name="type_site" value="sur_mesure" class="b-chip-input"><span>Site sur mesure</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="objectifs-legend">Objectifs principaux</span>
            <div class="b-check-grid" role="group" aria-labelledby="objectifs-legend">
              <label class="b-check"><input type="checkbox" name="objectifs" value="visibilite" class="b-check-input"><span>Gagner en visibilité</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="prospects" class="b-check-input"><span>Attirer des prospects</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="vente_ligne" class="b-check-input"><span>Vendre en ligne</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="notoriete" class="b-check-input"><span>Renforcer la notoriété</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="credibilite" class="b-check-input"><span>Crédibiliser l'activité</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="recrutement" class="b-check-input"><span>Faciliter le recrutement</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="objectifs-autre" class="b-reveal hidden">
              <input type="text" name="objectifs_autre" aria-label="Précisez votre objectif" placeholder="Précisez votre objectif…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="nb-pages-legend">Nombre de pages souhaitées</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="nb-pages-legend">
              <label class="b-chip"><input type="radio" name="nb_pages" value="1-4" class="b-chip-input"><span>1 à 4 pages</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="4-6" class="b-chip-input"><span>4 à 6 pages</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="6+" class="b-chip-input"><span>6 pages et plus</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="je_ne_sais_pas" class="b-chip-input"><span>Je ne sais pas encore</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label">Noms des pages souhaitées <span class="b-hint">(laissez vide les cases inutilisées)</span></span>
            <div class="b-pages-grid">
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">1</span><input type="text" name="page_1" aria-label="Nom de la page 1" placeholder="Ex : Accueil" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">2</span><input type="text" name="page_2" aria-label="Nom de la page 2" placeholder="Ex : Nos prestations" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">3</span><input type="text" name="page_3" aria-label="Nom de la page 3" placeholder="Ex : Notre histoire" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">4</span><input type="text" name="page_4" aria-label="Nom de la page 4" placeholder="Ex : Réalisations" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">5</span><input type="text" name="page_5" aria-label="Nom de la page 5" placeholder="Ex : Témoignages" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">6</span><input type="text" name="page_6" aria-label="Nom de la page 6" placeholder="Ex : Blog et actualités" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">7</span><input type="text" name="page_7" aria-label="Nom de la page 7" placeholder="Ex : FAQ" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">8</span><input type="text" name="page_8" aria-label="Nom de la page 8" placeholder="Ex : Contact" class="b-input"></div>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="fonctionnalites-legend">Fonctionnalités souhaitées</span>
            <div class="b-check-grid" role="group" aria-labelledby="fonctionnalites-legend">
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="formulaire_contact" class="b-check-input"><span>Formulaire de contact</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="galerie" class="b-check-input"><span>Galerie de photos</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="blog" class="b-check-input"><span>Blog et actualités</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="reservation" class="b-check-input"><span>Réservation en ligne</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="espace_client" class="b-check-input"><span>Espace client</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="carte" class="b-check-input"><span>Carte interactive</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="newsletter" class="b-check-input"><span>Newsletter</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="multilingue" class="b-check-input"><span>Site multilingue</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="fonctionnalites-autre" class="b-reveal hidden">
              <input type="text" name="fonctionnalites_autre" aria-label="Précisez la fonctionnalité souhaitée" placeholder="Précisez la fonctionnalité souhaitée…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="boutique-legend">Une boutique en ligne ?</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="boutique-legend">
              <label class="b-chip"><input type="radio" name="boutique_actif" value="oui" class="b-chip-input"><span>Oui</span></label>
              <label class="b-chip"><input type="radio" name="boutique_actif" value="non" class="b-chip-input"><span>Non</span></label>
            </div>
          </div>
          <div id="boutique-extra" class="b-nested hidden">
            <p class="b-nested-label">À propos de votre boutique</p>
            <div class="b-field">
              <label class="b-label" for="boutique_nb_produits">Nombre de produits approximatif</label>
              <input id="boutique_nb_produits" type="text" name="boutique_nb_produits" placeholder="Ex : 30 produits" class="b-input">
            </div>
          </div>
        </div>
      </section>

      <!-- 05 · Votre univers visuel -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">05</span>
          <div>
            <p class="b-overline">L'identité de votre site</p>
            <h2 class="b-title">Votre univers visuel</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="style-legend">L'image que vous souhaitez renvoyer</span>
            <div class="b-check-grid" role="group" aria-labelledby="style-legend">
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="moderne" class="b-check-input"><span>Moderne</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="epure" class="b-check-input"><span>Épuré et minimaliste</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="chaleureux" class="b-check-input"><span>Chaleureux</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="nature" class="b-check-input"><span>Nature et organique</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="professionnel" class="b-check-input"><span>Professionnel</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="dynamique" class="b-check-input"><span>Dynamique</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="luxe" class="b-check-input"><span>Luxe et premium</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="artisanal" class="b-check-input"><span>Artisanal</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="colore" class="b-check-input"><span>Coloré et vivant</span></label>
              <label class="b-check"><input type="checkbox" name="style_adjectifs" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="style_adjectifs-autre" class="b-reveal hidden">
              <input type="text" name="style_autre" aria-label="Décrivez l'ambiance souhaitée" placeholder="Décrivez l'ambiance souhaitée…" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="couleurs_aimees">Couleurs que vous aimez</label>
              <textarea id="couleurs_aimees" name="couleurs_aimees" rows="3" placeholder="Ex : Vert forêt, blanc cassé, touches de terracotta…" class="b-textarea"></textarea>
            </div>
            <div class="b-field">
              <label class="b-label" for="couleurs_non_aimees">Couleurs à éviter</label>
              <textarea id="couleurs_non_aimees" name="couleurs_non_aimees" rows="3" placeholder="Ex : Le rouge vif, le jaune flashy…" class="b-textarea"></textarea>
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="sites_aimes">Sites qui vous inspirent <span class="b-hint">(et ce que vous y aimez)</span></label>
            <textarea id="sites_aimes" name="sites_aimes" rows="3" placeholder="https://exemple.fr, j'aime le design épuré et les grandes photos…" class="b-textarea"></textarea>
          </div>
        </div>
      </section>

      <!-- 06 · Budget et délai -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">06</span>
          <div>
            <p class="b-overline">Organisation du projet</p>
            <h2 class="b-title">Budget et délai</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="budget-legend">Budget approximatif</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="budget-legend">
              <label class="b-chip"><input type="radio" name="budget" value="800_1000" class="b-chip-input"><span>800 à 1 000 €</span></label>
              <label class="b-chip"><input type="radio" name="budget" value="1000_2000" class="b-chip-input"><span>1 000 à 2 000 €</span></label>
              <label class="b-chip"><input type="radio" name="budget" value="2000_3000" class="b-chip-input"><span>2 000 à 3 000 €</span></label>
              <label class="b-chip"><input type="radio" name="budget" value="3000_4000" class="b-chip-input"><span>3 000 à 4 000 €</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="delai-legend">Délai de lancement souhaité</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="delai-legend">
              <label class="b-chip"><input type="radio" name="delai" value="asap" class="b-chip-input"><span>Dès que possible</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="un_mois" class="b-chip-input"><span>Dans 1 mois environ</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="trois_mois" class="b-chip-input"><span>Dans 3 mois environ</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="six_mois" class="b-chip-input"><span>Dans 6 mois ou plus</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="pas_urgent" class="b-chip-input"><span>Pas de délai particulier</span></label>
            </div>
          </div>
        </div>
      </section>

      <!-- 07 · Pour terminer -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">07</span>
          <div>
            <p class="b-overline">Pour finir</p>
            <h2 class="b-title">Quelque chose à ajouter ?</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <label class="b-label" for="message_important">Un message, une contrainte, une envie particulière ?</label>
            <textarea id="message_important" name="message_important" rows="4" placeholder="Une date butoir, une exigence spécifique, quelque chose que vous ne voulez surtout pas sur votre site, ou tout ce que vous n'avez pas pu exprimer dans les questions précédentes…" class="b-textarea"></textarea>
          </div>
        </div>
      </section>

      <div id="form-error" class="b-error hidden" role="alert">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3.5M8 11v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span id="form-error-text"></span>
      </div>

      <div class="brief-submit-wrap">
        <button id="submit-btn" type="submit" class="b-submit">
          Recevoir mon devis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

    </form>
  </div>

  <div id="success-screen" class="success-screen hidden">
    <div class="success-inner">
      <div class="success-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M5 14l6 6 12-12" stroke="#3d4f28" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <p class="success-overline">Demande reçue</p>
      <h2 class="success-title">Merci.<br>C'est noté.</h2>
      <p class="success-body">Votre demande de devis a bien été reçue. Je vais l'étudier avec soin et vous enverrai votre devis personnalisé <strong>sous 48H</strong>.</p>
      <div class="success-footer">
        <span>07 69 36 27 27</span>
        <span class="success-sep" aria-hidden="true">/</span>
        <a href="https://caelestis.fr" class="success-link">caelestis.fr</a>
      </div>
    </div>
  </div>

</div>

<style>
  .brief-root {
    --cream:       #EDE3D4;
    --cream-dark:  #CFC0A0;
    --ocre:        #4C3D19;
    --ocre-dark:   #362A10;
    --golden:      #CFBB99;
    --brun:        #3d4f28;
    --brun-mid:    #6B6040;
    --sauge:       #5C6A40;
    --sauge-pale:  #D8CDB0;
    --pierre:      #6E6852;
    --encre:       #2A1E0C;
    --surface:     rgba(255,253,248,0.82);
    --border:      rgba(207,192,160,0.75);
