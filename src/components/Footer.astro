---
const year = new Date().getFullYear();
---
<footer class="bg-brun text-cream">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1fr_auto_1fr] gap-10 lg:gap-12 mb-12 items-start">

      <!-- Colonne brand -->
      <div>
        <a href="/" class="font-display text-xl font-medium tracking-[-0.02em] block mb-3 hover:text-ocre transition-colors duration-300">
          Caelestis<em class="text-ocre not-italic">.</em>
        </a>
        <p class="font-display text-base font-light italic mb-4" style="color: rgba(237,227,212,0.78)">
          Sites web soignés et visibles,<br>pour ceux qui construisent quelque chose.
        </p>
        <p class="font-body text-sm leading-relaxed max-w-xs" style="color: rgba(237,227,212,0.4)">
          Création de site, référencement naturel et accompagnement pour artisans, praticiens et professionnels engagés. Basé dans la Drôme, disponible partout en France.
        </p>
      </div>

      <!-- Carte centrée — masquée sur tablette md où elle écrase, visible lg+ -->
      <div class="hidden lg:flex flex-col items-center gap-3">
        <div class="relative overflow-hidden" style="width: 200px; height: 148px; border-radius: 3px;">
          <!-- Lien overlay cliquable au-dessus de la carte -->
          <a
            href="https://www.google.com/maps/place/Dr%C3%B4me/@44.7308,5.0197,9z"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Voir la Drôme sur Google Maps"
            class="absolute inset-0 z-20 transition-colors duration-200 hover:bg-white/5"
          ></a>
          <!-- Dégradé décoratif -->
          <div class="absolute inset-0 z-10 pointer-events-none" style="
            background:
              linear-gradient(to bottom, #354024 0%, transparent 20%, transparent 80%, #354024 100%),
              linear-gradient(to right,  #354024 0%, transparent 15%, transparent 85%, #354024 100%);
          "></div>
          <iframe
            src="https://maps.google.com/maps?q=Drome,+France&t=&z=9&ie=UTF8&iwloc=&output=embed&hl=fr"
            width="200"
            height="148"
            style="border:0; filter: grayscale(1) brightness(0.55) contrast(1.1) sepia(0.2); display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            sandbox="allow-scripts allow-same-origin"
            title="Drôme, France"
          ></iframe>
        </div>
        <p class="font-body text-xs tracking-[0.22em] uppercase" style="color: rgba(237,227,212,0.25)">Drôme · France</p>
      </div>

      <!-- Nav + Contact groupés à droite -->
      <div class="flex flex-wrap justify-start md:justify-end gap-10 md:gap-12">
        <!-- Navigation -->
        <div>
          <p class="font-body text-xs tracking-widest uppercase mb-4" style="color: rgba(237,227,212,0.35)">Navigation</p>
          <nav class="flex flex-col gap-2.5" aria-label="Navigation du site">
            {[
              { href: '/',           label: 'Accueil'    },
              { href: '/services',   label: 'Services'   },
              { href: '/simulateur', label: 'Simulateur' },
              { href: '/a-propos',   label: 'À propos'   },
              { href: '/contact',    label: 'Contact'    },
            ].map(({ href, label }) => (
              <a href={href} class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.82)">{label}</a>
            ))}
          </nav>
        </div>

        <!-- Contact -->
        <div>
          <p class="font-body text-xs tracking-widest uppercase mb-4" style="color: rgba(237,227,212,0.35)">Contact</p>
          <div class="flex flex-col gap-2.5">
            <a href="mailto:contact@caelestis.fr" class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.82)">
              contact@caelestis.fr
            </a>
            <a href="tel:+33769362727" class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.82)">
              07 69 36 27 27
            </a>
            <p class="font-body text-sm" style="color: rgba(237,227,212,0.82)">Drôme, France</p>
            <p class="font-body text-xs mt-1" style="color: rgba(237,227,212,0.78)">Lun–Sam · 9h–18h</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bandeau CTA -->
    <div class="border-t py-10 flex flex-col items-center gap-5" style="border-color: rgba(237,227,212,0.08)">
      <p class="font-display text-base font-light italic text-center" style="color: rgba(237,227,212,0.70)">
        Une question, un conseil ?
      </p>
      <a
        href="/contact"
        class="font-body text-sm font-medium px-6 py-2.5 rounded-full border transition-colors duration-200 hover:bg-cream hover:text-brun"
        style="border-color: rgba(237,227,212,0.45); color: rgba(237,227,212,0.92);"
      >
        Écrivez-moi
      </a>
    </div>

    <!-- Bas de page -->
    <div class="border-t pt-8 flex flex-col md:flex-row justify-between items-center gap-3" style="border-color: rgba(237,227,212,0.08)">
      <p class="font-body text-xs" style="color: rgba(237,227,212,0.78)">© {year} Caelestis — Tous droits réservés</p>
      <div class="flex flex-wrap justify-center md:justify-end gap-x-5 gap-y-2">
        <a href="/mentions-legales" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.78)">Mentions légales</a>
        <a href="/politique-confidentialite" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.78)">Politique de confidentialité</a>
        <a href="/cgv" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.78)">CGV</a>
        <!-- Lien CNIL requis : l'utilisateur doit pouvoir retirer son consentement facilement -->
        <button
          id="footer-cookie-btn"
          class="font-body text-xs hover:text-cream transition-colors duration-200 cursor-pointer bg-transparent border-0 p-0"
          style="color: rgba(237,227,212,0.78)"
        >
          Gérer mes cookies
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('footer-cookie-btn')?.addEventListener('click', () => {
    const reset = (window as Window & { caelestisResetCookies?: () => void }).caelestisResetCookies;
    if (typeof reset === 'function') reset();
  });
</script>
