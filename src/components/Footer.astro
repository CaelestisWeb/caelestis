---
const year = new Date().getFullYear();
---
<footer class="bg-brun text-cream">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16">
    <div class="grid md:grid-cols-[1fr_auto_1fr] gap-10 mb-12 items-start">

      <!-- Colonne brand -->
      <div>
        <a href="/" class="font-display text-xl font-medium tracking-[-0.02em] block mb-3 hover:text-ocre transition-colors duration-300">
          Caelestis<em class="text-ocre not-italic">.</em>
        </a>
        <p class="font-display text-base font-light italic mb-4" style="color: rgba(237,227,212,0.65)">
          Sites web soignés et visibles,<br>pour ceux qui construisent quelque chose.
        </p>
        <p class="font-body text-sm leading-relaxed max-w-xs" style="color: rgba(237,227,212,0.4)">
          Création de site, référencement naturel et accompagnement pour artisans, praticiens et professionnels engagés. Basé dans la Drôme, disponible partout en France.
        </p>
      </div>

      <!-- Carte centrée -->
      <div class="hidden md:flex flex-col items-center gap-3">
        <div class="relative overflow-hidden" style="width: 200px; height: 148px; border-radius: 3px;">
          <div class="absolute inset-0 z-10 pointer-events-none" style="
            background:
              linear-gradient(to bottom, #354024 0%, transparent 20%, transparent 80%, #354024 100%),
              linear-gradient(to right,  #354024 0%, transparent 15%, transparent 85%, #354024 100%);
          "></div>
          <iframe
            src="https://maps.google.com/maps?q=Crest,+Drome,+France&t=&z=13&ie=UTF8&iwloc=&output=embed&hl=fr"
            width="200"
            height="148"
            style="border:0; filter: grayscale(1) brightness(0.55) contrast(1.1) sepia(0.2); display:block;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            sandbox="allow-scripts allow-same-origin"
            title="Crest, Drôme"
          ></iframe>
        </div>
        <p class="font-body text-xs tracking-[0.22em] uppercase" style="color: rgba(237,227,212,0.25)">Crest · Drôme</p>
      </div>

      <!-- Nav + Contact groupés à droite -->
      <div class="flex justify-end gap-12">
        <!-- Navigation -->
        <div>
          <p class="font-body text-xs tracking-widest uppercase mb-4" style="color: rgba(237,227,212,0.35)">Navigation</p>
          <nav class="flex flex-col gap-2.5" aria-label="Navigation du site">
            {[
              { href: '/services',  label: 'Services'  },
              { href: '/a-propos',  label: 'À propos'  },
              { href: '/contact',   label: 'Contact'   },
            ].map(({ href, label }) => (
              <a href={href} class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.6)">{label}</a>
            ))}
          </nav>
        </div>

        <!-- Contact -->
        <div>
          <p class="font-body text-xs tracking-widest uppercase mb-4" style="color: rgba(237,227,212,0.35)">Contact</p>
          <div class="flex flex-col gap-2.5">
            <a href="mailto:contact@caelestis.fr" class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.6)">
              contact@caelestis.fr
            </a>
            <a href="tel:+33782687399" class="font-body text-sm hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.6)">
              07 82 68 73 99
            </a>
            <p class="font-body text-sm" style="color: rgba(237,227,212,0.6)">Drôme, France</p>
            <p class="font-body text-xs mt-1" style="color: rgba(237,227,212,0.3)">Lun–Ven · 9h–18h</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bandeau CTA -->
    <div class="border-t py-10 flex flex-col items-center gap-5" style="border-color: rgba(237,227,212,0.08)">
      <p class="font-display text-base font-light italic text-center" style="color: rgba(237,227,212,0.70)">
        Besoin d'une réponse à vos questions ou simplement d'un conseil ?
      </p>
      <a
        href="/contact"
        class="font-body text-sm font-medium px-6 py-2.5 rounded-full border transition-colors duration-200 hover:bg-cream hover:text-brun"
        style="border-color: rgba(237,227,212,0.30); color: rgba(237,227,212,0.85);"
      >
        Contactez-nous
      </a>
    </div>

    <!-- Bas de page -->
    <div class="border-t pt-8 flex flex-col md:flex-row justify-between items-center gap-3" style="border-color: rgba(237,227,212,0.08)">
      <p class="font-body text-xs" style="color: rgba(237,227,212,0.3)">© {year} Caelestis — Tous droits réservés</p>
      <div class="flex gap-5">
        <a href="/mentions-legales" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.3)">Mentions légales</a>
        <a href="/politique-confidentialite" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.3)">Politique de confidentialité</a>
        <a href="/cgv" class="font-body text-xs hover:text-cream transition-colors duration-200" style="color: rgba(237,227,212,0.3)">CGV</a>
      </div>
    </div>
  </div>
</footer>
