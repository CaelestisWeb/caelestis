---
const nav = [
  { href: '/services',  label: 'Services'  },
  { href: '/a-propos',  label: 'À propos'  },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact',   label: 'Contact'   },
];
const current = Astro.url.pathname;
---
<header id="header" class="sticky top-0 z-50 bg-cream/90 backdrop-blur-sm border-b border-cream-dark">
  <div class="max-w-6xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <a href="/" class="font-display text-xl font-semibold text-brun tracking-tight">
      Caelestis<span class="text-ocre">.</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class={`font-body text-sm font-medium transition-colors hover:text-ocre ${
            current.startsWith(href) ? 'text-ocre' : 'text-brun-mid'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="font-body text-sm font-medium bg-brun text-cream px-5 py-2 hover:bg-ocre transition-colors duration-200"
      >
        Parler de mon projet
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden text-brun" aria-label="Ouvrir le menu" aria-expanded="false">
      <svg width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
        <line x1="0" y1="1"  x2="22" y2="1"  stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="8"  x2="22" y2="8"  stroke="currentColor" stroke-width="1.5"/>
        <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-cream border-t border-cream-dark">
    <nav class="px-6 py-6 flex flex-col gap-4">
      {nav.map(({ href, label }) => (
        <a href={href} class="font-body text-base text-brun hover:text-ocre transition-colors">{label}</a>
      ))}
      <a
        href="/contact"
        class="font-body text-base font-medium bg-brun text-cream px-5 py-3 text-center mt-2 hover:bg-ocre transition-colors duration-200"
      >
        Parler de mon projet
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
