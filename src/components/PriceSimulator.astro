---
// PriceSimulator.astro — Branches par type de site, 4 questions, option Autre
---

<div id="simulator" class="sim-wrap" aria-label="Simulateur de prix Caelestis">

  <div class="sim-progress-outer" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
    <div class="sim-progress-inner" id="sim-progress-bar"></div>
  </div>

  <div class="sim-body">

    <!-- ══ s0 — Accueil ══ -->
    <div class="sim-step is-active sim-s0-centered" id="s0">
      <p class="sim-overline">Bienvenue</p>
      <h2 class="sim-headline">Estimer<br>mon projet.</h2>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" id="continue-s0">Commencer l'estimation →</button>
      </div>
    </div>

    <!-- ══ s1 — Type de site (single select) ══ -->
    <div class="sim-step" id="s1">
      <p class="sim-overline">Votre projet · 1 sur 4</p>
      <h2 class="sim-headline">Quel type de site<br>vous correspond&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="vitrine" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">Site vitrine</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Présenter votre activité, vos services et vos coordonnées. L'essentiel pour exister en ligne et inspirer confiance.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="boutique" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Boutique en ligne</strong>
            <span class="sim-card-desc">Vendre vos produits ou services directement depuis votre site, avec paiement sécurisé et gestion des commandes</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="surMesure" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Site sur mesure</strong>
            <span class="sim-card-desc">Un projet avec des fonctionnalités avancées comme un espace client, un système de réservation ou des outils sur mesure.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" id="continue-s1" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══════════ BRANCHE VITRINE ══════════ -->

    <!-- s2v — Nombre de pages -->
    <div class="sim-step" id="s2v" data-branch-q="q2">
      <p class="sim-overline">Votre projet · 2 sur 4</p>
      <h2 class="sim-headline">Sur combien de pages<br>souhaitez-vous présenter<br>votre activité&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="simple" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">Simple · 1 à 4 pages</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Accueil, Services, À propos et Contact réunis en quelques pages claires et directes.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="standard" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Standard · 4 à 6 pages</strong>
            <span class="sim-card-desc">Avec galerie, blog, témoignages ou pages de services détaillées. Inclut l'optimisation de votre fiche Google Business.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="complet" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Complet · 6 pages et +</strong>
            <span class="sim-card-desc">Site riche avec plusieurs rubriques et beaucoup de contenu à structurer. Inclut le référencement optimisé (SEO on-page complet).</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- s3v — Contenu prêt ? -->
    <div class="sim-step" id="s3v" data-branch-q="q3">
      <p class="sim-overline">Votre projet · 3 sur 4</p>
      <h2 class="sim-headline">Côté contenus,<br>où en êtes-vous&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="ready" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Tout est prêt</strong>
            <span class="sim-card-desc">Logo soigné, textes rédigés, photos professionnelles. Tout est prêt à intégrer.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="has_logo" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">J'ai mon logo, mais les textes manquent</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Mon identité visuelle existe, mais je n'ai pas encore écrit ce que je veux dire</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="nothing" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Tout est à construire</strong>
            <span class="sim-card-desc">Je n'ai ni logo, ni textes, ni photos pour le moment. On construit tout ensemble.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre situation en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : j'ai des photos mais pas de logo…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══════════ BRANCHE BOUTIQUE ══════════ -->

    <!-- s2b — Nombre de produits -->
    <div class="sim-step" id="s2b" data-branch-q="q2">
      <p class="sim-overline">Votre projet · 2 sur 5</p>
      <h2 class="sim-headline">Combien de produits<br>souhaitez-vous vendre&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="small" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">0 à 10 produits</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Quelques produits ou services soigneusement mis en valeur pour une offre ciblée.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="medium" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">10 à 30 produits</strong>
            <span class="sim-card-desc">Une gamme complète avec catégories et filtres. Inclut l'optimisation de votre fiche Google Business.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="large" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">30 à 50 produits</strong>
            <span class="sim-card-desc">Un catalogue étoffé avec variantes de produits, gestion des stocks et promotions. Inclut le référencement optimisé (SEO on-page complet).</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre situation en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : plus de 50 produits, vente en gros…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- s3b — Gestion des produits -->
    <div class="sim-step" id="s3b" data-branch-q="q3">
      <p class="sim-overline">Votre projet · 3 sur 5</p>
      <h2 class="sim-headline">Comment gérez-vous<br>vos produits aujourd'hui&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="starting" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Je démarre</strong>
            <span class="sim-card-desc">Artisan, créateur ou petite structure, je gère un stock limité, tout à saisir en ligne.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="existing" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">J'ai un stock existant à intégrer</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Mes produits existent, il faut les importer et les structurer en ligne</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="collective" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Regroupement de producteurs ou artisans</strong>
            <span class="sim-card-desc">Plusieurs producteurs, créateurs ou artisans qui vendent ensemble depuis une boutique partagée.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre situation en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : créations artisanales sur commande…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══════════ BRANCHE SUR MESURE ══════════ -->

    <!-- s3s — Complexité technique -->
    <div class="sim-step" id="s3s" data-branch-q="q3">
      <p class="sim-overline">Votre projet · 2 sur 4</p>
      <h2 class="sim-headline">Quel niveau de complexité<br>envisagez-vous&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="simple" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">Design soigné, contenu riche</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Animations, mises en page élaborées, visuels travaillés. Pas de fonctionnalité technique particulière.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="medium" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Interactions & espace membre</strong>
            <span class="sim-card-desc">Zone de connexion, prise de rendez-vous en ligne, accès réservé à certains utilisateurs. Inclut l'optimisation de votre fiche Google Business.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="complex" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Projet technique avancé</strong>
            <span class="sim-card-desc">Gestion de données complexes, tableau de bord, automatisations ou fonctionnalités vraiment sur mesure. Inclut le référencement optimisé (SEO on-page complet).</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Décrivez la complexité attendue…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══ s4b — Volume de contenu (boutique) ══ -->
    <div class="sim-step" id="s4b" data-branch-q="qc">
      <p class="sim-overline">Votre projet · 4 sur 5</p>
      <h2 class="sim-headline">Quel volume de contenu<br>éditorial prévoyez-vous&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="few" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Peu de contenu</strong>
            <span class="sim-card-desc">Quelques descriptions de produits et textes de présentation à rédiger ou affiner.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="moderate" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">Volume modéré</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Plusieurs dizaines de fiches produit, photos ou catégories à structurer et mettre en ligne.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="rich" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Contenu riche</strong>
            <span class="sim-card-desc">Un catalogue fourni avec beaucoup de descriptions, médias et données à intégrer et organiser.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre situation en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : imports CSV, traductions, fiches techniques…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══ s4s — Maturité du projet (sur mesure) ══ -->
    <div class="sim-step" id="s4s" data-branch-q="qc">
      <p class="sim-overline">Votre projet · 3 sur 4</p>
      <h2 class="sim-headline">Où en êtes-vous<br>dans votre réflexion&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="brief" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Tout est défini</strong>
            <span class="sim-card-desc">J'ai un cahier des charges, des maquettes ou des specs claires à soumettre</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="ideas" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">Les grandes lignes sont claires</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">Je sais ce que je veux mais rien n'est encore formalisé par écrit</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="blank" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Je cherche encore</strong>
            <span class="sim-card-desc">J'ai un besoin ou une idée, mais j'ai besoin d'être accompagné pour le définir</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre situation en quelques mots</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : base de données existante, flux API, contenu multilingue…" maxlength="300" />
        </div>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══ s5gb — Google Business (universel) ══ -->
    <div class="sim-step" id="s5gb" data-branch-q="gb">
      <p class="sim-overline">Votre projet · 4 sur 5</p>
      <h2 class="sim-headline">Souhaitez-vous optimiser<br>votre fiche Google Business&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="yes" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Oui, je veux l'optimiser</strong>
            <span class="sim-card-desc">Fiche Google complète : description, catégories, photos, horaires, pour apparaître dans les recherches locales dès le lancement.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="no" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Non, pas pour l'instant</strong>
            <span class="sim-card-desc">Je me concentre sur le site pour l'instant. Je pourrai y revenir plus tard.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
      </div>
      <div class="sim-step-actions">
        <button class="sim-continue sim-btn-primary" disabled>Continuer →</button>
      </div>
    </div>

    <!-- ══ s4 — Délai (universel) ══ -->
    <div class="sim-step" id="s4" data-branch-q="q4">
      <p class="sim-overline">Votre calendrier · 4 sur 4</p>
      <h2 class="sim-headline">Dans quel délai<br>souhaitez-vous lancer&nbsp;?</h2>
      <div class="sim-cards-col">
        <button class="sim-card" data-value="slow" aria-pressed="false">
          <span class="sim-card-num">01</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Je prends le temps qu'il faut</strong>
            <span class="sim-card-desc">Dans 2 à 3 mois. Pas d'urgence particulière, je préfère que ce soit bien fait.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="soon" aria-pressed="false">
          <span class="sim-card-num">02</span>
          <span class="sim-card-body">
            <span class="sim-card-head">
              <strong class="sim-card-title">D'ici 4 à 6 semaines</strong>
              <span class="sim-badge">Le plus courant</span>
            </span>
            <span class="sim-card-desc">J'ai une échéance qui approche : une saison, un événement ou un lancement à venir.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card" data-value="urgent" aria-pressed="false">
          <span class="sim-card-num">03</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Dès que possible</strong>
            <span class="sim-card-desc">Je perds des opportunités sans site en ligne et je veux démarrer le plus vite possible.</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <button class="sim-card sim-card-alt" data-value="autre" aria-pressed="false">
          <span class="sim-card-num">04</span>
          <span class="sim-card-body">
            <strong class="sim-card-title">Autre</strong>
            <span class="sim-card-desc">Précisez votre contrainte de calendrier</span>
          </span>
          <span class="sim-card-check" aria-hidden="true"></span>
        </button>
        <div class="sim-autre-wrap">
          <input type="text" class="sim-input sim-autre-field" placeholder="Ex : avant la saison estivale, avant un salon…" maxlength="300" />
        </div>
      </div>
