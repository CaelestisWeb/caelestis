<script>
  declare global {
    interface Window {
      caelTrack?: (event: string, params?: Record<string, unknown>) => void;
    }
  }

  (function () {

    /* ══ ÉTAT ══ */
    const state = {
      stepNum:  0,
      activity: '',
      types:    [] as string[],
      q2Vals:   [] as string[], q2Other: '',
      q3Vals:   [] as string[], q3Other: '',
      qcVals:   [] as string[], qcOther: '',  // volume de contenu — boutique/surMesure
      q4Vals:   [] as string[], q4Other: '',
      gbVals:   [] as string[],               // Google Business
      interest: 0,
    };

    /* ══ DOM ══ */
    const progressBar  = document.getElementById('sim-progress-bar')    as HTMLElement | null;
    const backBtn      = document.getElementById('sim-back-btn')         as HTMLButtonElement | null;
    const indicator    = document.getElementById('sim-step-indicator')   as HTMLElement | null;
    const simFooter    = document.getElementById('sim-footer')           as HTMLElement | null;
    const activityDisp = document.getElementById('sim-activity-display') as HTMLElement | null;

    /* ══ Type dominant (surMesure > boutique > vitrine) ══ */
    function dominantType(): string {
      if (state.types.includes('surMesure')) return 'surMesure';
      if (state.types.includes('boutique'))  return 'boutique';
      return 'vitrine';
    }

    /* ══ Boutique et sur mesure ont une étape "contenu" en plus ══ */

    /* ══ Dernier stepNum ══ */
    function maxStep(): number { return dominantType() === 'boutique' ? 8 : 7; }

    /* ══ stepNum → ID HTML ══
       Vitrine   : 0 s0 | 1 s1 | 2 s2v | 3 s3v | 4 s5gb | 5 s4 | 6 s6 | 7 s5
       Boutique  : 0 s0 | 1 s1 | 2 s2b | 3 s3b | 4 s4b  | 5 s5gb | 6 s4 | 7 s6 | 8 s5
       Sur mesure: 0 s0 | 1 s1 | 2 s3s | 3 s4s | 4 s5gb | 5 s4 | 6 s6 | 7 s5
    ══ */
    function stepId(n: number): string {
      const dt = dominantType();
      if (dt === 'vitrine') {
        const m: Record<number, string> = { 0:'s0', 1:'s1', 2:'s2v', 3:'s3v', 4:'s5gb', 5:'s4', 6:'s6', 7:'s5' };
        return m[n] ?? 's0';
      }
      if (dt === 'boutique') {
        const m: Record<number, string> = { 0:'s0', 1:'s1', 2:'s2b', 3:'s3b', 4:'s4b', 5:'s5gb', 6:'s4', 7:'s6', 8:'s5' };
        return m[n] ?? 's0';
      }
      // surMesure
      const m: Record<number, string> = { 0:'s0', 1:'s1', 2:'s3s', 3:'s4s', 4:'s5gb', 5:'s4', 6:'s6', 7:'s5' };
      return m[n] ?? 's0';
    }

    /* ══ Progression ══ */
    function getProgress(n: number): number {
      if (dominantType() === 'boutique') {
        const m: Record<number, number> = { 0:0, 1:11, 2:22, 3:34, 4:47, 5:60, 6:73, 7:86, 8:100 };
        return m[n] ?? 0;
      }
      // vitrine + surMesure
      const m: Record<number, number> = { 0:0, 1:13, 2:27, 3:44, 4:60, 5:74, 6:87, 7:100 };
      return m[n] ?? 0;
    }

    /* ══ RENDER ══ */
    function render(): void {
      const id = stepId(state.stepNum);
      const ms = maxStep();

      document.querySelectorAll<HTMLElement>('.sim-step').forEach(el => {
        el.classList.remove('is-active');
        el.style.display = 'none';
      });
      const target = document.getElementById(id);
      if (target) {
        target.style.display = 'block';
        void target.offsetHeight;
        target.classList.add('is-active');
        if (id === 's5gb') {
          const ol = target.querySelector('.sim-overline');
          if (ol) ol.textContent = dominantType() === 'boutique' ? 'Votre projet · 5 sur 6' : 'Votre projet · 4 sur 5';
        }
        if (id === 's4') {
          const ol = target.querySelector('.sim-overline');
          if (ol) ol.textContent = dominantType() === 'boutique' ? 'Votre calendrier · 6 sur 6' : 'Votre calendrier · 5 sur 5';
        }
      }

      const pct = getProgress(state.stepNum);
      if (progressBar) {
        progressBar.style.width = pct + '%';
        progressBar.closest('[role="progressbar"]')?.setAttribute('aria-valuenow', String(pct));
      }

      const isBoutique = dominantType() === 'boutique';
      const intSt = isBoutique ? 8 : 7;
      if (backBtn) backBtn.hidden = state.stepNum === 0 || state.stepNum >= intSt;

      if (indicator) {
        const total = isBoutique ? 6 : 5;
        const lastQ = isBoutique ? 6 : 5;
        indicator.textContent =
          (state.stepNum >= 1 && state.stepNum <= lastQ) ? `${state.stepNum} / ${total}` : '';
      }

      if (simFooter) simFooter.style.visibility = state.stepNum === ms ? 'hidden' : 'visible';

      const intStep = isBoutique ? 8 : 7; // stepNum de l'interlude
      const frmStep = isBoutique ? 7 : 6; // stepNum du formulaire
      if (state.stepNum === intStep && activityDisp) {
        activityDisp.textContent = state.activity
          ? state.activity.charAt(0).toUpperCase() + state.activity.slice(1).toLowerCase()
          : 'votre projet';
      }
      if (state.stepNum === frmStep && state.activity) {
        const actEl = document.getElementById('sim-activity') as HTMLInputElement | null;
        if (actEl && !actEl.value) actEl.value = state.activity;
      }
    }

    /* ══ s1 — type (mono-select) ══ */
    document.querySelectorAll<HTMLButtonElement>('#s1 .sim-card').forEach(card => {
      card.addEventListener('click', () => {
        const value = card.dataset.value ?? '';
        if (card.classList.contains('is-selected')) return;
        document.querySelectorAll<HTMLButtonElement>('#s1 .sim-card').forEach(c => {
          c.classList.remove('is-selected');
          c.setAttribute('aria-pressed', 'false');
        });
        card.classList.add('is-selected');
        card.setAttribute('aria-pressed', 'true');
        state.types = [value];
        // Reset branches quand le type change
        state.q2Vals = []; state.q2Other = '';
        state.q3Vals = []; state.q3Other = '';
        state.qcVals = []; state.qcOther = '';
        state.gbVals = [];
        const btn = document.getElementById('continue-s1') as HTMLButtonElement | null;
        if (btn) btn.disabled = false;
      });
    });

    /* ══ Questions branchées — mono-select ══ */
    const BRANCH_IDS = ['s2v','s2b','s3v','s3b','s3s','s4b','s4s','s5gb','s4'];

    BRANCH_IDS.forEach(sid => {
      const stepEl = document.getElementById(sid);
      if (!stepEl) return;
      const q = stepEl.dataset.branchQ as 'q2' | 'q3' | 'qc' | 'q4' | 'gb';

      stepEl.querySelectorAll<HTMLButtonElement>('.sim-card').forEach(card => {
        card.addEventListener('click', () => {
          const value = card.dataset.value ?? '';
          if (card.classList.contains('is-selected')) return;
          // Désélectionner toutes les cartes du step
          stepEl.querySelectorAll<HTMLButtonElement>('.sim-card').forEach(c => {
            c.classList.remove('is-selected');
            c.setAttribute('aria-pressed', 'false');
          });
          card.classList.add('is-selected');
          card.setAttribute('aria-pressed', 'true');
          if (q === 'q2') state.q2Vals = [value];
          if (q === 'q3') state.q3Vals = [value];
          if (q === 'qc') state.qcVals = [value];
          if (q === 'q4') state.q4Vals = [value];
          if (q === 'gb') state.gbVals = [value];
          // Champ "autre"
          const wrap = stepEl.querySelector<HTMLElement>('.sim-autre-wrap');
          if (wrap) {
            wrap.classList.toggle('is-visible', value === 'autre');
            if (value === 'autre') wrap.querySelector<HTMLInputElement>('.sim-autre-field')?.focus();
          }
          refreshContinue(stepEl, q);
        });
      });

      const autreField = stepEl.querySelector<HTMLInputElement>('.sim-autre-field');
      autreField?.addEventListener('input', () => {
        const text = autreField.value.trim();
        if (q === 'q2') state.q2Other = text;
        if (q === 'q3') state.q3Other = text;
        if (q === 'qc') state.qcOther = text;
        if (q === 'q4') state.q4Other = text;
        refreshContinue(stepEl, q);
      });
    });

    function refreshContinue(stepEl: HTMLElement, q: 'q2' | 'q3' | 'qc' | 'q4' | 'gb'): void {
      const btn = stepEl.querySelector<HTMLButtonElement>('.sim-continue');
      if (!btn) return;
      const vals  = q === 'q2' ? state.q2Vals  : q === 'q3' ? state.q3Vals  : q === 'qc' ? state.qcVals  : q === 'q4' ? state.q4Vals : state.gbVals;
      const other = q === 'q2' ? state.q2Other : q === 'q3' ? state.q3Other : q === 'qc' ? state.qcOther : q === 'q4' ? state.q4Other : '';
      const autreOk = !vals.includes('autre') || other.length > 0;
      btn.disabled = vals.length === 0 || !autreOk;
    }

    /* ══ Boutons Continuer ══ */
    document.querySelectorAll<HTMLButtonElement>('.sim-continue').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.disabled) return;
        state.stepNum += 1;
        render();
      });
    });

    /* ══ Retour ══ */
    backBtn?.addEventListener('click', () => {
      if (state.stepNum > 0) { state.stepNum -= 1; render(); }
    });

    /* ══ Question étoiles ══ */
    document.querySelectorAll<HTMLButtonElement>('.sim-star-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = parseInt(btn.dataset.val ?? '0', 10);
        state.interest = val;
        document.querySelectorAll<HTMLButtonElement>('.sim-star-opt').forEach(b => {
          b.classList.toggle('is-selected', b === btn);
        });
      });
    });

    /* ══ Formulaire ══ */
    const form      = document.getElementById('sim-form')     as HTMLFormElement | null;
    const submitBtn = document.getElementById('sim-submit')    as HTMLButtonElement | null;
    const btnText   = submitBtn?.querySelector<HTMLElement>('.sim-btn-text');
    const btnLoader = submitBtn?.querySelector<HTMLElement>('.sim-btn-loader');
    const errorMsg  = document.getElementById('sim-error-msg') as HTMLElement | null;

    const showErr = (m: string) => { if (errorMsg) { errorMsg.textContent = m; errorMsg.hidden = false; } };
    const hideErr = ()          => { if (errorMsg) errorMsg.hidden = true; };
    const setLoad = (on: boolean) => {
      if (!submitBtn || !btnText || !btnLoader) return;
      submitBtn.disabled = on; btnText.hidden = on; btnLoader.hidden = !on;
    };

    form?.addEventListener('submit', async (e: SubmitEvent) => {
      e.preventDefault();
      hideErr();
      const prenom   = (document.getElementById('sim-prenom')   as HTMLInputElement | null)?.value.trim() ?? '';
      const activity = (document.getElementById('sim-activity') as HTMLInputElement | null)?.value.trim() ?? '';
      const company  = (document.getElementById('sim-company')  as HTMLInputElement | null)?.value.trim() ?? '';
      const email    = (document.getElementById('sim-email')    as HTMLInputElement | null)?.value.trim() ?? '';
      const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]')?.value ?? '';

      if (!prenom || !activity || !email) { showErr('Veuillez remplir tous les champs.'); return; }
      if (!state.interest) { showErr("Veuillez indiquer votre niveau d'intérêt."); return; }

      /* Blocage adresses fictives / jetables */
      const _el = email.toLowerCase(); const _at = _el.indexOf('@');
      const _local = _at >= 0 ? _el.slice(0, _at) : ''; const _dom = _at >= 0 ? _el.slice(_at + 1) : '';
      const _fakeL = new Set(['test','fake','temp','demo','sample','noreply','no-reply','spam','asdf','qwerty','toto','tata','azerty','blabla','aaa','bbb','xxx','null','undefined']);
      const _fakeD = new Set(['test.com','test.fr','example.com','example.org','example.fr','fake.com','fake.fr','mailinator.com','guerrillamail.com','yopmail.com','throwaway.email','tempmail.com','trashmail.com','trashmail.me','maildrop.cc','sharklasers.com','spam4.me','dispostable.com','getairmail.com','filzmail.com','tempr.email','getnada.com']);
      if (_fakeL.has(_local) || _fakeD.has(_dom)) { showErr('Veuillez entrer votre vraie adresse email pour recevoir votre estimation.'); return; }

      setLoad(true);
      try {
        const res = await fetch('/api/simulator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            prenom, activity, company, email,
            types:   state.types,
            q2Vals:  dominantType() === 'surMesure' ? ['creation'] : state.q2Vals,  q2Other: state.q2Other,
            q3Vals:  state.q3Vals,  q3Other: state.q3Other,
            qcVals:  state.qcVals,  qcOther: state.qcOther,
            q4Vals:  state.q4Vals,  q4Other: state.q4Other,
            gbVals:  state.gbVals,
            interest: state.interest,
            website: honeypot,
          }),
        });
        const data = await res.json() as { success?: boolean; error?: string; };

        if (!res.ok || !data.success) {
          showErr(data.error ?? 'Une erreur est survenue. Réessayez ou écrivez à contact@caelestis.fr');
          setLoad(false); return;
        }

        /* GA4 — conversion simulateur (ne se déclenche que si le consentement cookies est donné) */
        window.caelTrack?.('generate_lead', { lead_source: 'simulateur', site_type: dominantType() });
        state.stepNum = dominantType() === 'boutique' ? 8 : 7; render(); setLoad(false);
      } catch {
        showErr('Erreur réseau. Vérifiez votre connexion et réessayez.');
        setLoad(false);
      }
    });

    render();
  })();
</script>
