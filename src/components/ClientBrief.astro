---
---

<div class="brief-root">

  <!-- ── Bannière de restauration ── -->
  <div id="restore-banner" class="restore-banner hidden" role="alert">
    <div class="restore-inner">
      <span class="restore-dot" aria-hidden="true"></span>
      <p class="restore-msg">Réponses sauvegardées. Souhaitez-vous reprendre là où vous en étiez&nbsp;?</p>
      <div class="restore-actions">
        <button id="restore-btn" class="restore-yes">Reprendre</button>
        <button id="discard-btn" class="restore-no" aria-label="Ignorer">✕</button>
      </div>
    </div>
  </div>

  <div id="form-container" class="brief-container">

    <!-- ── En-tête ── -->
    <header class="brief-header">
      <p class="brief-overline">Caelestis. Questionnaire client</p>
      <h1 class="brief-title">Questionnaire de création<br>de site internet</h1>
      <p class="brief-subtitle">Répondez à votre rythme, même partiellement. Chaque détail nous aide à préparer votre projet avec soin. Vos réponses sont sauvegardées automatiquement.</p>
      <div class="brief-divider" aria-hidden="true"></div>
    </header>

    <!-- Indicateur de sauvegarde masqué visuellement -->
    <div aria-live="polite" style="display:none;">
      <span id="save-indicator" aria-label="Formulaire sauvegardé">
        <span id="save-time"></span>
      </span>
    </div>

    <form id="brief-form" novalidate>

      <!-- Honeypot -->
      <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>

      <!-- ══════════════════════════════
           01 · Qui êtes-vous ?
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">01</span>
          <div>
            <p class="b-overline">Pour commencer</p>
            <h2 class="b-title">Qui êtes-vous ?</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="nom_entreprise">Nom de l'entreprise</label>
              <input id="nom_entreprise" type="text" name="nom_entreprise" placeholder="Ex : Jardins Dupont" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="nom_dirigeant">Votre prénom et nom</label>
              <input id="nom_dirigeant" type="text" name="nom_dirigeant" placeholder="Ex : Jean Dupont" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="activite">Activité principale</label>
              <input id="activite" type="text" name="activite" placeholder="Ex : Paysagiste, thérapeute, artisan…" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="ville">Ville / Département</label>
              <input id="ville" type="text" name="ville" placeholder="Ex : Valence (26)" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="telephone">Téléphone</label>
              <input id="telephone" type="tel" name="telephone" placeholder="07 xx xx xx xx" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="email_contact">
                Email <span class="b-required" aria-label="champ obligatoire">*</span>
              </label>
              <input id="email_contact" type="email" name="email_contact" placeholder="votre@email.fr" class="b-input" required>
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="site_actuel">Site internet actuel <span class="b-hint">(si vous en avez un)</span></label>
              <input id="site_actuel" type="text" name="site_actuel" placeholder="https://..." class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="domaine_souhaite">Nom de domaine souhaité (si disponible)</label>
              <input id="domaine_souhaite" type="text" name="domaine_souhaite" placeholder="Ex : jardins-dupont.fr" class="b-input">
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           02 · Votre activité
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">02</span>
          <div>
            <p class="b-overline">Votre histoire</p>
            <h2 class="b-title">Votre activité</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <label class="b-label" for="description_activite">Décrivez votre activité en quelques phrases</label>
            <textarea id="description_activite" name="description_activite" rows="4" placeholder="Ce que vous faites, depuis combien de temps, ce qui vous tient à cœur dans ce métier…" class="b-textarea"></textarea>
          </div>
          <div class="b-field">
            <label class="b-label" for="ce_qui_vous_differencie">Ce qui vous différencie de vos concurrents</label>
            <textarea id="ce_qui_vous_differencie" name="ce_qui_vous_differencie" rows="3" placeholder="Votre approche, votre expérience, votre façon de travailler, ce que les autres ne font pas…" class="b-textarea"></textarea>
          </div>
          <div class="b-field">
            <span class="b-label" id="type-client-legend">Clientèle ciblée</span>
            <div class="b-chips b-chips-wrap" role="group" aria-labelledby="type-client-legend">
              <label class="b-chip"><input type="checkbox" name="type_client" value="particuliers" class="b-chip-input"><span>Particuliers</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="professionnels" class="b-chip-input"><span>Professionnels (B2B)</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="collectivites" class="b-chip-input"><span>Collectivités</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="associations" class="b-chip-input"><span>Associations</span></label>
              <label class="b-chip"><input type="checkbox" name="type_client" value="autre" class="b-chip-input"><span>Autre</span></label>
            </div>
            <div id="type_client-autre" class="b-reveal hidden">
              <input type="text" name="type_client_autre" placeholder="Précisez votre clientèle…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="zone_geo">Zone géographique desservie</label>
            <input id="zone_geo" type="text" name="zone_geo" placeholder="Ex : Drôme et Ardèche, toute la France, international…" class="b-input">
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           03 · Vos services
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">03</span>
          <div>
            <p class="b-overline">Ce que vous proposez</p>
            <h2 class="b-title">Vos services</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label">Vos principales prestations</span>
            <div class="b-services">
              <div class="b-service-row">
                <span class="b-service-num" aria-hidden="true">1</span>
                <input type="text" name="service_1" placeholder="Ex : Création et aménagement de jardins" class="b-input">
              </div>
              <div class="b-service-row">
                <span class="b-service-num" aria-hidden="true">2</span>
                <input type="text" name="service_2" placeholder="Ex : Entretien régulier (tonte, taille…)" class="b-input">
              </div>
              <div class="b-service-row">
                <span class="b-service-num" aria-hidden="true">3</span>
                <input type="text" name="service_3" placeholder="Service 3 (optionnel)" class="b-input">
              </div>
              <div class="b-service-row">
                <span class="b-service-num" aria-hidden="true">4</span>
                <input type="text" name="service_4" placeholder="Service 4 (optionnel)" class="b-input">
              </div>
              <div class="b-service-row">
                <span class="b-service-num" aria-hidden="true">5</span>
                <input type="text" name="service_5" placeholder="Service 5 (optionnel)" class="b-input">
              </div>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="tarifs-legend">Afficher les tarifs sur le site ?</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="tarifs-legend">
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="oui" class="b-chip-input"><span>Oui, mes prix</span></label>
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="sur_demande" class="b-chip-input"><span>Sur demande</span></label>
              <label class="b-chip"><input type="radio" name="affichage_tarifs" value="non" class="b-chip-input"><span>Non</span></label>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           04 · Votre site internet
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">04</span>
          <div>
            <p class="b-overline">Votre vision</p>
            <h2 class="b-title">Votre site internet</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="type-site-legend">Type de site</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="type-site-legend">
              <label class="b-chip"><input type="radio" name="type_site" value="vitrine" class="b-chip-input"><span>Site vitrine</span></label>
              <label class="b-chip"><input type="radio" name="type_site" value="boutique_en_ligne" class="b-chip-input"><span>Boutique en ligne</span></label>
              <label class="b-chip"><input type="radio" name="type_site" value="sur_mesure" class="b-chip-input"><span>Site sur mesure</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="objectifs-legend">Objectifs principaux</span>
            <div class="b-check-grid" role="group" aria-labelledby="objectifs-legend">
              <label class="b-check"><input type="checkbox" name="objectifs" value="visibilite" class="b-check-input"><span>Gagner en visibilité</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="prospects" class="b-check-input"><span>Attirer des prospects</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="vente_ligne" class="b-check-input"><span>Vendre en ligne</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="notoriete" class="b-check-input"><span>Renforcer la notoriété</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="credibilite" class="b-check-input"><span>Crédibiliser l'activité</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="recrutement" class="b-check-input"><span>Faciliter le recrutement</span></label>
              <label class="b-check"><input type="checkbox" name="objectifs" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="objectifs-autre" class="b-reveal hidden">
              <input type="text" name="objectifs_autre" placeholder="Précisez votre objectif…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="delai-legend">Délai de lancement souhaité</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="delai-legend">
              <label class="b-chip"><input type="radio" name="delai" value="asap" class="b-chip-input"><span>Dès que possible</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="un_mois" class="b-chip-input"><span>Dans 1 mois</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="trois_mois" class="b-chip-input"><span>Dans 3 mois</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="six_mois" class="b-chip-input"><span>6 mois ou plus</span></label>
              <label class="b-chip"><input type="radio" name="delai" value="pas_urgent" class="b-chip-input"><span>Pas de délai</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="fonctionnalites-legend">Fonctionnalités souhaitées</span>
            <div class="b-check-grid" role="group" aria-labelledby="fonctionnalites-legend">
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="formulaire_contact" class="b-check-input"><span>Formulaire de contact</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="galerie" class="b-check-input"><span>Galerie photos</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="blog" class="b-check-input"><span>Blog / Actualités</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="reservation" class="b-check-input"><span>Réservation en ligne</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="espace_client" class="b-check-input"><span>Espace client</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="carte" class="b-check-input"><span>Carte interactive</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="newsletter" class="b-check-input"><span>Newsletter</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="multilingue" class="b-check-input"><span>Multi-langue</span></label>
              <label class="b-check"><input type="checkbox" name="fonctionnalites" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="fonctionnalites-autre" class="b-reveal hidden">
              <input type="text" name="fonctionnalites_autre" placeholder="Précisez la fonctionnalité souhaitée…" class="b-input">
            </div>
          </div>
          <!-- ── Pages du site ── -->
          <div class="b-field">
            <span class="b-label" id="nb-pages-legend">Nombre de pages souhaitées</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="nb-pages-legend">
              <label class="b-chip"><input type="radio" name="nb_pages" value="1-3" class="b-chip-input"><span>1 – 3 pages</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="4-6" class="b-chip-input"><span>4 – 6 pages</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="7-10" class="b-chip-input"><span>7 – 10 pages</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="10+" class="b-chip-input"><span>10 pages et plus</span></label>
              <label class="b-chip"><input type="radio" name="nb_pages" value="je_ne_sais_pas" class="b-chip-input"><span>Je ne sais pas</span></label>
            </div>
          </div>
          <div class="b-field">
            <span class="b-label">Noms des pages <span class="b-hint">(laissez vide les cases inutilisées)</span></span>
            <div class="b-pages-grid">
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">1</span><input type="text" name="page_1" placeholder="Ex : Accueil" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">2</span><input type="text" name="page_2" placeholder="Ex : Nos prestations" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">3</span><input type="text" name="page_3" placeholder="Ex : Notre histoire" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">4</span><input type="text" name="page_4" placeholder="Ex : Réalisations" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">5</span><input type="text" name="page_5" placeholder="Ex : Témoignages" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">6</span><input type="text" name="page_6" placeholder="Ex : Blog / Actualités" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">7</span><input type="text" name="page_7" placeholder="Ex : FAQ" class="b-input"></div>
              <div class="b-page-row"><span class="b-page-num" aria-hidden="true">8</span><input type="text" name="page_8" placeholder="Ex : Contact" class="b-input"></div>
            </div>
          </div>

          <div class="b-field">
            <span class="b-label" id="boutique-legend">Boutique en ligne ?</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="boutique-legend">
              <label class="b-chip"><input type="radio" name="boutique_actif" value="oui" class="b-chip-input"><span>Oui</span></label>
              <label class="b-chip"><input type="radio" name="boutique_actif" value="non" class="b-chip-input"><span>Non</span></label>
            </div>
          </div>
          <div id="boutique-extra" class="b-nested hidden">
            <p class="b-nested-label">Détails boutique</p>
            <div class="b-field">
              <label class="b-label" for="boutique_nb_produits">Nombre de produits approximatif</label>
              <input id="boutique_nb_produits" type="text" name="boutique_nb_produits" placeholder="Ex : 30 produits" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="boutique_livraison">Mode de livraison prévu</label>
              <input id="boutique_livraison" type="text" name="boutique_livraison" placeholder="Ex : Colissimo, retrait en boutique, livraison locale…" class="b-input">
            </div>
            <div class="b-field">
              <span class="b-label" id="paiement-legend">Modes de paiement souhaités</span>
              <div class="b-chips b-chips-wrap" role="group" aria-labelledby="paiement-legend">
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="cb" class="b-chip-input"><span>Carte bancaire</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="virement" class="b-chip-input"><span>Virement</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="cheque" class="b-chip-input"><span>Chèque</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="paypal" class="b-chip-input"><span>PayPal</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="autre" class="b-chip-input"><span>Autre</span></label>
              </div>
              <div id="boutique_paiement-autre" class="b-reveal hidden">
                <input type="text" name="boutique_paiement_autre" placeholder="Précisez le mode de paiement…" class="b-input">
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           05 · Contenu disponible
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">05</span>
          <div>
            <p class="b-overline">Ce que vous avez déjà</p>
            <h2 class="b-title">Contenu disponible</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="contenu-legend">Éléments que vous pouvez fournir</span>
            <div class="b-check-grid" role="group" aria-labelledby="contenu-legend">
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="logo" class="b-check-input"><span>Logo / charte graphique</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="photos" class="b-check-input"><span>Photos</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="textes_rediges" class="b-check-input"><span>Textes rédigés</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="videos" class="b-check-input"><span>Vidéos</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="temoignages" class="b-check-input"><span>Témoignages clients</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="rien" class="b-check-input"><span>Rien pour l'instant</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="contenu_dispo-autre" class="b-reveal hidden">
              <input type="text" name="contenu_dispo_autre" placeholder="Précisez ce que vous avez…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="textes-legend">Rédaction des textes du site</span>
            <div class="b-chips b-chips-col" role="radiogroup" aria-labelledby="textes-legend">
              <label class="b-chip"><input type="radio" name="textes" value="je_fournis" class="b-chip-input"><span>Je fournis les textes moi-même</span></label>
              <label class="b-chip"><input type="radio" name="textes" value="aide" class="b-chip-input"><span>Vous m'aidez à les améliorer</span></label>
              <label class="b-chip"><input type="radio" name="textes" value="vous_redigez" class="b-chip-input"><span>Vous rédigez entièrement pour moi</span></label>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           06 · Présence en ligne
      ══════════════════════════════ -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">06</span>
          <div>
            <p class="b-overline">Votre empreinte digitale</p>
            <h2 class="b-title">Présence en ligne</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="reseaux-legend">Réseaux sociaux utilisés</span>
            <div class="b-check-grid" role="group" aria-labelledby="reseaux-legend">
              <label class="b-check"><input type="checkbox" name="reseaux" value="facebook" class="b-check-input"><span>Facebook</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="instagram" class="b-check-input"><span>Instagram</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="linkedin" class="b-check-input"><span>LinkedIn</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="youtube" class="b-check-input"><span>YouTube</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="tiktok" class="b-check-input"><span>TikTok</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="pinterest" class="b-check-input"><span>Pinterest</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="reseaux-autre" class="b-reveal hidden">
              <input type="text" name="reseaux_autre" placeholder="Précisez le réseau social…" class="b-input">
            </div>
          </div>
          <div class="b-field">
