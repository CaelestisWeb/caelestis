---
---

<div class="brief-root">

  <div id="restore-banner" class="restore-banner hidden" role="alert">
    <div class="restore-inner">
      <span class="restore-dot" aria-hidden="true"></span>
      <p class="restore-msg">Réponses sauvegardées. Souhaitez-vous reprendre là où vous en étiez&nbsp;?</p>
      <div class="restore-actions">
        <button id="restore-btn" class="restore-yes">Reprendre</button>
        <button id="discard-btn" class="restore-no" aria-label="Ignorer">✕</button>
      </div>
    </div>
  </div>

  <div id="form-container" class="brief-container">

    <header class="brief-header">
      <p class="brief-overline">Caelestis. Questionnaire de création</p>
      <h1 class="brief-title">Donnons vie<br>à votre site.</h1>
      <p class="brief-subtitle">Vous avez validé votre devis, bravo ! Ce questionnaire me donne toutes les informations nécessaires pour démarrer la création de votre site. Prenez votre temps, il se sauvegarde automatiquement.</p>
      <div class="brief-divider" aria-hidden="true"></div>
    </header>

    <div aria-live="polite" style="display:none;">
      <span id="save-indicator" aria-label="Formulaire sauvegardé"><span id="save-time"></span></span>
    </div>

    <form id="brief-form" novalidate>

      <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off">
      </div>

      <!-- Identification légère -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="5" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 12c0-2.21 2.239-4 5-4s5 1.79 5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          </span>
          <div>
            <p class="b-overline">Pour commencer</p>
            <h2 class="b-title">Vos coordonnées</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="nom_entreprise">Nom de l'entreprise</label>
              <input id="nom_entreprise" type="text" name="nom_entreprise" placeholder="Ex : Jardins Dupont" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="nom_dirigeant">Votre prénom et nom</label>
              <input id="nom_dirigeant" type="text" name="nom_dirigeant" placeholder="Ex : Jean Dupont" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="email_contact">
                Email <span class="b-required" aria-label="champ obligatoire">*</span>
              </label>
              <input id="email_contact" type="email" name="email_contact" placeholder="votre@email.fr" class="b-input" required>
            </div>
            <div class="b-field">
              <label class="b-label" for="telephone">Téléphone</label>
              <input id="telephone" type="tel" name="telephone" placeholder="07 xx xx xx xx" class="b-input">
            </div>
          </div>
        </div>
      </section>

      <!-- 01 · Votre contenu -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">01</span>
          <div>
            <p class="b-overline">Ce que vous avez</p>
            <h2 class="b-title">Votre contenu</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="contenu-legend">Éléments que vous pouvez fournir</span>
            <div class="b-check-grid" role="group" aria-labelledby="contenu-legend">
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="logo" class="b-check-input"><span>Logo et charte graphique</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="photos" class="b-check-input"><span>Photos professionnelles</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="textes_rediges" class="b-check-input"><span>Textes rédigés</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="videos" class="b-check-input"><span>Vidéos</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="temoignages" class="b-check-input"><span>Témoignages clients</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="rien" class="b-check-input"><span>Rien pour l'instant</span></label>
              <label class="b-check"><input type="checkbox" name="contenu_dispo" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="contenu_dispo-autre" class="b-reveal hidden">
              <input type="text" name="contenu_dispo_autre" aria-label="Précisez ce que vous pouvez apporter" placeholder="Précisez ce que vous pouvez apporter…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <span class="b-label" id="textes-legend">Les textes du site</span>
            <div class="b-chips b-chips-col" role="radiogroup" aria-labelledby="textes-legend">
              <label class="b-chip b-chip-block"><input type="radio" name="textes" value="je_fournis" class="b-chip-input"><span>Je fournis les textes moi-même</span></label>
              <label class="b-chip b-chip-block"><input type="radio" name="textes" value="aide" class="b-chip-input"><span>Vous m'aidez à les améliorer</span></label>
              <label class="b-chip b-chip-block"><input type="radio" name="textes" value="vous_redigez" class="b-chip-input"><span>Vous rédigez entièrement pour moi</span></label>
            </div>
          </div>
        </div>
      </section>

      <!-- 02 · Vos réseaux sociaux -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">02</span>
          <div>
            <p class="b-overline">Votre présence en ligne</p>
            <h2 class="b-title">Vos réseaux sociaux</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="reseaux-legend">Réseaux à intégrer sur le site <span class="b-hint">(optionnel)</span></span>
            <div class="b-check-grid" role="group" aria-labelledby="reseaux-legend">
              <label class="b-check"><input type="checkbox" name="reseaux" value="facebook" class="b-check-input"><span>Facebook</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="instagram" class="b-check-input"><span>Instagram</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="linkedin" class="b-check-input"><span>LinkedIn</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="youtube" class="b-check-input"><span>YouTube</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="tiktok" class="b-check-input"><span>TikTok</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="pinterest" class="b-check-input"><span>Pinterest</span></label>
              <label class="b-check"><input type="checkbox" name="reseaux" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="reseaux-autre" class="b-reveal hidden">
              <input type="text" name="reseaux_autre" aria-label="Précisez le réseau social" placeholder="Précisez le réseau…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="comptes_reseaux">URLs ou noms de vos comptes</label>
            <textarea id="comptes_reseaux" name="comptes_reseaux" rows="3" placeholder="Ex : instagram.com/jardins.dupont, facebook.com/jardinsdupont…" class="b-textarea"></textarea>
          </div>
        </div>
      </section>

      <!-- 03 · Votre boutique en ligne -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">03</span>
          <div>
            <p class="b-overline">Vente en ligne</p>
            <h2 class="b-title">Votre boutique</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="boutique-legend">Votre site inclut-il une boutique en ligne ?</span>
            <div class="b-chips" role="radiogroup" aria-labelledby="boutique-legend">
              <label class="b-chip"><input type="radio" name="boutique_actif" value="oui" class="b-chip-input"><span>Oui</span></label>
              <label class="b-chip"><input type="radio" name="boutique_actif" value="non" class="b-chip-input"><span>Non</span></label>
            </div>
          </div>
          <div id="boutique-extra" class="b-nested hidden">
            <p class="b-nested-label">Détails de votre boutique</p>
            <div class="b-field">
              <label class="b-label" for="boutique_nb_produits">Nombre de produits approximatif</label>
              <input id="boutique_nb_produits" type="text" name="boutique_nb_produits" placeholder="Ex : 30 produits, 5 catégories" class="b-input">
            </div>
            <div class="b-field">
              <label class="b-label" for="boutique_livraison">Modalités de livraison</label>
              <textarea id="boutique_livraison" name="boutique_livraison" rows="2" placeholder="Ex : Livraison Colissimo, click and collect, livraison offerte dès 50 €…" class="b-textarea"></textarea>
            </div>
            <div class="b-field">
              <span class="b-label" id="paiement-legend">Modes de paiement souhaités</span>
              <div class="b-chips b-chips-wrap" role="group" aria-labelledby="paiement-legend">
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="cb" class="b-chip-input"><span>Carte bancaire</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="paypal" class="b-chip-input"><span>PayPal</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="virement" class="b-chip-input"><span>Virement bancaire</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="cheque" class="b-chip-input"><span>Chèque</span></label>
                <label class="b-chip"><input type="checkbox" name="boutique_paiement" value="autre" class="b-chip-input"><span>Autre</span></label>
              </div>
              <div id="boutique_paiement-autre" class="b-reveal hidden">
                <input type="text" name="boutique_paiement_autre" aria-label="Précisez le mode de paiement" placeholder="Précisez le mode de paiement…" class="b-input">
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 04 · Informations légales -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">04</span>
          <div>
            <p class="b-overline">Pour les mentions légales</p>
            <h2 class="b-title">Informations légales</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="statut-legend">Statut juridique</span>
            <div class="b-chips b-chips-wrap" role="radiogroup" aria-labelledby="statut-legend">
              <label class="b-chip"><input type="radio" name="statut_juridique" value="ei" class="b-chip-input"><span>Auto-entrepreneur ou EI</span></label>
              <label class="b-chip"><input type="radio" name="statut_juridique" value="eurl" class="b-chip-input"><span>EURL</span></label>
              <label class="b-chip"><input type="radio" name="statut_juridique" value="sarl" class="b-chip-input"><span>SARL</span></label>
              <label class="b-chip"><input type="radio" name="statut_juridique" value="sas" class="b-chip-input"><span>SAS ou SASU</span></label>
              <label class="b-chip"><input type="radio" name="statut_juridique" value="association" class="b-chip-input"><span>Association</span></label>
              <label class="b-chip"><input type="radio" name="statut_juridique" value="autre" class="b-chip-input"><span>Autre</span></label>
            </div>
            <div id="statut-autre" class="b-reveal hidden">
              <input type="text" name="statut_autre" aria-label="Précisez votre statut juridique" placeholder="Précisez votre statut juridique…" class="b-input">
            </div>
          </div>
          <div class="b-row-2">
            <div class="b-field">
              <label class="b-label" for="siret">Numéro SIRET <span class="b-hint">(optionnel)</span></label>
              <input id="siret" type="text" name="siret" placeholder="Ex : 123 456 789 00010" class="b-input" maxlength="20" inputmode="numeric">
            </div>
            <div class="b-field">
              <label class="b-label" for="numero_tva">Numéro de TVA <span class="b-hint">(si applicable)</span></label>
              <input id="numero_tva" type="text" name="numero_tva" placeholder="Ex : FR 12 345678901" class="b-input">
            </div>
          </div>
        </div>
      </section>

      <!-- 05 · Vos valeurs -->
      <section class="b-card">
        <div class="b-card-head">
          <span class="b-num" aria-hidden="true">05</span>
          <div>
            <p class="b-overline">Ce qui vous définit</p>
            <h2 class="b-title">Vos valeurs</h2>
          </div>
        </div>
        <div class="b-body">
          <div class="b-field">
            <span class="b-label" id="valeurs-legend">Les valeurs à mettre en avant sur votre site</span>
            <div class="b-check-grid" role="group" aria-labelledby="valeurs-legend">
              <label class="b-check"><input type="checkbox" name="valeurs" value="proximite" class="b-check-input"><span>Proximité</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="qualite" class="b-check-input"><span>Qualité</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="confiance" class="b-check-input"><span>Confiance</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="innovation" class="b-check-input"><span>Innovation</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="transparence" class="b-check-input"><span>Transparence</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="engagement" class="b-check-input"><span>Engagement</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="passion" class="b-check-input"><span>Passion</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="expertise" class="b-check-input"><span>Expertise</span></label>
              <label class="b-check"><input type="checkbox" name="valeurs" value="autre" class="b-check-input"><span>Autre</span></label>
            </div>
            <div id="valeurs-autre" class="b-reveal hidden">
              <input type="text" name="valeurs_autre" aria-label="Précisez vos valeurs" placeholder="Précisez vos valeurs…" class="b-input">
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="message_important">Message important ou contrainte particulière <span class="b-hint">(optionnel)</span></label>
            <textarea id="message_important" name="message_important" rows="4" placeholder="Une date butoir, quelque chose que vous ne voulez surtout pas sur votre site, une idée de page ou de fonctionnalité qui vous tient à cœur…" class="b-textarea"></textarea>
          </div>
        </div>
      </section>

      <!-- 06 · Vos fichiers -->
      <section class="b-card b-card-upload">
        <div class="b-card-head">
          <span class="b-num b-num-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 10V1m0 0L4.5 4M7.5 1l3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M1.5 10.5v1a2 2 0 002 2h8a2 2 0 002-2v-1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </span>
          <div>
            <p class="b-overline">Documents et médias</p>
            <h2 class="b-title">Vos fichiers</h2>
          </div>
        </div>
        <div class="b-body">
          <p class="b-docs-note">Logo, photos de vos réalisations, brochures, textes rédigés… Tout ce qui peut nous aider à démarrer. <span class="b-hint">5 Mo max par fichier, 8 Mo total.</span> Pour des fichiers plus lourds, utilisez WeTransfer et collez le lien ci-dessous.</p>
          <div class="b-field">
            <div class="b-upload-zone" id="upload-zone">
              <input type="file" id="attachments" name="attachments" multiple
                accept="image/jpeg,image/png,image/webp,image/gif,application/pdf,.doc,.docx"
                class="b-upload-input" aria-label="Joindre des fichiers">
              <div class="b-upload-ui" id="upload-ui">
                <div class="b-upload-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 18V7m0 0L9 12m5-5l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 20v1.5A2.5 2.5 0 006.5 24h15a2.5 2.5 0 002.5-2.5V20" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                </div>
                <p class="b-upload-text">Glissez vos fichiers ici</p>
                <p class="b-upload-sub">ou cliquez pour parcourir vos dossiers</p>
                <p class="b-upload-sub">Images (JPG, PNG, WebP), PDF, Word</p>
              </div>
              <ul id="file-list" class="b-file-list" aria-label="Fichiers sélectionnés"></ul>
              <p id="upload-error" class="b-upload-error hidden"></p>
            </div>
          </div>
          <div class="b-field">
            <label class="b-label" for="wetransfer_link">Lien WeTransfer <span class="b-hint">(pour les fichiers volumineux)</span></label>
            <input id="wetransfer_link" type="url" name="wetransfer_link" placeholder="https://we.tl/t-xxxxxxxxxx" class="b-input">
          </div>
        </div>
      </section>

      <div id="form-error" class="b-error hidden" role="alert">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3.5M8 11v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span id="form-error-text"></span>
      </div>

      <div class="brief-submit-wrap">
        <button id="submit-btn" type="submit" class="b-submit">
          Envoyer le questionnaire
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

    </form>
  </div>

  <div id="success-screen" class="success-screen hidden">
    <div class="success-inner">
      <div class="success-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M5 14l6 6 12-12" stroke="#3d4f28" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <p class="success-overline">Questionnaire envoyé</p>
      <h2 class="success-title">Merci.<br>C'est bien reçu.</h2>
      <p class="success-body">Votre questionnaire de création a bien été transmis. Célestin va le lire avec attention et vous recontactera <strong>sous 48h maximum</strong> pour démarrer le projet.</p>
      <div class="success-footer">
        <span>07 69 36 27 27</span>
        <span class="success-sep" aria-hidden="true">/</span>
        <a href="https://caelestis.fr" class="success-link">caelestis.fr</a>
      </div>
    </div>
  </div>

</div>

<style>
  .brief-root {
    --cream:       #EDE3D4;
    --cream-dark:  #CFC0A0;
    --ocre:        #4C3D19;
    --ocre-dark:   #362A10;
    --golden:      #CFBB99;
    --brun:        #3d4f28;
    --brun-mid:    #6B6040;
    --sauge:       #5C6A40;
    --sauge-pale:  #D8CDB0;
    --pierre:      #665F4B;
    --encre:       #2A1E0C;
    --surface:     rgba(255,253,248,0.82);
    --border:      rgba(207,192,160,0.75);
    --border-focus:#3d4f28;
    font-family: 'DM Sans Variable', 'DM Sans', sans-serif;
    background: var(--cream);
    min-height: 100vh;
    padding-bottom: 80px;
  }
  .restore-banner { position:sticky;top:0;z-index:50;background:var(--brun);border-bottom:1px solid rgba(61,79,40,.4); }
  .restore-inner { max-width:760px;margin:0 auto;padding:12px 20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap; }
  .restore-dot { width:6px;height:6px;border-radius:50%;background:var(--golden);flex-shrink:0;animation:pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.3)} }
  .restore-msg { font-size:.8125rem;color:rgba(237,227,212,.9);flex:1;min-width:180px; }
  .restore-actions { display:flex;gap:8px;flex-shrink:0; }
  .restore-yes { font-size:.75rem;font-weight:700;background:var(--golden);color:var(--encre);border:none;border-radius:6px;padding:6px 14px;cursor:pointer;transition:background .2s;font-family:inherit; }
  .restore-yes:hover { background:#e0cd9e; }
  .restore-no { font-size:.8rem;color:rgba(237,227,212,.6);background:none;border:none;cursor:pointer;padding:6px 8px;font-family:inherit;transition:color .2s; }
  .restore-no:hover { color:rgba(237,227,212,.95); }
  .brief-container { max-width:760px;margin:0 auto;padding:0 20px; }
  .brief-header { padding-top:56px;margin-bottom:8px; }
  .brief-overline { font-size:.625rem;font-weight:700;text-transform:uppercase;letter-spacing:.22em;color:var(--sauge);display:block;margin-bottom:14px; }
  .brief-title { font-family:'Lora',serif;font-size:clamp(1.9rem,5vw,2.75rem);font-weight:400;color:var(--brun);line-height:1.1;letter-spacing:-.025em;margin-bottom:18px; }
  .brief-subtitle { font-size:.875rem;color:var(--brun-mid);line-height:1.75;max-width:520px;margin-bottom:28px; }
  .brief-divider { width:48px;height:2px;background:linear-gradient(90deg,var(--sauge),transparent);border-radius:2px;margin-bottom:32px; }
  .b-card { background:var(--surface);border:1.5px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:16px;transition:border-color .25s ease,box-shadow .25s ease; }
  .b-card:focus-within { border-color:rgba(136,144,99,.55);box-shadow:0 6px 28px rgba(61,79,40,.07); }
  .b-card-head { display:flex;align-items:flex-start;gap:16px;padding:20px 26px 16px;border-bottom:1px solid var(--border);background:rgba(237,227,212,.35); }
  .b-num { font-family:'Lora',serif;font-size:.875rem;font-weight:400;color:var(--sauge);line-height:1;padding-top:3px;flex-shrink:0;min-width:24px; }
  .b-num-icon { display:flex;align-items:center;color:var(--sauge); }
  .b-overline { font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.18em;color:var(--sauge);display:block;margin-bottom:4px; }
  .b-title { font-family:'Lora',serif;font-size:1rem;font-weight:400;color:var(--brun);line-height:1.2;letter-spacing:-.018em; }
  .b-body { padding:22px 26px;display:flex;flex-direction:column;gap:18px; }
  .b-field { display:flex;flex-direction:column;gap:7px; }
  .b-label { font-size:.6875rem;font-weight:600;text-transform:uppercase;letter-spacing:.09em;color:var(--brun-mid); }
  .b-required { color:#b45309;margin-left:2px; }
  .b-hint { font-weight:400;text-transform:none;letter-spacing:0;color:var(--pierre); }
  .b-input { width:100%;border:1.5px solid var(--border);border-radius:8px;padding:10px 13px;font-size:.875rem;color:var(--encre);background:rgba(255,253,248,.85);outline:none;font-family:inherit;transition:border-color .18s ease,box-shadow .18s ease;box-sizing:border-box; }
  .b-input::placeholder { color:var(--pierre); }
  .b-input:focus { border-color:var(--brun);box-shadow:0 0 0 3px rgba(61,79,40,.1);background:rgba(255,253,248,1); }
  .b-textarea { width:100%;border:1.5px solid var(--border);border-radius:8px;padding:10px 13px;font-size:.875rem;color:var(--encre);background:rgba(255,253,248,.85);outline:none;resize:vertical;min-height:80px;font-family:inherit;line-height:1.65;transition:border-color .18s ease,box-shadow .18s ease;box-sizing:border-box; }
  .b-textarea::placeholder { color:var(--pierre); }
  .b-textarea:focus { border-color:var(--brun);box-shadow:0 0 0 3px rgba(61,79,40,.1);background:rgba(255,253,248,1); }
  .b-row-2 { display:grid;grid-template-columns:1fr;gap:14px; }
  @media (min-width:560px) { .b-row-2 { grid-template-columns:1fr 1fr; } }
  .b-chips { display:flex;flex-wrap:wrap;gap:7px; }
  .b-chips-wrap { flex-wrap:wrap; }
  .b-chips-col { flex-direction:column; }
  .b-chip { display:inline-flex;align-items:center;gap:8px;padding:7px 13px;border:1.5px solid var(--border);border-radius:99px;cursor:pointer;font-size:.8125rem;color:var(--brun-mid);background:rgba(255,253,248,.7);transition:border-color .18s ease,background .18s ease,color .18s ease;-webkit-tap-highlight-color:transparent;user-select:none; }
  .b-chip-block { border-radius:9px;width:100%; }
  .b-chip:hover { border-color:var(--sauge);background:rgba(136,144,99,.08);color:var(--brun); }
  .b-chip:has(.b-chip-input:checked) { border-color:var(--brun);background:rgba(61,79,40,.08);color:var(--brun);font-weight:500; }
  .b-chip-input { position:absolute;opacity:0;width:0;height:0;pointer-events:none; }
  .b-check-grid { display:grid;grid-template-columns:1fr 1fr;gap:6px; }
  @media (min-width:560px) { .b-check-grid { grid-template-columns:repeat(3,1fr); } }
  .b-check { display:flex;align-items:center;gap:9px;padding:8px 11px;border:1.5px solid var(--border);border-radius:8px;cursor:pointer;font-size:.8125rem;color:var(--brun-mid);background:rgba(255,253,248,.6);transition:border-color .18s ease,background .18s ease,color .18s ease;-webkit-tap-highlight-color:transparent;user-select:none; }
  .b-check:hover { border-color:var(--sauge);background:rgba(136,144,99,.08);color:var(--brun); }
  .b-check:has(.b-check-input:checked) { border-color:var(--brun);background:rgba(61,79,40,.07);color:var(--brun);font-weight:500; }
  .b-check-input { width:14px;height:14px;accent-color:var(--brun);flex-shrink:0;cursor:pointer; }
  .b-reveal { margin-top:6px;animation:b-fadein .22s ease both; }
  @keyframes b-fadein { from{opacity:0;transform:translateY(-4px)} to{opacity:1;transform:translateY(0)} }
  .b-nested { background:rgba(61,79,40,.04);border:1px solid rgba(136,144,99,.3);border-radius:10px;padding:18px;display:flex;flex-direction:column;gap:16px; }
  .b-nested-label { font-size:.625rem;font-weight:700;text-transform:uppercase;letter-spacing:.18em;color:var(--sauge); }
  .b-docs-note { font-size:.8125rem;color:var(--brun-mid);line-height:1.65;margin:0; }
  .b-upload-zone { border:1.5px dashed var(--cream-dark);border-radius:10px;background:rgba(255,253,248,.6);cursor:pointer;transition:border-color .18s ease,background .18s ease;position:relative;min-height:120px; }
  .b-upload-zone.is-dragover { border-color:var(--brun);background:rgba(61,79,40,.05); }
  .b-upload-input { position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;z-index:2; }
  .b-upload-ui { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:24px 16px;pointer-events:none;text-align:center; }
  .b-upload-icon { width:44px;height:44px;border-radius:50%;background:rgba(136,144,99,.12);display:flex;align-items:center;justify-content:center;color:var(--sauge);margin-bottom:4px; }
  .b-upload-text { font-size:.875rem;font-weight:500;color:var(--brun); }
  .b-upload-sub { font-size:.75rem;color:var(--pierre);margin:0; }
  .b-file-list { list-style:none;padding:0 10px 10px;margin:0;display:flex;flex-direction:column;gap:4px; }
  .b-file-item { display:flex;align-items:center;gap:8px;background:rgba(61,79,40,.06);border-radius:6px;padding:7px 10px; }
  .b-file-name { flex:1;font-size:.8125rem;color:var(--brun);white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
  .b-file-size { font-size:.75rem;color:var(--pierre);flex-shrink:0; }
  .b-file-remove { background:none;border:none;cursor:pointer;color:var(--pierre);font-size:.75rem;padding:2px 4px;line-height:1;transition:color .15s ease;font-family:inherit; }
  .b-file-remove:hover { color:var(--brun); }
  .b-upload-error { font-size:.75rem;color:#b45309;margin:0 10px 10px;padding:6px 10px;background:rgba(180,83,9,.06);border-radius:6px; }
  .b-error { display:flex;align-items:flex-start;gap:10px;background:rgba(180,83,9,.07);border:1.5px solid rgba(180,83,9,.25);border-radius:10px;padding:14px 16px;font-size:.875rem;color:#92400e;margin-bottom:16px; }
  .b-error svg { flex-shrink:0;margin-top:1px; }
  .brief-submit-wrap { display:flex;flex-direction:column;align-items:center;gap:10px;padding-bottom:8px; }
  .b-submit { display:inline-flex;align-items:center;gap:10px;padding:14px 36px;background:var(--sauge);color:#fff;border:none;border-radius:10px;font-family:inherit;font-size:.875rem;font-weight:600;letter-spacing:.04em;cursor:pointer;position:relative;transition:background .22s ease,transform .2s cubic-bezier(.34,1.2,.64,1),box-shadow .22s ease; }
  .b-submit::before { content:'';position:absolute;inset:-6px;border-radius:14px;border:1.5px solid rgba(136,144,99,.4);opacity:0;transform:scale(.93);transition:opacity .36s ease,transform .36s cubic-bezier(.34,1.2,.64,1);pointer-events:none; }
  .b-submit:hover { background:var(--brun-mid);transform:translateY(-2px);box-shadow:0 8px 28px rgba(136,144,99,.28); }
  .b-submit:hover::before { opacity:1;transform:scale(1); }
  .b-submit:active { transform:translateY(0);box-shadow:none; }
  .b-submit:disabled { opacity:.55;cursor:not-allowed;transform:none;box-shadow:none; }
  .success-screen { max-width:580px;margin:0 auto;padding:80px 24px; }
  .success-inner { text-align:center; }
  .success-icon { width:64px;height:64px;border-radius:50%;background:rgba(61,79,40,.1);border:1.5px solid rgba(61,79,40,.2);display:flex;align-items:center;justify-content:center;margin:0 auto 24px; }
  .success-overline { font-size:.625rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--sauge);display:block;margin-bottom:12px; }
  .success-title { font-family:'Lora',serif;font-size:clamp(1.75rem,5vw,2.5rem);font-weight:400;color:var(--brun);line-height:1.12;letter-spacing:-.025em;margin-bottom:20px; }
  .success-body { font-size:.875rem;color:var(--brun-mid);line-height:1.75;margin-bottom:12px; }
  .success-body strong { color:var(--encre);font-weight:600; }
  .success-link { color:var(--brun);text-decoration:underline;text-underline-offset:3px; }
  .success-link:hover { color:var(--ocre); }
  .success-footer { display:flex;align-items:center;justify-content:center;gap:10px;font-size:.75rem;color:var(--pierre);margin-top:28px; }
  .success-sep { opacity:.4; }
  .hidden { display:none !important; }
</style>

<script>
  const form          = document.getElementById('brief-form')      as HTMLFormElement | null;
  const saveIndicator = document.getElementById('save-indicator')  as HTMLElement | null;
  const saveTimeEl    = document.getElementById('save-time')       as HTMLElement | null;
  const restoreBanner = document.getElementById('restore-banner')  as HTMLElement | null;
  const restoreBtn    = document.getElementById('restore-btn')     as HTMLElement | null;
  const discardBtn    = document.getElementById('discard-btn')     as HTMLElement | null;
  const submitBtn     = document.getElementById('submit-btn')      as HTMLButtonElement | null;
  const formContainer = document.getElementById('form-container')  as HTMLElement | null;
  const successScreen = document.getElementById('success-screen')  as HTMLElement | null;
  const formError     = document.getElementById('form-error')      as HTMLElement | null;
  const formErrorText = document.getElementById('form-error-text') as HTMLElement | null;

  const STORAGE_KEY = 'caelestis_creation_v2';

  function getFormState(): Record<string, string | string[]> {
    if (!form) return {};
    const state: Record<string, string | string[]> = {};
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      'input:not([type="checkbox"]):not([type="radio"]):not([type="file"]), textarea'
    ).forEach(el => { if (el.name) state[el.name] = el.value; });
    const radioNames = new Set<string>();
    form.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach(el => { if (el.name) radioNames.add(el.name); });
    radioNames.forEach(name => {
      const checked = form!.querySelector<HTMLInputElement>(`input[type="radio"][name="${CSS.escape(name)}"]:checked`);
      state[name] = checked ? checked.value : '';
    });
    const cbNames = new Set<string>();
    form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach(el => { if (el.name) cbNames.add(el.name); });
    cbNames.forEach(name => {
      state[name] = Array.from(
        form!.querySelectorAll<HTMLInputElement>(`input[type="checkbox"][name="${CSS.escape(name)}"]:checked`)
      ).map(el => el.value);
    });
    return state;
  }

  function restoreFormState(state: Record<string, string | string[]>) {
    if (!form) return;
    Object.entries(state).forEach(([name, value]) => {
      if (Array.isArray(value)) {
        form!.querySelectorAll<HTMLInputElement>(`input[type="checkbox"][name="${CSS.escape(name)}"]`).forEach(el => {
          el.checked = value.includes(el.value);
        });
      } else if (value) {
        const isRadioGroup = !!form!.querySelector<HTMLInputElement>(`input[type="radio"][name="${CSS.escape(name)}"]`);
        if (isRadioGroup) {
          const r = form!.querySelector<HTMLInputElement>(`input[type="radio"][name="${CSS.escape(name)}"][value="${CSS.escape(value)}"]`);
          if (r) r.checked = true;
        } else {
          const el = form!.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${CSS.escape(name)}"]`);
          if (el && el.type !== 'radio' && el.type !== 'checkbox' && el.type !== 'file') el.value = value;
        }
      }
    });
    syncAllConditionals();
  }

  let saveTimer: ReturnType<typeof setTimeout> | null = null;
  function triggerSave() {
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(getFormState()));
        const hhmm = new Date().toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' });
        if (saveTimeEl) saveTimeEl.textContent = hhmm;
        saveIndicator?.classList.remove('hidden');
      } catch (_) {}
    }, 600);
  }
  form?.addEventListener('input', triggerSave);
  form?.addEventListener('change', triggerSave);

  function watchCbOther(groupName: string, panelId: string) {
    const sync = () => {
      const hasAutre = !!form?.querySelector<HTMLInputElement>(
        `input[type="checkbox"][name="${CSS.escape(groupName)}"][value="autre"]:checked`
      );
      document.getElementById(panelId)?.classList.toggle('hidden', !hasAutre);
    };
    form?.querySelectorAll<HTMLInputElement>(`input[type="checkbox"][name="${CSS.escape(groupName)}"]`)
      .forEach(el => el.addEventListener('change', sync));
  }

  function watchRadioValue(groupName: string, triggerValue: string, panelId: string) {
    const sync = () => {
      const checked = form?.querySelector<HTMLInputElement>(`input[type="radio"][name="${CSS.escape(groupName)}"]:checked`);
      document.getElementById(panelId)?.classList.toggle('hidden', checked?.value !== triggerValue);
    };
    form?.querySelectorAll<HTMLInputElement>(`input[type="radio"][name="${CSS.escape(groupName)}"]`)
      .forEach(el => el.addEventListener('change', sync));
  }

  function syncAllConditionals() {
    [['contenu_dispo','contenu_dispo-autre'],['reseaux','reseaux-autre'],['valeurs','valeurs-autre'],['boutique_paiement','boutique_paiement-autre']]
      .forEach(([name, id]) => {
        const has = !!form?.querySelector(`input[type="checkbox"][name="${CSS.escape(name)}"][value="autre"]:checked`);
        document.getElementById(id)?.classList.toggle('hidden', !has);
      });
    const boutique = form?.querySelector<HTMLInputElement>('input[type="radio"][name="boutique_actif"]:checked');
    document.getElementById('boutique-extra')?.classList.toggle('hidden', boutique?.value !== 'oui');
    const statut = form?.querySelector<HTMLInputElement>('input[type="radio"][name="statut_juridique"]:checked');
    document.getElementById('statut-autre')?.classList.toggle('hidden', statut?.value !== 'autre');
  }

  watchCbOther('contenu_dispo',      'contenu_dispo-autre');
  watchCbOther('reseaux',            'reseaux-autre');
  watchCbOther('valeurs',            'valeurs-autre');
  watchCbOther('boutique_paiement',  'boutique_paiement-autre');
  watchRadioValue('boutique_actif',   'oui',   'boutique-extra');
  watchRadioValue('statut_juridique', 'autre', 'statut-autre');

  /* ══ Pièces jointes ══ */
  const uploadZone  = document.getElementById('upload-zone')  as HTMLElement | null;
  const fileInputEl = document.getElementById('attachments')  as HTMLInputElement | null;
  const fileListEl  = document.getElementById('file-list')    as HTMLUListElement | null;
  const uploadErrEl = document.getElementById('upload-error') as HTMLElement | null;

  let attachedFiles: File[] = [];
  const MAX_FILE_BYTES  = 5 * 1024 * 1024;
  const MAX_TOTAL_BYTES = 8 * 1024 * 1024;

  function fmtSize(b: number): string {
    return b < 1024 * 1024 ? Math.round(b / 1024) + ' Ko' : (b / (1024 * 1024)).toFixed(1) + ' Mo';
  }
  function escHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function renderFiles(): void {
    if (!fileListEl) return;
    fileListEl.innerHTML = attachedFiles.map((f, i) => `
      <li class="b-file-item">
        <span class="b-file-name">${escHtml(f.name)}</span>
        <span class="b-file-size">${fmtSize(f.size)}</span>
        <button type="button" class="b-file-remove" data-i="${i}" aria-label="Retirer ${escHtml(f.name)}">✕</button>
      </li>
    `).join('');
    fileListEl.querySelectorAll<HTMLButtonElement>('.b-file-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.i ?? '0', 10);
        attachedFiles.splice(idx, 1);
        renderFiles();
        if (uploadErrEl) uploadErrEl.classList.add('hidden');
      });
    });
  }

  function addFiles(list: FileList | File[]): void {
    let totalBytes = attachedFiles.reduce((s, f) => s + f.size, 0);
    let skipped = false;
    Array.from(list).forEach(f => {
      if (f.size > MAX_FILE_BYTES) { skipped = true; return; }
      if (totalBytes + f.size > MAX_TOTAL_BYTES) { skipped = true; return; }
      if (attachedFiles.some(ex => ex.name === f.name && ex.size === f.size)) return;
      attachedFiles.push(f);
      totalBytes += f.size;
    });
    renderFiles();
    if (uploadErrEl) {
      if (skipped) {
        uploadErrEl.textContent = 'Certains fichiers ont été ignorés (5 Mo max par fichier, 8 Mo total).';
        uploadErrEl.classList.remove('hidden');
      } else {
        uploadErrEl.classList.add('hidden');
      }
    }
  }

  fileInputEl?.addEventListener('change', () => {
    if (fileInputEl.files) addFiles(fileInputEl.files);
    fileInputEl.value = '';
  });
  uploadZone?.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('is-dragover'); });
  ['dragleave','dragend'].forEach(ev => uploadZone?.addEventListener(ev, () => uploadZone.classList.remove('is-dragover')));
  uploadZone?.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('is-dragover');
    if ((e as DragEvent).dataTransfer?.files) addFiles((e as DragEvent).dataTransfer!.files);
  });

  function showError(msg: string) {
    if (!formError || !formErrorText) return;
    formErrorText.textContent = msg;
    formError.classList.remove('hidden');
    formError.scrollIntoView({ behavior:'smooth', block:'center' });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError?.classList.add('hidden');

    const emailInput = form.querySelector<HTMLInputElement>('input[name="email_contact"]');
    if (!emailInput?.value.trim()) {
      emailInput?.scrollIntoView({ behavior:'smooth', block:'center' });
      setTimeout(() => emailInput?.focus(), 400);
      showError('Votre adresse email est requise pour envoyer le questionnaire.');
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Envoi en cours… <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin .8s linear infinite" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>';
    }

    try {
      const fd = new FormData();
      const state = getFormState();
      for (const [k, v] of Object.entries(state)) {
        if (Array.isArray(v)) v.forEach(val => fd.append(k, val));
        else fd.append(k, v);
      }
      attachedFiles.forEach(f => fd.append('files', f));

      const res  = await fetch('/api/brief', { method:'POST', body:fd });
      const data = await res.json() as { success?: boolean; error?: string };

      if (data.success) {
        try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
        formContainer?.classList.add('hidden');
        restoreBanner?.classList.add('hidden');
        successScreen?.classList.remove('hidden');
        window.scrollTo({ top:0, behavior:'smooth' });
      } else {
        throw new Error(data.error ?? "Erreur lors de l'envoi");
      }
    } catch (err) {
      showError((err as Error).message ?? 'Erreur. Réessayez ou écrivez à contact@caelestis.fr');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Envoyer le questionnaire <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      }
    }
  });

  const spinStyle = document.createElement('style');
  spinStyle.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
  document.head.appendChild(spinStyle);

  (function init() {
    let saved: Record<string, string | string[]> | null = null;
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) saved = JSON.parse(raw) as Record<string, string | string[]>;
    } catch (_) {}
    if (!saved || Object.keys(saved).length === 0) return;
    const hasContent = Object.values(saved).some(v => Array.isArray(v) ? v.length > 0 : v.trim() !== '');
    if (!hasContent) return;
    restoreBanner?.classList.remove('hidden');
    restoreBtn?.addEventListener('click', () => {
      restoreFormState(saved!);
      restoreBanner?.classList.add('hidden');
      if (saveTimeEl) saveTimeEl.textContent = 'restauré';
      saveIndicator?.classList.remove('hidden');
    });
    discardBtn?.addEventListener('click', () => {
      try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
      restoreBanner?.classList.add('hidden');
    });
  })();
</script>
