---
import BaseLayout from '../layouts/BaseLayout.astro';
import PriceSimulator from '../components/PriceSimulator.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Simulateur de prix', item: 'https://caelestis.fr/simulateur' },
  ],
};
---

<BaseLayout
  title="Simulateur de prix — Créez votre site web · Caelestis"
  description="Obtenez une estimation personnalisée pour votre projet de site internet en 2 minutes. Vitrine, boutique ou sur mesure — recevez votre fourchette de prix par email, sans engagement."
  schema={breadcrumbSchema}
>

  <!-- ── Fond décoratif subtil ── -->
  <div aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;">
    <div style="position:absolute;top:-10%;right:-8%;width:420px;height:420px;background:radial-gradient(circle,rgba(136,144,99,0.07) 0%,transparent 70%);border-radius:50%;"></div>
    <div style="position:absolute;bottom:5%;left:-6%;width:340px;height:340px;background:radial-gradient(circle,rgba(76,61,25,0.05) 0%,transparent 70%);border-radius:50%;"></div>
  </div>

  <main style="position:relative;z-index:1;">

    <!-- ── En-tête de page ── -->
    <section class="pt-20 pb-4 px-6 md:px-10 text-center">
      <p
        class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-5"
        data-reveal
      >Simulateur de prix</p>
      <h1
        class="font-display font-light text-brun leading-tight tracking-tight mb-5"
        style="font-size: clamp(2rem, 5vw, 3.2rem);"
        data-reveal data-delay="1"
      >
        Quelle est votre<br>
        <em class="not-italic" style="color:#889063;">fourchette de prix</em>&nbsp;?
      </h1>
      <p
        class="font-body text-sm text-brun-mid max-w-md mx-auto leading-relaxed mb-2"
        data-reveal data-delay="2"
      >
        4 questions — moins de 2 minutes — estimation reçue par email.
      </p>
    </section>

    <!-- ── Simulateur ── -->
    <section class="px-6 md:px-10 pb-28 pt-10">
      <div class="max-w-lg mx-auto">
        <!-- Carte contenant le simulateur -->
        <div
          style="
            background: rgba(255,252,245,0.55);
            border: 1.5px solid rgba(207,192,160,0.55);
            border-radius: 16px;
            padding: clamp(28px, 5vw, 52px) clamp(24px, 5vw, 48px);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
          "
          data-reveal data-delay="3"
        >
          <PriceSimulator />
        </div>

        <!-- Note de confiance -->
        <p
          class="font-body text-xs text-brun-mid/50 text-center mt-6 leading-relaxed"
          data-reveal
        >
          Gratuit · Sans engagement · Aucune carte bancaire requise
        </p>
      </div>
    </section>

  </main>

</BaseLayout>
