---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import imgHero from '../assets/images/atelier-botanique.jpg';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Caelestis',
  alternateName: 'CaelestisWeb',
  description: 'Création de site web soigné et référencement naturel pour artisans, praticiens et indépendants.',
  url: 'https://caelestis.fr',
  email: 'contact@caelestis.fr',
  telephone: '+33769362727',
  image: 'https://caelestis.fr/og-image.jpg',
  logo: 'https://caelestis.fr/favicon.svg',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Crest',
    addressRegion: 'Drôme',
    postalCode: '26400',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '44.7308',
    longitude: '5.0197',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '18:00',
  },
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Virement bancaire, Carte bancaire',
  areaServed: { '@type': 'Country', name: 'France' },
  knowsAbout: ['Création de site web', 'Référencement naturel', 'SEO', 'Développement Astro', 'Tailwind CSS'],
  sameAs: [
    'https://caelestis.fr',
    'https://share.google/IKYSIPaXxlTN0W5Zz',
  ],
  serviceArea: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: '44.7308', longitude: '5.0197' },
    geoRadius: '500000',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Prestations Caelestis',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Création de site vitrine',
          description: 'Site web soigné, visible sur Google, adapté à votre activité.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          minPrice: '800',
          priceCurrency: 'EUR',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Référencement naturel (SEO)',
          description: 'Audit, stratégie et optimisation pour apparaître sur Google.',
        },
      },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Caelestis',
  url: 'https://caelestis.fr',
  description: 'Création de site web et référencement naturel pour artisans et indépendants dans la Drôme.',
  inLanguage: 'fr-FR',
  publisher: {
    '@type': 'Organization',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    logo: {
      '@type': 'ImageObject',
      url: 'https://caelestis.fr/favicon.svg',
    },
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://caelestis.fr/blog?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Caelestis',
  alternateName: 'CaelestisWeb',
  url: 'https://caelestis.fr',
  logo: {
    '@type': 'ImageObject',
    url: 'https://caelestis.fr/og-image.jpg',
    width: 1200,
    height: 630,
  },
  description: 'Développeur web indépendant spécialisé dans la création de sites internet sur mesure et le référencement naturel pour artisans, paysagistes et indépendants dans la Drôme.',
  email: 'contact@caelestis.fr',
  telephone: '+33769362727',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Crest',
    addressRegion: 'Drôme',
    postalCode: '26400',
    addressCountry: 'FR',
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Drôme' },
    { '@type': 'Country', name: 'France' },
  ],
  foundingDate: '2024',
  founder: {
    '@type': 'Person',
    name: 'Célestin Fruleux',
    jobTitle: 'Développeur web & consultant SEO',
    url: 'https://caelestis.fr/a-propos',
  },
  knowsAbout: ['Création de site web', 'Développement Astro', 'Référencement naturel', 'SEO local', 'Tailwind CSS'],
  sameAs: [
    'https://caelestis.fr',
    'https://share.google/IKYSIPaXxlTN0W5Zz',
  ],
};

---
<BaseLayout
  title="Création de site internet dans la Drôme · Caelestis"
  description="Sites web soignés pour artisans, paysagistes et indépendants dans la Drôme. Visible sur Google, livré en 2 à 4 semaines. Devis gratuit — à partir de 800€."
  schema={[localBusiness, organizationSchema, websiteSchema]}
>

  <!-- ─── FIL BOTANIQUE ─── -->
  <div class="vine-wrap" aria-hidden="true">
    <svg
      id="vine"
      class="vine-svg"
      viewBox="0 0 50 1000"
      preserveAspectRatio="none"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        id="vine-path"
        d="M 25,0
           C 48,38 2,90 18,148
           C 48,208 2,255 30,312
           C 50,368 1,418 15,474
           C 47,532 2,582 30,638
           C 50,692 1,742 18,796
           C 48,848 3,894 25,944
           C 41,968 9,992 25,1000"
        stroke-width="1.8"
        stroke-linecap="round"
        vector-effect="non-scaling-stroke"
      />
    </svg>
  </div>


  <!-- ─── HERO ─── -->
  <section class="min-h-[100vh] flex flex-col justify-center px-6 md:px-10 lg:px-20 pt-20 pb-16 relative overflow-hidden">

    <!-- Lumière ambiante organique -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="light-blob light-blob-sauge absolute w-[600px] h-[600px]"
           style="top: -8%; left: -12%; opacity: 0.7;"></div>
      <div class="light-blob light-blob-ocre absolute w-[420px] h-[420px]"
           style="bottom: 5%; right: -8%; opacity: 0.55;"></div>
      <div class="light-blob light-blob-cream absolute w-[300px] h-[300px]"
           style="top: 40%; left: 38%; opacity: 0.4;"></div>
    </div>

    <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-[1fr_42%] gap-12 lg:gap-24 items-center relative z-10">

      <!-- Colonne gauche : texte -->
      <div class="text-center lg:pl-8">

        <!-- Eyebrow -->
        <p class="font-body text-sm tracking-[0.22em] uppercase text-sauge mb-8" data-reveal>
          Création de site web · Drôme, France
        </p>

        <!-- H1 -->
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-[-0.03em] mb-7 hero-title"
          style="font-size: clamp(2rem, 5.5vw, 4.8rem);"
        >
          <span class="sl"><span>Valorisez</span></span>
          <span class="sl">votre <span class="text-sauge">activité.</span></span>
        </h1>

        <!-- Sous-titre -->
        <p class="font-body text-base leading-relaxed max-w-[500px] mb-5 text-brun-mid mx-auto" data-reveal data-delay="1">
          Des sites web pour ceux qui créent, cultivent et bâtissent avec passion. J'aide les artisans, praticiens et indépendants à avoir une présence en ligne à la hauteur de leur travail.
        </p>

        <!-- CTA -->
        <div class="flex flex-col items-center" data-reveal data-delay="2">
          <Button href="/contact" variant="primary">Parler de mon projet →</Button>
          <div class="flex items-center justify-center gap-4 mt-6 flex-wrap">
            <span class="font-body text-xs text-brun-mid/60 tracking-[0.12em] uppercase">Réponse sous 48h</span>
            <span class="text-brun-mid/25">·</span>
            <span class="font-body text-xs text-brun-mid/60 tracking-[0.12em] uppercase">Devis gratuit</span>
            <span class="text-brun-mid/25">·</span>
            <span class="font-body text-xs text-brun-mid/60 tracking-[0.12em] uppercase">À partir de 800€</span>
          </div>
        </div>

      </div>

      <!-- Colonne droite : photo éditoriale (desktop) -->
      <div class="hidden lg:flex items-center justify-center h-full">
        <div class="img-zoom img-editorial w-full" style="height: min(72vh, 620px);">
          <Image
            src={imgHero}
            alt="Atelier botanique artisanal — encres naturelles, fleurs séchées et tampons botaniques"
            class="w-full h-full object-cover object-center"
            data-parallax
            loading="eager"
            fetchpriority="high"
            widths={[480, 768, 1024]}
            sizes="(max-width: 1024px) 0px, 50vw"
          />
        </div>
      </div>

    </div>

    <!-- Photo hero mobile/tablette uniquement -->
    <div class="lg:hidden mt-10 w-full max-w-xl mx-auto px-0">
      <div class="img-zoom img-editorial overflow-hidden" style="aspect-ratio: 16/10; max-height: 360px; border-radius: 12px;">
        <Image
          src={imgHero}
          alt="Atelier botanique artisanal — encres naturelles, fleurs séchées et tampons botaniques"
          class="w-full h-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
          widths={[400, 640, 768]}
          sizes="(max-width: 640px) 100vw, 576px"
          quality={72}
        />
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator absolute bottom-8 left-6 md:left-10 lg:left-20 hidden sm:flex items-center gap-3" aria-hidden="true">
      <div class="scroll-line w-8 h-px bg-brun opacity-35"></div>
      <span class="font-body text-xs tracking-[0.18em] uppercase text-brun opacity-35">Découvrir</span>
    </div>

  </section>


  <!-- ─── POUR QUI ─── -->
  <section class="py-10 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-6xl mx-auto text-center" data-reveal>
      <p class="font-body text-sm leading-relaxed" style="color: rgba(76,61,25,0.65); letter-spacing: 0.05em;">
        Artisans · Créateurs · Paysagistes · Maraîchers · Producteurs locaux · Pépiniéristes · Praticiens bien-être · Éco-constructeurs · Gîtes de charme · Projets engagés
      </p>
      <p class="font-body text-xs mt-3" style="color: #889063; letter-spacing: 0.12em;">et bien d'autres…</p>
    </div>
  </section>


  <!-- ─── SERVICES ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Prestations</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-5">
          Ce que je peux faire pour vous.
        </h2>

      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 lg:gap-6" id="service-cards" data-reveal data-delay="1">

        <button type="button" data-service="0"
          class="service-card border-2 border-cream-dark rounded-2xl p-5 md:p-7 flex flex-col gap-4 text-center cursor-pointer transition-all duration-300 hover:border-sauge/40">
          <h3 class="font-display text-xl font-light text-brun">Site vitrine</h3>
          <p class="font-body text-sm text-brun-mid leading-relaxed flex-1">Votre activité en ligne, claire et lisible sur tous les écrans. Vos visiteurs comprennent ce que vous faites en quelques secondes et savent comment vous joindre.</p>
          <p class="service-price font-body text-xs text-sauge transition-colors duration-300">À partir de 800€</p>
        </button>

        <button type="button" data-service="1"
          class="service-card border-2 border-cream-dark rounded-2xl p-5 md:p-7 flex flex-col gap-4 text-center cursor-pointer transition-all duration-300 hover:border-sauge/40">
          <h3 class="font-display text-xl font-light text-brun">Boutique en ligne</h3>
          <p class="font-body text-sm text-brun-mid leading-relaxed flex-1">Vendez vos produits directement depuis votre site. Catalogue en ligne, paiement sécurisé, connecté à vos outils de gestion.</p>
          <p class="service-price font-body text-xs text-sauge transition-colors duration-300">Sur devis</p>
        </button>

        <button type="button" data-service="2"
          class="service-card border-2 border-cream-dark rounded-2xl p-5 md:p-7 flex flex-col gap-4 text-center cursor-pointer transition-all duration-300 hover:border-sauge/40">
          <h3 class="font-display text-xl font-light text-brun">Site sur mesure</h3>
          <p class="font-body text-sm text-brun-mid leading-relaxed flex-1">Un site entièrement conçu selon vos besoins, votre identité et vos objectifs. Une solution unique pensée pour valoriser votre activité et soutenir son développement.</p>
          <p class="service-price font-body text-xs text-sauge transition-colors duration-300">Sur devis</p>
        </button>

      </div>

      <!-- Note de modalité — rassurance sur le paiement -->
      <p class="font-body text-xs sm:text-sm font-semibold text-sauge text-center mt-10" data-reveal data-delay="2">
        30&nbsp;% d'acompte à la signature, solde à la mise en ligne.
      </p>

    </div>
  </section>


  <!-- ─── POURQUOI MOI ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth">
    <div class="max-w-6xl mx-auto">

      <div class="mb-10 text-center" data-reveal>
        <h2 class="font-display font-light leading-[1.3]" style="color: rgba(237,227,212,0.85);">
          <span class="block text-2xl md:text-3xl">Un site construit ensemble.</span>
          <span class="block text-xl md:text-2xl text-sauge mt-1">Un site qui vous ressemble.</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-10 sm:gap-8 md:gap-12 lg:gap-14">

        <div class="text-center" data-reveal>
          <div class="w-8 h-px bg-sauge mb-7 mx-auto"></div>
          <h3 class="font-display text-xl font-light mb-4">Je comprends votre métier.</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            Avant de concevoir quoi que ce soit, je cherche à comprendre votre activité, vos clients et ce qui vous distingue.
          </p>
        </div>

        <div class="text-center" data-reveal data-delay="1">
          <div class="w-8 h-px bg-sauge mb-7 mx-auto"></div>
          <h3 class="font-display text-xl font-light mb-4">Un site construit avec vous.</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            Chaque projet débute par un échange. Je réalise une maquette, nous l'améliorons ensemble et ne publions le site que lorsqu'il correspond pleinement à vos attentes.
          </p>
        </div>

        <div class="text-center" data-reveal data-delay="2">
          <div class="w-8 h-px bg-sauge mb-7 mx-auto"></div>
          <h3 class="font-display text-xl font-light mb-4">Je reste là après le lancement.</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            La mise en ligne ne marque pas la fin du projet. Je reste à votre disposition pour vous conseiller et vous accompagner dans les éventuels ajustements de votre site.
          </p>
        </div>

      </div>

      <!-- 2% FNE — intégré ici -->
      <div class="mt-16 pt-10 border-t text-center" style="border-color: rgba(237,227,212,0.10)" data-reveal>
        <p class="font-body text-sm" style="color: rgba(237,227,212,0.38)">
          2&nbsp;% de chaque projet est reversé à <a href="https://www.fne.asso.fr" target="_blank" rel="noopener noreferrer" class="text-sauge hover:opacity-80 transition-opacity">France Nature Environnement</a>. Parce que construire quelque chose de beau ne s'arrête pas à soi.
        </p>
      </div>

    </div>
  </section>


  <!-- ─── CTA FINAL ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 text-center section-ambient border-t border-cream-dark" data-reveal>
    <div class="max-w-xl mx-auto">
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6">Un premier échange.</p>
      <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-6">
        Vous avez un projet ?<br>On en parle.
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Décrivez votre activité en quelques lignes.<br>Je reviens vers vous sous 48h.
      </p>
      <Button href="/contact" variant="primary">Lancer la conversation →</Button>
    </div>
  </section>

</BaseLayout>


<style>
  /* ── Fil botanique — visible desktop uniquement ── */
  .vine-wrap {
    position: absolute;
    left: clamp(6px, 1.8vw, 22px);
    top: 0;
    bottom: 0;
    width: 50px;
    pointer-events: none;
    z-index: 2;
    display: none;
    mix-blend-mode: difference;
  }
  #vine-path {
    stroke: #655371;
  }
  @media (min-width: 1024px) {
    .vine-wrap { display: block; }
  }
  .vine-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 50px;
    height: 100%;
  }

  /* ── Scroll indicator ── */
  @keyframes scroll-breathe {
    0%, 100% { transform: scaleX(1);   opacity: 0.35; }
    50%       { transform: scaleX(1.5); opacity: 0.55; }
  }
  .scroll-line {
    transform-origin: left;
    animation: scroll-breathe 2.8s ease-in-out infinite;
  }

  /* ── Service cards — état actif ── */
  .service-card.active {
    border-color: #889063;
    background: rgba(136, 144, 99, 0.06);
  }
  .service-card.active .service-num {
    color: #889063 !important;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.service-card').forEach((card) => {
    card.addEventListener('click', () => {
      const isActive = card.classList.contains('active');
      document.querySelectorAll('.service-card').forEach((c) => c.classList.remove('active'));
      if (!isActive) card.classList.add('active');
    });
  });
</script>
