---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout
  title="Caelestis — Sites web pour artisans et PME engagées"
  description="Caelestis crée des sites web simples, beaux et durables pour artisans, producteurs locaux et petites entreprises engagées. Basé dans la Drôme."
>

  <!-- ─── HERO ─── -->
  <section class="min-h-[92vh] flex flex-col justify-center px-6 md:px-10 lg:px-20 pt-16 pb-20 relative overflow-hidden">
    <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-[1fr_280px] gap-12 items-center">

      <div>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-10" data-reveal>
          Agence web · Drôme, France
        </p>

        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-[-0.03em] mb-8"
          style="font-size: clamp(2.8rem, 6vw, 5.2rem);"
          data-reveal data-delay="1"
        >
          Des sites web<br>
          <em>qui ont du sens,</em><br>
          pour ceux qui en<br>
          donnent à leur métier.
        </h1>

        <p class="font-body text-lg leading-relaxed max-w-[520px] mb-10 text-brun-mid" data-reveal data-delay="2">
          Caelestis accompagne artisans, producteurs et petites entreprises engagées
          à révéler leur singularité sur le web. Avec des sites simples, beaux et qui durent.
        </p>

        <div data-reveal data-delay="3">
          <Button href="/contact" variant="primary">Parlons de votre projet →</Button>
        </div>
      </div>

      <!-- Lignes organiques décoratives — style topographique -->
      <div class="hidden lg:block" aria-hidden="true">
        <svg viewBox="0 0 260 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full opacity-[0.22]">
          <path d="M240,10 C185,38 125,82 68,155 S8,268 0,380" stroke="#7A8B5C" stroke-width="1.3" fill="none"/>
          <path d="M260,35 C205,63 145,107 88,180 S28,292 20,405" stroke="#7A8B5C" stroke-width="1.1" fill="none"/>
          <path d="M220,0 C165,26 105,68 48,140 S-12,252 -20,362" stroke="#7A8B5C" stroke-width="0.9" fill="none"/>
          <path d="M260,70 C205,96 145,138 88,210 S30,320 22,432" stroke="#7A8B5C" stroke-width="0.8" fill="none"/>
          <path d="M200,5 C148,30 92,70 38,140 S-18,248 -24,355" stroke="#C97B45" stroke-width="1.0" fill="none"/>
          <path d="M230,25 C178,50 120,90 66,162 S6,270 -2,378" stroke="#C97B45" stroke-width="0.75" fill="none"/>
          <path d="M180,0 C130,22 76,60 24,128 S-28,234 -32,340" stroke="#C97B45" stroke-width="0.6" fill="none"/>
          <circle cx="128" cy="105" r="2"   fill="#C97B45" opacity="0.55"/>
          <circle cx="74"  cy="195" r="1.5" fill="#7A8B5C" opacity="0.6"/>
          <circle cx="168" cy="62"  r="1.5" fill="#7A8B5C" opacity="0.45"/>
          <circle cx="42"  cy="278" r="2.2" fill="#7A8B5C" opacity="0.35"/>
          <circle cx="195" cy="30"  r="1"   fill="#C97B45" opacity="0.4"/>
        </svg>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-6 md:left-10 lg:left-20 flex items-center gap-3 opacity-35" aria-hidden="true">
      <div class="w-8 h-px bg-brun"></div>
      <span class="font-body text-xs tracking-widest uppercase text-brun">Découvrir</span>
    </div>
  </section>


  <!-- ─── POUR QUI ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-6xl mx-auto">

      <div class="max-w-lg mb-16" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Pour qui ?</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1]">
          Pour celles et ceux<br>qui font les choses<br><em>autrement.</em>
        </h2>
        <p class="font-body text-base text-brun-mid mt-5 leading-relaxed">
          Vous mettez du cœur dans ce que vous faites.<br>Vous méritez un site qui vous ressemble.
        </p>
      </div>

      <!-- Disposition organique — pas une grille -->
      <div class="space-y-3" data-reveal data-delay="1">
        <div class="flex items-baseline gap-5">
          <span class="font-display text-5xl font-light select-none" style="color: rgba(61,46,31,0.12)">—</span>
          <div>
            <h3 class="font-display text-3xl md:text-4xl font-light text-brun">Artisans</h3>
            <p class="font-body text-sm text-brun-mid mt-1">Menuisiers, céramistes, boulangers, couturiers…</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 ml-16 md:ml-36">
          <span class="font-display text-5xl font-light select-none" style="color: rgba(61,46,31,0.12)">—</span>
          <div>
            <h3 class="font-display text-3xl md:text-4xl font-light text-brun">Producteurs locaux</h3>
            <p class="font-body text-sm text-brun-mid mt-1">Circuits courts, AMAP, domaines agricoles…</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 ml-6 md:ml-14">
          <span class="font-display text-5xl font-light select-none" style="color: rgba(61,46,31,0.12)">—</span>
          <div>
            <h3 class="font-display text-3xl md:text-4xl font-light text-brun">PME engagées</h3>
            <p class="font-body text-sm text-brun-mid mt-1">Éco-construction, associations, énergies renouvelables…</p>
          </div>
        </div>

        <div class="flex items-baseline gap-5 ml-24 md:ml-52">
          <span class="font-display text-5xl font-light select-none" style="color: rgba(61,46,31,0.12)">—</span>
          <div>
            <h3 class="font-display text-3xl md:text-4xl font-light text-ocre italic">Créateurs</h3>
            <p class="font-body text-sm text-brun-mid mt-1">Fait-main, collections, marques indépendantes…</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── MA FAÇON DE TRAVAILLER ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 bg-brun text-cream">
    <div class="max-w-6xl mx-auto">

      <div class="mb-16" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Mes valeurs</p>
        <h2 class="font-display text-4xl md:text-5xl font-light leading-[1.1]">
          Une autre façon<br><em>de faire du web.</em>
        </h2>
      </div>

      <!-- 2 colonnes décalées : colonne droite démarre plus bas -->
      <div class="grid md:grid-cols-2 gap-x-16">
        <div class="border-t py-10" style="border-color: rgba(250,246,240,0.15)" data-reveal>
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(250,246,240,0.1)">01</span>
          <h3 class="font-display text-2xl font-light mb-3">Humain avant tout</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(250,246,240,0.6)">
            Je prends le temps de vous écouter, vraiment. Pas de template appliqué sans réfléchir — chaque site naît d'une conversation honnête sur votre activité, vos clients, vos valeurs.
          </p>
        </div>

        <div class="border-t py-10 md:mt-28" style="border-color: rgba(250,246,240,0.15)" data-reveal data-delay="1">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(250,246,240,0.1)">02</span>
          <h3 class="font-display text-2xl font-light mb-3">Engagé pour le local</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(250,246,240,0.6)">
            Je crois aux circuits courts, à l'économie de proximité, aux gens qui font de belles choses près de chez eux. C'est ce qui m'a donné envie de créer Caelestis.
          </p>
        </div>

        <div class="border-t py-10" style="border-color: rgba(250,246,240,0.15)" data-reveal data-delay="1">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(250,246,240,0.1)">03</span>
          <h3 class="font-display text-2xl font-light mb-3">Sites qui durent</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(250,246,240,0.6)">
            Code propre, rapide, accessible. Pas de technologie inutile, pas de dépendance fragile. Votre site doit encore bien fonctionner dans cinq ans, sans coûter une fortune.
          </p>
        </div>

        <div class="border-t py-10" style="border-color: rgba(250,246,240,0.15)" data-reveal data-delay="2">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(250,246,240,0.1)">04</span>
          <h3 class="font-display text-2xl font-light mb-3">Juste prix</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(250,246,240,0.6)">
            Je ne crois pas aux grilles tarifaires opaques. On discute de votre projet, je vous propose un devis transparent, et on travaille dans votre budget réel.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── APERÇU SERVICES ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-end">

      <div data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Ce que je fais</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-6">
          Des sites faits<br>pour durer.
        </h2>
        <p class="font-body text-base text-brun-mid leading-relaxed mb-8">
          Sites vitrine, boutiques, blogs, refontes — je m'adapte à votre projet, pas l'inverse.
          Chaque prestation est sur devis, selon vos vrais besoins.
        </p>
        <Button href="/services" variant="outline">Voir mes prestations →</Button>
      </div>

      <div class="space-y-0" data-reveal data-delay="1">
        {['Sites vitrine', 'Sites avec blog', 'Petites boutiques en ligne', 'Refonte de site existant', 'Accompagnement & maintenance'].map((service) => (
          <div class="flex items-center gap-4 py-4 border-b border-cream-dark">
            <span class="w-1.5 h-1.5 rounded-full bg-ocre flex-shrink-0"></span>
            <span class="font-body text-base text-brun">{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── APERÇU À PROPOS ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 bg-sauge-pale">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_1.3fr] gap-16 items-center">

      <div
        class="aspect-[4/5] bg-sauge/10 border border-sauge/25 flex items-center justify-center"
        data-reveal
        aria-label="Illustration — photo à venir"
      >
        <svg viewBox="0 0 120 130" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 opacity-25">
          <circle cx="60" cy="44" r="22" stroke="#7A8B5C" stroke-width="1.5"/>
          <path d="M16 118 C16 90 36 72 60 72 C84 72 104 90 104 118" stroke="#7A8B5C" stroke-width="1.5"/>
        </svg>
      </div>

      <div data-reveal data-delay="1">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Qui suis-je ?</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-6">
          Salut, je suis<br><em>Célestin.</em>
        </h2>
        <p class="font-body text-base text-brun-mid leading-relaxed mb-4">
          22 ans, Drôme, la nature chevillée au corps depuis l'enfance. J'ai créé Caelestis pour mettre
          les mêmes valeurs au service des artisans et entreprises locales qui méritent mieux que les sites génériques.
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed mb-8">
          Faire les choses simplement, sans bullshit, en restant humain.
        </p>
        <Button href="/a-propos" variant="outline">En savoir plus →</Button>
      </div>
    </div>
  </section>


  <!-- ─── CTA FINAL ─── -->
  <section class="py-28 px-6 md:px-10 lg:px-20 text-center" data-reveal>
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-6">
        Votre projet mérite<br><em>une vraie conversation.</em>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10">
        Décrivez-moi votre activité en quelques lignes. Je vous réponds sous 48h.
      </p>
      <Button href="/contact" variant="primary">Parlons-en →</Button>
    </div>
  </section>

</BaseLayout>
