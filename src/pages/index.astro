---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Image, getImage } from 'astro:assets';
import imgHero        from '../assets/images/laptop-jardin.jpg';
import imgArtisan     from '../assets/images/atelier-botanique.jpg';
import imgBougies     from '../assets/images/bougies-artisan.jpg';
import imgYoga        from '../assets/images/yoga-soleil.jpg';
import imgJardin      from '../assets/images/jardin-communautaire.jpg';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://caelestis.fr/#business',
  name: 'Caelestis',
  alternateName: 'CaelestisWeb',
  description: 'Développeur web freelance et agence web indépendante. Création de sites internet sur mesure et référencement naturel pour artisans, producteurs et indépendants en Auvergne-Rhône-Alpes. Basé à Crest (26400), dans la Drôme.',
  url: 'https://caelestis.fr',
  email: 'contact@caelestis.fr',
  telephone: '+33769362727',
  image: 'https://caelestis.fr/og-image.jpg',
  logo: 'https://caelestis.fr/favicon.svg',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Crest',
    addressRegion: 'Drôme',
    postalCode: '26400',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '44.7308',
    longitude: '5.0197',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '18:00',
  },
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Virement bancaire, Carte bancaire',
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' },
    { '@type': 'AdministrativeArea', name: 'Drôme' },
    { '@type': 'AdministrativeArea', name: 'Ardèche' },
    { '@type': 'Country', name: 'France' },
  ],
  knowsAbout: ['Création de site web', 'Référencement naturel', 'SEO local Auvergne-Rhône-Alpes', 'Agence web Auvergne-Rhône-Alpes', 'Développement Astro', 'Création site internet Drôme'],
  sameAs: ['https://share.google/IKYSIPaXxlTN0W5Zz'],
  serviceArea: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: '44.7308', longitude: '5.0197' },
    geoRadius: '220000',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Prestations Caelestis',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Création de site une page',
          description: 'Un site professionnel en une seule page. La solution accessible pour démarrer, visible sur Google.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '500',
          priceCurrency: 'EUR',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Création de site vitrine',
          description: 'Site web soigné, visible sur Google, adapté à votre activité. Idéal pour artisans, producteurs et indépendants.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '800',
          priceCurrency: 'EUR',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Création de boutique en ligne',
          description: 'Boutique e-commerce avec catalogue, paiement sécurisé et gestion des commandes.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '1200',
          priceCurrency: 'EUR',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Site sur mesure',
          description: 'Site entièrement conçu selon vos besoins, votre identité et vos objectifs.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          price: '2500',
          priceCurrency: 'EUR',
        },
      },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Caelestis',
  url: 'https://caelestis.fr',
  description: 'Création de site web et référencement naturel pour artisans et indépendants en Auvergne-Rhône-Alpes.',
  inLanguage: 'fr-FR',
  publisher: {
    '@type': 'Organization',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    logo: {
      '@type': 'ImageObject',
      url: 'https://caelestis.fr/favicon.svg',
    },
  },
};

// FAQ — source unique : alimente le schema FAQPage (SEO) ET l'affichage
const faqs = [
  {
    q: 'Quel est le délai pour créer un site internet ?',
    a: 'En général, un site internet est livré en 2 à 6 semaines selon la complexité du projet et la rapidité de transmission des contenus (textes, photos et autres). Nous vous accompagnons à chaque étape avec un planning clair dès le départ.',
  },
  {
    q: 'Et si je n\'ai pas encore mes textes ni mes photos ?',
    a: 'C\'est très fréquent, et ce n\'est pas un frein. Nous vous accompagnons pour structurer vos contenus, nous pouvons rédiger les textes à partir de nos échanges et vous orienter sur les visuels. Pas besoin d\'arriver avec un dossier complet pour démarrer.',
  },
  {
    q: 'Pourrai-je modifier le contenu de mon site moi-même ?',
    a: 'Par défaut, c\'est nous qui gérons vos modifications : vous nous envoyez vos changements et on s\'en occupe rapidement. Votre site reste ainsi rapide et sécurisé, sans outil technique à gérer. Et si vous préférez être autonome, nous pouvons intégrer un espace simple pour éditer votre site vous-même.',
  },
  {
    q: 'Mon site sera-t-il adapté aux mobiles ?',
    a: 'Oui, systématiquement. Chaque site s\'affiche parfaitement sur mobile, tablette et ordinateur. Comme la majorité de vos visiteurs viennent du téléphone, c\'est une priorité dès la conception.',
  },
  {
    q: 'Mon site sera-t-il visible sur Google ?',
    a: 'Oui. Chaque site repose sur des bases techniques saines, optimisées pour le référencement naturel : structure claire, pages rapides, contenus pensés pour vos mots-clés. Vous pouvez aussi aller plus loin avec un accompagnement SEO dédié pour gagner en visibilité dans le temps.',
  },
  {
    q: 'Pourquoi faire appel à vous plutôt qu\'à un outil comme Wix ?',
    a: 'Un site fait main est plus rapide, mieux référencé et vraiment à votre image, sans les limites ni les abonnements des outils en ligne. Vous gagnez du temps, un résultat professionnel et un interlocuteur unique qui reste disponible après la mise en ligne.',
  },
  {
    q: 'Proposez-vous la maintenance du site après livraison ?',
    a: 'Oui. Nous proposons un accompagnement après la mise en ligne : mises à jour, modifications de contenu, suivi SEO. On en discute ensemble selon vos besoins lors du premier appel.',
  },
  {
    q: 'L\'hébergement est-il inclus ?',
    a: 'Oui. Votre site est hébergé sur une infrastructure rapide et sécurisée, et son maintien en ligne est couvert par votre abonnement de maintenance. Aucun hébergeur séparé à gérer, aucune facture surprise.',
  },
  {
    q: 'J\'ai déjà un site, pouvez-vous le refondre ?',
    a: 'Bien sûr. Si votre site actuel est vieillissant, lent ou ne vous ressemble plus, nous le repensons entièrement : design moderne, performances et meilleure visibilité sur Google. On part de l\'existant et on en discute ensemble.',
  },
  {
    q: 'Comment connaître le prix de mon projet ?',
    a: 'C\'est gratuit et sans engagement. Vous pouvez estimer votre projet en 2 minutes avec notre simulateur, ou nous écrire directement pour un devis personnalisé.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://caelestis.fr/#organization',
  name: 'Caelestis',
  alternateName: 'CaelestisWeb',
  url: 'https://caelestis.fr',
  logo: {
    '@type': 'ImageObject',
    url: 'https://caelestis.fr/og-image.jpg',
    width: 1200,
    height: 630,
  },
  description: 'Développeur web freelance et agence web indépendante, spécialisé dans la création de sites internet sur mesure et le référencement naturel pour artisans, producteurs et indépendants en Auvergne-Rhône-Alpes. Basé à Crest (26400), dans la Drôme.',
  email: 'contact@caelestis.fr',
  telephone: '+33769362727',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Crest',
    addressRegion: 'Drôme',
    postalCode: '26400',
    addressCountry: 'FR',
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' },
    { '@type': 'AdministrativeArea', name: 'Drôme' },
    { '@type': 'AdministrativeArea', name: 'Ardèche' },
    { '@type': 'Country', name: 'France' },
  ],
  foundingDate: '2024',
  founder: {
    '@type': 'Person',
    name: 'Célestin Fruleux',
    jobTitle: 'Développeur web & consultant SEO',
    url: 'https://caelestis.fr/a-propos',
  },
  knowsAbout: ['Création de site web', 'Développement Astro', 'Référencement naturel', 'SEO local Drôme', 'Agence web Drôme', 'Création site internet Crest'],
  sameAs: ['https://share.google/IKYSIPaXxlTN0W5Zz'],
};

// ── Hero mobile (LCP) ──
// Variantes générées UNE SEULE FOIS et réutilisées à l'identique par le <img> ET
// le <link rel=preload> : garantit qu'un seul fichier est téléchargé (zéro doublon,
// le preload ne concurrence plus l'image rendue). Largeurs plafonnées à la taille
// réellement affichée (vignette ~364px), qualité 56 (photo décorative, petit format).
const heroSm = await getImage({ src: imgHero, width: 340, format: 'webp', quality: 54 });
const heroMd = await getImage({ src: imgHero, width: 440, format: 'webp', quality: 54 });
const heroSrcset = `${heroSm.src} 340w, ${heroMd.src} 440w`;
const heroSizes  = '(max-width: 640px) calc(100vw - 48px), 440px';

// ── Hero desktop (colonne droite, ≥1024px) ──
// Mêmes précautions : variantes réutilisées par le <img> ET un preload borné par
// media-query desktop. Les deux <img> hero sont en loading="lazy" pour que le
// scanner de préchargement du navigateur n'aille PAS chercher l'image de l'autre
// breakpoint (elle est en display:none) ; chaque preload media-scopé garantit que
// seul le bon fichier est téléchargé, une fois, par appareil.
const heroDeskMd = await getImage({ src: imgHero, width: 480, format: 'webp', quality: 55 });
const heroDeskLg = await getImage({ src: imgHero, width: 640, format: 'webp', quality: 55 });
const heroDeskSrcset = `${heroDeskMd.src} 480w, ${heroDeskLg.src} 640w`;
const heroDeskSizes  = '42vw';

---
<BaseLayout
  title="Création de site internet, Caelestis, Drôme & France"
  description="Sites web soignés pour artisans, producteurs et indépendants, en Auvergne-Rhône-Alpes. Agence basée dans la Drôme. Devis gratuit, dès 500€."
  schema={[localBusiness, organizationSchema, websiteSchema, faqSchema]}
>

  <!-- Preload hero image pour améliorer le LCP -->
  <link
    slot="head"
    rel="preload"
    as="image"
    media="(max-width: 1023px)"
    imagesrcset={heroSrcset}
    imagesizes={heroSizes}
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    media="(min-width: 1024px)"
    imagesrcset={heroDeskSrcset}
    imagesizes={heroDeskSizes}
    fetchpriority="high"
  />

  <!-- ─── FIL BOTANIQUE ─── -->
  <div class="vine-wrap" aria-hidden="true">
    <svg
      id="vine"
      class="vine-svg"
      viewBox="0 0 50 1000"
      preserveAspectRatio="none"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        id="vine-path"
        d="M 25,0
           C 48,38 2,90 18,148
           C 48,208 2,255 30,312
           C 50,368 1,418 15,474
           C 47,532 2,582 30,638
           C 50,692 1,742 18,796
           C 48,848 3,894 25,944
           C 41,968 9,992 25,1000"
        stroke-width="1.8"
        stroke-linecap="round"
        vector-effect="non-scaling-stroke"
      />
    </svg>
  </div>


  <!-- ─── HERO ─── -->
  <section class="hero-screen flex flex-col justify-center px-6 md:px-10 lg:px-20 pt-8 md:pt-20 pb-16 relative overflow-hidden">

    <!-- Lumière ambiante organique -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="light-blob light-blob-sauge absolute w-[600px] h-[600px]"
           style="top: -8%; left: -12%; opacity: 0.7;"></div>
      <div class="light-blob light-blob-ocre absolute w-[420px] h-[420px]"
           style="bottom: 5%; right: -8%; opacity: 0.55;"></div>
      <div class="light-blob light-blob-cream absolute w-[300px] h-[300px]"
           style="top: 40%; left: 38%; opacity: 0.4;"></div>
    </div>

    <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-2 gap-12 lg:gap-16 items-center lg:items-stretch relative z-10">

      <!-- Colonne gauche : texte -->
      <div class="text-center flex flex-col">

        <!-- Eyebrow — ancré en haut -->
        <p class="font-body text-xs tracking-[0.22em] uppercase mb-8 text-sauge" data-reveal>
          Création de site web en Drôme et Auvergne-Rhône-Alpes
        </p>

        <!-- Bloc principal — centré entre eyebrow et badges -->
        <div class="flex-1 flex flex-col justify-center">

          <!-- H1 -->
          <h1
            class="font-display font-light text-brun leading-[1.05] tracking-[-0.03em] mb-7 hero-title"
            style="font-size: clamp(2rem, 4.4vw, 3.8rem);"
          >
            <span class="sl"><span>Valorisez votre activité</span></span>
            <span class="sl"><span class="text-sauge whitespace-nowrap">avec votre site web.</span></span>
          </h1>

          <!-- Sous-titre -->
          <p class="font-body text-base leading-relaxed max-w-[500px] mb-5 text-brun-mid mx-auto" data-reveal data-delay="1">
            Une présence en ligne à la hauteur de votre travail. Pour les artisans, praticiens et indépendants qui créent, cultivent et bâtissent avec passion.
          </p>

          <!-- Boutons CTA -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3" data-reveal data-delay="2">
            <Button href="/contact" variant="primary">Parler de mon projet</Button>
            <Button href="/simulateur" variant="outline">Estimer mon projet</Button>
          </div>

        </div>

        <!-- Badges — ancrés en bas -->
        <div class="flex flex-col items-center gap-2 mt-8 sm:flex-row sm:flex-wrap sm:justify-center sm:gap-4" data-reveal data-delay="2">
          <span class="font-body text-xs text-brun-mid/75 tracking-[0.12em] uppercase">Réponse sous 48h</span>
          <span class="font-body text-xs text-brun-mid/75 tracking-[0.12em] uppercase">Devis gratuit</span>
          <span class="font-body text-xs text-brun-mid/75 tracking-[0.12em] uppercase">À partir de 500€</span>
        </div>

      </div>

      <!-- Colonne droite : photo éditoriale (desktop) -->
      <div class="hidden lg:flex items-center justify-center h-full">
        <div class="img-zoom img-editorial w-full max-w-[500px]" style="height: min(72vh, 620px);">
          <img
            src={heroDeskLg.src}
            srcset={heroDeskSrcset}
            sizes={heroDeskSizes}
            width="640"
            height="794"
            alt="Laptop ouvert dans un jardin verdoyant, création de site internet par Caelestis, Drôme"
            class="w-full h-full object-cover object-center"
            data-parallax
            loading="lazy"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>

    </div>

    <!-- Photo hero mobile/tablette uniquement -->
    <div class="lg:hidden mt-10 w-full max-w-xl mx-auto px-0">
      <div class="img-zoom img-editorial overflow-hidden" style="aspect-ratio: 16/10; max-height: 360px; border-radius: 12px;">
        <img
          src={heroMd.src}
          srcset={heroSrcset}
          sizes={heroSizes}
          width="440"
          height="275"
          alt="Laptop ouvert dans un jardin verdoyant, création de site internet par Caelestis, Drôme"
          class="w-full h-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator absolute bottom-8 left-6 md:left-10 lg:left-20 hidden sm:flex items-center gap-3" aria-hidden="true">
      <div class="scroll-line w-8 h-px bg-brun opacity-35"></div>
    </div>

  </section>


  <!-- ─── POUR QUI ─── -->
  <section class="pt-14 pb-6 md:py-14 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient overflow-hidden">
    <div class="max-w-6xl mx-auto">

      <!-- Ligne métiers — centrée et statique desktop, défilante en boucle sur mobile -->
      <div class="metiers mb-10" data-reveal>
        <div class="metiers-track">
          <span class="metiers-group font-body">Artisans,&nbsp;Créateurs,&nbsp;Projets engagés,&nbsp;Maraîchers,&nbsp;Producteurs locaux,&nbsp;Pépiniéristes,&nbsp;Praticiens bien-être,&nbsp;Éco-constructeurs,&nbsp;Gîtes de charme,&nbsp;Espaces verts</span>
          <span class="metiers-group font-body" aria-hidden="true">Artisans,&nbsp;Créateurs,&nbsp;Projets engagés,&nbsp;Maraîchers,&nbsp;Producteurs locaux,&nbsp;Pépiniéristes,&nbsp;Praticiens bien-être,&nbsp;Éco-constructeurs,&nbsp;Gîtes de charme,&nbsp;Espaces verts</span>
        </div>
      </div>

      <!-- Galerie portfolio — 5 photos, 2 grandes + 3 petites -->
      <!-- Bento grid responsive : 2×2 mobile → bento desktop -->
      <div class="bento-gallery" data-reveal data-delay="1">

        <!-- Jardin communautaire -->
        <div class="bento-cell bento-jardin img-zoom overflow-hidden">
          <Image
            src={imgJardin}
            alt="Jardin maraîcher et espace vert verdoyant"
            class="w-full h-full object-cover object-center"
            widths={[200, 400, 760]}
            sizes="(max-width: 768px) 50vw, 50vw"
            loading="lazy"
            quality={72}
          />
        </div>

        <!-- Yoga : portrait pleine hauteur (bento desktop) -->
        <div class="bento-cell bento-yoga img-zoom overflow-hidden">
          <Image
            src={imgYoga}
            alt="Praticien bien-être, yoga au coucher de soleil"
            class="w-full h-full object-cover object-center"
            widths={[200, 320, 480]}
            sizes="(max-width: 768px) 50vw, 33vw"
            loading="lazy"
            quality={72}
          />
        </div>

        <!-- Atelier botanique -->
        <div class="bento-cell bento-artisan img-zoom overflow-hidden">
          <Image
            src={imgArtisan}
            alt="Artisane dans son atelier botanique, créatrice indépendante"
            class="w-full h-full object-cover object-center"
            widths={[200, 400, 760]}
            sizes="(max-width: 768px) 50vw, 50vw"
            loading="lazy"
            quality={72}
          />
        </div>

        <!-- Bougies artisan -->
        <div class="bento-cell bento-bougies img-zoom overflow-hidden">
          <Image
            src={imgBougies}
            alt="Atelier de bougies artisanales, artisan"
            class="w-full h-full object-cover object-center"
            widths={[200, 320, 480]}
            sizes="(max-width: 768px) 50vw, 33vw"
            loading="lazy"
            quality={72}
          />
        </div>

      </div>

    </div>
  </section>


  <!-- ─── TRANSITION EDITORIALE ─── -->
  <section class="pt-10 pb-20 md:py-24 px-6 md:px-10 lg:px-20">
    <div class="max-w-3xl mx-auto text-center">

      <p class="inline-block font-body text-xs tracking-[0.22em] uppercase text-sauge border border-sauge/40 rounded-full px-4 py-1.5 mb-8" data-reveal>
        L'importance d'un site web
      </p>

      <h2
        class="font-display font-light text-brun leading-[1.15] tracking-tight mb-8"
        style="font-size: clamp(1.5rem, 2.6vw, 2.1rem);"
        data-reveal data-delay="1"
      >
        <span class="block">Les fleurs donnent vie à un jardin,</span>
        <span class="block text-sauge">votre site web donne vie à votre entreprise.</span>
      </h2>

      <div class="para-card" data-reveal data-delay="2">
        <p class="font-body text-base leading-relaxed mb-3">
          Aujourd'hui, vos futurs clients se forgent une première impression de votre entreprise bien avant le premier échange. Dans la plupart des cas, cette découverte commence sur Internet.
        </p>
        <p class="font-body text-base leading-relaxed">
          Un site internet professionnel vous permet de présenter votre activité avec clarté, de valoriser ce qui fait votre différence et d'offrir une expérience rassurante à vos prospects. Il devient un véritable levier pour développer votre visibilité, et transformer l'intérêt en une nouvelle opportunité commerciale.
        </p>
      </div>

    </div>
  </section>


  <!-- ─── SERVICES ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Prestations</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-5">
          Ce que nous pouvons faire pour vous.
        </h2>

      </div>

      <a href="/site-une-page" class="group block max-w-3xl mx-auto mb-6 rounded-2xl border border-sauge/40 bg-cream/60 p-5 md:p-7 transition-all duration-300 hover:border-sauge/70 hover:bg-cream hover:shadow-[0_8px_30px_rgba(53,64,36,0.08)]" data-reveal data-delay="1">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-7">
          <div class="flex-1 min-w-0 text-center sm:text-left">
            <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-2">Pour démarrer</p>
            <h3 class="font-display text-xl font-light text-brun mb-1.5">Page unique</h3>
            <p class="font-body text-sm text-brun-mid leading-relaxed">L'essentiel de votre activité, soigné sur une seule page. La solution accessible pour démarrer simplement.</p>
          </div>
          <div class="shrink-0 text-center sm:text-right">
            <p class="font-body text-xs tracking-[0.16em] uppercase text-brun-mid/70 mb-0.5">À partir de</p>
            <p class="font-display font-light text-brun leading-none mb-2" style="font-size: clamp(1.8rem, 4vw, 2.3rem); letter-spacing: -0.02em;">
