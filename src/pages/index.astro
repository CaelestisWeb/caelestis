---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import imgHero      from '../assets/images/atelier-botanique.jpg';
import imgMosaique1 from '../assets/images/jardin-communautaire.jpg';
import imgMosaique2 from '../assets/images/bougies-artisan.jpg';
import imgMosaique3 from '../assets/images/yoga-soleil.jpg';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Caelestis',
  alternateName: 'CaelestisWeb',
  description: 'Création de site web soigné et référencement naturel pour artisans, praticiens et indépendants.',
  url: 'https://caelestis.fr',
  email: 'contact@caelestis.fr',
  telephone: '+33782687399',
  image: 'https://caelestis.fr/og-image.jpg',
  logo: 'https://caelestis.fr/favicon.svg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '60 rue François 1er',
    postalCode: '75008',
    addressLocality: 'Paris',
    addressRegion: 'Drôme',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '44.7308',
    longitude: '5.0197',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '18:00',
  },
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Virement bancaire, Carte bancaire',
  areaServed: { '@type': 'Country', name: 'France' },
  knowsAbout: ['Création de site web', 'Référencement naturel', 'SEO', 'Développement Astro', 'Tailwind CSS'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Prestations Caelestis',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Création de site vitrine',
          description: 'Site web soigné, visible sur Google, adapté à votre activité.',
        },
        priceSpecification: {
          '@type': 'PriceSpecification',
          minPrice: '600',
          priceCurrency: 'EUR',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Référencement naturel (SEO)',
          description: 'Audit, stratégie et optimisation pour apparaître sur Google.',
        },
      },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Combien de temps faut-il pour créer mon site ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Entre 2 et 4 semaines en général, selon ce dont vous avez besoin. On avance par étapes — à chaque phase, je vous montre où j\'en suis et on valide ensemble avant de continuer.',
      },
    },
    {
      '@type': 'Question',
      name: 'Comment ça se passe concrètement ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Un premier appel pour parler de votre projet. Ensuite un devis sous 48h. On construit le site ensemble, par étapes, avec vos retours à chaque fois. Mise en ligne, transmission des accès. Et je reste disponible après.',
      },
    },
    {
      '@type': 'Question',
      name: 'Est-ce que mon site sera visible sur Google ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. Chaque site est construit sur de bonnes bases : structure claire, chargement rapide, balisage propre et référencement pensé dès le départ. Votre site sera lisible par Google, optimisé pour les recherches locales et relié à la fiche Google de votre entreprise afin de renforcer votre visibilité. Et si vous souhaitez aller plus loin, un travail de référencement plus avancé peut également être mis en place.',
      },
    },
    {
      '@type': 'Question',
      name: 'Combien ça coûte ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Les sites démarrent à partir de 600 €. Le prix final dépend surtout de la complexité du projet : nombre de pages, fonctionnalités souhaitées, réservation, boutique en ligne, rédaction, référencement, identité visuelle etc.',
      },
    },
    {
      '@type': 'Question',
      name: 'Est-ce que je peux modifier mon site après ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Oui. Un site n'est pas figé : il peut évoluer avec votre activité. Nouveaux contenus, nouvelles fonctionnalités, pages supplémentaires ou modifications plus importantes, tout peut être ajusté au fil du temps. Je vous propose simplement un devis adapté selon l'ampleur des changements à réaliser.",
      },
    },
  ],
};
---
<BaseLayout
  title="Caelestis — Création de site web soigné · Drôme & toute la France"
  description="Création de site web soigné et visible sur Google. Pour artisans, praticiens et indépendants. Basé dans la Drôme, disponible partout en France. Devis gratuit sous 48h."
  schema={[localBusiness, faqSchema]}
>

  <!-- ─── FIL BOTANIQUE ─── -->
  <div class="vine-wrap" aria-hidden="true">
    <svg
      id="vine"
      class="vine-svg"
      viewBox="0 0 50 1000"
      preserveAspectRatio="none"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        id="vine-path"
        d="M 25,0
           C 48,38 2,90 18,148
           C 48,208 2,255 30,312
           C 50,368 1,418 15,474
           C 47,532 2,582 30,638
           C 50,692 1,742 18,796
           C 48,848 3,894 25,944
           C 41,968 9,992 25,1000"
        stroke-width="1.8"
        stroke-linecap="round"
        vector-effect="non-scaling-stroke"
      />
    </svg>
  </div>

  <!-- ─── HERO ─── -->
  <section class="min-h-[100vh] flex flex-col justify-center px-6 md:px-10 lg:px-20 pt-20 pb-16 relative overflow-hidden">

    <!-- Lumière ambiante organique -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="light-blob light-blob-sauge absolute w-[600px] h-[600px]"
           style="top: -8%; left: -12%; opacity: 0.7;"></div>
      <div class="light-blob light-blob-ocre absolute w-[420px] h-[420px]"
           style="bottom: 5%; right: -8%; opacity: 0.55;"></div>
      <div class="light-blob light-blob-cream absolute w-[300px] h-[300px]"
           style="top: 40%; left: 38%; opacity: 0.4;"></div>
      <div class="light-blob light-blob-bois absolute w-[280px] h-[280px]"
           style="top: 65%; left: 8%; opacity: 0.5;"></div>
    </div>

    <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-[1fr_42%] gap-12 lg:gap-24 items-center relative z-10">

      <!-- Colonne gauche : texte centré -->
      <div class="text-center lg:pl-8">

        <!-- Eyebrow -->
        <div class="mb-10" data-reveal>
          <p class="font-body text-sm tracking-[0.22em] uppercase text-sauge">
            Agence web · Drôme, France
          </p>
          <p class="font-body text-sm tracking-[0.18em] uppercase mt-1.5" style="color: rgba(136,144,99,0.55)">
            Création de site internet
          </p>
        </div>

        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-[-0.03em] mb-10"
          style="font-size: clamp(2.8rem, 6vw, 5.2rem);"
          data-split
        >
          <span class="sl"><span>Votre projet,</span></span>
          <span class="sl">mis en <span class="text-sauge">valeur.</span></span>
        </h1>

        <p class="font-body text-lg leading-relaxed max-w-[460px] mb-10 text-brun-mid mx-auto" data-reveal data-delay="2">
          Votre site est souvent la première impression que vous laissez.
          Bien conçu, il attire les bons clients, rend votre message évident
          et installe une confiance immédiate.
        </p>

        <div data-reveal data-delay="4">
          <Button href="/contact" variant="primary">Lancer mon projet →</Button>
          <div class="flex items-center justify-center gap-4 mt-6">
            <span class="font-body text-xs text-brun-mid/40 tracking-wide">Réponse sous 48h</span>
            <span class="text-brun-mid/20">·</span>
            <span class="font-body text-xs text-brun-mid/40 tracking-wide">Devis gratuit</span>
            <span class="text-brun-mid/20">·</span>
            <span class="font-body text-xs text-brun-mid/40 tracking-wide">À partir de 600€</span>
          </div>
        </div>
      </div>

      <!-- Colonne droite : photo éditoriale -->
      <div class="hidden lg:flex items-center justify-center h-full">
        <div class="img-zoom img-editorial w-full" style="height: min(72vh, 620px);">
          <Image
            src={imgHero}
            alt="Atelier botanique artisanal — encres naturelles, fleurs séchées et tampons botaniques"
            class="w-full h-full object-cover object-center"
            data-parallax
            loading="eager"
            fetchpriority="high"
            widths={[480, 768, 1024]}
            sizes="(max-width: 1024px) 0px, 50vw"
          />
        </div>
      </div>

    </div>

    <!-- Badge disponibilité — coin haut droit -->
    <span class="absolute top-6 right-6 md:right-10 lg:right-20 inline-flex items-center gap-1.5 font-body text-[10px] tracking-widest uppercase text-sauge/70 border border-sauge/20 px-3 py-1.5 rounded-full z-20 bg-cream/60 backdrop-blur-sm" data-reveal>
      <span class="w-1.5 h-1.5 rounded-full bg-sauge animate-pulse"></span>
      Disponible
    </span>

    <!-- Scroll indicator — respiration GSAP -->
    <div class="scroll-indicator absolute bottom-8 left-6 md:left-10 lg:left-20 flex items-center gap-3" aria-hidden="true">
      <div class="w-8 h-px bg-brun opacity-40"></div>
      <span class="font-body text-xs tracking-widest uppercase text-brun opacity-40">Découvrir</span>
    </div>
  </section>


  <!-- ─── BARRE MOTS-CLÉS ─── -->
  <div class="caelestis-bar">
    <ul class="caelestis-bar-inner" aria-label="Mots-clés Caelestis">
      <li><span>savoir-faire</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>passion</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>bâtir</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>expertise</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>clarté</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>présence</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>visibilité</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>confiance</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>transmettre</span></li>
      <li aria-hidden="true" class="sep">✦</li>
      <li><span>durer</span></li>
    </ul>
  </div>

  <style is:global>
    .caelestis-bar {
      width: 100%;
      padding: 18px 40px;
      background: linear-gradient(
        135deg,
        rgba(76, 61, 25, 0.04)   0%,
        rgba(207, 192, 160, 0.28) 40%,
        rgba(237, 227, 212, 0.55) 60%,
        rgba(76, 61, 25, 0.04)   100%
      );
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border-top:    1px solid rgba(76, 61, 25, 0.10);
      border-bottom: 1px solid rgba(76, 61, 25, 0.10);
    }
    .caelestis-bar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      list-style: none;
      margin: 0; padding: 0;
      width: 100%;
    }
    .caelestis-bar-inner li span {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: #4C3D19; opacity: 0.75;
      white-space: nowrap;
      transition: opacity 0.3s ease, color 0.3s ease;
    }
    .caelestis-bar-inner li:hover span { opacity: 1; color: #889063; }
    .caelestis-bar-inner li.sep { color: #A08060; font-size: 7px; opacity: 0.35; flex-shrink: 0; }

  </style>


  <!-- ─── POUR QUI ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_480px] gap-16 lg:gap-20 items-start">

        <!-- Colonne gauche : texte + liste -->
        <div class="lg:pt-4">
          <div class="mb-12" data-reveal>
            <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1]">
              Votre site devrait<br>vous ressembler.
            </h2>
            <p class="font-body text-base text-brun-mid mt-5 leading-relaxed">
              Donnez à votre activité la présence qu'elle mérite.
            </p>
          </div>

          <!-- Liste éditoriale numérotée -->
          <div class="divide-y" style="border-color: rgba(76,61,25,0.08)" data-reveal data-delay="1">
            {[
              { num: '01', label: 'Artisans & créateurs'      },
              { num: '02', label: 'Agriculteurs & maraîchers' },
              { num: '03', label: 'Praticiens bien-être'      },
              { num: '04', label: "Pros de l'environnement"   },
              { num: '05', label: 'Paysagistes & espaces verts' },
            ].map(({ num, label }) => (
              <div class="group flex items-center justify-between py-4 cursor-default">
                <div class="flex items-center gap-5">
                  <span class="font-body text-xs tabular-nums select-none" style="color: rgba(136,144,99,0.45)">{num}</span>
                  <h3
                    class="font-display font-light text-brun transition-colors duration-300 group-hover:text-ocre"
                    style="font-size: clamp(1.15rem, 2vw, 1.45rem);"
                  >
                    {label}
                  </h3>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Colonne droite : mosaïque éditoriale -->
        <div class="relative" data-reveal data-delay="2">

          <!-- Grande image en haut -->
          <div class="img-zoom aspect-[4/3] overflow-hidden mb-3">
            <Image
              src={imgMosaique1}
              alt="Jardin partagé urbain avec parcelles maraîchères"
              class="w-full h-full object-cover"
              data-parallax
              loading="lazy"
              widths={[480, 768]}
              sizes="(max-width: 768px) 100vw, 40vw"
            />
          </div>

          <!-- Deux images côte à côte, décalées -->
          <div class="grid grid-cols-2 gap-3">
            <div class="img-zoom overflow-hidden" style="aspect-ratio: 3/4">
              <Image
                src={imgMosaique2}
                alt="Atelier de bougies artisanales en cire d'abeille"
                class="w-full h-full object-cover"
                data-parallax
                loading="lazy"
                widths={[320, 480]}
                sizes="(max-width: 768px) 50vw, 20vw"
              />
            </div>
            <div class="img-zoom overflow-hidden mt-8" style="aspect-ratio: 3/4">
              <Image
                src={imgMosaique3}
                alt="Posture de yoga au coucher du soleil face à la mer"
                class="w-full h-full object-cover"
                data-parallax
                loading="lazy"
                widths={[320, 480]}
                sizes="(max-width: 768px) 50vw, 20vw"
              />
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>


  <!-- ─── BANDEAU 2% ─── -->
  <section class="py-8 px-6 border-t border-cream-dark" data-reveal>
    <div class="max-w-xl mx-auto flex flex-col items-center gap-2 text-center">
      <div class="flex items-center gap-4 justify-center">
        <p class="font-display text-lg md:text-xl font-light text-brun whitespace-nowrap">
          2 % de chaque projet reversé à une association environnementale.
        </p>
        <svg viewBox="0 0 80 130" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="width:32px;height:52px;flex-shrink:0;overflow:visible">
          <ellipse cx="40" cy="125" rx="18" ry="4.5" fill="rgba(78,100,64,0.12)"/>
          <rect x="38" y="18" width="4" height="103" rx="2" fill="rgba(78,100,64,0.45)"/>
          <ellipse cx="26" cy="89" rx="16" ry="7" fill="rgba(78,100,64,0.28)" transform="rotate(-35 26 89)"/>
          <ellipse cx="54" cy="66" rx="16" ry="7" fill="rgba(78,100,64,0.22)" transform="rotate(35 54 66)"/>
          <g>
            <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(0   40 18)"/>
            <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(72  40 18)"/>
            <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(144 40 18)"/>
            <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(216 40 18)"/>
            <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(288 40 18)"/>
            <circle cx="40" cy="18" r="5" fill="rgba(168,92,44,0.55)"/>
          </g>
        </svg>
      </div>
      <p class="font-body text-sm text-brun-mid">
        Parce que construire quelque chose de beau ne s'arrête pas à soi.
      </p>
    </div>
  </section>


  <!-- ─── MES VALEURS ─── -->
  <section class="py-16 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth">
    <div class="max-w-6xl mx-auto">

      <div class="mb-16" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Ma façon de travailler</p>
        <h2 class="font-display text-4xl md:text-5xl font-light leading-[1.1]">
          Ce qu'on<br>bâtit ensemble.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-x-16">

        <div class="card-lift border-t py-10 px-4 -mx-4 rounded-sm" style="border-color: rgba(237,227,212,0.15)" data-reveal>
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(237,227,212,0.1)">01</span>
          <h3 class="font-display text-2xl font-light mb-3">Votre projet au centre</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            Chaque projet fonctionne différemment. Avant de concevoir le site, je cherche à comprendre votre activité, votre manière de travailler et ce que vos visiteurs doivent ressentir en arrivant dessus. Le but n'est pas de suivre un modèle, mais de créer une présence cohérente avec ce que vous faites réellement.
          </p>
        </div>

        <div class="card-lift border-t py-10 md:mt-28 px-4 -mx-4 rounded-sm" style="border-color: rgba(237,227,212,0.15)" data-reveal data-delay="1">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(237,227,212,0.1)">02</span>
          <h3 class="font-display text-2xl font-light mb-3">Clair dès la première seconde</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            En quelques secondes, vos visiteurs doivent comprendre ce que vous faites et pourquoi vous choisir. C'est la différence entre un site qui travaille pour vous et un site qui ne fonctionne pas.
          </p>
        </div>

        <div class="card-lift border-t py-10 px-4 -mx-4 rounded-sm" style="border-color: rgba(237,227,212,0.15)" data-reveal data-delay="1">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(237,227,212,0.1)">03</span>
          <h3 class="font-display text-2xl font-light mb-3">Construit pour durer</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            Un site rapide, bien affiché sur tout type d'écran (ordinateur, mobile et tablette), et bien positionné dans votre niche sur Google.
          </p>
        </div>

        <div class="card-lift border-t py-10 px-4 -mx-4 rounded-sm" style="border-color: rgba(237,227,212,0.15)" data-reveal data-delay="2">
          <span class="font-display text-6xl font-light block mb-4" style="color: rgba(237,227,212,0.1)">04</span>
          <h3 class="font-display text-2xl font-light mb-3">Prix clairs, zéro surprise</h3>
          <p class="font-body text-sm leading-relaxed" style="color: rgba(237,227,212,0.6)">
            Devis sous 48h. Chaque ligne expliquée simplement. Vous savez exactement ce que vous investissez. Chaque devis est proposé dans une fourchette indicative, puis précisé et ajusté après discussion afin de correspondre parfaitement à votre projet.
          </p>
        </div>

      </div>
    </div>
  </section>






  <!-- ─── FAQ ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth">
    <div class="max-w-4xl mx-auto">

      <div class="mb-16" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">FAQ</p>
        <h2 class="font-display text-4xl md:text-5xl font-light leading-[1.1]">
          On répond<br>à vos questions.
        </h2>
      </div>

      <div id="faq-list" data-reveal data-delay="1">
        {[
          {
            q: "Combien de temps faut-il pour créer mon site ?",
            a: "Il faut entre 2 et 4 semaines en général, selon vos besoins et nos échanges. Je réalise d'abord une maquette du site, puis nous l'ajustons ensemble étape par étape jusqu'à obtenir un résultat qui vous correspond vraiment.",
          },
          {
            q: "Comment ça se passe concrètement ?",
            a: "Nous échangeons d'abord autour de votre projet lors d'un premier appel. Vous recevez ensuite un devis sous 48h. Une première version du site est créée, puis nous l'ajustons ensemble étape par étape grâce à vos retours. Une fois le site finalisé, il est mis en ligne sur votre page Google. Le paiement n'intervient qu'après la mise en ligne et le bon fonctionnement du site. Et bien sûr, je reste disponible par la suite si besoin.",
          },
          {
            q: "Est-ce que mon site sera visible sur Google ?",
            a: "Oui. Chaque site est construit sur de bonnes bases : structure claire, chargement rapide, balisage propre et référencement pensé dès le départ. Votre site sera lisible par Google, optimisé pour les recherches locales et relié à la fiche Google de votre entreprise afin de renforcer votre visibilité. Et si vous souhaitez aller plus loin, un travail de référencement plus avancé peut également être mis en place.",
          },
          {
            q: "Combien ça coûte ?",
            a: "Les sites démarrent à partir de 600 €. Le prix final dépend surtout de la complexité du projet : nombre de pages, fonctionnalités souhaitées, réservation, boutique en ligne, rédaction, référencement, identité visuelle etc.",
          },
          {
            q: "Est-ce que je peux modifier mon site après ?",
            a: "Oui. Un site n'est pas figé : il peut évoluer avec votre activité. Nouveaux contenus, nouvelles fonctionnalités, pages supplémentaires ou modifications plus importantes, tout peut être ajusté au fil du temps. Je vous propose simplement un devis adapté selon l'ampleur des changements à réaliser.",
          },
        ].map(({ q, a }) => (
          <div class="faq-item border-t" style="border-color: rgba(237,227,212,0.15)">
            <button class="faq-trigger w-full flex items-center justify-between gap-6 py-6 text-left" aria-expanded="false">
              <span class="font-display text-lg font-light">{q}</span>
              <span class="faq-icon font-body text-xl font-light flex-shrink-0" style="color: rgba(237,227,212,0.4)">+</span>
            </button>
            <div class="faq-body overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out">
              <p class="font-body text-sm leading-relaxed pb-6" style="color: rgba(237,227,212,0.6)">{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── CTA FINAL ─── -->
  <section class="py-28 px-6 md:px-10 lg:px-20 text-center section-ambient" data-reveal>
    <div class="max-w-2xl mx-auto">
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6">Un premier échange.</p>
      <h2 class="font-display text-4xl md:text-5xl font-light text-brun leading-[1.1] mb-6">
        Faites rayonner<br>ce que vous créez.
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 max-w-md mx-auto leading-relaxed">
        Parlez-moi de votre activité en quelques lignes. Je reviens vers vous sous 48h.
      </p>
      <Button href="/contact" variant="primary">Discutons de votre projet →</Button>
    </div>
  </section>

</BaseLayout>

<script>
  /* Couleurs inline FAQ — constantes nommées */
  const FAQ_COLOR_CLOSED = 'rgba(237,227,212,0.4)';
  const FAQ_COLOR_OPEN   = '#A08060';

  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.parentElement;
      const body = item?.querySelector<HTMLElement>('.faq-body');
      const icon = trigger.querySelector<HTMLElement>('.faq-icon');
      if (!item || !body || !icon) return;

      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      /* Ferme tous les autres items */
      document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((t) => {
        if (t === trigger) return;
        t.setAttribute('aria-expanded', 'false');
        const b  = t.parentElement?.querySelector<HTMLElement>('.faq-body');
        const ic = t.querySelector<HTMLElement>('.faq-icon');
        if (b)  b.style.maxHeight  = '0';
        if (ic) { ic.textContent = '+'; ic.style.color = FAQ_COLOR_CLOSED; ic.style.transform = ''; }
      });

      /* Bascule l'item courant */
      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        body.style.maxHeight = '0';
        icon.textContent     = '+';
        icon.style.color     = FAQ_COLOR_CLOSED;
        icon.style.transform = '';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.textContent     = '–';
        icon.style.color     = FAQ_COLOR_OPEN;
        icon.style.transform = '';
      }
    });
  });
</script>

<style>
  /* ── Fil botanique — visible desktop uniquement ── */
  .vine-wrap {
    position: absolute;
    left: clamp(6px, 1.8vw, 22px);
    top: 0;
    bottom: 0;
    width: 50px;
    pointer-events: none;
    z-index: 2;
    display: none;
    mix-blend-mode: difference; /* inversion auto selon fond clair/sombre */
  }

  /* Couleur source pour mix-blend-mode:difference.
     Bone #EDE3D4 = (237,227,212). Cible mousse #889063 = (136,144,99).
     Source = (237−136, 227−144, 212−99) = (101,83,113) = #655371.
     Résultat sur bone : mousse mat · sur kombu : violet-ardoise doux. */
  #vine-path {
    stroke: #655371;
  }
  @media (min-width: 1024px) {
    .vine-wrap { display: block; }
  }
  .vine-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 50px;
    height: 100%;
  }
</style>
