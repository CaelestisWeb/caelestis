  <!-- ── Comment nous travaillons — 5 étapes enrichies ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-5xl mx-auto">

      <!-- Titre centré -->
      <div class="text-center mb-12 lg:mb-16" data-reveal>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.9rem, 3.2vw, 2.8rem);">
          Comment se déroule un projet&nbsp;?
        </h2>
      </div>

      <!-- Timeline botanique : fil de liaison + nœuds numérotés (mobile),
           grille en relief (desktop) -->
      <ol class="proc-list">
        {etapes.map((e, i) => (
          <li class={`proc-step${i === 4 ? ' proc-step--last' : ''}`} data-reveal data-delay={i}>
            <span class="proc-num" aria-hidden="true">{e.num}</span>
            <div class="proc-card">
              <h3 class="proc-title">{e.title}</h3>
              <p class="proc-desc">{e.desc}</p>
            </div>
          </li>
        ))}
      </ol>

    </div>
  </section>

  <style>
    /* ═══════════════════════════════════════════
       Timeline « Comment se déroule un projet »
       Mobile : fil botanique vertical + nœuds.
       Desktop : grille 2 colonnes en relief.
    ═══════════════════════════════════════════ */
    .proc-list {
      position: relative;
      list-style: none;
      margin: 0;
      padding: 0;
      max-width: 600px;
      margin-inline: auto;
    }

    /* Étape — serpentin : impaires à gauche, paires à droite */
    .proc-step {
      position: relative;
      display: flex;
      margin-bottom: 16px;
    }
    .proc-step:last-child { margin-bottom: 0; }
    .proc-step:nth-of-type(odd)  { justify-content: flex-start; }
    .proc-step:nth-of-type(even) { justify-content: flex-end; }

    /* Nœud numéroté — ancré au coin extérieur, alterne de côté */
    .proc-num {
      position: absolute;
      top: -14px;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: var(--color-cream);
      border: 1.5px solid rgba(136, 144, 99, 0.75);
      font-family: 'Lora', serif;
      font-size: 1rem;
      letter-spacing: 0.04em;
      color: #889063;
      box-shadow: 0 6px 16px rgba(76, 61, 25, 0.16);
      z-index: 2;
    }
    .proc-step:nth-of-type(odd)  .proc-num { left: -8px; }
    .proc-step:nth-of-type(even) .proc-num { right: -8px; }

    /* Carte large, relief par l'ombre, accent du côté extérieur */
    .proc-card {
      position: relative;
      width: 87%;
      background: #F4EDDF;
      border-radius: 14px;
      padding: 36px 22px 20px;
      text-align: left;
      box-shadow:
        0 12px 30px rgba(76, 61, 25, 0.11),
        0 3px 8px rgba(76, 61, 25, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.45);
      transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.35s ease;
    }
    .proc-step:nth-of-type(odd)  .proc-card { border-left: 3px solid rgba(136, 144, 99, 0.6); }
    .proc-step:nth-of-type(even) .proc-card { border-right: 3px solid rgba(136, 144, 99, 0.6); }
    .proc-card:hover {
      transform: translateY(-3px);
      box-shadow:
        0 18px 40px rgba(76, 61, 25, 0.15),
        0 4px 10px rgba(76, 61, 25, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 0.45);
    }

    .proc-title {
      font-family: 'Lora', serif;
      font-weight: 300;
      font-size: 1.18rem;
      color: #889063;
      margin-bottom: 8px;
      line-height: 1.3;
    }
    .proc-desc {
      font-family: 'DM Sans Variable', 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: #3d4f28;
      line-height: 1.65;
    }

    /* Dernière étape — touche de clôture plus chaleureuse */
    .proc-step--last .proc-num {
      background: var(--grad-main, linear-gradient(135deg, #028183, #1DBD8E));
      background: linear-gradient(140deg, #889063, #6B7A4A);
      border-color: transparent;
      color: #F4EDDF;
    }
    .proc-step--last .proc-card {
      border-left-color: rgba(136, 144, 99, 0.85);
    }

    /* ── Desktop ≥ 640px : grille 2 colonnes en relief, fil masqué ── */
    @media (min-width: 640px) {
      .proc-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px 18px;
        max-width: none;
        align-items: stretch;
      }
      .proc-step {
        margin-bottom: 0;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
      }
      .proc-num,
      .proc-step:nth-of-type(odd) .proc-num,
      .proc-step:nth-of-type(even) .proc-num {
        position: static;
        margin: 0 0 16px;
        left: auto;
        right: auto;
        top: 0;
        width: 56px;
        height: 56px;
        font-size: 1.05rem;
        flex-shrink: 0;
      }
      .proc-card,
      .proc-step:nth-of-type(odd) .proc-card,
      .proc-step:nth-of-type(even) .proc-card {
        text-align: center;
        width: 100%;
        flex: 1;
        border-left: none;
        border-right: none;
        border-top: 3px solid rgba(136, 144, 99, 0.5);
        padding: 30px 28px 26px;
      }
      .proc-title { font-size: 1.25rem; }
      .proc-desc { font-size: 0.92rem; }
      .proc-step--last {
        grid-column: 1 / -1;
      }
      .proc-step--last .proc-card {
        border-top-color: rgba(136, 144, 99, 0.85);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .proc-card { transition: none; }
    }
  </style>

  <!-- ── CTA — fond brun profond avec accent sauge ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
