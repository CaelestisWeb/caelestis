---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import imgBureau from '../assets/images/riviere-montagne.jpg';

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Prestations Caelestis',
  description: 'Sites web sur mesure et référencement naturel pour artisans, indépendants et petites entreprises.',
  url: 'https://caelestis.fr/services',
  numberOfItems: 5,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: {
        '@type': 'Service',
        name: 'Site vitrine',
        description: "Votre activité présentée clairement, visible sur Google, lisible sur tout type d'écran.",
        provider: { '@type': 'LocalBusiness', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: { '@type': 'Country', name: 'France' },
        offers: {
          '@type': 'Offer',
          priceSpecification: {
            '@type': 'PriceSpecification',
            minPrice: '800',
            priceCurrency: 'EUR',
          },
        },
      },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@type': 'Service',
        name: 'Boutique en ligne',
        description: 'Catalogue en ligne, paiement sécurisé, connecté à votre logiciel de gestion.',
        provider: { '@type': 'LocalBusiness', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: { '@type': 'Country', name: 'France' },
      },
    },
    {
      '@type': 'ListItem',
      position: 3,
      item: {
        '@type': 'Service',
        name: 'Référencement naturel (SEO)',
        description: "Apparaître en tête des résultats quand vos clients vous cherchent. Référencement local et national.",
        provider: { '@type': 'LocalBusiness', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: { '@type': 'Country', name: 'France' },
      },
    },
    {
      '@type': 'ListItem',
      position: 4,
      item: {
        '@type': 'Service',
        name: 'Refonte de site existant',
        description: 'Votre site date ou ne vous ressemble plus ? On repart proprement sur de bonnes bases.',
        provider: { '@type': 'LocalBusiness', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: { '@type': 'Country', name: 'France' },
      },
    },
    {
      '@type': 'ListItem',
      position: 5,
      item: {
        '@type': 'Service',
        name: 'Maintenance & accompagnement',
        description: 'Évolutions, mises à jour, nouvelles pages — forfait mensuel ou à la tâche.',
        provider: { '@type': 'LocalBusiness', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: { '@type': 'Country', name: 'France' },
      },
    },
  ],
};

const breadcrumbServices = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
  ],
};

const prestations = [
  {
    title: 'Site vitrine',
    desc: "Votre activité en ligne, claire et lisible sur tous les écrans. Vos visiteurs comprennent ce que vous faites et savent comment vous contacter.",
  },
  {
    title: 'Boutique en ligne',
    desc: "Vendez directement depuis votre site. Catalogue, paiement sécurisé, connecté à vos outils.",
  },
  {
    title: 'Référencement naturel',
    desc: "Apparaître quand vos clients vous cherchent. Je travaille votre visibilité locale pour que les bonnes personnes vous trouvent.",
  },
  {
    title: 'Refonte de site existant',
    desc: "Votre site date ou ne vous ressemble plus ? On repart sur des bases propres.",
  },
  {
    title: 'Accompagnement & maintenance',
    desc: "Je reste disponible après la mise en ligne. Forfait mensuel ou intervention ponctuelle, selon vos besoins.",
  },
];

const etapes = [
  { num: '01', title: 'Premier échange', desc: "On parle de votre activité, vos clients, ce que vous voulez. Je ne propose rien avant d'avoir bien compris." },
  { num: '02', title: 'Devis',           desc: "Sous 48h, chaque ligne expliquée. Vous savez exactement ce pour quoi vous vous engagez." },
  { num: '03', title: 'Conception',      desc: "Je construis une première version, puis on ajuste ensemble jusqu'à ce que le résultat vous ressemble." },
  { num: '04', title: 'Mise en ligne',   desc: "Le site est publié et vérifié ensemble. Vous avez les clés." },
  { num: '05', title: 'Suivi',           desc: "Le paiement intervient après la mise en ligne. Je reste disponible pour vos questions et évolutions." },
];
---
<BaseLayout
  title="Création site internet & SEO Drôme — Prestations · Caelestis"
  description="Site vitrine, boutique en ligne, référencement naturel local. Solutions web sur mesure pour artisans et indépendants dans la Drôme et toute la France. Devis gratuit sous 48h."
  schema={[servicesSchema, breadcrumbServices]}
>

  <!-- En-tête de page -->
  <section class="pt-20 pb-10 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">

    <!-- Blob sauge atmosphérique -->
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[420px] h-[420px]"></div>
    <!-- Blob doré secondaire -->
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/3 w-64 h-64"></div>

    <!-- Vagues SVG organiques — palette forêt -->
    <svg aria-hidden="true" class="pointer-events-none absolute right-0 top-0 h-full w-auto opacity-[0.07]" viewBox="0 0 320 480" fill="none" preserveAspectRatio="xMaxYMid slice">
      <path d="M320 60 C270 80 210 40 160 60 C110 80 60 40 0 60" stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 90 C270 110 210 70 160 90 C110 110 60 70 0 90" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 120 C270 140 210 100 160 120 C110 140 60 100 0 120" stroke="#A08060" stroke-width="0.9"/>
      <path d="M320 160 C270 180 210 140 160 160 C110 180 60 140 0 160" stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 190 C270 210 210 170 160 190 C110 210 60 170 0 190" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 220 C270 240 210 200 160 220 C110 240 60 200 0 220" stroke="#A08060" stroke-width="0.9"/>
      <path d="M320 270 C270 290 210 250 160 270 C110 290 60 250 0 270" stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 300 C270 320 210 280 160 300 C110 320 60 280 0 300" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 330 C270 350 210 310 160 330 C110 350 60 310 0 330" stroke="#A08060" stroke-width="0.9"/>
      <path d="M320 380 C270 400 210 360 160 380 C110 400 60 360 0 380" stroke="#4C3D19" stroke-width="1.2"/>
      <path d="M320 410 C270 430 210 390 160 410 C110 430 60 390 0 410" stroke="#889063" stroke-width="1.0"/>
      <path d="M320 440 C270 460 210 420 160 440 C110 460 60 420 0 440" stroke="#A08060" stroke-width="0.8"/>
    </svg>

    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_480px] gap-12 lg:gap-16 items-center relative">

      <!-- Texte -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 mb-6" data-reveal>
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Prestations</p>
        </div>
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl"
          style="font-size: clamp(2.2rem, 5.5vw, 4.5rem);"
          data-reveal data-delay="1"
        >
          Un site adapté à ce que vous faites,<br class="hidden sm:block"> <span class="text-sauge">construit pour durer.</span>
        </h1>
        <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed" data-reveal data-delay="2">
          Ce dont vous avez besoin. Pas plus, pas moins.
        </p>
        <!-- Badges -->
        <div class="flex flex-wrap gap-3 mt-8" data-reveal data-delay="3">
          <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-body font-medium bg-sauge-pale text-brun border border-cream-dark">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="#889063" stroke-width="1.2"/><path d="M4 6l1.5 1.5L8 4" stroke="#889063" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Devis gratuit
          </span>
          <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-body font-medium bg-sauge-pale text-brun border border-cream-dark">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="#889063" stroke-width="1.2"/><path d="M4 6l1.5 1.5L8 4" stroke="#889063" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Réponse sous 48h
          </span>
          <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-body font-medium bg-sauge-pale text-brun border border-cream-dark">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="#889063" stroke-width="1.2"/><path d="M4 6l1.5 1.5L8 4" stroke="#889063" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            À partir de 800€
          </span>
        </div>
      </div>

      <!-- Photo visible mobile/tablette uniquement -->
      <div class="lg:hidden mt-8" data-reveal>
        <div class="overflow-hidden" style="height: 240px; border-radius: 6px; box-shadow: 0 12px 40px rgba(76,61,25,0.14);">
          <Image
            src={imgBureau}
            alt="Paysage de rivière en montagne — nature et environnement, Drôme"
            class="w-full h-full object-cover object-center"
            loading="eager"
            widths={[480, 768]}
            sizes="100vw"
          />
        </div>
      </div>

      <!-- Mockup laptop épuré -->
      <div class="hidden lg:flex items-end justify-center py-4">
        <div class="mk-wrap">

          <!-- Écran -->
          <div class="mk-lid">

            <!-- Chrome navigateur -->
            <div class="mk-chrome">
              <div class="mk-dots">
                <span style="background:#ff5f57"></span>
                <span style="background:#febc2e"></span>
                <span style="background:#28c840"></span>
              </div>
              <div class="mk-url">
                <svg width="5" height="6" viewBox="0 0 5 6" fill="none" aria-hidden="true"><path d="M.8 3C.8 1.6 4.2 1.6 4.2 3v1.6C4.2 5 3.8 5.3 2.5 5.3 1.2 5.3.8 5 .8 4.6Z" stroke="rgba(136,144,99,.6)" stroke-width=".8"/><path d="M1.6 3V2.4C1.6 1.6 3.4 1.6 3.4 2.4V3" stroke="rgba(136,144,99,.6)" stroke-width=".8"/></svg>
                caelestis.fr
              </div>
            </div>

            <!-- Contenu du site -->
            <div class="mk-screen">

              <!-- Nav -->
              <div class="mk-nav">
                <span class="mk-brand">Caelestis<em style="color:#889063;font-style:normal">.</em></span>
                <div class="mk-links">
                  <span>Accueil</span><span>Services</span><span>À propos</span><span>Contact</span>
                </div>
                <div class="mk-cta-nav">Lancer mon projet</div>
              </div>

              <!-- Hero -->
              <div class="mk-hero">
                <div class="mk-hero-text">
                  <div class="mk-eyebrow">Développeur web indépendant · Drôme</div>
                  <div class="mk-h1">Votre site devrait</div>
                  <div class="mk-h1 mk-h1i">vous ressembler.</div>
                  <div class="mk-body">Un bon site internet devient un outil de croissance.</div>
                  <div class="mk-body mk-body-s">Il renforce votre image et contribue au développement de votre entreprise.</div>
                  <div class="mk-btns">
                    <div class="mk-btn-p">Lancer mon projet</div>
                    <div class="mk-btn-g">Nos prestations</div>
                  </div>
                  <div class="mk-meta">
                    <span>Réponse sous 48h</span><span class="mk-sep">·</span>
                    <span>Devis gratuit</span><span class="mk-sep">·</span>
                    <span>À partir de 800€</span>
                  </div>
                </div>
                <div class="mk-hero-img">
                  <div class="mk-img-inner"></div>
                  <div class="mk-img-over"></div>
                </div>
              </div>

              <!-- Cartes -->
              <div class="mk-cards">
                {[{n:'01',t:'Votre projet au centre'},{n:'02',t:'Clair dès la première seconde'},{n:'03',t:'Construit pour durer'}].map(({n,t})=>(
                  <div class="mk-card">
                    <span class="mk-card-n">{n}</span>
                    <span class="mk-card-t">{t}</span>
                    <div class="mk-card-bar"></div>
                    <div class="mk-card-bar mk-card-bar-s"></div>
                  </div>
                ))}
              </div>

            </div>
          </div>

          <!-- Charnière -->
          <div class="mk-hinge"></div>

          <!-- Base -->
          <div class="mk-base">
            <div class="mk-trackpad"></div>
          </div>

          <!-- Ombre sol -->
          <div class="mk-shadow"></div>

        </div>
      </div>

    </div>
  </section>

  <style>
    /* ═══════════════════════════════════════
       Mockup laptop — style épuré / design
    ═══════════════════════════════════════ */

    /* Wrapper + perspective légère */
    .mk-wrap {
      position: relative;
      width: 420px;
      perspective: 1200px;
      perspective-origin: 50% 30%;
    }

    /* ════════════════════════════════════════
       Mockup device — style épuré Caelestis
    ════════════════════════════════════════ */

    /* Le laptop tourne légèrement, animation flottante */
    .mk-lid, .mk-base {
      transform: rotateX(2deg) rotateY(-12deg);
      animation: mk-float 7s ease-in-out infinite;
    }
    @keyframes mk-float {
      0%,100% { transform: rotateX(2deg) rotateY(-12deg) translateY(0); }
      50%      { transform: rotateX(3deg) rotateY(-11deg) translateY(-8px); }
    }

    /* ── ÉCRAN ── */
    .mk-lid {
      width: 420px;
      background: #f0f0ee;
      border-radius: 14px 14px 4px 4px;
      border: 1.5px solid #d8d8d4;
      box-shadow:
        0 2px 0 #c8c8c4,
        0 8px 32px rgba(53,64,36,0.14),
        0 2px 8px rgba(53,64,36,0.08);
      overflow: hidden;
    }

    /* Chrome navigateur */
    .mk-chrome {
      height: 26px;
      background: #e8e8e4;
      border-bottom: 1px solid #d0d0cc;
      display: flex;
      align-items: center;
      padding: 0 10px;
      gap: 8px;
      flex-shrink: 0;
    }
    .mk-dots {
      display: flex; gap: 4px; align-items: center;
      flex-shrink: 0;
    }
    .mk-dots span {
      display: block;
      width: 7px; height: 7px;
      border-radius: 50%;
      box-shadow: inset 0 0.5px 0 rgba(255,255,255,0.4);
    }
    .mk-url {
      flex: 1; max-width: 200px; margin: 0 auto;
      height: 15px;
      background: rgba(255,255,255,0.80);
      border: 1px solid #c8c8c4;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-family: -apple-system, sans-serif;
      font-size: 6px;
      color: rgba(53,64,36,0.50);
      letter-spacing: 0.01em;
    }

    /* Contenu du site */
    .mk-screen {
      background: #ede3d4;
      height: 252px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Nav site */
    .mk-nav {
      height: 24px;
      background: rgba(237,227,212,0.98);
      border-bottom: 1px solid rgba(76,61,25,0.08);
      display: flex; align-items: center;
      padding: 0 12px;
      flex-shrink: 0;
    }
    .mk-brand {
      font-family: Georgia, serif;
      font-size: 8px; font-weight: 500;
      color: #354024; letter-spacing: -0.02em;
      margin-right: auto;
    }
    .mk-links {
      display: flex; gap: 10px;
      font-family: -apple-system, sans-serif;
      font-size: 5.5px; color: rgba(53,64,36,0.55);
    }
    .mk-cta-nav {
      font-family: -apple-system, sans-serif;
      font-size: 5px; font-weight: 600;
      background: #354024; color: #ede3d4;
      padding: 3px 7px; border-radius: 10px;
      margin-left: 10px;
    }

    /* Hero */
    .mk-hero {
      display: grid;
      grid-template-columns: 1fr 100px;
      gap: 8px;
      padding: 14px 12px 10px;
      flex: 1;
    }
    .mk-hero-text { display: flex; flex-direction: column; gap: 3px; }
    .mk-eyebrow {
      font-family: -apple-system, sans-serif;
      font-size: 4.5px; letter-spacing: 0.18em; text-transform: uppercase;
      color: #889063; margin-bottom: 3px;
    }
    .mk-h1 {
      font-family: Georgia, serif;
      font-size: 12px; font-weight: 300;
      color: #354024; line-height: 1.15; letter-spacing: -0.02em;
    }
    .mk-h1i { color: #4a5630; }
    .mk-body {
      font-family: -apple-system, sans-serif;
      font-size: 5px; color: rgba(76,61,25,0.55); line-height: 1.5;
    }
    .mk-body-s { width: 75%; }
    .mk-btns { display: flex; gap: 5px; margin-top: 7px; }
    .mk-btn-p {
      font-family: -apple-system, sans-serif;
      font-size: 5px; font-weight: 600;
      background: #354024; color: #ede3d4;
      padding: 4px 9px; border-radius: 10px;
    }
    .mk-btn-g {
      font-family: -apple-system, sans-serif;
      font-size: 5px; color: #354024;
      padding: 4px 9px; border-radius: 10px;
      border: 1px solid rgba(53,64,36,0.20);
    }
    .mk-meta {
      display: flex; gap: 4px; margin-top: 5px;
      font-family: -apple-system, sans-serif;
      font-size: 4.5px; color: rgba(76,61,25,0.30);
    }
    .mk-sep { opacity: 0.4; }

    /* Image hero */
    .mk-hero-img { border-radius: 6px; overflow: hidden; position: relative; }
    .mk-img-inner {
      width: 100%; height: 100%;
      background: linear-gradient(145deg, #c5cc9f 0%, #a4b07e 45%, #788a55 100%);
    }
    .mk-img-over {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 55%, rgba(53,64,36,0.22) 100%);
    }

    /* Cartes */
    .mk-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
      padding: 7px 12px 9px;
      border-top: 1px solid rgba(76,61,25,0.07);
      flex-shrink: 0;
    }
    .mk-card {
      background: rgba(255,255,255,0.52);
      border: 1px solid rgba(76,61,25,0.08);
      border-radius: 5px;
      padding: 6px 7px;
      display: flex; flex-direction: column; gap: 3px;
    }
    .mk-card-n {
      font-family: Georgia, serif;
      font-size: 9px; color: rgba(136,144,99,0.35); line-height: 1;
    }
    .mk-card-t {
      font-family: Georgia, serif;
      font-size: 5.5px; color: #354024; line-height: 1.3;
    }
    .mk-card-bar {
      height: 2.5px;
      background: rgba(76,61,25,0.10);
      border-radius: 1.5px;
    }
    .mk-card-bar-s { width: 62%; }

    /* ── CHARNIÈRE ── */
    .mk-hinge {
      width: 100%;
      height: 3px;
      background: #d0d0cc;
      border-top: 1px solid #c0c0bc;
      border-bottom: 1px solid #e0e0dc;
    }

    /* ── BASE ── */
    .mk-base {
      width: 440px;
      height: 18px;
      background: linear-gradient(to bottom, #f0f0ee 0%, #e4e4e0 100%);
      border-radius: 0 0 10px 10px;
      border: 1.5px solid #d8d8d4;
      border-top: none;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow:
        0 4px 16px rgba(53,64,36,0.10),
        0 1px 3px rgba(53,64,36,0.06);
    }

    /* Trackpad */
    .mk-trackpad {
      width: 80px; height: 10px;
      background: #e0e0dc;
      border: 1px solid #c8c8c4;
      border-radius: 3px;
    }

    /* ── OMBRE SOL ── */
    .mk-shadow {
      position: absolute;
      bottom: -14px; left: 8%; right: 8%;
      height: 20px;
      background: radial-gradient(ellipse at center,
        rgba(53,64,36,0.20) 0%, rgba(53,64,36,0.06) 60%, transparent 80%);
      filter: blur(5px);
      pointer-events: none;
    }
  </style>

  <!-- ── Tarif + Prestations ── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 relative overflow-hidden">

    <!-- Blob sauge atmosphérique gauche -->
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-32 -left-24 w-80 h-80"></div>

    <div class="max-w-6xl mx-auto">

      <!-- Bloc tarif — card centrée -->
      <div class="relative rounded-2xl p-6 sm:p-8 md:p-12 mb-16 sm:mb-24 overflow-hidden bg-sauge-pale border border-cream-dark text-center" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Budget</p>
        <p class="font-display font-light text-brun leading-tight mb-3 text-center w-full" style="font-size: clamp(2.2rem, 4vw, 3.2rem);">
          De&nbsp;<span class="text-ocre">800€</span>&nbsp;à&nbsp;<span class="text-ocre">2&nbsp;500€</span>
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed mx-auto max-w-lg">
          Sur devis uniquement, selon vos besoins réels.
        </p>
      </div>

      <!-- Liste des prestations -->
      <div class="mb-24">
        <div class="flex items-center gap-3 mb-12" data-reveal>
          <span class="block w-8 h-px bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Ce que je peux faire pour vous</p>
        </div>
        <div>
          {prestations.map((p, i) => (
            <div class="border-t border-cream-dark py-8 md:grid md:grid-cols-[220px_1fr] md:gap-16 items-baseline" data-reveal>
              <h3 class="font-display text-xl font-light text-brun mb-3 md:mb-0">{p.title}</h3>
              <p class="font-body text-sm text-brun-mid leading-relaxed">{p.desc}</p>
            </div>
          ))}
          <div class="border-t border-cream-dark"></div>
        </div>
      </div>

      <!-- Mes réalisations -->
      <div class="mb-24" data-reveal>
        <div class="text-center mb-10">
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Réalisations</p>
          <h2 class="font-display font-light text-brun leading-[1.1]" style="font-size: clamp(2rem, 3.5vw, 3rem);">
            Mes réalisations
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">

          <!-- Carte — Atelier Néra -->
          <a href="/demos/atelier-nera" target="_blank" rel="noopener noreferrer"
             class="group relative overflow-hidden rounded-sm border border-cream-dark hover:border-ocre/40 transition-colors duration-300 bg-white block">
            <div class="h-2 w-full" style="background: linear-gradient(90deg, #1C1510 0%, #C4963C 50%, #8B6B4A 100%)"></div>
            <div class="relative overflow-hidden" style="aspect-ratio: 16/10; background: #F4EFE6;">
              <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-8 text-center">
                <p class="font-body text-[10px] tracking-[0.25em] uppercase" style="color: #8B6B4A">Ébénisterie sur mesure</p>
                <p class="font-display font-light text-2xl md:text-3xl" style="color: #1C1510; letter-spacing: -0.02em">Atelier Néra</p>
                <div class="w-8 h-px mt-1" style="background: #C4963C"></div>
                <p class="font-body text-xs leading-relaxed" style="color: rgba(28,21,16,0.5); max-width: 260px">
                  Site vitrine haut de gamme pour un artisan ébéniste. Galerie, processus de création, prise de contact.
                </p>
              </div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: rgba(28,21,16,0.7)">
                <span class="font-body text-sm tracking-widest uppercase text-white border border-white/40 px-6 py-3">Voir le site →</span>
              </div>
            </div>
            <div class="p-5 flex items-center justify-between">
              <div>
                <p class="font-display text-base font-light text-brun">Atelier Néra</p>
                <p class="font-body text-xs text-brun-mid mt-0.5">Ébénisterie · Site vitrine</p>
              </div>
              <div class="flex gap-1.5">
                <span class="font-body text-[10px] tracking-wider uppercase px-2 py-1 rounded-sm border border-cream-dark text-brun-mid">Artisan</span>
                <span class="font-body text-[10px] tracking-wider uppercase px-2 py-1 rounded-sm border border-cream-dark text-brun-mid">Premium</span>
              </div>
            </div>
          </a>

          <!-- Carte — Lunéa Botanique -->
          <a href="/demos/lunea-botanique" target="_blank" rel="noopener noreferrer"
             class="group relative overflow-hidden rounded-sm border border-cream-dark hover:border-ocre/40 transition-colors duration-300 bg-white block">
            <div class="h-2 w-full" style="background: linear-gradient(90deg, #2C3D2A 0%, #8B9E7E 50%, #D4C5A9 100%)"></div>
            <div class="relative overflow-hidden" style="aspect-ratio: 16/10; background: #F7F4EF;">
              <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-8 text-center">
                <p class="font-body text-[10px] tracking-[0.25em] uppercase" style="color: #8B9E7E">Bougies botaniques artisanales</p>
                <p class="font-display font-light text-2xl md:text-3xl" style="color: #2C3D2A; letter-spacing: -0.02em">Lunéa Botanique</p>
                <div class="w-8 h-px mt-1" style="background: #8B9E7E"></div>
                <p class="font-body text-xs leading-relaxed" style="color: rgba(44,61,42,0.5); max-width: 260px">
                  E-commerce botanique élégant. Produits vedettes, histoire de marque, fabrication artisanale, newsletter.
                </p>
              </div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: rgba(44,61,42,0.7)">
                <span class="font-body text-sm tracking-widets uppercase text-white border border-white/40 px-6 py-3">Voir le site →</span>
              </div>
            </div>
            <div class="p-5 flex items-center justify-between">
              <div>
                <p class="font-display text-base font-light text-brun">Lunéa Botanique</p>
                <p class="font-body text-xs text-brun-mid mt-0.5">Bougies artisanales · E-commerce</p>
              </div>
              <div class="flex gap-1.5">
                <span class="font-body text-[10px] tracking-wider uppercase px-2 py-1 rounded-sm border border-cream-dark text-brun-mid">Boutique</span>
                <span class="font-body text-[10px] tracking-wider uppercase px-2 py-1 rounded-sm border border-cream-dark text-brun-mid">Premium</span>
              </div>
            </div>
          </a>

        </div>
        <p class="font-body text-xs text-brun-mid/50 text-center mt-6">Projets fictifs réalisés à titre de démonstration.</p>
      </div>

    </div>
  </section>

  <!-- ── Comment je travaille ── -->
  <section class="py-16 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-5xl mx-auto">

      <!-- Titre centré compact -->
      <div class="text-center mb-12" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Comment je travaille</p>
        <h2 class="font-display font-light text-brun leading-[1.1]" style="font-size: clamp(1.8rem, 3vw, 2.6rem);">
          5 étapes, <span class="text-sauge">rien de caché.</span>
        </h2>
      </div>

      <!-- Étapes en liste verticale épurée -->
      <div class="flex flex-col divide-y divide-cream-dark">
        {etapes.map((e, i) => (
          <div class="flex items-start gap-6 md:gap-10 py-7 group" data-reveal data-delay={i}>

            <!-- Numéro -->
            <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-display font-light text-sm text-cream transition-all duration-300"
                 style={`background: ${i % 2 === 0 ? '#889063' : '#354024'};`}>
              {e.num}
            </div>

            <!-- Contenu -->
            <div class="flex-1 pt-1.5">
              <h4 class="font-display text-lg font-light text-brun mb-1.5">{e.title}</h4>
              <p class="font-body text-sm text-brun-mid leading-relaxed max-w-xl">{e.desc}</p>
            </div>

            <!-- Trait décoratif qui s'allonge au hover -->
            <div class="hidden md:block self-center h-px w-8 bg-cream-dark group-hover:w-16 transition-all duration-500 flex-shrink-0"></div>

          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── CTA — fond brun profond avec accent sauge ── -->
  <section class="relative py-24 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <!-- Blobs atmosphériques -->
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <!-- Feuille SVG déco -->
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-5 leading-[1.1]">
        Vous avez un projet ?<br><span class="text-sauge">Parlons-en.</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Décrivez votre activité en quelques lignes. Je reviens vers vous sous 48h.
      </p>
      <Button href="/contact" variant="primary">Me contacter →</Button>
    </div>
  </section>

</BaseLayout>
