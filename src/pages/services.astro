---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Prestations Caelestis',
  description: 'Sites web sur mesure et référencement naturel pour artisans, indépendants et petites entreprises en Auvergne-Rhône-Alpes. Agence basée à Crest, dans la Drôme.',
  url: 'https://caelestis.fr/services',
  numberOfItems: 6,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: {
        '@type': 'Service',
        name: 'Site vitrine',
        description: "Votre activité présentée clairement, visible sur Google, lisible sur tout type d'écran.",
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
        offers: {
          '@type': 'Offer',
          priceSpecification: {
            '@type': 'PriceSpecification',
            price: '800',
            priceCurrency: 'EUR',
          },
        },
      },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@type': 'Service',
        name: 'Boutique en ligne',
        description: 'Catalogue en ligne, paiement sécurisé, connecté à votre logiciel de gestion.',
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
        offers: {
          '@type': 'Offer',
          priceSpecification: {
            '@type': 'PriceSpecification',
            price: '1200',
            priceCurrency: 'EUR',
          },
        },
      },
    },
    {
      '@type': 'ListItem',
      position: 3,
      item: {
        '@type': 'Service',
        name: 'Référencement naturel (SEO)',
        description: "Apparaître en tête des résultats quand vos clients vous cherchent. Référencement local et national.",
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
      },
    },
    {
      '@type': 'ListItem',
      position: 4,
      item: {
        '@type': 'Service',
        name: 'Refonte de site existant',
        description: 'Votre site date ou ne vous ressemble plus ? On repart proprement sur de bonnes bases.',
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
      },
    },
    {
      '@type': 'ListItem',
      position: 5,
      item: {
        '@type': 'Service',
        name: 'Maintenance & accompagnement',
        description: 'Évolutions, mises à jour, nouvelles pages — forfait mensuel ou à la tâche.',
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
      },
    },
    {
      '@type': 'ListItem',
      position: 6,
      item: {
        '@type': 'Service',
        name: 'Page unique',
        description: "L'essentiel de votre activité sur une seule page. La solution accessible pour démarrer simplement et être visible sur Google.",
        url: 'https://caelestis.fr/site-une-page',
        provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
        areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
        offers: {
          '@type': 'Offer',
          priceSpecification: {
            '@type': 'PriceSpecification',
            price: '500',
            priceCurrency: 'EUR',
          },
        },
      },
    },
  ],
};

const breadcrumbServices = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
  ],
};

const etapes = [
  {
    num: '01',
    title: 'Faire connaissance',
    desc: "Tout commence par un échange. Nous prenons le temps de découvrir votre activité, votre parcours et vos objectifs afin de bien comprendre votre projet et ce qui le rend unique."
  },
  {
    num: '02',
    title: 'Définir vos besoins',
    desc: "À partir de nos échanges, nous vous proposons une solution adaptée à votre activité. Le devis détaille simplement ce qui sera réalisé et vous permet d'avancer en toute sérénité. Après signature du devis, un acompte de 30 % permet de lancer la création de votre site. Le reste est réglé une fois le site terminé et validé ensemble."
  },
  {
    num: '03',
    title: 'Concevoir votre site',
    desc: "Nous réalisons une première version du site que nous faisons évoluer ensemble. Chaque détail est ajusté jusqu'à obtenir un résultat fidèle à votre image et à vos attentes."
  },
  {
    num: '04',
    title: 'Mettre en ligne et valider',
    desc: "Une fois le site finalisé, il est mis en ligne. Nous effectuons ensemble les derniers contrôles, testons et validons le résultat. Quand tout est en place et que vous êtes satisfait, le projet est clôturé et la facturation intervient."
  },
  {
    num: '05',
    title: 'Rester à vos côtés',
    desc: "La mise en ligne ne marque pas la fin du projet. Nous restons disponibles pour répondre à vos questions, effectuer les modifications nécessaires et accompagner l'évolution de votre site au fil du temps."
  },
];
---
<BaseLayout
  title="Création de site internet · Tarifs & Prestations · Caelestis"
  description="Site une page dès 500 €, vitrine dès 800 €, boutique dès 1 200 €, sur mesure dès 2 500 €. Devis gratuit sous 48h pour artisans et indépendants."
  schema={[servicesSchema, breadcrumbServices]}
>

  <!-- En-tête de page -->
  <section class="pt-20 pb-10 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">

    <!-- Blob sauge atmosphérique -->
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[420px] h-[420px]"></div>
    <!-- Blob doré secondaire -->
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/3 w-64 h-64"></div>

    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_480px] gap-12 lg:gap-16 items-center relative">

      <!-- Texte -->
      <div class="text-center">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 mb-6" data-reveal>
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Création de site internet</p>
        </div>
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl mx-auto"
          style="font-size: clamp(2.2rem, 5.5vw, 4.5rem);"
          data-reveal data-delay="1"
        >
          Un site internet qui reflète vraiment<br class="hidden sm:block"> <span class="text-sauge">votre activité.</span>
        </h1>
        <p class="font-body text-lg text-brun-mid mt-8 max-w-xl leading-relaxed mx-auto" data-reveal data-delay="2">
          En 2 à 6 semaines, nous construisons ensemble un site sobre, authentique et durable. Un site qui raconte votre histoire, met en lumière votre travail et transforme les visiteurs en futurs clients.
        </p>

        <!-- CTA + ligne d'info discrète -->
        <div class="mt-10 flex flex-col sm:flex-row sm:items-center justify-center gap-5 sm:gap-7" data-reveal data-delay="3">
          <Button href="/contact" variant="primary">Lancer mon projet</Button>
          <div class="flex items-center justify-center gap-3 flex-wrap">
            <span class="font-body text-xs tracking-[0.18em] uppercase text-brun-mid/70">Devis gratuit</span>
            <span class="text-bois-mid/30">·</span>
            <span class="font-body text-xs tracking-[0.18em] uppercase text-brun-mid/70">Réponse sous 48h</span>
          </div>
        </div>
      </div>


      <!-- Mockup laptop épuré -->
      <div class="hidden lg:flex items-end justify-center py-4">
        <div class="mk-wrap">

          <!-- Écran -->
          <div class="mk-lid">

            <!-- Chrome navigateur -->
            <div class="mk-chrome">
              <div class="mk-dots">
                <span style="background:#ff5f57"></span>
                <span style="background:#febc2e"></span>
                <span style="background:#28c840"></span>
              </div>
              <div class="mk-url">
                <svg width="5" height="6" viewBox="0 0 5 6" fill="none" aria-hidden="true"><path d="M.8 3C.8 1.6 4.2 1.6 4.2 3v1.6C4.2 5 3.8 5.3 2.5 5.3 1.2 5.3.8 5 .8 4.6Z" stroke="rgba(136,144,99,.6)" stroke-width=".8"/><path d="M1.6 3V2.4C1.6 1.6 3.4 1.6 3.4 2.4V3" stroke="rgba(136,144,99,.6)" stroke-width=".8"/></svg>
                caelestis.fr
              </div>
            </div>

            <!-- Contenu du site -->
            <div class="mk-screen">

              <!-- Nav -->
              <div class="mk-nav">
                <span class="mk-brand">Caelestis<em style="color:#889063;font-style:normal">.</em></span>
                <div class="mk-links">
                  <span>Accueil</span><span>Services</span><span>À propos</span><span>Contact</span>
                </div>
                <div class="mk-cta-nav">Lancer mon projet</div>
              </div>

              <!-- Hero -->
              <div class="mk-hero">
                <div class="mk-hero-text">
                  <div class="mk-eyebrow">Développeur web indépendant · Drôme</div>
                  <div class="mk-h1">Votre site devrait</div>
                  <div class="mk-h1 mk-h1i">vous ressembler.</div>
                  <div class="mk-body">Un bon site internet devient un outil de croissance.</div>
                  <div class="mk-body mk-body-s">Il renforce votre image et contribue au développement de votre entreprise.</div>
                  <div class="mk-btns">
                    <div class="mk-btn-p">Lancer mon projet</div>
                    <div class="mk-btn-g">Nos prestations</div>
                  </div>
                  <div class="mk-meta">
                    <span>Réponse sous 48h</span><span class="mk-sep">·</span>
                    <span>Devis gratuit</span><span class="mk-sep">·</span>
                    <span>À partir de 800€</span>
                  </div>
                </div>
                <div class="mk-hero-img">
                  <div class="mk-img-inner"></div>
                  <div class="mk-img-over"></div>
                </div>
              </div>

              <!-- Cartes -->
              <div class="mk-cards">
                {[{n:'01',t:'Votre projet au centre'},{n:'02',t:'Clair dès la première seconde'},{n:'03',t:'Construit pour durer'}].map(({n,t})=>(
                  <div class="mk-card">
                    <span class="mk-card-n">{n}</span>
                    <span class="mk-card-t">{t}</span>
                    <div class="mk-card-bar"></div>
                    <div class="mk-card-bar mk-card-bar-s"></div>
                  </div>
                ))}
              </div>

            </div>
          </div>

          <!-- Charnière -->
          <div class="mk-hinge"></div>

          <!-- Base -->
          <div class="mk-base">
            <div class="mk-trackpad"></div>
          </div>

          <!-- Ombre sol -->
          <div class="mk-shadow"></div>

        </div>
      </div>

    </div>
  </section>

  <style>
    /* ═══════════════════════════════════════
       Mockup laptop — style épuré / design
    ═══════════════════════════════════════ */

    /* Wrapper + perspective légère */
    .mk-wrap {
      position: relative;
      width: 420px;
      perspective: 1200px;
      perspective-origin: 50% 30%;
    }

    /* ════════════════════════════════════════
       Mockup device — style épuré Caelestis
    ════════════════════════════════════════ */

    /* Le laptop tourne légèrement, animation flottante */
    .mk-lid, .mk-base {
      transform: rotateX(2deg) rotateY(-12deg);
      animation: mk-float 7s ease-in-out infinite;
    }
    @keyframes mk-float {
      0%,100% { transform: rotateX(2deg) rotateY(-12deg) translateY(0); }
      50%      { transform: rotateX(3deg) rotateY(-11deg) translateY(-8px); }
    }

    /* ── ÉCRAN ── */
    .mk-lid {
      width: 420px;
      background: #f0f0ee;
      border-radius: 14px 14px 4px 4px;
      border: 1.5px solid #d8d8d4;
      box-shadow:
        0 2px 0 #c8c8c4,
        0 8px 32px rgba(53,64,36,0.14),
        0 2px 8px rgba(53,64,36,0.08);
      overflow: hidden;
    }

    /* Chrome navigateur */
    .mk-chrome {
      height: 26px;
      background: #e8e8e4;
      border-bottom: 1px solid #d0d0cc;
      display: flex;
      align-items: center;
      padding: 0 10px;
      gap: 8px;
      flex-shrink: 0;
    }
    .mk-dots {
      display: flex; gap: 4px; align-items: center;
      flex-shrink: 0;
    }
    .mk-dots span {
      display: block;
      width: 7px; height: 7px;
      border-radius: 50%;
      box-shadow: inset 0 0.5px 0 rgba(255,255,255,0.4);
    }
    .mk-url {
      flex: 1; max-width: 200px; margin: 0 auto;
      height: 15px;
      background: rgba(255,255,255,0.80);
      border: 1px solid #c8c8c4;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-family: -apple-system, sans-serif;
      font-size: 6px;
      color: rgba(53,64,36,0.50);
      letter-spacing: 0.01em;
    }

    /* Contenu du site */
    .mk-screen {
      background: #ede3d4;
      height: 252px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Nav site */
    .mk-nav {
      height: 24px;
      background: rgba(237,227,212,0.98);
      border-bottom: 1px solid rgba(76,61,25,0.08);
      display: flex; align-items: center;
      padding: 0 12px;
      flex-shrink: 0;
    }
    .mk-brand {
      font-family: Georgia, serif;
      font-size: 8px; font-weight: 500;
      color: #354024; letter-spacing: -0.02em;
      margin-right: auto;
    }
    .mk-links {
      display: flex; gap: 10px;
      font-family: -apple-system, sans-serif;
      font-size: 5.5px; color: rgba(53,64,36,0.55);
    }
    .mk-cta-nav {
      font-family: -apple-system, sans-serif;
      font-size: 5px; font-weight: 600;
      background: #354024; color: #ede3d4;
      padding: 3px 7px; border-radius: 10px;
      margin-left: 10px;
    }

    /* Hero */
    .mk-hero {
      display: grid;
      grid-template-columns: 1fr 100px;
      gap: 8px;
      padding: 14px 12px 10px;
      flex: 1;
    }
    .mk-hero-text { display: flex; flex-direction: column; gap: 3px; }
    .mk-eyebrow {
      font-family: -apple-system, sans-serif;
      font-size: 4.5px; letter-spacing: 0.18em; text-transform: uppercase;
      color: #889063; margin-bottom: 3px;
    }
    .mk-h1 {
      font-family: Georgia, serif;
      font-size: 12px; font-weight: 300;
      color: #354024; line-height: 1.15; letter-spacing: -0.02em;
    }
    .mk-h1i { color: #4a5630; }
    .mk-body {
      font-family: -apple-system, sans-serif;
      font-size: 5px; color: rgba(76,61,25,0.55); line-height: 1.5;
    }
    .mk-body-s { width: 75%; }
    .mk-btns { display: flex; gap: 5px; margin-top: 7px; }
    .mk-btn-p {
      font-family: -apple-system, sans-serif;
      font-size: 5px; font-weight: 600;
      background: #354024; color: #ede3d4;
      padding: 4px 9px; border-radius: 10px;
    }
    .mk-btn-g {
      font-family: -apple-system, sans-serif;
      font-size: 5px; color: #354024;
      padding: 4px 9px; border-radius: 10px;
      border: 1px solid rgba(53,64,36,0.20);
    }
    .mk-meta {
      display: flex; gap: 4px; margin-top: 5px;
      font-family: -apple-system, sans-serif;
      font-size: 4.5px; color: rgba(76,61,25,0.30);
    }
    .mk-sep { opacity: 0.4; }

    /* Image hero */
    .mk-hero-img { border-radius: 12px; overflow: hidden; position: relative; }
    .mk-img-inner {
      width: 100%; height: 100%;
      background: linear-gradient(145deg, #c5cc9f 0%, #a4b07e 45%, #788a55 100%);
    }
    .mk-img-over {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 55%, rgba(53,64,36,0.22) 100%);
    }

    /* Cartes */
    .mk-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
      padding: 7px 12px 9px;
      border-top: 1px solid rgba(76,61,25,0.07);
      flex-shrink: 0;
    }
    .mk-card {
      background: rgba(255,255,255,0.52);
      border: 1px solid rgba(76,61,25,0.08);
      border-radius: 5px;
      padding: 6px 7px;
      display: flex; flex-direction: column; gap: 3px;
    }
    .mk-card-n {
      font-family: Georgia, serif;
      font-size: 9px; color: rgba(136,144,99,0.35); line-height: 1;
    }
    .mk-card-t {
      font-family: Georgia, serif;
      font-size: 5.5px; color: #354024; line-height: 1.3;
    }
    .mk-card-bar {
      height: 2.5px;
      background: rgba(76,61,25,0.10);
      border-radius: 1.5px;
    }
    .mk-card-bar-s { width: 62%; }

    /* ── CHARNIÈRE ── */
    .mk-hinge {
      width: 100%;
      height: 3px;
      background: #d0d0cc;
      border-top: 1px solid #c0c0bc;
      border-bottom: 1px solid #e0e0dc;
    }

    /* ── BASE ── */
    .mk-base {
      width: 440px;
      height: 18px;
      background: linear-gradient(to bottom, #f0f0ee 0%, #e4e4e0 100%);
      border-radius: 0 0 10px 10px;
      border: 1.5px solid #d8d8d4;
      border-top: none;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow:
        0 4px 16px rgba(53,64,36,0.10),
        0 1px 3px rgba(53,64,36,0.06);
    }

    /* Trackpad */
    .mk-trackpad {
      width: 80px; height: 10px;
      background: #e0e0dc;
      border: 1px solid #c8c8c4;
      border-radius: 3px;
    }

    /* ── OMBRE SOL ── */
    .mk-shadow {
      position: absolute;
      bottom: -14px; left: 8%; right: 8%;
      height: 20px;
      background: radial-gradient(ellipse at center,
        rgba(53,64,36,0.20) 0%, rgba(53,64,36,0.06) 60%, transparent 80%);
      filter: blur(5px);
      pointer-events: none;
    }
  </style>

  <!-- ── Tarif — trois typologies ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 relative overflow-hidden">

    <!-- Blob sauge atmosphérique gauche -->
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-32 -left-24 w-80 h-80"></div>

    <div class="max-w-6xl mx-auto">

      <!-- Bloc tarif — trois typologies éditoriales -->
      <div data-reveal>

        <!-- Header -->
        <div class="text-center mb-12 lg:mb-16">
          <div class="inline-flex items-center gap-3 mb-4">
            <span class="block w-8 h-px bg-sauge"></span>
            <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Comprendre nos offres</p>
            <span class="block w-8 h-px bg-sauge"></span>
          </div>
        </div>

        <!-- Offre d'entrée : Site une page (mise en avant) -->
        <a href="/site-une-page" class="group block max-w-5xl mx-auto mb-5 rounded-2xl border border-sauge/40 bg-cream p-7 sm:p-8 lg:px-10 transition-all duration-300 hover:border-sauge/70 hover:shadow-[0_12px_30px_rgba(76,61,25,0.10)]" data-reveal>
          <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-8">
            <div class="flex-1 min-w-0 text-center sm:text-left">
              <div class="inline-flex items-center gap-2 mb-3">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
                <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Pour démarrer</p>
              </div>
              <h3 class="font-display text-2xl font-light text-brun mb-1">Page unique</h3>
              <p class="font-body text-sm font-medium text-brun mb-2.5">L'essentiel en une page</p>
              <p class="font-body text-sm text-brun-mid leading-relaxed max-w-md">
                Une présence professionnelle et soignée, pour démarrer simplement et vite.
              </p>
            </div>
            <div class="shrink-0 text-center sm:text-right">
              <p class="font-body text-xs tracking-[0.16em] uppercase text-brun-mid/70 mb-1">À partir de</p>
              <p class="font-display font-light text-brun leading-none mb-3" style="font-size: clamp(2rem, 4vw, 2.6rem); letter-spacing: -0.025em;">
                <span class="text-sauge">500</span><span class="text-bois-mid text-lg ml-0.5">€</span>
              </p>
              <span class="inline-flex items-center gap-1.5 font-body text-sm font-medium text-sauge group-hover:gap-2.5 transition-all">
                Découvrir l'offre <span aria-hidden="true">→</span>
              </span>
            </div>
          </div>
        </a>

        <!-- Trois typologies : Vitrine · Boutique · Sur mesure -->
        <div class="grid sm:grid-cols-3 gap-px bg-cream-dark border border-cream-dark rounded-2xl overflow-hidden max-w-5xl mx-auto" data-reveal data-delay="1">

          <!-- Site vitrine -->
          <div class="bg-cream p-7 sm:p-8 lg:p-10 flex flex-col text-center items-center">
            <p class="font-body text-xs tracking-[0.22em] uppercase text-bois-mid mb-4">Site vitrine</p>
            <div class="mb-5">
              <p class="font-body text-xs tracking-[0.16em] uppercase text-brun-mid/70 mb-1">À partir de</p>
