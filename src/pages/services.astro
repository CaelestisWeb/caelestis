---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const prestations = [
  {
    title: 'Site vitrine',
    desc: "Présenter votre activité, vos produits ou services avec élégance. Jusqu'à 5–7 pages, responsive, optimisé SEO.",
  },
  {
    title: 'Site avec blog',
    desc: "Un vitrine + un espace de publication pour partager votre expertise, vos actualités, vos recettes, votre quotidien d'artisan.",
  },
  {
    title: 'Petite boutique en ligne',
    desc: "Vendre vos créations ou productions directement depuis votre site. Catalogue produits, panier, paiement sécurisé.",
  },
  {
    title: 'Refonte de site existant',
    desc: "Votre site actuel ne vous ressemble plus ou est trop lent ? On repart sur des bases saines, en gardant ce qui fonctionne.",
  },
  {
    title: 'Accompagnement & maintenance',
    desc: "Mises à jour, évolutions, support : je reste disponible après la livraison. Pas d'abandon après remise des clés.",
  },
];

const etapes = [
  { num: '01', title: 'Écoute',            desc: "On se parle. Vous m'expliquez votre activité, vos objectifs, vos contraintes. Je pose des questions." },
  { num: '02', title: 'Devis',             desc: "Je vous envoie un devis clair et détaillé. Pas de ligne floue, pas de surprise à la fin." },
  { num: '03', title: 'Conception',        desc: "On conçoit ensemble, par itérations. Vous validez chaque étape avant que je continue." },
  { num: '04', title: 'Livraison & maintien', desc: "Mise en ligne, formation pour gérer votre site, et je reste disponible après." },
];
---
<BaseLayout
  title="Mes prestations — Caelestis"
  description="Sites vitrine, boutiques, blogs, refontes — Caelestis propose des sites web sur devis, adaptés à votre projet réel. À partir de 600€. Drôme, France."
>

  <!-- En-tête de page -->
  <section class="pt-20 pb-16 px-6 md:px-10 lg:px-20 border-b border-cream-dark">
    <div class="max-w-6xl mx-auto">
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6" data-reveal>Prestations</p>
      <h1
        class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl"
        style="font-size: clamp(2.6rem, 5.5vw, 4.5rem);"
        data-reveal data-delay="1"
      >
        Mes prestations.
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed" data-reveal data-delay="2">
        Chaque projet est unique. Je vous propose un accompagnement sur mesure, adapté à vos besoins réels
        et à votre budget — pas une offre standardisée qui ne vous ressemble pas.
      </p>
    </div>
  </section>

  <section class="py-20 px-6 md:px-10 lg:px-20">
    <div class="max-w-6xl mx-auto">

      <!-- Bloc tarif mis en avant -->
      <div class="border-l-4 border-ocre pl-8 py-2 mb-20" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-2">Budget</p>
        <p class="font-display font-light text-brun leading-tight" style="font-size: clamp(2rem, 4vw, 3rem);">
          De 600€ à 2 500€
        </p>
        <p class="font-body text-base text-brun-mid mt-3 max-w-lg">
          Sur devis uniquement — en fonction de votre projet et de vos besoins réels. Aucune surprise.
        </p>
      </div>

      <!-- Liste des prestations -->
      <div class="mb-20">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-8" data-reveal>Ce que je peux faire pour vous</p>
        <div>
          {prestations.map((p) => (
            <div class="grid md:grid-cols-[220px_1fr] gap-6 py-9 border-t border-cream-dark" data-reveal>
              <h3 class="font-display text-2xl font-light text-brun">{p.title}</h3>
              <p class="font-body text-base text-brun-mid leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Comment je travaille -->
      <div class="bg-sauge-pale p-8 md:p-12" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-10">Comment je travaille</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
          {etapes.map((e) => (
            <div>
              <span class="font-display text-4xl font-light text-sauge/30 block mb-3">{e.num}</span>
              <h4 class="font-display text-xl font-light text-brun mb-2">{e.title}</h4>
              <p class="font-body text-sm text-brun-mid leading-relaxed">{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark text-center" data-reveal>
    <div class="max-w-xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-6">
        Un projet en tête ?
      </h2>
      <p class="font-body text-base text-brun-mid mb-8">
        Contactez-moi pour en parler. Je vous réponds sous 48h.
      </p>
      <Button href="/contact" variant="primary">Me contacter →</Button>
    </div>
  </section>

</BaseLayout>
