---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & accompagnement mensuel — Caelestis',
  description: 'Forfait mensuel de maintenance, modifications et suivi de site internet pour artisans, indépendants et petites entreprises en France.',
  provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
  areaServed: { '@type': 'Country', name: 'France' },
  offers: [
    { '@type': 'Offer', name: 'Maintenance site vitrine',      priceSpecification: { '@type': 'PriceSpecification', price: '9.99',  priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Maintenance boutique en ligne',  priceSpecification: { '@type': 'PriceSpecification', price: '19.99', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Maintenance site sur mesure',    priceSpecification: { '@type': 'PriceSpecification', price: '29.99', priceCurrency: 'EUR', unitText: 'MONTH' } },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil',     item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
    { '@type': 'ListItem', position: 3, name: 'Maintenance mensuelle', item: 'https://caelestis.fr/maintenance' },
  ],
};

const etapes = [
  {
    num: '01',
    titre: 'Vous choisissez votre formule',
    texte: "Selon votre type de site — vitrine, boutique ou sur mesure. L'abonnement commence dès la livraison de votre site, ou à tout moment si votre site existe déjà.",
  },
  {
    num: '02',
    titre: "Je veille sur votre site",
    texte: "Mises à jour de sécurité, sauvegardes, surveillance, corrections techniques... Tout est traité en arrière-plan, sans que vous ayez à y penser.",
  },
  {
    num: '03',
    titre: 'Une évolution ? Sur devis',
    texte: "Besoin de changer un contenu, d'ajouter une page ou une fonctionnalité ? Je vous fais un devis simple et clair, selon vos besoins — vous ne payez que ce dont vous avez vraiment besoin.",
  },
];

// Abonnement maintenance — un tarif par type de site (maintenance technique pure)
const formules = [
  {
    type: 'Vitrine',
    prix: '9,99',
    desc: 'Pour garder votre site vitrine en ligne, rapide et sécurisé.',
    lien: '#',
    feats: [
      'Site surveillé et maintenu en ligne',
      'Mises à jour de sécurité',
      'Sauvegardes régulières',
      'Correction des bugs techniques',
      'Support par email',
    ],
  },
  {
    type: 'Boutique en ligne',
    prix: '19,99',
    desc: 'La tranquillité pour votre boutique : paiements et données surveillés.',
    lien: '#',
    feats: [
      'Tout le suivi d\'un site vitrine',
      'Surveillance des paiements en ligne',
      'Mises à jour des modules boutique',
      'Sauvegarde du site et des données',
      'Support par email prioritaire',
    ],
  },
  {
    type: 'Sur mesure',
    prix: '29,99',
    desc: 'Pour les sites complexes ou boutiques avancées qui demandent une veille poussée.',
    lien: '#',
    feats: [
      'Tout le suivi d\'une boutique en ligne',
      'Surveillance de disponibilité avec alertes',
      'Mises à jour techniques et dépendances',
      'Sauvegardes rapprochées',
      'Support par email prioritaire',
    ],
  },
];
---

<BaseLayout
  title="Maintenance & accompagnement mensuel — Caelestis"
  description="Abonnement de maintenance pour site vitrine, boutique en ligne et site sur mesure. Sécurité, sauvegardes et surveillance technique. Dès 9,99 €/mois, sans engagement."
  schema={[schema, breadcrumb]}
  noindex={true}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-14 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[400px] h-[400px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/3 w-56 h-56"></div>

    <svg aria-hidden="true" class="pointer-events-none absolute right-0 top-0 h-full w-auto opacity-[0.07]" viewBox="0 0 320 480" fill="none" preserveAspectRatio="xMaxYMid slice">
      <path d="M320 60 C270 80 210 40 160 60 C110 80 60 40 0 60"   stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 90 C270 110 210 70 160 90 C110 110 60 70 0 90" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 130 C270 150 210 110 160 130 C110 150 60 110 0 130" stroke="#A08060" stroke-width="0.9"/>
      <path d="M320 170 C270 190 210 150 160 170 C110 190 60 150 0 170" stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 210 C270 230 210 190 160 210 C110 230 60 190 0 210" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 260 C270 280 210 240 160 260 C110 280 60 240 0 260" stroke="#4C3D19" stroke-width="1.2"/>
      <path d="M320 300 C270 320 210 280 160 300 C110 320 60 280 0 300" stroke="#889063" stroke-width="1.0"/>
      <path d="M320 350 C270 370 210 330 160 350 C110 370 60 330 0 350" stroke="#A08060" stroke-width="0.8"/>
      <path d="M320 400 C270 420 210 380 160 400 C110 420 60 380 0 400" stroke="#4C3D19" stroke-width="1.2"/>
      <path d="M320 440 C270 460 210 420 160 440 C110 460 60 420 0 440" stroke="#889063" stroke-width="0.9"/>
    </svg>

    <div class="max-w-4xl mx-auto relative text-center">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Accompagnement mensuel</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl mx-auto"
        style="font-size: clamp(2.2rem, 5.5vw, 4.2rem);"
        data-reveal data-delay="1"
      >
        Votre site reste entre<br class="hidden sm:block"> <span class="text-sauge">de bonnes mains.</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed mx-auto" data-reveal data-delay="2">
        La mise en ligne n'est pas une fin. Mises à jour, retouches, sauvegardes, rapports de performances...<br>Chaque semaine, je veille à ce que votre site fonctionne parfaitement et continue de vous ressembler.
      </p>
    </div>
  </section>

  <!-- ── Cartes d'abonnement — une par type de site ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 relative overflow-hidden">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-40 -left-24 w-72 h-72"></div>

    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12" data-reveal>
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">L'abonnement maintenance</p>
          <span class="block w-8 h-px bg-sauge"></span>
        </div>
        <h2 class="font-display font-light text-brun leading-[1.1] mb-4" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
          Un tarif selon votre site.
        </h2>
        <p class="font-body text-base text-brun-mid max-w-xl mx-auto leading-relaxed">
          Un abonnement unique qui garde votre site en ligne, sécurisé et sauvegardé — sans engagement.
        </p>
      </div>

      <!-- 3 cartes : une par type de site -->
      <div class="grid sm:grid-cols-3 gap-5 lg:gap-6 items-stretch" data-reveal data-delay="1">
        {formules.map((f) => (
          <div class="bg-cream border-2 border-sauge/30 rounded-2xl p-6 lg:p-8 flex flex-col">
            <p class="font-body text-xs tracking-[0.22em] uppercase text-bois-mid mb-4">{f.type}</p>
            <div class="mb-5">
              <p class="font-display font-light text-brun leading-none" style="font-size: clamp(2rem, 4vw, 2.6rem); letter-spacing: -0.02em;">
                {f.prix}<span class="text-bois-mid text-lg ml-1">€</span>
              </p>
              <p class="font-body text-xs text-brun-mid/75 mt-2">par mois · sans engagement</p>
            </div>
            <p class="font-body text-sm text-brun-mid mb-6 leading-relaxed">{f.desc}</p>
            <ul class="flex flex-col gap-3 flex-1 mb-7">
              {f.feats.map((feat) => (
                <li class="feat-std flex items-start gap-3 font-body text-sm text-brun-mid leading-snug">{feat}</li>
              ))}
            </ul>
            <a
              href={f.lien}
              class="inline-flex items-center justify-center font-body font-medium text-sm tracking-[0.04em] transition-all duration-300 min-h-[44px] border border-sauge/70 text-sauge px-6 py-3 rounded-full hover:bg-sauge hover:text-cream hover:border-sauge btn-magnetic"
            >
              S'abonner
            </a>
          </div>
        ))}
      </div>

      <!-- Note bas de cards -->
      <div class="mt-8 text-center" data-reveal data-delay="2">
        <p class="font-body text-sm text-brun-mid/70 leading-relaxed">
          Modifications et évolutions du site sur devis, selon vos besoins — 65&nbsp;€/h. Sans engagement.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Comment ça marche — 3 étapes ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12 lg:mb-16" data-reveal>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.9rem, 3.2vw, 2.8rem);">
          Comment ça fonctionne ?
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-5">
        {etapes.map((e, i) => (
          <div class="bg-cream border-2 border-sauge/40 rounded-2xl p-7 lg:p-9 text-center" data-reveal data-delay={i}>
            <p class="font-body text-[10px] tracking-[0.22em] uppercase text-sauge mb-4">{e.num}</p>
            <h3 class="font-display text-xl font-light text-sauge mb-3 leading-snug">{e.titre}</h3>
            <p class="font-body text-sm text-brun leading-relaxed">{e.texte}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Ce que « heures incluses » veut dire ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-3xl mx-auto" data-reveal>

      <div class="inline-flex items-center gap-3 mb-6">
        <span class="block w-8 h-px bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">À savoir</p>
      </div>

      <h2 class="font-display font-light text-brun leading-[1.1] mb-10" style="font-size: clamp(1.6rem, 2.8vw, 2.2rem);">
        Maintenance et modifications,<br>deux choses distinctes.
      </h2>

      <div class="grid sm:grid-cols-2 gap-6">

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Ce que couvre l'abonnement</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Garder votre site en ligne, rapide et sécurisé : mises à jour de sécurité, sauvegardes, surveillance de la disponibilité et correction des bugs techniques. Tout le travail de fond, en continu, sans que vous ayez à y penser.
          </p>
        </div>

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Ce qui passe par un devis</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Changer un contenu, remplacer des photos, ajouter une page, intégrer une nouvelle fonctionnalité ou faire évoluer votre site. Chaque demande fait l'objet d'un devis simple et clair — vous ne payez que ce dont vous avez besoin.
          </p>
        </div>

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark sm:col-span-2">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Pourquoi un abonnement ?</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Un site internet n'est pas figé : les technologies évoluent, des failles de sécurité apparaissent, les sauvegardes doivent rester régulières. Sans entretien, un site se fragilise avec le temps. L'abonnement garantit qu'il reste fiable et disponible, mois après mois — même si vous n'y touchez jamais.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-5 leading-[1.1]">
        Votre site mérite d'être<br><span class="text-sauge">entre de bonnes mains.</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Dites-moi sur quel site vous travaillez et quelle formule vous correspond. Je vous réponds sous 48h.
      </p>
      <Button href="/contact" variant="primary">Prendre contact</Button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Icône check des fonctionnalités */
  .feat-std::before {
    content: '';
    display: block;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='%23889063' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='%23889063' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }
</style>

