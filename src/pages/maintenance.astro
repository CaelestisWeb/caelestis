---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & accompagnement mensuel — Caelestis',
  description: 'Forfait mensuel de maintenance, modifications et suivi de site internet pour artisans, indépendants et petites entreprises en France.',
  provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
  areaServed: { '@type': 'Country', name: 'France' },
  offers: [
    { '@type': 'Offer', name: 'Standard Vitrine', priceSpecification: { '@type': 'PriceSpecification', price: '19', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Premium Vitrine',  priceSpecification: { '@type': 'PriceSpecification', price: '59', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Standard Boutique', priceSpecification: { '@type': 'PriceSpecification', price: '29', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Premium Boutique',  priceSpecification: { '@type': 'PriceSpecification', price: '89', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Standard Sur mesure', priceSpecification: { '@type': 'PriceSpecification', price: '39', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Premium Sur mesure',  priceSpecification: { '@type': 'PriceSpecification', price: '119', priceCurrency: 'EUR', unitText: 'MONTH' } },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil',     item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
    { '@type': 'ListItem', position: 3, name: 'Maintenance mensuelle', item: 'https://caelestis.fr/maintenance' },
  ],
};

const etapes = [
  {
    num: '01',
    titre: 'Vous choisissez votre formule',
    texte: "Standard ou Premium, selon le niveau d'accompagnement dont vous avez besoin. La formule commence dès la livraison de votre site, ou à tout moment si votre site existe déjà.",
  },
  {
    num: '02',
    titre: "Je m'en occupe chaque mois",
    texte: "Mises à jour, sauvegardes, petites retouches... tout est traité discrètement, sans que vous ayez à y penser. Un email suffit pour me signaler ce que vous souhaitez modifier.",
  },
  {
    num: '03',
    titre: 'Votre site évolue avec vous',
    texte: "Avec les heures incluses chaque mois, votre site reste à jour. Il reflète vos nouveaux services, vos photos récentes, vos tarifs actuels — sans avoir à relancer un projet à chaque changement.",
  },
];
---

<BaseLayout
  title="Maintenance & accompagnement mensuel — Caelestis"
  description="Forfaits mensuels de maintenance pour site vitrine, boutique en ligne et site sur mesure. Mises à jour, modifications, rapports de performances. Dès 49 €/mois HT."
  schema={[schema, breadcrumb]}
  noindex={true}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-14 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[400px] h-[400px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/3 w-56 h-56"></div>

    <svg aria-hidden="true" class="pointer-events-none absolute right-0 top-0 h-full w-auto opacity-[0.07]" viewBox="0 0 320 480" fill="none" preserveAspectRatio="xMaxYMid slice">
      <path d="M320 60 C270 80 210 40 160 60 C110 80 60 40 0 60"   stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 90 C270 110 210 70 160 90 C110 110 60 70 0 90" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 130 C270 150 210 110 160 130 C110 150 60 110 0 130" stroke="#A08060" stroke-width="0.9"/>
      <path d="M320 170 C270 190 210 150 160 170 C110 190 60 150 0 170" stroke="#4C3D19" stroke-width="1.4"/>
      <path d="M320 210 C270 230 210 190 160 210 C110 230 60 190 0 210" stroke="#889063" stroke-width="1.1"/>
      <path d="M320 260 C270 280 210 240 160 260 C110 280 60 240 0 260" stroke="#4C3D19" stroke-width="1.2"/>
      <path d="M320 300 C270 320 210 280 160 300 C110 320 60 280 0 300" stroke="#889063" stroke-width="1.0"/>
      <path d="M320 350 C270 370 210 330 160 350 C110 370 60 330 0 350" stroke="#A08060" stroke-width="0.8"/>
      <path d="M320 400 C270 420 210 380 160 400 C110 420 60 380 0 400" stroke="#4C3D19" stroke-width="1.2"/>
      <path d="M320 440 C270 460 210 420 160 440 C110 460 60 420 0 440" stroke="#889063" stroke-width="0.9"/>
    </svg>

    <div class="max-w-4xl mx-auto relative">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Accompagnement mensuel</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl"
        style="font-size: clamp(2.2rem, 5.5vw, 4.2rem);"
        data-reveal data-delay="1"
      >
        Votre site reste entre<br class="hidden sm:block"> <span class="text-sauge">de bonnes mains.</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed" data-reveal data-delay="2">
        La mise en ligne n'est pas une fin. Mises à jour, retouches, sauvegardes, rapports de performances... Chaque mois, je veille à ce que votre site fonctionne parfaitement et continue de vous ressembler.
      </p>
    </div>
  </section>

  <!-- ── Sélecteur de type + cards ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 relative overflow-hidden">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-40 -left-24 w-72 h-72"></div>

    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12" data-reveal>
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Choisir votre formule</p>
          <span class="block w-8 h-px bg-sauge"></span>
        </div>
        <h2 class="font-display font-light text-brun leading-[1.1] mb-8" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
          Pour quel type de site ?
        </h2>

        <!-- Sélecteur -->
        <div class="inline-flex gap-2 bg-cream border border-cream-dark rounded-2xl p-1.5" role="group" aria-label="Type de site">
          <button id="btn-vitrine"    class="type-btn font-body text-sm px-6 py-2.5 rounded-xl transition-all duration-200" data-type="vitrine">Vitrine</button>
          <button id="btn-boutique"   class="type-btn font-body text-sm px-6 py-2.5 rounded-xl transition-all duration-200" data-type="boutique">Boutique</button>
          <button id="btn-surmesure"  class="type-btn font-body text-sm px-6 py-2.5 rounded-xl transition-all duration-200" data-type="surmesure">Sur mesure</button>
        </div>
      </div>

      <!-- Cards -->
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8" data-reveal data-delay="1">

        <!-- Standard -->
        <div class="bg-cream border-2 rounded-2xl p-8 lg:p-10 flex flex-col" style="border-color: rgba(136,144,99,0.3);">
          <p class="font-body text-xs tracking-[0.22em] uppercase text-bois-mid mb-5">Standard</p>
          <div class="mb-2">
            <p class="font-display font-light text-brun leading-none" style="font-size: clamp(2.2rem, 4vw, 3rem); letter-spacing: -0.025em;">
              <span id="price-std">49</span><span class="text-bois-mid text-xl ml-1">€</span>
            </p>
            <p class="font-body text-xs text-brun-mid/60 mt-1">par mois, hors taxe</p>
          </div>
          <p class="font-body text-sm text-brun-mid mt-4 mb-7 leading-relaxed">L'essentiel pour que votre site reste fiable, à jour et bien entretenu.</p>
          <ul id="feats-std" class="flex flex-col gap-3.5 flex-1 mb-8"></ul>
          <a id="cta-std" href="https://buy.stripe.com/00w00iacm2ztaYieOadAk01" target="_blank" rel="noopener" class="inline-flex items-center justify-center font-body font-medium text-sm tracking-[0.04em] transition-all duration-300 min-h-[44px] border border-sauge/70 text-sauge px-8 py-3 rounded-full hover:bg-sauge hover:text-cream hover:border-sauge btn-magnetic">Choisir Standard</a>
        </div>

        <!-- Premium -->
        <div class="rounded-2xl p-8 lg:p-10 flex flex-col relative overflow-hidden" style="background: #354024;">
          <!-- Badge -->
          <div class="absolute top-0 right-0">
            <div class="font-body text-[10px] tracking-[0.18em] uppercase px-4 py-1.5 rounded-bl-xl" style="background: rgba(136,144,99,0.35); color: #c8d4a0;">
              Recommandé
            </div>
          </div>

          <p class="font-body text-xs tracking-[0.22em] uppercase mb-5" style="color: rgba(200,212,160,0.7);">Premium</p>
          <div class="mb-2">
            <p class="font-display font-light leading-none" style="font-size: clamp(2.2rem, 4vw, 3rem); letter-spacing: -0.025em; color: #ede3d4;">
              <span id="price-prm">89</span><span class="text-xl ml-1" style="color: rgba(237,227,212,0.45);">€</span>
            </p>
            <p class="font-body text-xs mt-1" style="color: rgba(237,227,212,0.4);">par mois, hors taxe</p>
          </div>
          <p class="font-body text-sm mt-4 mb-7 leading-relaxed" style="color: rgba(237,227,212,0.65);">Un accompagnement complet, avec contenu SEO et suivi de performances inclus.</p>
          <ul id="feats-prm" class="flex flex-col gap-3.5 flex-1 mb-8"></ul>
          <a
            id="cta-prm"
            href="https://buy.stripe.com/aFa8wO5W66PJgiCbBYdAk02"
            target="_blank" rel="noopener"
            class="block text-center font-body text-sm font-medium px-7 py-3.5 rounded-full transition-all duration-200 hover:opacity-90"
            style="background: #889063; color: #ede3d4;"
          >
            Choisir Premium
          </a>
        </div>

      </div>

      <!-- Note bas de cards -->
      <div class="mt-8 text-center" data-reveal data-delay="2">
        <p class="font-body text-sm text-brun-mid/70 leading-relaxed">
          Heures supplémentaires facturées 65&nbsp;€/h. Sans engagement minimum.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Comment ça marche — 3 étapes ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12 lg:mb-16" data-reveal>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.9rem, 3.2vw, 2.8rem);">
          Comment ça fonctionne ?
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-5">
        {etapes.map((e, i) => (
          <div class="bg-cream border-2 border-sauge/40 rounded-2xl p-7 lg:p-9 text-center" data-reveal data-delay={i}>
            <p class="font-body text-[10px] tracking-[0.22em] uppercase text-sauge mb-4">{e.num}</p>
            <h3 class="font-display text-xl font-light text-sauge mb-3 leading-snug">{e.titre}</h3>
            <p class="font-body text-sm text-brun leading-relaxed">{e.texte}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Ce que « heures incluses » veut dire ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-3xl mx-auto" data-reveal>

      <div class="inline-flex items-center gap-3 mb-6">
        <span class="block w-8 h-px bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">À savoir</p>
      </div>

      <h2 class="font-display font-light text-brun leading-[1.1] mb-10" style="font-size: clamp(1.6rem, 2.8vw, 2.2rem);">
        Ce que recouvrent les heures de modifications.
      </h2>

      <div class="grid sm:grid-cols-2 gap-6">

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Ce qui est inclus</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Changer un texte, remplacer une photo, mettre à jour vos tarifs, ajouter un nouveau service, ajuster une couleur ou corriger une mise en page. Tout ce qui se règle rapidement et tient dans le quota mensuel.
          </p>
        </div>

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Ce qui est hors forfait</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Créer une nouvelle page complète, intégrer une fonctionnalité inédite ou refondre une section entière dépasse le cadre d'une maintenance courante. Ces travaux font l'objet d'un devis séparé, comme n'importe quel nouveau projet.
          </p>
        </div>

        <div class="bg-cream rounded-2xl p-6 border border-cream-dark sm:col-span-2">
          <p class="font-body text-xs tracking-[0.18em] uppercase text-sauge mb-3">Les heures non utilisées</p>
          <p class="font-body text-sm text-brun leading-relaxed">
            Elles ne sont pas reportées d'un mois sur l'autre. Ce fonctionnement permet de maintenir un rythme régulier et d'éviter les accumulations. Si un mois vous n'avez rien à modifier, la maintenance technique et les sauvegardes sont assurées quoi qu'il arrive.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-5 leading-[1.1]">
        Votre site mérite d'être<br><span class="text-sauge">entre de bonnes mains.</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Dites-moi sur quel site vous travaillez et quelle formule vous correspond. Je vous réponds sous 48h.
      </p>
      <Button href="/contact" variant="primary">Prendre contact</Button>
    </div>
  </section>

</BaseLayout>

<style>
  .type-btn {
    color: #52647A;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .type-btn.active {
    background: #ffffff;
    color: #354024;
    font-weight: 500;
    box-shadow: 0 1px 4px rgba(76,61,25,0.10);
  }
  .type-btn:hover:not(.active) {
    color: #354024;
  }

  /* Icône check Standard */
  .feat-std::before {
    content: '';
    display: block;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='%23889063' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='%23889063' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }
  /* Icône check Premium */
  .feat-prm::before {
    content: '';
    display: block;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='rgba(200%2C212%2C160%2C0.55)' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='rgba(200%2C212%2C160%2C0.9)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }
</style>

<script>
  const LIENS: Record<string, { std: string; prm: string }> = {
    vitrine:   { std: 'https://buy.stripe.com/00w00iacm2ztaYieOadAk01', prm: 'https://buy.stripe.com/aFa8wO5W66PJgiCbBYdAk02' },
    boutique:  { std: 'https://buy.stripe.com/aFa14m2JUfmf6I221odAk03', prm: 'https://buy.stripe.com/14A6oG5W6eib4zU35sdAk04' },
    surmesure: { std: 'https://buy.stripe.com/fZu7sKesCfmf0jEeOadAk05', prm: 'https://buy.stripe.com/00weVc1FQb5Z3vQcG2dAk06' },
  };

  const OFFRES: Record<string, { std: { prix: string; feats: string[] }; prm: { prix: string; feats: string[] } }> = {
    vitrine: {
      std: { prix: '19', feats: [
        "Mises à jour de sécurité chaque mois",
        "1 heure de modifications incluse par mois",
        "Sauvegarde mensuelle du site",
        "Rapport de performances tous les trimestres",
        "Réponse par email sous 3 jours ouvrés",
      ]},
      prm: { prix: '59', feats: [
        "Mises à jour de sécurité chaque mois",
        "3 heures de modifications incluses par mois",
        "Sauvegardes hebdomadaires",
        "Rapport de performances et de référencement chaque mois",
        "Réponse par email sous 24 heures ouvrées",
        "1 article optimisé pour le référencement par mois",
        "Audit complet du site après 12 mois d'abonnement",
      ]},
    },
    boutique: {
      std: { prix: '29', feats: [
        "Mises à jour de sécurité et extensions boutique",
        "1 heure de modifications incluse par mois",
        "Sauvegarde mensuelle du site et des données clients",
        "Surveillance des paiements en ligne avec alertes",
        "Réponse par email sous 3 jours ouvrés",
      ]},
      prm: { prix: '89', feats: [
        "Mises à jour de sécurité et extensions boutique",
        "3 heures de modifications incluses par mois",
        "Sauvegardes hebdomadaires du site et de la base de données",
        "Surveillance des paiements en temps réel",
        "Réponse par email sous 24 heures ouvrées",
        "Gestion des fiches produits incluse",
        "Rapport mensuel performances et taux de conversion",
      ]},
    },
    surmesure: {
      std: { prix: '39', feats: [
        "Mises à jour techniques et dépendances logicielles",
        "2 heures de modifications incluses par mois",
        "Sauvegardes hebdomadaires",
        "Surveillance de la disponibilité du site",
        "Réponse par email sous 3 jours ouvrés",
      ]},
      prm: { prix: '119', feats: [
        "Mises à jour techniques et dépendances logicielles",
        "4 heures de modifications incluses par mois",
        "Sauvegardes quotidiennes",
        "Surveillance de la disponibilité avec alertes immédiates",
        "Réponse par email sous 24 heures ouvrées",
        "Petites évolutions fonctionnelles incluses",
        "Audit complet du site après 12 mois d'abonnement",
      ]},
    },
  };

  let typeActif = 'vitrine';

  function render(type: string) {
    typeActif = type;
    const o = OFFRES[type];
    if (!o) return;

    const priceStd = document.getElementById('price-std');
    const pricePrm = document.getElementById('price-prm');
    const featsStd = document.getElementById('feats-std');
    const featsPrm = document.getElementById('feats-prm');

    if (priceStd) priceStd.textContent = o.std.prix;
    if (pricePrm) pricePrm.textContent = o.prm.prix;

    const ctaStd = document.getElementById('cta-std') as HTMLAnchorElement | null;
    const ctaPrm = document.getElementById('cta-prm') as HTMLAnchorElement | null;
    if (ctaStd) ctaStd.href = LIENS[type]?.std ?? '#';
    if (ctaPrm) ctaPrm.href = LIENS[type]?.prm ?? '#';

    if (featsStd) {
      featsStd.innerHTML = o.std.feats
        .map(f => `<li class="feat-std flex items-start gap-3 font-body text-sm text-brun-mid leading-snug">${f}</li>`)
        .join('');
    }
    if (featsPrm) {
      featsPrm.innerHTML = o.prm.feats
        .map(f => `<li class="feat-prm flex items-start gap-3 font-body text-sm leading-snug" style="color: rgba(237,227,212,0.7);">${f}</li>`)
        .join('');
    }

    document.querySelectorAll<HTMLButtonElement>('.type-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.type === type);
    });
  }

  function init() {
    document.querySelectorAll<HTMLButtonElement>('.type-btn').forEach(btn => {
      btn.addEventListener('click', () => render(btn.dataset.type ?? 'vitrine'));
    });
    render(typeActif);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
</script>
