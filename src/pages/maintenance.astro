---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance mensuelle de site internet, Caelestis',
  description: 'Abonnement mensuel de maintenance technique de site internet pour artisans, indépendants et petites entreprises en France : sécurité, sauvegardes et surveillance.',
  provider: { '@type': 'LocalBusiness', '@id': 'https://caelestis.fr/#business', name: 'Caelestis', url: 'https://caelestis.fr' },
  areaServed: [{ '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' }, { '@type': 'Country', name: 'France' }],
  offers: [
    { '@type': 'Offer', name: 'Maintenance site une page',     priceSpecification: { '@type': 'PriceSpecification', price: '7.99',  priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Maintenance site vitrine',      priceSpecification: { '@type': 'PriceSpecification', price: '9.99',  priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Maintenance boutique en ligne',  priceSpecification: { '@type': 'PriceSpecification', price: '14.99', priceCurrency: 'EUR', unitText: 'MONTH' } },
    { '@type': 'Offer', name: 'Maintenance site sur mesure',    priceSpecification: { '@type': 'PriceSpecification', price: '19.99', priceCurrency: 'EUR', unitText: 'MONTH' } },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil',     item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
    { '@type': 'ListItem', position: 3, name: 'Maintenance mensuelle', item: 'https://caelestis.fr/maintenance' },
  ],
};

// Abonnement maintenance — un tarif par type de site (maintenance technique uniquement)
const formules = [
  {
    type: 'Page unique',
    prix: '7,99',
    desc: 'Pour garder votre Page unique en ligne, rapide et sécurisée.',
    lien: 'https://buy.stripe.com/9B63cugAK8XR0jE6hEdAk0c',
    feats: [
      '1 mise à jour par mois',
      'Site protégé et sécurisé',
      'Sauvegardes régulières',
      'Toujours en ligne',
    ],
  },
  {
    type: 'Vitrine',
    prix: '9,99',
    desc: 'Pour garder votre site vitrine en ligne, rapide et sécurisé.',
    lien: 'https://buy.stripe.com/eVq7sKbgq2ztaYidK6dAk07',
    feats: [
      '1 mise à jour par semaine',
      'Site protégé et sécurisé',
      'Sauvegardes régulières',
      'Toujours en ligne',
    ],
  },
  {
    type: 'Boutique en ligne',
    prix: '14,99',
    desc: 'La tranquillité pour votre boutique : paiements et données surveillés.',
    lien: 'https://buy.stripe.com/8x2cN41FQa1V4zUdK6dAk0b',
    feats: [
      '3 mises à jour par semaine',
      'Boutique et paiements sécurisés',
      'Sauvegardes régulières',
      'Toujours en ligne',
    ],
  },
  {
    type: 'Sur mesure',
    prix: '19,99',
    desc: 'Pour les sites complexes ou les boutiques avancées qui demandent une veille poussée.',
    lien: 'https://buy.stripe.com/8x25kCacm0rl3vQcG2dAk0a',
    feats: [
      'Mises à jour 7 jours sur 7',
      'Surveillance permanente',
      'Site protégé et sécurisé',
      'Sauvegardes régulières',
    ],
  },
];

// Ce que couvre la maintenance (liste de la section distinction)
const couvert = [
  'Mises à jour régulières',
  'Site protégé et sécurisé',
  'Sauvegardes régulières',
  'Toujours en ligne',
];
---

<BaseLayout
  title="Maintenance de site internet, Caelestis"
  description="Abonnement de maintenance pour votre site internet : sécurité, sauvegardes et surveillance technique. Dès 7,99 € par mois, sans engagement."
  schema={[schema, breadcrumb]}
  noindex={true}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-14 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[400px] h-[400px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/3 w-56 h-56"></div>

    <div class="max-w-4xl mx-auto relative text-center">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Maintenance mensuelle</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.05] tracking-tight max-w-3xl mx-auto"
        style="font-size: clamp(2.1rem, 5vw, 3.9rem);"
        data-reveal data-delay="1"
      >
        Votre site reste entre<br class="hidden sm:block"> <span class="text-sauge">de bonnes mains.</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed mx-auto" data-reveal data-delay="2">
        La mise en ligne n'est pas une fin. Un site internet n'est jamais figé : les technologies évoluent, des failles de sécurité apparaissent, et sans entretien il se fragilise avec le temps. Chaque semaine, nous veillons à ce que le vôtre reste rapide, sécurisé et toujours en ligne, en coulisses, sans que vous ayez à y penser.
      </p>
    </div>
  </section>

  <!-- ── Maintenance vs Modifications — l'explication, en premier ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20">
    <div class="max-w-4xl mx-auto" data-reveal>

      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">À ne pas confondre</p>
          <span class="block w-8 h-px bg-sauge"></span>
        </div>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Deux choses bien distinctes.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 lg:gap-6 items-stretch">

        <!-- 1. Maintenance -->
        <div class="relative bg-cream rounded-2xl p-7 lg:p-8 border-2 border-sauge/40 flex flex-col text-center">
          <span class="absolute -top-3 right-5 inline-block font-body text-[11px] font-semibold tracking-[0.16em] uppercase px-3 py-1 rounded-full bg-[#5A653A] text-cream shadow-[0_2px_8px_rgba(53,64,36,0.22)]">Obligatoire</span>
          <span class="self-center inline-block font-body text-[11px] tracking-[0.18em] uppercase px-3 py-1 rounded-full bg-sauge/15 text-sauge mb-5">Abonnement, en continu</span>
          <h3 class="font-display text-xl font-light text-brun mb-3">La maintenance</h3>
          <p class="font-body text-sm text-brun-mid leading-relaxed mb-5">
            Le socle technique qui garde votre site en ligne, rapide et protégé. Il tourne tout seul, en fond, sans rien vous demander.
          </p>
          <ul class="flex flex-col gap-2.5 flex-1 mb-5">
            {couvert.map((c) => (
              <li class="feat-std flex items-start justify-center gap-3 font-body text-sm text-brun leading-snug">{c}</li>
            ))}
          </ul>
          <p class="font-body text-sm font-semibold text-sauge">Dès 7,99 € par mois, selon votre site.</p>
        </div>

        <!-- 2. Modifications -->
        <div class="bg-cream rounded-2xl p-7 lg:p-8 border border-cream-dark flex flex-col text-center">
          <span class="self-center inline-block font-body text-[11px] tracking-[0.18em] uppercase px-3 py-1 rounded-full bg-ocre/12 text-ocre-dark mb-5">À la demande, sur devis</span>
          <h3 class="font-display text-xl font-light text-brun mb-3">Les modifications et retouches</h3>
          <p class="font-body text-sm text-brun-mid leading-relaxed mb-5">
            Tout ce qui change le contenu ou ajoute des fonctions : modifier un texte, remplacer une photo, ajouter une page ou une nouvelle fonctionnalité.
          </p>
          <p class="font-body text-sm text-brun-mid leading-relaxed flex-1">
            Un service à part, facturé sur devis. Vous ne payez que ce dont vous avez besoin, quand vous le décidez.
          </p>
          <p class="font-body text-sm font-semibold text-brun mt-5">Sur devis, sans engagement.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- ── L'abonnement maintenance — les cartes, en second ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark relative overflow-hidden">

    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-40 -left-24 w-72 h-72"></div>

    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12" data-reveal>
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="block w-8 h-px bg-sauge"></span>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">L'abonnement maintenance</p>
          <span class="block w-8 h-px bg-sauge"></span>
        </div>
        <h2 class="font-display font-light text-brun leading-[1.1] mb-4" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Un tarif selon votre site.
        </h2>
        <p class="font-body text-base text-brun-mid max-w-xl mx-auto leading-relaxed">
          Un abonnement qui garde votre site en ligne, sécurisé et sauvegardé, sans engagement.
        </p>
      </div>

      <!-- 4 cartes : une par type de site -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6 items-stretch" data-reveal data-delay="1">
        {formules.map((f) => (
          <div class="bg-cream border-2 border-sauge/30 rounded-2xl p-6 lg:p-8 flex flex-col text-center">
            <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">{f.type}</p>
            <div class="mb-5">
              <p class="font-display font-light text-brun leading-none" style="font-size: clamp(2rem, 4vw, 2.6rem); letter-spacing: -0.02em;">
                {f.prix}<span class="text-bois-mid text-lg ml-1">€</span>
              </p>
              <p class="font-body text-xs text-brun-mid/75 mt-2">par mois, sans engagement</p>
            </div>
            <p class="font-body text-sm text-brun-mid mb-6 leading-relaxed">{f.desc}</p>
            <ul class="flex flex-col gap-3 flex-1 mb-7">
              {f.feats.map((feat) => (
                <li class="feat-std flex items-start justify-center gap-3 font-body text-sm text-brun-mid leading-snug">{feat}</li>
              ))}
            </ul>
            <a
              href={f.lien}
              class="inline-flex items-center justify-center font-body font-medium text-sm tracking-[0.04em] transition-all duration-300 min-h-[44px] border border-sauge/70 text-[#5C6A40] px-6 py-3 rounded-full hover:bg-[#5A653A] hover:text-cream hover:border-[#5A653A] btn-magnetic"
            >
              S'abonner
            </a>
          </div>
        ))}
      </div>

      <!-- Rappel modifications -->
      <div class="mt-8 text-center" data-reveal data-delay="2">
        <p class="font-body text-sm text-brun-mid/70 leading-relaxed">
          Pour rappel, modifier le contenu de votre site reste un service à la demande, facturé sur devis.
        </p>
      </div>

    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-10 leading-[1.1]">
        Votre site mérite d'être<br><span class="text-sauge">entre de bonnes mains.</span>
      </h2>
      <Button href="/contact" variant="primary">Prendre contact</Button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Icône check des fonctionnalités */
  .feat-std::before {
    content: '';
    display: block;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='%23889063' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='%23889063' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }
</style>
