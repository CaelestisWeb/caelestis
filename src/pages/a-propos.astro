---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const valeurs = [
  "La nature et l'écologie comme boussole",
  "L'économie locale et les circuits courts",
  "Le travail bien fait, qui dure",
  "L'honnêteté dans la relation client",
];
---
<BaseLayout
  title="À propos — Caelestis"
  description="Je suis Célestin, 22 ans, basé dans la Drôme. J'ai créé Caelestis pour accompagner artisans et PME locales avec des sites web qui leur ressemblent vraiment."
>

  <section class="pt-20 pb-28 px-6 md:px-10 lg:px-20">
    <div class="max-w-6xl mx-auto">

      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-16 md:gap-24 items-start">

        <!-- Colonne gauche : placeholder photo + petites infos -->
        <div data-reveal>
          <!-- Rivière de montagne — évoque la Drôme, la nature, le calme -->
          <div class="aspect-[3/4] overflow-hidden mb-4">
            <img
              src="/images/riviere-montagne.jpg"
              alt="Table au bord d'une rivière turquoise en montagne — paysage de la Drôme"
              class="w-full h-full object-cover"
            />
          </div>
          <p class="font-body text-xs text-brun-mid/50 text-center">Drôme, France</p>

          <!-- Petites stats discrètes -->
          <div class="mt-10 space-y-4">
            <div class="flex justify-between items-baseline border-b border-cream-dark pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-sauge">Âge</span>
              <span class="font-display text-xl font-light text-brun">22 ans</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-cream-dark pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-sauge">Basé à</span>
              <span class="font-display text-xl font-light text-brun">Drôme</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-cream-dark pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-sauge">Spécialité</span>
              <span class="font-display text-xl font-light text-brun">Web & SEO</span>
            </div>
          </div>
        </div>

        <!-- Colonne droite : texte -->
        <div>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6" data-reveal>À propos</p>
          <h1
            class="font-display font-light text-brun leading-[1.05] tracking-tight mb-10"
            style="font-size: clamp(2.6rem, 5vw, 4rem);"
            data-reveal data-delay="1"
          >
            Salut,<br>je suis <em>Célestin.</em>
          </h1>

          <div class="space-y-6 font-body text-base text-brun-mid leading-relaxed" data-reveal data-delay="2">
            <p>
              J'ai 22 ans, je vis dans la Drôme, et la nature fait partie de moi depuis tout petit.
              C'est elle qui m'a appris la patience, l'attention aux choses bien faites,
              et le respect de ce qui prend le temps de pousser.
            </p>
            <p>
              Aujourd'hui, je veux mettre ces mêmes valeurs au service d'artisans et d'entreprises locales.
              Faire des sites qui respirent, qui parlent vrai, qui aident les gens à vivre de leur passion.
            </p>
            <p>
              Je crois qu'on peut faire les choses simplement, sans bullshit, en restant humain.
              C'est pour ça que j'ai créé Caelestis.
            </p>
          </div>

          <!-- Valeurs -->
          <div class="mt-12 pt-10 border-t border-cream-dark" data-reveal data-delay="3">
            <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6">Ce qui me motive</p>
            <div class="space-y-3">
              {valeurs.map((v) => (
                <div class="flex items-start gap-3">
                  <span class="w-1 h-1 rounded-full bg-ocre mt-[0.45rem] flex-shrink-0"></span>
                  <span class="font-body text-sm text-brun-mid">{v}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-10" data-reveal data-delay="3">
            <Button href="/contact" variant="primary">Travaillons ensemble →</Button>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
