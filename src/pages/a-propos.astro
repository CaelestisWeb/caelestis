---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Image } from 'astro:assets';
import imgBureau from '../assets/images/photo-bureau.jpg';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Célestin Fruleux',
  jobTitle: 'Développeur web & consultant SEO',
  description: 'Développeur web freelance et fondateur de Caelestis, agence web basée dans la Drôme. J\'aide artisans, producteurs et indépendants partout en France à avoir une présence en ligne claire, soignée et visible sur Google.',
  url: 'https://caelestis.fr/a-propos',
  email: 'contact@caelestis.fr',
  telephone: '+33769362727',
  image: 'https://caelestis.fr/og-image.jpg',
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Drôme',
    addressCountry: 'FR',
  },
  worksFor: {
    '@type': 'LocalBusiness',
    '@id': 'https://caelestis.fr/#business',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
  },
  knowsAbout: ['Création de site web', 'Développement Astro', 'Référencement naturel', 'SEO local Drôme', 'UX Design', 'Création site internet Crest'],
  sameAs: ['https://share.google/IKYSIPaXxlTN0W5Zz'],
};

const breadcrumbApropos = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'À propos', item: 'https://caelestis.fr/a-propos' },
  ],
};

---
<BaseLayout
  title="Célestin Fruleux, développeur web & SEO · Caelestis"
  description="Célestin Fruleux, développeur web basé dans la Drôme. J'accompagne artisans, producteurs et indépendants partout en France avec des sites soignés et visibles sur Google."
  schema={[personSchema, breadcrumbApropos]}
>

  <section class="pt-20 pb-28 px-6 md:px-10 lg:px-20 overflow-hidden">
    <div class="max-w-6xl mx-auto">

      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-12 md:gap-16 lg:gap-24 items-start">

        <!-- Colonne gauche : placeholder photo + petites infos -->
        <div data-reveal>
          <!-- Portrait au bureau — évoque le travail, la Drôme, le calme -->
          <div class="img-zoom img-editorial aspect-[3/4] mb-4 overflow-hidden max-h-[480px] lg:max-h-none">
            <Image
              src={imgBureau}
              alt="Célestin Fruleux, fondateur de Caelestis, à son bureau — création de site internet dans la Drôme"
              class="w-full h-full object-cover"
              style="object-position: center 20%;"
              data-parallax
              loading="eager"
              fetchpriority="high"
              widths={[480, 768]}
              sizes="(max-width: 1024px) 100vw, 35vw"
              quality={72}
            />
          </div>
          <p class="font-body text-xs text-brun-mid/75 text-center">Célestin · Drôme</p>

          <!-- Petites stats discrètes -->
          <div class="mt-10 space-y-4">
            <div class="flex justify-between items-baseline border-b border-bois-pale/40 pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-bois-mid">Âge</span>
              <span class="font-display text-xl font-light text-brun">22 ans</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-bois-pale/40 pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-bois-mid">Basé à</span>
              <span class="font-display text-xl font-light text-brun">Drôme</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-bois-pale/40 pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-bois-mid">Spécialité</span>
              <span class="font-display text-xl font-light text-brun">Création web</span>
            </div>
            <div class="flex justify-between items-baseline border-b border-bois-pale/40 pb-3">
              <span class="font-body text-xs tracking-widest uppercase text-bois-mid">Réponse</span>
              <span class="font-display text-xl font-light text-brun">Sous 48h</span>
            </div>
          </div>
        </div>

        <!-- Colonne droite : texte -->
        <div>
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6" data-reveal>À propos</p>
          <h1
            class="font-display font-light text-brun leading-[1.05] tracking-tight mb-10"
            style="font-size: clamp(2.6rem, 5vw, 4rem);"
            data-reveal data-delay="1"
          >
            Pourquoi <span class="text-sauge">Caelestis</span> ?
          </h1>

          <div class="space-y-6 font-body text-base text-brun-mid leading-relaxed" data-reveal data-delay="2">
            <p>
              Le nom Caelestis est inspiré de mon prénom Célestin, dont l'origine latine évoque le ciel.
            </p>
            <p>
              Je suis Célestin Fruleux, j'ai 22 ans, et je suis passionné par la nature, le bien-être et l'entrepreneuriat.
            </p>
            <p>
              J'ai commencé par créer des sites internet pour mes propres projets. Puis mes proches m'ont demandé de les aider à leur tour. De fil en aiguille, j'ai conçu plusieurs sites, expérimenté différentes approches et développé mes compétences en conception web, image de marque et présence en ligne.
            </p>
            <p>
              Ces expériences m'ont montré que beaucoup d'artisans, d'indépendants et de petites structures réalisent un travail remarquable. Pourtant, une grande partie d'entre eux restent peu visibles et ne génèrent pas toujours les revenus qu'ils méritent. Non pas par manque de qualité, mais souvent à cause d'une présence en ligne insuffisante ou d'une communication qui ne reflète pas pleinement la valeur de leur savoir-faire.
            </p>
            <p>
              Un bon site internet ne change pas votre activité. Il la valorise. Il la rend visible, crédible et facile à trouver. En bref, il devient un véritable outil de croissance pour une entreprise.
            </p>
            <p>
              C'est donc pour cette raison que j'ai créé Caelestis : aider les artisans, indépendants et entrepreneurs à disposer d'une présence en ligne à la hauteur de leur savoir-faire.
            </p>
            <p class="font-display font-light text-sauge text-lg">
              Caelestis.
            </p>
          </div>

          <div class="mt-12 flex justify-center" data-reveal data-delay="3">
            <Button href="/contact" variant="primary">Réserver un appel</Button>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
