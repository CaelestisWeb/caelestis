---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://caelestis.fr/blog' },
  ],
};

const articles = [
  {
    slug: 'creation-site-internet-artisan',
    titre: 'Pourquoi chaque artisan a besoin d\'un site internet en 2025',
    extrait: 'En 2025, ne pas avoir de site internet, c\'est laisser des clients partir chez vos concurrents. Voici pourquoi un site bien fait change vraiment les choses pour un artisan.',
    date: '2025-05-01',
    dateLabel: 'mai 2025',
    categorie: 'Création de site web',
    lecture: '5 min',
  },
  {
    slug: 'seo-local-drome-artisan',
    titre: 'SEO local dans la Drôme : comment apparaître sur Google quand on est artisan',
    extrait: 'Le référencement local est l\'outil le plus efficace pour attirer des clients dans votre zone géographique. Voici comment le mettre en place concrètement.',
    date: '2025-05-15',
    dateLabel: 'mai 2025',
    categorie: 'Référencement SEO',
    lecture: '6 min',
  },
];
---
<BaseLayout
  title="Blog — Création de site internet & SEO pour artisans · Caelestis"
  description="Conseils pratiques sur la création de site internet et le référencement naturel pour artisans, paysagistes et indépendants. Par Caelestis, agence web dans la Drôme."
  schema={[breadcrumb]}
>

  <section class="pt-20 pb-16 px-6 md:px-10 lg:px-20 section-ambient border-b border-cream-dark">
    <div class="max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Blog · Conseils web & SEO</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.06] tracking-tight mb-6"
        style="font-size: clamp(2.2rem, 4.5vw, 3.5rem);"
        data-reveal data-delay="1"
      >
        Conseils pour mieux<br><span class="text-sauge">exister sur le web.</span>
      </h1>
      <p class="font-body text-base text-brun-mid max-w-xl leading-relaxed" data-reveal data-delay="2">
        Des articles pratiques sur la création de site internet et le référencement naturel, écrits pour les artisans, indépendants et professionnels de terrain.
      </p>
    </div>
  </section>

  <section class="py-16 px-6 md:px-10 lg:px-20">
    <div class="max-w-4xl mx-auto">
      <div class="space-y-8">
        {articles.map(({ slug, titre, extrait, dateLabel, categorie, lecture }) => (
          <article class="border-t border-cream-dark pt-8 group" data-reveal>
            <a href={`/blog/${slug}`} class="block">
              <div class="flex flex-wrap items-center gap-4 mb-3">
                <span class="font-body text-xs tracking-[0.18em] uppercase text-sauge">{categorie}</span>
                <span class="text-brun-mid/30 text-xs">·</span>
                <span class="font-body text-xs text-brun-mid/50">{dateLabel}</span>
                <span class="text-brun-mid/30 text-xs">·</span>
                <span class="font-body text-xs text-brun-mid/50">{lecture} de lecture</span>
              </div>
              <h2 class="font-display text-xl md:text-2xl font-light text-brun group-hover:text-ocre transition-colors duration-300 mb-3 leading-[1.2]">
                {titre}
              </h2>
              <p class="font-body text-sm text-brun-mid leading-relaxed max-w-2xl mb-4">{extrait}</p>
              <span class="font-body text-sm text-sauge group-hover:underline underline-offset-4">Lire l'article →</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
