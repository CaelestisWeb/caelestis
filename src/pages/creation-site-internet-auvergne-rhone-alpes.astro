---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const canonical = 'https://caelestis.fr/creation-site-internet-auvergne-rhone-alpes';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Création de site internet en Auvergne-Rhône-Alpes',
  serviceType: 'Création de site internet et référencement naturel',
  description: "Création de sites internet sur mesure et référencement naturel pour les producteurs, artisans, créateurs et associations d'Auvergne-Rhône-Alpes. Agence web indépendante basée dans la Drôme.",
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://caelestis.fr/#business',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    address: { '@type': 'PostalAddress', addressLocality: 'Crest', addressRegion: 'Drôme', postalCode: '26400', addressCountry: 'FR' },
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' },
    { '@type': 'AdministrativeArea', name: 'Drôme' },
    { '@type': 'AdministrativeArea', name: 'Ardèche' },
    { '@type': 'AdministrativeArea', name: 'Isère' },
    { '@type': 'AdministrativeArea', name: 'Rhône' },
    { '@type': 'AdministrativeArea', name: 'Loire' },
    { '@type': 'AdministrativeArea', name: 'Puy-de-Dôme' },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Création de site internet en Auvergne-Rhône-Alpes', item: canonical },
  ],
};

// Départements de la région (mention naturelle, pas de pages dédiées)
const departements = [
  'Drôme', 'Ardèche', 'Isère', 'Rhône', 'Loire', 'Savoie',
  'Haute-Savoie', 'Ain', 'Puy-de-Dôme', 'Cantal', 'Haute-Loire', 'Allier',
];
---

<BaseLayout
  title="Création de site internet en Auvergne-Rhône-Alpes, Caelestis"
  description="Agence web au service de l'Auvergne-Rhône-Alpes : création de site internet et référencement pour producteurs, artisans et créateurs. Basés dans la Drôme."
  canonical={canonical}
  schema={[schema, breadcrumb]}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-16 md:pt-24 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-24 w-[420px] h-[420px]"></div>

    <div class="max-w-4xl mx-auto relative text-center">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Auvergne-Rhône-Alpes</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.08] tracking-tight max-w-3xl mx-auto"
        style="font-size: clamp(2rem, 5vw, 3.8rem);"
        data-reveal data-delay="1"
      >
        Création de site internet<br class="hidden sm:block"> en <span class="text-sauge">Auvergne-Rhône-Alpes</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed mx-auto" data-reveal data-delay="2">
        Basés dans la Drôme, nous créons des sites soignés et bien référencés pour les producteurs, artisans, créateurs et associations engagées de toute la région. Du Vercors aux volcans d'Auvergne, votre savoir-faire mérite d'être trouvé.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4" data-reveal data-delay="2">
        <Button href="/contact#devis" variant="primary">Demander un devis</Button>
        <Button href="/simulateur" variant="outline">Estimer mon projet</Button>
      </div>
    </div>
  </section>

  <!-- ── Une région que nous connaissons ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-10">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Votre territoire</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Une agence web qui connaît votre région.
        </h2>
      </div>
      <div class="max-w-2xl mx-auto space-y-4 text-center">
        <p class="font-body text-base text-brun-mid leading-relaxed">
          L'Auvergne-Rhône-Alpes, c'est douze départements de terroirs, de montagnes et de savoir-faire : la Drôme et l'Ardèche aux accents provençaux, l'Isère et les deux Savoie alpines, le Rhône et la Loire, le Puy-de-Dôme et le Cantal volcaniques, sans oublier l'Ain, la Haute-Loire et l'Allier.
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed">
          Que vous soyez à Valence, Lyon, Grenoble, Annecy, Chambéry, Clermont-Ferrand, Saint-Étienne ou dans un village du Diois, nous construisons votre site avec la même attention et la même connaissance du terrain local.
        </p>
      </div>

      <!-- Bande départements -->
      <div class="mt-12 grid grid-cols-3 justify-items-center gap-2.5 sm:flex sm:flex-wrap sm:justify-center max-w-xl mx-auto" data-reveal data-delay="1">
        {departements.map((d) => (
          <span class="font-body text-xs tracking-[0.08em] text-brun-mid border border-cream-dark rounded-full px-3.5 py-1.5">{d}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Pour qui ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Pour qui</p>
        <h2 class="font-display font-light leading-[1.2]" style="font-size: clamp(1.6rem, 2.8vw, 2.3rem); color: rgba(237,227,212,0.92);">
          Les métiers de passion de la région.
        </h2>
      </div>
      <p class="font-body text-base leading-relaxed text-center max-w-2xl mx-auto" style="color: rgba(237,227,212,0.80)" data-reveal data-delay="1">
        Nous travaillons surtout avec les acteurs de la nature et du terroir : paysagistes, maraîchers, fromagers, apiculteurs, vignerons, éco-constructeurs, gîtes de charme, naturopathes, associations environnementales et producteurs locaux. Des métiers de passion, souvent peu visibles en ligne, qui méritent un site à la hauteur de leur savoir-faire.
      </p>
    </div>
  </section>

  <!-- ── La distance n'est pas un frein ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-10">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Comment ça marche</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          La distance n'est pas un frein.
        </h2>
      </div>
      <div class="max-w-2xl mx-auto space-y-4 text-center">
        <p class="font-body text-base text-brun-mid leading-relaxed">
          Pas besoin d'être dans le même village pour bien travailler ensemble. Tout se fait simplement, à distance : un premier échange en visio ou par téléphone, des points réguliers, et un site livré sans que vous ayez à vous déplacer.
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed">
          Et si vous êtes proches de la Drôme, on peut bien sûr se rencontrer. Où que vous soyez dans la région, vous gardez un interlocuteur unique, disponible avant comme après la mise en ligne.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Être trouvé près de chez vous ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-10">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Référencement local</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Être trouvé près de chez vous.
        </h2>
      </div>
      <p class="font-body text-base text-brun-mid leading-relaxed text-center max-w-2xl mx-auto" data-reveal data-delay="1">
        Un beau site ne sert à rien si personne ne le trouve. Nous optimisons chaque site pour le référencement naturel et local : structure technique saine, contenus pensés pour vos mots-clés, et signaux géographiques qui aident vos clients de la région à tomber sur vous quand ils cherchent votre métier sur Google.
      </p>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-6 leading-[1.1]">
        Prêt à donner vie à<br><span class="text-sauge">votre projet&nbsp;?</span>
      </h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
        <Button href="/contact#devis" variant="primary">Demander un devis</Button>
        <Button href="/simulateur" variant="outline">Estimer mon projet</Button>
      </div>
    </div>
  </section>

</BaseLayout>
