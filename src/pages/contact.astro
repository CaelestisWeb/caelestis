---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import imgBureau from '../assets/images/bureau-jardin.jpg';

const breadcrumbContact = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://caelestis.fr/contact' },
  ],
};
---
<BaseLayout
  title="Devis création site internet Drôme — Contacter Caelestis"
  description="Demandez votre devis gratuit pour la création de votre site internet. Réponse sous 48h. Caelestis, agence web spécialisée artisans et indépendants, Crest — Drôme."
  schema={breadcrumbContact}
>

  <!-- ─── INTRO ÉDITORIALE ─── -->
  <section class="pt-24 pb-14 px-6 md:px-10 lg:px-20 border-b border-cream-dark">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 lg:gap-8">

      <div>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-5" data-reveal>Contact</p>
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-[-0.02em]"
          style="font-size: clamp(2.4rem, 6vw, 5.5rem);"
          data-reveal data-delay="1"
        >
          Faites rayonner<br>ce que vous créez.
        </h1>
      </div>

      <div class="lg:text-right" data-reveal data-delay="2">
        <p class="font-body text-base text-brun-mid leading-relaxed mb-3">
          Parlez-moi de votre activité en quelques lignes.<br>Je reviens vers vous sous 48h.
        </p>
        <span class="inline-flex items-center gap-2 font-body text-xs tracking-widest uppercase text-sauge border border-sauge/30 px-4 py-2">
          <span class="w-1.5 h-1.5 rounded-full bg-sauge animate-pulse"></span>
          Disponible
        </span>
      </div>

    </div>
  </section>


  <!-- ─── CONTENU ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_1.45fr] gap-16 items-start">

      <!-- ── Colonne gauche ── -->
      <div>

        <!-- Image — hauteur limitée sur mobile pour éviter une photo qui prend toute la page -->
        <div class="img-zoom img-editorial aspect-[3/4] overflow-hidden mb-8 lg:mb-12 max-h-[400px] lg:max-h-none" data-reveal>
          <Image
            src={imgBureau}
            alt="Bureau en bois sous une pergola dans un jardin verdoyant"
            class="w-full h-full object-cover"
            data-parallax
            loading="lazy"
            widths={[480, 768]}
            sizes="(max-width: 1024px) 100vw, 35vw"
          />
        </div>

        <!-- Infos contact -->
        <div data-reveal data-delay="1">
          <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6">Me joindre</p>
          <div class="space-y-0">
            {[
              { label: 'Email',        value: 'contact@caelestis.fr', href: 'mailto:contact@caelestis.fr' },
              { label: 'Téléphone',    value: '07 69 36 27 27',            href: 'tel:+33769362727'                },
              { label: 'Localisation', value: 'Drôme, France',             href: null                              },
              { label: 'Horaires',     value: 'Lun–Sam · 9h–17h',         href: null                              },
            ].map(({ label, value, href }) => (
              <div class="flex items-baseline justify-between gap-4 border-b border-cream-dark py-4">
                <span class="font-body text-xs tracking-widest uppercase text-sauge flex-shrink-0">{label}</span>
                {href
                  ? <a href={href} class="font-display text-base font-light text-brun hover:text-ocre transition-colors text-right">{value}</a>
                  : <span class="font-display text-base font-light text-brun text-right">{value}</span>
                }
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- ── Colonne droite : sélecteur + formulaires ── -->
      <div data-reveal data-delay="1">

        <!-- Sélecteur -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8" role="tablist" aria-label="Type de contact">
          {[
            { id: 'message', label: 'Rédiger un message', icon: '✉' },
            { id: 'appel',   label: 'Réserver un appel',  icon: '☎' },
            { id: 'devis',   label: 'Obtenir un devis',   icon: '◈'  },
          ].map(({ id, label, icon }) => (
            <button
              type="button"
              id={`tab-${id}`}
              data-tab={id}
              role="tab"
              aria-selected={id === 'message' ? 'true' : 'false'}
              aria-controls={`panel-${id}`}
              class={`tab-btn flex-1 flex items-center gap-2.5 px-4 py-3.5 border font-body text-sm transition-all duration-200 text-left ${id === 'message' ? 'border-sauge bg-sauge text-cream' : 'border-cream-dark text-brun-mid hover:border-sauge/40'}`}
            >
              <span class="text-base leading-none" aria-hidden="true">{icon}</span>
              <span>{label}</span>
            </button>
          ))}
        </div>

        <!-- Wrapper commun -->
        <div class="bg-cream-dark p-5 sm:p-8 md:p-10">

          <!-- ══ FORMULAIRE 1 — Message ══ -->
          <div id="panel-message" role="tabpanel" aria-labelledby="tab-message" class="tab-panel">
            <div class="mb-7 pb-7 border-b border-cream flex items-end justify-between gap-6">
              <div>
                <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-1.5">Message</p>
                <p class="font-display text-2xl font-light text-brun">Une question, une idée,<br>un premier contact.</p>
              </div>
              <div id="plant-message" aria-hidden="true" class="flex-shrink-0" style="width:50px;height:78px">
                <svg viewBox="0 0 80 130" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full overflow-visible">
                  <ellipse cx="40" cy="125" rx="18" ry="4.5" fill="rgba(78,100,64,0.12)"/>
                  <rect id="msg-stem" x="38" y="18" width="4" height="103" rx="2" fill="rgba(78,100,64,0.45)"/>
                  <ellipse id="msg-leaf-l" cx="26" cy="89" rx="16" ry="7" fill="rgba(78,100,64,0.28)" transform="rotate(-35 26 89)"/>
                  <ellipse id="msg-leaf-r" cx="54" cy="66" rx="16" ry="7" fill="rgba(78,100,64,0.22)" transform="rotate(35 54 66)"/>
                  <g id="msg-flower">
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(0   40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(72  40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(144 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(216 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(288 40 18)"/>
                    <circle cx="40" cy="18" r="5" fill="rgba(168,92,44,0.55)"/>
                  </g>
                </svg>
              </div>
            </div>

            <div id="success-message" role="status" aria-live="polite" class="hidden text-center py-12">
              <div class="w-12 h-12 rounded-full bg-sauge/15 flex items-center justify-center mx-auto mb-5">
                <svg class="w-6 h-6 text-sauge" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
              <p class="font-display text-xl font-light text-brun">Message envoyé !</p>
              <p class="font-body text-sm text-brun-mid mt-2">Je vous réponds sous 48h.</p>
            </div>

            <form id="form-message" class="space-y-5" novalidate>
              <input type="hidden" name="formType" value="message" />
              <!-- Honeypot anti-bot : doit rester vide, caché des utilisateurs réels -->
              <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;width:1px;height:1px;" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="msg-prenom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Prénom <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                  <input type="text" id="msg-prenom" name="prenom" autocomplete="given-name" placeholder="Votre prénom" aria-required="true"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
                <div>
                  <label for="msg-nom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Nom</label>
                  <input type="text" id="msg-nom" name="nom" autocomplete="family-name" placeholder="Votre nom"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
              </div>

              <div>
                <label for="msg-email" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Email <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <input type="email" id="msg-email" name="email" autocomplete="email" placeholder="votre@email.com" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
              </div>

              <div>
                <label for="msg-sujet" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Sujet</label>
                <input type="text" id="msg-sujet" name="sujet" placeholder="En quelques mots…"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
              </div>

              <div>
                <label for="msg-message" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Message <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <textarea id="msg-message" name="projet" rows="5" placeholder="Votre message…" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200 resize-none"></textarea>
              </div>

              <p id="error-message" role="alert" aria-live="assertive" class="hidden font-body text-xs text-ocre-dark text-center bg-ocre/8 px-4 py-3"></p>

              <p class="font-display text-sm font-light text-brun-mid/70 text-center border-t border-cream pt-5">
                Il n'y a pas de mauvaise question ! Nous aurons le plaisir de vous répondre :)
              </p>

              <button type="submit" class="submit-btn w-full bg-brun text-cream font-body font-medium text-sm py-4 rounded-full hover:bg-ocre transition-colors duration-200 cursor-pointer disabled:opacity-50">
                <span class="submit-label">Envoyer le message →</span>
              </button>

              <p class="font-body text-xs text-brun-mid/50 text-center">Réponse sous 48h</p>
              <!-- Notice RGPD art. 13 — obligatoire avant collecte -->
              <p class="font-body text-[11px] text-brun-mid/40 text-center leading-relaxed">
                Vos données sont traitées par <strong class="text-brun-mid/55">Caelestis</strong> (Célestin Fruleux) uniquement pour répondre à votre demande. Aucune revente. Durée : 3 ans.
                <a href="/politique-confidentialite" class="underline underline-offset-2 hover:text-brun-mid transition-colors">Politique de confidentialité →</a>
              </p>
            </form>
          </div>

          <!-- ══ FORMULAIRE 2 — Appel ══ -->
          <div id="panel-appel" role="tabpanel" aria-labelledby="tab-appel" class="tab-panel hidden">
            <div class="mb-7 pb-7 border-b border-cream flex items-end justify-between gap-6">
              <div>
                <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-1.5">Appel</p>
                <p class="font-display text-2xl font-light text-brun">Parlons-en<br>directement.</p>
              </div>
              <div id="plant-appel" aria-hidden="true" class="flex-shrink-0" style="width:50px;height:78px">
                <svg viewBox="0 0 80 130" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full overflow-visible">
                  <ellipse cx="40" cy="125" rx="18" ry="4.5" fill="rgba(78,100,64,0.12)"/>
                  <rect id="appel-stem" x="38" y="18" width="4" height="103" rx="2" fill="rgba(78,100,64,0.45)"/>
                  <ellipse id="appel-leaf-l" cx="26" cy="89" rx="16" ry="7" fill="rgba(78,100,64,0.28)" transform="rotate(-35 26 89)"/>
                  <ellipse id="appel-leaf-r" cx="54" cy="66" rx="16" ry="7" fill="rgba(78,100,64,0.22)" transform="rotate(35 54 66)"/>
                  <g id="appel-flower">
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(0   40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(72  40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(144 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(216 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(288 40 18)"/>
                    <circle cx="40" cy="18" r="5" fill="rgba(168,92,44,0.55)"/>
                  </g>
                </svg>
              </div>
            </div>

            <div id="success-appel" role="status" aria-live="polite" class="hidden text-center py-12">
              <div class="w-12 h-12 rounded-full bg-sauge/15 flex items-center justify-center mx-auto mb-5">
                <svg class="w-6 h-6 text-sauge" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
              <p class="font-display text-xl font-light text-brun">Demande reçue !</p>
              <p class="font-body text-sm text-brun-mid mt-2">Je vous confirme le créneau sous 48h.</p>
            </div>

            <form id="form-appel" class="space-y-5" novalidate>
              <input type="hidden" name="formType" value="appel" />
              <!-- Honeypot anti-bot -->
              <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;width:1px;height:1px;" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="appel-prenom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Prénom <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                  <input type="text" id="appel-prenom" name="prenom" autocomplete="given-name" placeholder="Votre prénom" aria-required="true"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
                <div>
                  <label for="appel-tel" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Téléphone <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                  <input type="tel" id="appel-tel" name="telephone" autocomplete="tel" placeholder="06 00 00 00 00" aria-required="true"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
              </div>

              <div>
                <label for="appel-email" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Email <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <input type="email" id="appel-email" name="email" autocomplete="email" placeholder="votre@email.com" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
              </div>

              <!-- Créneau horaire — fieldset pour grouper les radios WCAG 1.3.1 -->
              <fieldset>
                <legend class="font-body text-xs tracking-widest uppercase text-brun-mid mb-3">Moment préféré <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></legend>
                <div class="flex flex-col xs:flex-row gap-2 sm:gap-3">
                  {['Matin (9h–12h)', 'Après-midi (14h–18h)', 'Indifférent'].map((slot) => (
                    <label class="slot-label flex-1 flex items-center justify-center text-center px-3 py-2.5 border border-cream-dark bg-cream font-body text-xs text-brun-mid cursor-pointer transition-all duration-200 hover:border-sauge/50 has-[:checked]:border-ocre has-[:checked]:bg-ocre/6 has-[:checked]:text-brun min-h-[44px]">
                      <input type="radio" name="creneau" value={slot} class="sr-only" />
                      {slot}
                    </label>
                  ))}
                </div>
              </fieldset>

              <!-- Jours disponibles — fieldset pour les checkboxes WCAG 1.3.1 -->
              <fieldset>
                <legend class="font-body text-xs tracking-widest uppercase text-brun-mid mb-3">Jours disponibles</legend>
                <div class="flex gap-2 flex-wrap">
                  {['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'].map((jour) => (
                    <label class="flex items-center justify-center w-12 h-10 border border-cream-dark bg-cream font-body text-xs text-brun-mid cursor-pointer transition-all duration-200 hover:border-sauge/50 has-[:checked]:border-ocre has-[:checked]:bg-ocre/6 has-[:checked]:text-brun">
                      <input type="checkbox" name="jours" value={jour} class="sr-only" />
                      {jour}
                    </label>
                  ))}
                </div>
              </fieldset>

              <div>
                <label for="appel-sujet" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Sujet de l'appel <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <textarea id="appel-sujet" name="projet" rows="3" placeholder="En quelques mots, ce que vous souhaitez aborder…" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200 resize-none"></textarea>
              </div>

              <p id="error-appel" role="alert" aria-live="assertive" class="hidden font-body text-xs text-ocre-dark text-center bg-ocre/8 px-4 py-3"></p>

              <p class="font-display text-sm font-light text-brun-mid/70 text-center border-t border-cream pt-5">
                10 minutes suffisent pour faire connaissance et poser les bases d'une future collaboration.
              </p>

              <button type="submit" class="submit-btn w-full bg-brun text-cream font-body font-medium text-sm py-4 rounded-full hover:bg-ocre transition-colors duration-200 cursor-pointer disabled:opacity-50">
                <span class="submit-label">Réserver mon créneau →</span>
              </button>

              <p class="font-body text-xs text-brun-mid/50 text-center">Appel de 10 à 20 min · Gratuit</p>
              <!-- Notice RGPD art. 13 — obligatoire avant collecte -->
              <p class="font-body text-[11px] text-brun-mid/40 text-center leading-relaxed">
                Vos données sont traitées par <strong class="text-brun-mid/55">Caelestis</strong> (Célestin Fruleux) uniquement pour répondre à votre demande. Aucune revente. Durée : 3 ans.
                <a href="/politique-confidentialite" class="underline underline-offset-2 hover:text-brun-mid transition-colors">Politique de confidentialité →</a>
              </p>
            </form>
          </div>

          <!-- ══ FORMULAIRE 3 — Devis ══ -->
          <div id="panel-devis" role="tabpanel" aria-labelledby="tab-devis" class="tab-panel hidden">
            <div class="mb-7 pb-7 border-b border-cream flex items-end justify-between gap-6">
              <div>
                <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-1.5">Devis</p>
                <p class="font-display text-2xl font-light text-brun">Votre projet,<br>chiffré sous 48h.</p>
              </div>
              <!-- Plante germinale -->
              <div id="form-plant" aria-hidden="true" class="flex-shrink-0" style="width:50px;height:78px">
                <svg viewBox="0 0 80 130" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full overflow-visible">
                  <ellipse cx="40" cy="125" rx="18" ry="4.5" fill="rgba(78,100,64,0.12)"/>
                  <rect id="fp-stem" x="38" y="18" width="4" height="103" rx="2" fill="rgba(78,100,64,0.45)"/>
                  <ellipse id="fp-leaf-l" cx="26" cy="89" rx="16" ry="7" fill="rgba(78,100,64,0.28)" transform="rotate(-35 26 89)"/>
                  <ellipse id="fp-leaf-r" cx="54" cy="66" rx="16" ry="7" fill="rgba(78,100,64,0.22)" transform="rotate(35 54 66)"/>
                  <g id="fp-flower">
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(0   40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(72  40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(144 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(216 40 18)"/>
                    <ellipse cx="40" cy="11" rx="5" ry="7.5" fill="rgba(168,92,44,0.28)" transform="rotate(288 40 18)"/>
                    <circle cx="40" cy="18" r="5" fill="rgba(168,92,44,0.55)"/>
                  </g>
                </svg>
              </div>
            </div>

            <div id="success-devis" role="status" aria-live="polite" class="hidden text-center py-12">
              <div class="w-12 h-12 rounded-full bg-sauge/15 flex items-center justify-center mx-auto mb-5">
                <svg class="w-6 h-6 text-sauge" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
              <p class="font-display text-xl font-light text-brun">Demande envoyée !</p>
              <p class="font-body text-sm text-brun-mid mt-2">Votre devis vous parvient sous 48h.</p>
            </div>

            <form id="form-devis" class="space-y-5" novalidate>
              <input type="hidden" name="formType" value="devis" />
              <!-- Honeypot anti-bot -->
              <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none;width:1px;height:1px;" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="devis-prenom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Prénom <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                  <input type="text" id="devis-prenom" name="prenom" autocomplete="given-name" placeholder="Votre prénom" aria-required="true"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
                <div>
                  <label for="devis-societe" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Entreprise</label>
                  <input type="text" id="devis-societe" name="societe" autocomplete="organization" placeholder="Ferme des Collines…"
                    class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
                </div>
              </div>

              <div>
                <label for="devis-email" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Email <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <input type="email" id="devis-email" name="email" autocomplete="email" placeholder="votre@email.com" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200" />
              </div>

              <!-- Type de projet — fieldset WCAG 1.3.1 -->
              <fieldset>
                <legend class="font-body text-xs tracking-widest uppercase text-brun-mid mb-3">Type de projet <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></legend>
                <div class="grid grid-cols-2 gap-2">
                  {[
                    { value: 'vitrine',  label: 'Site vitrine'      },
                    { value: 'boutique', label: 'Boutique en ligne' },
                    { value: 'refonte',  label: 'Refonte de site'   },
                    { value: 'autre',    label: 'Autre'             },
                  ].map(({ value, label }) => (
                    <label class="flex items-center gap-2.5 px-3 py-2.5 border border-cream-dark bg-cream font-body text-xs text-brun-mid cursor-pointer transition-all duration-200 hover:border-sauge/50 has-[:checked]:border-ocre has-[:checked]:bg-ocre/6 has-[:checked]:text-brun min-h-[44px]">
                      <input type="radio" name="typeProjet" value={value} class="sr-only" />
                      <span class="w-3.5 h-3.5 rounded-full border border-current flex-shrink-0 flex items-center justify-center" aria-hidden="true">
                        <span class="radio-dot w-1.5 h-1.5 rounded-full bg-ocre opacity-0 transition-opacity duration-150"></span>
                      </span>
                      {label}
                    </label>
                  ))}
                </div>
              </fieldset>

              <!-- Délai — fieldset WCAG 1.3.1 -->
              <fieldset>
                <legend class="font-body text-xs tracking-widest uppercase text-brun-mid mb-3">Délai souhaité</legend>
                <div class="flex gap-2 flex-wrap">
                  {['Le plus vite possible', '1 à 3 mois', '3 à 6 mois', 'Pas de contrainte'].map((d) => (
                    <label class="px-3 py-2 border border-cream-dark bg-cream font-body text-xs text-brun-mid cursor-pointer transition-all duration-200 hover:border-sauge/50 has-[:checked]:border-ocre has-[:checked]:bg-ocre/6 has-[:checked]:text-brun">
                      <input type="radio" name="delai" value={d} class="sr-only" />
                      {d}
                    </label>
                  ))}
                </div>
              </fieldset>

              <div>
                <label for="devis-projet" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">Votre projet <span class="text-ocre" aria-hidden="true">*</span><span class="sr-only">(requis)</span></label>
                <textarea id="devis-projet" name="projet" rows="4" placeholder="Votre activité, vos objectifs, ce que vous souhaitez accomplir…" aria-required="true"
                  class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200 resize-none"></textarea>
              </div>

              <p id="error-devis" role="alert" aria-live="assertive" class="hidden font-body text-xs text-ocre-dark text-center bg-ocre/8 px-4 py-3"></p>

              <p class="font-display text-sm font-light text-brun-mid/70 text-center border-t border-cream pt-5">
                Chaque devis est proposé dans une fourchette indicative, puis précisé et ajusté après discussion afin de correspondre parfaitement à votre projet.
              </p>

              <button type="submit" class="submit-btn w-full bg-brun text-cream font-body font-medium text-sm py-4 rounded-full hover:bg-ocre transition-colors duration-200 cursor-pointer disabled:opacity-50">
                <span class="submit-label">Demander mon devis →</span>
              </button>

              <p class="font-body text-xs text-brun-mid/50 text-center">Devis gratuit sous 48h · Aucune revente de données</p>
              <!-- Notice RGPD art. 13 — obligatoire avant collecte -->
              <p class="font-body text-[11px] text-brun-mid/40 text-center leading-relaxed">
                Vos données sont traitées par <strong class="text-brun-mid/55">Caelestis</strong> (Célestin Fruleux) uniquement pour répondre à votre demande. Aucune revente. Durée : 3 ans.
                <a href="/politique-confidentialite" class="underline underline-offset-2 hover:text-brun-mid transition-colors">Politique de confidentialité →</a>
              </p>
            </form>
          </div>

        </div>
      </div>

    </div>
  </section>


  <!-- ─── BANDEAU CONFIANCE ─── -->
  <section class="border-t border-cream-dark py-12 px-6 md:px-10 lg:px-20" data-reveal>
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
      {[
        { num: '48h',    label: 'Pour vous répondre'   },
        { num: '100%',   label: 'Suivi personnalisé'   },
        { num: '0',      label: 'Frais cachés'         },
        { num: '2%',     label: 'Reversés à une asso.' },
      ].map(({ num, label }) => (
        <div class="text-center">
          <p class="font-display text-2xl sm:text-3xl font-light text-ocre mb-1">{num}</p>
          <p class="font-body text-xs tracking-widest uppercase text-brun-mid">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── POPUP REMERCIEMENT ─── -->
  <div
    id="thanks-popup"
    role="dialog"
    aria-modal="true"
    aria-labelledby="thanks-title"
    class="fixed inset-0 z-[99999] items-center justify-center px-6"
    style="display:none"
  >
    <div id="thanks-backdrop" class="absolute inset-0 bg-encre/60 backdrop-blur-sm"></div>
    <div
      id="thanks-card"
      class="relative bg-cream rounded-sm shadow-2xl max-w-md w-full px-10 py-12 text-center"
      style="box-shadow: 0 32px 80px rgba(14,32,24,0.35)"
    >
      <button id="thanks-close" aria-label="Fermer"
        class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center text-brun-mid/40 hover:text-brun transition-colors duration-200 cursor-pointer">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="w-14 h-14 rounded-full bg-sauge/12 flex items-center justify-center mx-auto mb-7">
        <svg class="w-7 h-7 text-sauge" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
      </div>
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Reçu 5 sur 5</p>
      <h2 id="thanks-title" class="font-display text-3xl font-light text-brun mb-4 tracking-[-0.02em]">Envoyé !</h2>
      <p id="thanks-body" class="font-body text-sm text-brun-mid leading-relaxed mb-8">Je vous réponds sous 48h.</p>
      <div class="w-full h-px bg-cream-dark overflow-hidden rounded-full mb-6">
        <div id="thanks-progress" class="h-full bg-sauge/50 rounded-full" style="width:100%"></div>
      </div>
      <button id="thanks-cta" class="font-body text-sm font-medium text-brun-mid/60 hover:text-brun transition-colors duration-200 cursor-pointer">Fermer</button>
    </div>
  </div>

</BaseLayout>

<style is:global>
  /* Radio dot visible quand coché */
  label:has(input[type="radio"]:checked) .radio-dot { opacity: 1; }

  /* ── Champ invalide — bordure rouge ── */
  input.field-error,
  textarea.field-error {
    border-color: #b94a2c !important;
    background-color: rgba(185, 74, 44, 0.04) !important;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  fieldset.field-error {
    border: 1px solid #b94a2c;
    border-radius: 4px;
    padding: 6px 8px 8px;
    background-color: rgba(185, 74, 44, 0.03);
    transition: border-color 0.2s ease;
  }
</style>

<script>
  import gsap from 'gsap';

  /* ══════════════════════════════════════════
     ONGLETS
  ══════════════════════════════════════════ */
  const tabBtns   = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  function activateTab(id: string) {
    tabBtns.forEach(btn => {
      const active = btn.dataset.tab === id;
      btn.classList.toggle('border-sauge',      active);
      btn.classList.toggle('bg-sauge',          active);
      btn.classList.toggle('text-cream',        active);
      btn.classList.toggle('border-cream-dark', !active);
      btn.classList.toggle('text-brun-mid',     !active);
      /* WCAG 4.1.2 — mise à jour de aria-selected */
      btn.setAttribute('aria-selected', String(active));
    });
    tabPanels.forEach(panel => {
      panel.classList.toggle('hidden', panel.id !== `panel-${id}`);
    });
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => activateTab(btn.dataset.tab ?? 'message'));
  });

  /* ══════════════════════════════════════════
     ENVOI GÉNÉRIQUE
  ══════════════════════════════════════════ */
  function bindForm(formId: string, errorId: string, successId: string, popupMsg: string) {
    const form      = document.getElementById(formId)   as HTMLFormElement   | null;
    const errorEl   = document.getElementById(errorId)  as HTMLElement       | null;
    const successEl = document.getElementById(successId) as HTMLElement      | null;
    if (!form) return;

    const submitBtn = form.querySelector<HTMLButtonElement>('.submit-btn');
    const submitLbl = form.querySelector<HTMLElement>('.submit-label');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !submitLbl) return;

      /* ── Marque un champ invalide en rouge et efface dès la prochaine saisie ── */
      function markInvalid(name: string) {
        const el = form!.querySelector(`[name="${name}"]`) as HTMLElement | null;
        if (!el) return;
        const target = el.closest('fieldset') ?? el;
        target.classList.add('field-error');
        const clear = () => target.classList.remove('field-error');
        el.addEventListener('input',  clear, { once: true });
        el.addEventListener('change', clear, { once: true });
      }

      /* Validation côté client */
      const prenom  = (form.querySelector('[name="prenom"]')    as HTMLInputElement)?.value.trim();
      const email   = (form.querySelector('[name="email"]')     as HTMLInputElement)?.value.trim();
      const projet  = (form.querySelector('[name="projet"]')    as HTMLTextAreaElement)?.value.trim();
      const societe = (form.querySelector('[name="societe"]')   as HTMLInputElement)?.value.trim() ?? '';
      const tel     = (form.querySelector('[name="telephone"]') as HTMLInputElement)?.value.trim() ?? '';
      const creneau = (form.querySelector('[name="creneau"]:checked') as HTMLInputElement | null)?.value ?? '';

      const emailRegex = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$/;

      if (!prenom)                      { markInvalid('prenom');    showErr('Veuillez indiquer votre prénom.');        return; }
      if (prenom.length > 100)          {                           showErr('Prénom trop long (100 caractères max).'); return; }
      if (form.querySelector('[name="telephone"]') && !tel)
                                        { markInvalid('telephone'); showErr('Veuillez indiquer votre téléphone.');     return; }
      if (!email)                       { markInvalid('email');     showErr('Veuillez indiquer votre adresse email.'); return; }
      if (!emailRegex.test(email) || /[,;\r\n]/.test(email))
                                        { markInvalid('email');     showErr('Adresse email invalide.');                return; }
      if (email.length > 254)           {                           showErr('Email trop long.');                       return; }
      if (form.querySelector('[name="creneau"]') && !creneau)
                                        { markInvalid('creneau');   showErr('Veuillez choisir un moment préféré.');    return; }
      if (societe.length > 200)         {                           showErr('Nom d\'entreprise trop long.');           return; }
      if (projet && projet.length > 5000) {                         showErr('Message trop long (5000 caractères max).'); return; }

      /* Mémorise le label d'origine AVANT de l'écraser */
      const originalLabel = submitLbl.textContent ?? '→';

      submitBtn.disabled    = true;
      submitLbl.textContent = 'Envoi en cours…';
      hideErr();

      try {
        const res  = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
        const json = await res.json() as { success?: boolean; error?: string };

        if (res.ok && json.success) {
          form.classList.add('hidden');
          successEl?.classList.remove('hidden');
          /* Met à jour previousFocus vers l'onglet actif AVANT que le formulaire soit masqué,
             car le submitBtn sera display:none et ne pourra pas recevoir le focus au retour */
          const activeTab = document.querySelector<HTMLButtonElement>('[role="tab"][aria-selected="true"]');
          if (activeTab) previousFocus = activeTab;
          showPopup(prenom, popupMsg);
        } else {
          showErr(json.error ?? 'Une erreur est survenue. Veuillez réessayer.');
          submitBtn.disabled    = false;
          submitLbl.textContent = originalLabel;
        }
      } catch (err) {
        console.error('[contact] Erreur réseau :', err);
        showErr('Erreur réseau. Vérifiez votre connexion.');
        submitBtn.disabled    = false;
        submitLbl.textContent = originalLabel;
      }

      function showErr(msg: string) { if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); } }
      function hideErr()            { errorEl?.classList.add('hidden'); }
    });
  }

  bindForm('form-message', 'error-message', 'success-message', 'Je vous réponds sous 48h.');
  bindForm('form-appel',   'error-appel',   'success-appel',   'Je vous confirme le créneau sous 48h.');
  bindForm('form-devis',   'error-devis',   'success-devis',   'Votre devis vous parvient sous 48h.');

  /* ══════════════════════════════════════════
     POPUP
  ══════════════════════════════════════════ */
  const popup       = document.getElementById('thanks-popup')    as HTMLElement | null;
  const popupCard   = document.getElementById('thanks-card')     as HTMLElement | null;
  const popupBg     = document.getElementById('thanks-backdrop') as HTMLElement | null;
  const closeBtn    = document.getElementById('thanks-close')    as HTMLButtonElement | null;
  const ctaBtn      = document.getElementById('thanks-cta')      as HTMLButtonElement | null;
  const thanksBody  = document.getElementById('thanks-body')     as HTMLElement | null;
  const progressBar = document.getElementById('thanks-progress') as HTMLElement | null;

  let autoCloseTimer: ReturnType<typeof setTimeout> | null = null;
  let progressAnim:   ReturnType<typeof requestAnimationFrame> | null = null;
  let previousFocus:  HTMLElement | null = null;

  /* ── Piège de focus WCAG 2.1.2 ── */
  function trapFocus(e: KeyboardEvent) {
    if (!popup || popup.style.display === 'none') return;
    const focusable = popup.querySelectorAll<HTMLElement>(
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
    );
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.key === 'Tab') {
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    }
  }

  function showPopup(prenom: string, msg: string) {
    if (!popup || !popupCard) return;
    if (thanksBody) thanksBody.textContent = `Merci ${prenom} — ${msg}`;
    /* Mémorise l'élément focalisé avant l'ouverture pour le restaurer à la fermeture */
    previousFocus = document.activeElement as HTMLElement;
    popup.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', trapFocus);
    gsap.fromTo(popup,     { opacity: 0 }, { opacity: 1, duration: 0.28, ease: 'power2.out' });
    gsap.fromTo(popupCard, { opacity: 0, y: 28, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 0.42, delay: 0.06, ease: 'power3.out',
      onComplete: () => {
        /* WCAG 2.4.3 — focus sur le bouton de fermeture après l'animation */
        closeBtn?.focus();
      }
    });

    if (progressBar) {
      const DURATION = 6000;
      const start    = performance.now();
      const tick = (now: number) => {
        const pct = Math.max(0, 100 - ((now - start) / DURATION) * 100);
        progressBar.style.width = pct + '%';
        if (now - start < DURATION) progressAnim = requestAnimationFrame(tick);
      };
      progressAnim    = requestAnimationFrame(tick);
      autoCloseTimer  = setTimeout(closePopup, DURATION);
    }
  }

  function closePopup() {
    if (!popup || !popupCard) return;
    if (autoCloseTimer) { clearTimeout(autoCloseTimer); autoCloseTimer = null; }
    if (progressAnim)   { cancelAnimationFrame(progressAnim); progressAnim = null; }
    document.removeEventListener('keydown', trapFocus);
    gsap.to(popupCard, { opacity: 0, y: 14, scale: 0.97, duration: 0.26, ease: 'power2.in' });
    gsap.to(popup, { opacity: 0, duration: 0.32, delay: 0.10, ease: 'power2.in',
      onComplete: () => {
        popup.style.display = 'none';
        document.body.style.overflow = '';
        /* WCAG 2.4.3 — restitue le focus à l'élément d'origine */
        previousFocus?.focus();
        previousFocus = null;
      }
    });
  }

  closeBtn?.addEventListener('click',   closePopup);
  ctaBtn?.addEventListener('click',     closePopup);
  popupBg?.addEventListener('click',    closePopup);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup?.style.display !== 'none') closePopup();
  });

  /* ══════════════════════════════════════════
     PLANTE GERMINALE — 3 formulaires
  ══════════════════════════════════════════ */
  const SPRING = 'elastic.out(1, 0.48)';
  const EASE   = 'power2.inOut';

  function initPlant(prefix: string) {
    const stem   = document.getElementById(`${prefix}-stem`)   as SVGRectElement    | null;
    const leafL  = document.getElementById(`${prefix}-leaf-l`) as SVGEllipseElement | null;
    const leafR  = document.getElementById(`${prefix}-leaf-r`) as SVGEllipseElement | null;
    const flower = document.getElementById(`${prefix}-flower`) as SVGGElement        | null;
    if (!stem || !leafL || !leafR || !flower) return null;

    gsap.set(stem,   { scaleY: 0, transformOrigin: '50% 100%' });
    gsap.set(leafL,  { scale: 0,  svgOrigin: '38 89' });
    gsap.set(leafR,  { scale: 0,  svgOrigin: '42 66' });
    gsap.set(flower, { scale: 0,  opacity: 0, svgOrigin: '40 18' });

    const state = [false, false, false, false];

    return function update(stage: number, active: boolean) {
      if (state[stage] === active) return;
      state[stage] = active;
      if (stage === 0) active
        ? gsap.to(stem,   { scaleY: 1, duration: 1.1, ease: EASE,   transformOrigin: '50% 100%' })
        : gsap.to(stem,   { scaleY: 0, duration: 0.6, ease: EASE,   transformOrigin: '50% 100%' });
      if (stage === 1) active
        ? gsap.to(leafL,  { scale: 1, duration: 0.75, ease: SPRING, svgOrigin: '38 89' })
        : gsap.to(leafL,  { scale: 0, duration: 0.35, ease: 'power2.in', svgOrigin: '38 89' });
      if (stage === 2) active
        ? gsap.to(leafR,  { scale: 1, duration: 0.75, ease: SPRING, svgOrigin: '42 66' })
        : gsap.to(leafR,  { scale: 0, duration: 0.35, ease: 'power2.in', svgOrigin: '42 66' });
      if (stage === 3) active
        ? gsap.to(flower, { scale: 1, opacity: 1, duration: 0.9,  ease: SPRING,      svgOrigin: '40 18' })
        : gsap.to(flower, { scale: 0, opacity: 0, duration: 0.35, ease: 'power2.in', svgOrigin: '40 18' });
    };
  }

  /* ── Plante formulaire Message ── */
  const updateMsg = initPlant('msg');
  if (updateMsg) {
    const inp = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    inp('msg-sujet')  ?.addEventListener('input', (e) => updateMsg(0, (e.target as HTMLInputElement).value.trim().length > 0));
    inp('msg-prenom') ?.addEventListener('input', (e) => updateMsg(1, (e.target as HTMLInputElement).value.trim().length > 0));
    inp('msg-email')  ?.addEventListener('input', (e) => updateMsg(2, (e.target as HTMLInputElement).value.trim().length > 2));
    inp('msg-message')?.addEventListener('input', (e) => updateMsg(3, (e.target as HTMLTextAreaElement).value.trim().length > 8));
  }

  /* ── Plante formulaire Appel ── */
  const updateAppel = initPlant('appel');
  if (updateAppel) {
    const inp = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    document.querySelectorAll<HTMLInputElement>('[name="creneau"]').forEach(r =>
      r.addEventListener('change', () => updateAppel(0, true)));
    inp('appel-prenom')?.addEventListener('input', (e) => updateAppel(1, (e.target as HTMLInputElement).value.trim().length > 0));
    inp('appel-tel')   ?.addEventListener('input', (e) => updateAppel(2, (e.target as HTMLInputElement).value.trim().length > 5));
    inp('appel-sujet') ?.addEventListener('input', (e) => updateAppel(3, (e.target as HTMLTextAreaElement).value.trim().length > 8));
  }

  /* ── Plante formulaire Devis ── */
  const updateDevis = initPlant('fp');
  if (updateDevis) {
    const inp = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
    document.querySelectorAll<HTMLInputElement>('[name="typeProjet"]').forEach(r =>
      r.addEventListener('change', () => updateDevis(0, true)));
    inp('devis-prenom')?.addEventListener('input', (e) => updateDevis(1, (e.target as HTMLInputElement).value.trim().length > 0));
    inp('devis-email') ?.addEventListener('input', (e) => updateDevis(2, (e.target as HTMLInputElement).value.trim().length > 2));
    inp('devis-projet')?.addEventListener('input', (e) => updateDevis(3, (e.target as HTMLTextAreaElement).value.trim().length > 8));
  }
</script>
