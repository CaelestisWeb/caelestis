---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contactez Caelestis — Agence web Drôme"
  description="Décrivez votre projet en quelques lignes. Célestin vous répond sous 48h avec une vraie réponse personnalisée — pas un formulaire automatique. Caelestis, Drôme."
>

  <section class="pt-20 pb-28 px-6 md:px-10 lg:px-20">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_1.3fr] gap-16 md:gap-24 items-start">

      <!-- Colonne gauche : infos -->
      <div>
        <!-- Image atmosphérique — arrosage en serre -->
        <div class="w-full aspect-[4/3] overflow-hidden mb-10" data-reveal>
          <img
            src="/images/arrosage-serre.jpg"
            alt="Arrosage délicat de plants en serre — attention et soin"
            class="w-full h-full object-cover"
          />
        </div>

        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6" data-reveal>Contact</p>
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-tight mb-6"
          style="font-size: clamp(2.6rem, 5vw, 4rem);"
          data-reveal data-delay="1"
        >
          On en parle ?
        </h1>
        <p class="font-body text-base text-brun-mid leading-relaxed mb-12" data-reveal data-delay="2">
          Dites-moi qui vous êtes et ce que vous cherchez à faire.
          Je vous réponds sous 48h — une vraie réponse, pensée pour vous, pas un copier-coller.
        </p>

        <div class="space-y-6" data-reveal data-delay="3">
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Email</p>
            <a href="mailto:caelestis-pro@hotmail.com" class="font-body text-sm text-brun hover:text-ocre transition-colors">
              caelestis-pro@hotmail.com
            </a>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Téléphone</p>
            <a href="tel:+33782687399" class="font-body text-sm text-brun hover:text-ocre transition-colors">
              07 82 68 73 99
            </a>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Localisation</p>
            <p class="font-body text-sm text-brun">Drôme, France</p>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Disponibilité</p>
            <p class="font-body text-sm text-brun">Lun–Ven · 9h à 18h</p>
          </div>
        </div>
      </div>

      <!-- Colonne droite : formulaire -->
      <div class="bg-cream-dark p-8 md:p-10" data-reveal data-delay="1">
        <form name="contact" method="POST" class="space-y-6">

          <!-- Type de demande — dropdown custom -->
          <div>
            <label class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Je souhaite…
            </label>
            <div id="type-dropdown" class="relative">
              <!-- Champ caché pour la valeur soumise -->
              <input type="hidden" name="type" id="type-value" required />

              <!-- Bouton principal -->
              <button
                type="button"
                id="type-trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
                class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-left flex items-center justify-between transition-colors duration-200 focus:outline-none focus:border-ocre"
              >
                <span id="type-label" class="text-brun-mid/50">Choisir…</span>
                <svg id="type-arrow" class="w-4 h-4 text-brun-mid/50 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>

              <!-- Liste déroulante -->
              <ul
                id="type-list"
                role="listbox"
                class="absolute z-10 w-full bg-cream border border-ocre border-t-0 overflow-hidden max-h-0 transition-[max-height] duration-200 ease-out"
              >
                {[
                  { value: 'message', label: 'Envoyer un message' },
                  { value: 'appel',   label: 'Réserver un appel'  },
                  { value: 'devis',   label: 'Demander un devis'  },
                ].map(({ value, label }) => (
                  <li
                    role="option"
                    data-value={value}
                    class="type-option px-4 py-3 font-body text-sm text-brun cursor-pointer border-b border-cream-dark last:border-b-0 hover:bg-ocre/8 transition-colors duration-150"
                  >
                    {label}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div>
            <label for="prenom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Prénom
            </label>
            <input
              type="text"
              id="prenom"
              name="prenom"
              required
              autocomplete="given-name"
              placeholder="Votre prénom"
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200"
            />
          </div>

          <div>
            <label for="email" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="votre@email.com"
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200"
            />
          </div>

          <div>
            <label for="projet" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Votre projet
            </label>
            <textarea
              id="projet"
              name="projet"
              required
              rows="6"
              placeholder="Décrivez votre activité, ce que vous cherchez, vos contraintes de budget ou de délai… Rien n'est trop petit pour en parler."
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-brun text-cream font-body font-medium text-sm py-4 hover:bg-ocre transition-colors duration-200 cursor-pointer"
          >
            Envoyer →
          </button>

          <p class="font-body text-xs text-brun-mid/55 text-center">
            Réponse personnelle sous 48h. Aucun démarchage, aucune newsletter, aucune revente de données.
          </p>
        </form>
      </div>

    </div>
  </section>

<script>
  const trigger  = document.getElementById('type-trigger');
  const list     = document.getElementById('type-list');
  const labelEl  = document.getElementById('type-label');
  const valueEl  = document.getElementById('type-value');
  const arrow    = document.getElementById('type-arrow');
  const options  = document.querySelectorAll('.type-option');

  function openList() {
    list.style.maxHeight = list.scrollHeight + 'px';
    trigger.setAttribute('aria-expanded', 'true');
    trigger.classList.add('border-ocre');
    arrow.style.transform = 'rotate(180deg)';
  }

  function closeList() {
    list.style.maxHeight = '0';
    trigger.setAttribute('aria-expanded', 'false');
    trigger.classList.remove('border-ocre');
    arrow.style.transform = '';
  }

  trigger.addEventListener('click', () => {
    trigger.getAttribute('aria-expanded') === 'true' ? closeList() : openList();
  });

  options.forEach(opt => {
    opt.addEventListener('click', () => {
      const val = opt.dataset.value;
      valueEl.value = val;
      labelEl.textContent = opt.textContent.trim();
      labelEl.classList.remove('text-brun-mid/50');
      labelEl.classList.add('text-brun');
      options.forEach(o => o.classList.remove('bg-ocre/10', 'font-medium'));
      opt.classList.add('bg-ocre/10', 'font-medium');
      closeList();
    });
  });

  // Fermer si clic à l'extérieur
  document.addEventListener('click', e => {
    if (!document.getElementById('type-dropdown').contains(e.target)) closeList();
  });
</script>

</BaseLayout>
