---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contactez Caelestis — Agence web Drôme"
  description="Décrivez votre projet en quelques lignes. Célestin vous répond sous 48h avec une vraie réponse personnalisée — pas un formulaire automatique. Caelestis, Drôme."
>

  <section class="pt-20 pb-28 px-6 md:px-10 lg:px-20">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_1.3fr] gap-16 md:gap-24 items-start">

      <!-- Colonne gauche : infos -->
      <div>
        <div class="w-full aspect-[4/3] overflow-hidden mb-10" data-img-reveal>
          <img
            src="/images/arrosage-serre.jpg"
            alt="Arrosage délicat de plants en serre — attention et soin"
            class="w-full h-full object-cover"
            data-parallax
          />
        </div>

        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6" data-reveal>Contact</p>
        <h1
          class="font-display font-light text-brun leading-[1.05] tracking-tight mb-6"
          style="font-size: clamp(2.6rem, 5vw, 4rem);"
          data-reveal data-delay="1"
        >
          On en parle ?
        </h1>
        <p class="font-body text-base text-brun-mid leading-relaxed mb-12" data-reveal data-delay="2">
          Dites-moi qui vous êtes et ce que vous cherchez à faire.
          Je vous réponds sous 48h — une vraie réponse, pensée pour vous, pas un copier-coller.
        </p>

        <div class="space-y-6" data-reveal data-delay="3">
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Email</p>
            <a href="mailto:caelestis-pro@hotmail.com" class="font-body text-sm text-brun hover:text-ocre transition-colors">
              caelestis-pro@hotmail.com
            </a>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Téléphone</p>
            <a href="tel:+33782687399" class="font-body text-sm text-brun hover:text-ocre transition-colors">
              07 82 68 73 99
            </a>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Localisation</p>
            <p class="font-body text-sm text-brun">Drôme, France</p>
          </div>
          <div>
            <p class="font-body text-xs tracking-widest uppercase text-sauge mb-1">Disponibilité</p>
            <p class="font-body text-sm text-brun">Lun–Ven · 9h à 18h</p>
          </div>
        </div>
      </div>

      <!-- Colonne droite : formulaire -->
      <div class="bg-cream-dark p-8 md:p-10" data-reveal data-delay="1">

        <!-- État succès (masqué par défaut) -->
        <div id="form-success" class="hidden text-center py-10">
          <div class="w-12 h-12 rounded-full bg-sauge/15 flex items-center justify-center mx-auto mb-6">
            <svg class="w-6 h-6 text-sauge" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl font-light text-brun mb-3">Message envoyé !</h2>
          <p class="font-body text-sm text-brun-mid leading-relaxed">
            Merci pour votre message. Je vous réponds personnellement sous 48h.
          </p>
        </div>

        <!-- Formulaire -->
        <form id="contact-form" class="space-y-6" novalidate>

          <!-- Type de demande — dropdown custom -->
          <div>
            <label class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Je souhaite… <span class="text-ocre">*</span>
            </label>
            <div id="type-dropdown" class="relative">
              <input type="hidden" name="type" id="type-value" />
              <button
                type="button"
                id="type-trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
                class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-left flex items-center justify-between transition-colors duration-200 focus:outline-none focus:border-ocre"
              >
                <span id="type-label" class="text-brun-mid/50">Choisir…</span>
                <svg id="type-arrow" class="w-4 h-4 text-brun-mid/50 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <ul
                id="type-list"
                role="listbox"
                class="absolute z-10 w-full bg-cream border border-ocre border-t-0 overflow-hidden max-h-0 transition-[max-height] duration-200 ease-out"
              >
                {[
                  { value: 'message', label: 'Envoyer un message' },
                  { value: 'appel',   label: 'Réserver un appel'  },
                  { value: 'devis',   label: 'Demander un devis'  },
                ].map(({ value, label }) => (
                  <li
                    role="option"
                    data-value={value}
                    class="type-option px-4 py-3 font-body text-sm text-brun cursor-pointer border-b border-cream-dark last:border-b-0 hover:bg-ocre/8 transition-colors duration-150"
                  >
                    {label}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Prénom -->
          <div>
            <label for="prenom" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Prénom <span class="text-ocre">*</span>
            </label>
            <input
              type="text"
              id="prenom"
              name="prenom"
              autocomplete="given-name"
              placeholder="Votre prénom"
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200"
            />
          </div>

          <!-- Nom de l'entreprise -->
          <div>
            <label for="societe" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Nom de votre entreprise
            </label>
            <input
              type="text"
              id="societe"
              name="societe"
              autocomplete="organization"
              placeholder="Menuiserie Martin, Ferme des Collines…"
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Email <span class="text-ocre">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="votre@email.com"
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200"
            />
          </div>

          <!-- Description du projet -->
          <div>
            <label for="projet" class="font-body text-xs tracking-widest uppercase text-brun-mid block mb-2">
              Décrivez votre projet <span class="text-ocre">*</span>
            </label>
            <textarea
              id="projet"
              name="projet"
              rows="6"
              placeholder="Votre activité, ce que vous cherchez, vos contraintes de budget ou de délai… Plus c'est précis, mieux je peux vous répondre."
              class="w-full bg-cream border border-cream-dark px-4 py-3 font-body text-sm text-brun placeholder:text-brun-mid/40 focus:outline-none focus:border-ocre transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Message d'erreur -->
          <p id="form-error" class="hidden font-body text-xs text-ocre-dark text-center bg-ocre/8 px-4 py-3"></p>

          <!-- Bouton envoi -->
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-brun text-cream font-body font-medium text-sm py-4 hover:bg-ocre transition-colors duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="submit-label">Envoyer →</span>
          </button>

          <p class="font-body text-xs text-brun-mid/55 text-center">
            Réponse personnelle sous 48h. Aucun démarchage, aucune newsletter, aucune revente de données.
          </p>
        </form>
      </div>

    </div>
  </section>

<script>
  /* ── Dropdown type de demande ── */
  const trigger  = document.getElementById('type-trigger') as HTMLButtonElement;
  const list     = document.getElementById('type-list')    as HTMLUListElement;
  const labelEl  = document.getElementById('type-label')   as HTMLSpanElement;
  const valueEl  = document.getElementById('type-value')   as HTMLInputElement;
  const arrow    = document.getElementById('type-arrow')   as SVGElement;
  const options  = document.querySelectorAll<HTMLLIElement>('.type-option');

  function openList() {
    list.style.maxHeight = list.scrollHeight + 'px';
    trigger.setAttribute('aria-expanded', 'true');
    trigger.style.borderColor = '#C97B45';
    arrow.style.transform = 'rotate(180deg)';
  }
  function closeList() {
    list.style.maxHeight = '0';
    trigger.setAttribute('aria-expanded', 'false');
    trigger.style.borderColor = '';
    arrow.style.transform = '';
  }

  trigger.addEventListener('click', () => {
    trigger.getAttribute('aria-expanded') === 'true' ? closeList() : openList();
  });

  options.forEach(opt => {
    opt.addEventListener('click', () => {
      valueEl.value = opt.dataset.value ?? '';
      labelEl.textContent = opt.textContent?.trim() ?? '';
      labelEl.style.color = '#3D2E1F';
      options.forEach(o => { o.style.background = ''; o.style.fontWeight = ''; });
      opt.style.background = 'rgba(201,123,69,0.08)';
      opt.style.fontWeight = '500';
      closeList();
    });
  });

  document.addEventListener('click', e => {
    if (!document.getElementById('type-dropdown')!.contains(e.target as Node)) closeList();
  });

  /* ── Envoi du formulaire via fetch ── */
  const form       = document.getElementById('contact-form')  as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn')    as HTMLButtonElement;
  const submitLbl  = document.getElementById('submit-label')  as HTMLSpanElement;
  const errorEl    = document.getElementById('form-error')    as HTMLParagraphElement;
  const successEl  = document.getElementById('form-success')  as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validation manuelle
    const type   = valueEl.value;
    const prenom = (document.getElementById('prenom')  as HTMLInputElement).value.trim();
    const email  = (document.getElementById('email')   as HTMLInputElement).value.trim();
    const projet = (document.getElementById('projet')  as HTMLTextAreaElement).value.trim();

    if (!type)   { showError('Veuillez sélectionner un type de demande.'); return; }
    if (!prenom) { showError('Veuillez indiquer votre prénom.'); return; }
    if (!email)  { showError('Veuillez indiquer votre adresse email.'); return; }
    if (!projet) { showError('Veuillez décrire votre projet.'); return; }

    // Envoi
    submitBtn.disabled = true;
    submitLbl.textContent = 'Envoi en cours…';
    hideError();

    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const json = await res.json();

      if (res.ok && json.success) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        showError(json.error ?? 'Une erreur est survenue. Veuillez réessayer.');
        submitBtn.disabled = false;
        submitLbl.textContent = 'Envoyer →';
      }
    } catch {
      showError('Erreur réseau. Veuillez vérifier votre connexion et réessayer.');
      submitBtn.disabled = false;
      submitLbl.textContent = 'Envoyer →';
    }
  });

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }
  function hideError() {
    errorEl.classList.add('hidden');
  }
</script>

</BaseLayout>
