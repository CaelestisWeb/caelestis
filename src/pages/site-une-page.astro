---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const canonical = 'https://caelestis.fr/site-une-page';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Page unique',
  serviceType: 'Création de site internet une page',
  description: "Création d'un site internet professionnel en une seule page pour artisans, producteurs et indépendants. L'essentiel de votre activité, soigné et visible sur Google, à partir de 500 €.",
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://caelestis.fr/#business',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    address: { '@type': 'PostalAddress', addressLocality: 'Crest', addressRegion: 'Drôme', postalCode: '26400', addressCountry: 'FR' },
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' },
    { '@type': 'Country', name: 'France' },
  ],
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      price: '500',
      priceCurrency: 'EUR',
    },
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Site une page', item: canonical },
  ],
};

// Les 3 temps du projet
const etapes = [
  { n: '01', t: 'On échange', d: 'Un appel pour comprendre votre activité et ce que vous voulez montrer.' },
  { n: '02', t: 'On crée, on ajuste', d: 'On construit votre site, puis on l\'affine avec vous, jusqu\'au moindre détail.' },
  { n: '03', t: 'On met en ligne', d: 'Votre site est publié en quelques jours, prêt à vous faire connaître.' },
];

// Anatomie d'une page unique, de haut en bas
const anatomie = [
  { t: 'Bannière', d: 'Votre nom, votre accroche et un bouton de contact. La première impression.' },
  { t: 'Présentation', d: 'Qui vous êtes, votre parcours, ce qui vous rend unique.' },
  { t: 'Vos services ou produits', d: 'Ce que vous proposez, présenté simplement et clairement.' },
  { t: 'Galerie', d: 'Vos plus belles photos : réalisations, lieu, ambiance, produits.' },
  { t: 'Avis clients', d: 'Les retours de vos clients, pour inspirer confiance (optionnel).' },
  { t: 'Questions fréquentes', d: 'Les réponses aux questions que vos clients se posent souvent.' },
  { t: 'Contact', d: 'Formulaire, téléphone, e-mail et itinéraire, à portée de clic.' },
  { t: 'Pied de page', d: 'Vos informations essentielles, horaires et liens utiles.' },
];
---

<BaseLayout
  title="Page unique · Site une page dès 500 € · Caelestis"
  description="La Page unique : un site professionnel en une seule page, dès 500 €. L'essentiel de votre activité, soigné et visible sur Google, pour démarrer vite."
  canonical={canonical}
  schema={[schema, breadcrumb]}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-16 md:pt-24 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-24 w-[420px] h-[420px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/4 w-56 h-56"></div>

    <div class="max-w-4xl mx-auto relative text-center">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Page unique · pour démarrer</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.06] tracking-tight max-w-3xl mx-auto"
        style="font-size: clamp(2.1rem, 5vw, 3.9rem);"
        data-reveal data-delay="1"
      >
        Une seule page suffit<br class="hidden sm:block"> pour <span class="text-sauge">exister en ligne.</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed mx-auto" data-reveal data-delay="2">
        Un site professionnel, sur une seule page. Visible sur Google et prêt en quelques jours, sans gros budget.
      </p>

      <!-- Prix -->
      <div class="mt-9 inline-flex flex-col items-center" data-reveal data-delay="2">
        <p class="font-body text-xs tracking-[0.16em] uppercase text-brun-mid/70 mb-1">À partir de</p>
        <p class="font-display font-light text-brun leading-none" style="font-size: clamp(2.6rem, 6vw, 3.6rem); letter-spacing: -0.025em;">
          <span class="text-sauge">500</span><span class="text-bois-mid text-2xl ml-1">€</span>
        </p>
      </div>

      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4" data-reveal data-delay="3">
        <Button href="/contact#devis" variant="primary">Demander un devis</Button>
        <Button href="#inclus" variant="outline">Voir ce qui est inclus</Button>
      </div>
    </div>
  </section>

  <!-- ── En clair : c'est quoi ? ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20" style="background: linear-gradient(180deg, #EDE3D4 0%, #E4D6BD 100%);">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-10">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">En clair</p>
        <h2 class="font-display font-light text-brun leading-[1.15] mb-6" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Un site complet, en plus simple.
        </h2>
        <p class="font-body text-base text-brun-mid leading-relaxed max-w-2xl mx-auto">
          Un site une page, c'est un site internet à part entière : tout tient sur une seule page qui défile. Votre visiteur y découvre qui vous êtes, ce que vous proposez et comment vous joindre, sans menus compliqués ni pages à chercher.
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed max-w-2xl mx-auto mt-5">
          C'est l'offre idéale pour les artisans, producteurs et indépendants qui démarrent. On s'occupe de toute la technique : nom de domaine, mise en ligne, réglages. Vous n'avez qu'à nous parler de votre métier.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Ce que contient votre page (anatomie, fond vert) ── -->
  <section id="inclus" class="py-20 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth relative overflow-hidden">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-24 -left-24 w-72 h-72"></div>
    <div aria-hidden="true" class="light-blob light-blob-bois pointer-events-none absolute -bottom-10 right-0 w-80 h-80"></div>

    <div class="max-w-3xl mx-auto relative">
      <div class="text-center mb-12" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">L'anatomie de votre page</p>
        <h2 class="font-display font-light leading-[1.15] mb-5" style="font-size: clamp(1.7rem, 3vw, 2.4rem); color: rgba(237,227,212,0.94);">
          Ce que contient votre page.
        </h2>
        <p class="font-body text-base leading-relaxed max-w-xl mx-auto" style="color: rgba(237,227,212,0.78);">
          De haut en bas, voici les sections que découvre votre visiteur en faisant défiler votre page.
        </p>
      </div>

      <div class="anat-list max-w-lg mx-auto space-y-2.5" data-reveal data-delay="1">
        {anatomie.map((s, i) => (
          <button type="button" class={`anat-block ${i === 0 ? 'is-selected' : ''}`} aria-pressed={i === 0 ? 'true' : 'false'}>
            <span class="anat-title">{s.t}</span>
            <span class="anat-desc">{s.d}</span>
          </button>
        ))}
      </div>

      <p class="text-center font-body text-sm mt-8 max-w-xl mx-auto" style="color: rgba(237,227,212,0.65);" data-reveal data-delay="2">
        On choisit ensemble les sections utiles à votre activité. Certaines sont optionnelles : votre page reste simple et lisible.
      </p>
    </div>
  </section>

  <!-- ── Simple, rapide & au juste prix ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-12">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Comment ça se passe</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Simple, rapide, sans surprise.
        </h2>
      </div>

      <!-- 3 temps -->
      <div class="grid sm:grid-cols-3 gap-5 lg:gap-6 mb-12" data-reveal data-delay="1">
        {etapes.map((e) => (
          <div class="text-center">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full font-display text-base text-cream mb-4" style="background: linear-gradient(140deg, #889063, #6B7A4A); box-shadow: 0 6px 16px rgba(61,79,40,0.22);">{e.n}</span>
            <h3 class="font-display text-lg font-light text-brun mb-2">{e.t}</h3>
            <p class="font-body text-sm text-brun-mid leading-relaxed">{e.d}</p>
          </div>
        ))}
      </div>

      <!-- Le périmètre clair -->
      <div class="max-w-2xl mx-auto bg-cream border border-cream-dark rounded-2xl p-7 lg:p-8 text-center" data-reveal data-delay="2">
        <p class="font-display font-light text-brun leading-none" style="font-size: clamp(2.2rem, 5vw, 3rem); letter-spacing: -0.02em;">
          <span class="text-sauge">500 €</span>
        </p>
        <p class="font-body text-sm text-brun-mid mt-2">votre page, prête en quelques jours</p>

        <ul class="mt-7 space-y-3 text-left max-w-md mx-auto">
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>On la peaufine ensemble jusqu'à ce qu'elle vous plaise.</span>
          </li>
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>30 % pour démarrer, le solde une fois votre site en ligne.</span>
          </li>
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>Maintenance <strong class="font-semibold text-brun">obligatoire</strong> à <a href="/maintenance" class="text-sauge hover:text-brun underline decoration-sauge/40 underline-offset-2 transition-colors">7,99 € / mois</a> : votre site reste en ligne, rapide et sécurisé.</span>
          </li>
        </ul>

        <p class="font-body text-sm text-brun-mid/80 mt-7 pt-6 border-t border-cream-dark">
          Besoin de plus un jour (boutique, pages en plus) ? On passe à un <a href="/services" class="text-sauge hover:text-brun underline decoration-sauge/40 underline-offset-2 transition-colors">site vitrine ou une boutique</a>, sur devis.
        </p>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-5 leading-[1.1]">
        Prêt à exister<br><span class="text-sauge">en ligne&nbsp;?</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Décrivez votre activité en quelques lignes, on revient vers vous sous 48h. On peut même vous préparer un aperçu gratuit de votre futur site avant que vous décidiez.
      </p>
      <Button href="/contact#devis" variant="primary">Demander un devis</Button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Pastille check sauge des fonctionnalités */
  .sup-check {
    display: block;
    width: 20px;
    height: 20px;
    background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='%23889063' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='%23889063' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }

  /* ── Anatomie : cases sélectionnables au clic ── */
  .anat-block {
    display: block;
    width: 100%;
    text-align: left;
    border: 0;
    border-left: 3px solid #889063;
    border-radius: 12px;
    padding: 14px 20px;
    background: #EDE3D4;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    transition: background 0.45s ease,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.45s ease,
                border-color 0.3s ease,
                border-left-width 0.25s ease;
  }
  .anat-block .anat-title {
    display: block;
    font-family: 'Lora', serif;
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: #3d4f28;
    transition: color 0.3s ease;
  }
  .anat-block .anat-desc {
    display: block;
    margin-top: 3px;
    font-family: 'DM Sans Variable', 'DM Sans', sans-serif;
    font-size: 0.75rem;
    line-height: 1.45;
    color: #6B6040;
    transition: color 0.3s ease;
  }
  .anat-block:hover:not(.is-selected) {
    border-left-width: 6px;
    transform: translateX(3px);
  }
  .anat-block.is-selected {
    background: linear-gradient(135deg, #9AA275, #6B7A4A);
    border-left-color: transparent;
    transform: scale(1.025);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.24);
  }
  .anat-block.is-selected .anat-title { color: #EDE3D4; }
  .anat-block.is-selected .anat-desc { color: rgba(237, 227, 212, 0.85); }
  .anat-block:focus-visible {
    outline: 2px solid #EDE3D4;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .anat-block {
      transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    }
    .anat-block:hover:not(.is-selected),
    .anat-block.is-selected { transform: none; }
  }
</style>

<script>
  /* Anatomie : une seule section sélectionnée à la fois.
     Délégation sur document : survit aux navigations View Transitions,
     liée une seule fois grâce au flag window. */
  if (!(window as Window & { __anatBound?: boolean }).__anatBound) {
    (window as Window & { __anatBound?: boolean }).__anatBound = true;
    document.addEventListener('click', (e) => {
      const block = (e.target as HTMLElement).closest('.anat-block');
      if (!block) return;
      const list = block.closest('.anat-list');
      if (!list) return;
      list.querySelectorAll('.anat-block').forEach((x) => {
        x.classList.remove('is-selected');
        x.setAttribute('aria-pressed', 'false');
      });
      block.classList.add('is-selected');
      block.setAttribute('aria-pressed', 'true');
    });
  }
</script>
