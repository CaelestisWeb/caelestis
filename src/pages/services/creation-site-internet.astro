---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Création de site internet',
  description: 'Création de sites internet sur mesure pour artisans, paysagistes, agriculteurs et indépendants en Drôme et toute la France.',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    telephone: '+33769362727',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Crest',
      addressRegion: 'Drôme',
      postalCode: '26400',
      addressCountry: 'FR',
    },
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Drôme' },
    { '@type': 'Country', name: 'France' },
  ],
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '600',
      maxPrice: '2500',
      priceCurrency: 'EUR',
    },
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Prestations', item: 'https://caelestis.fr/services' },
    { '@type': 'ListItem', position: 3, name: 'Création de site internet', item: 'https://caelestis.fr/services/creation-site-internet' },
  ],
};

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Combien coûte la création d\'un site internet en Drôme ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Les sites internet que je crée démarrent à partir de 600 €. Le tarif final dépend de vos besoins : nombre de pages, fonctionnalités souhaitées (formulaire de contact, galerie, boutique en ligne, blog…). Je vous envoie un devis clair et détaillé sous 48h, sans engagement.' },
    },
    {
      '@type': 'Question',
      name: 'Combien de temps faut-il pour créer un site internet ?',
      acceptedAnswer: { '@type': 'Answer', text: 'En général, entre 2 et 4 semaines selon la complexité du projet. Je travaille par étapes validées ensemble, ce qui permet d\'avancer vite sans mauvaise surprise.' },
    },
    {
      '@type': 'Question',
      name: 'Mon site sera-t-il visible sur Google ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui. Chaque site est construit avec une structure claire, un chargement rapide et les bases du référencement naturel. Je lie également votre site à votre fiche Google My Business pour renforcer votre visibilité locale en Drôme.' },
    },
    {
      '@type': 'Question',
      name: 'Intervenez-vous uniquement en Drôme ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Non. Basé à Crest dans la Drôme, j\'interviens dans toute la France. Je travaille entièrement à distance, par échange vidéo ou email, ce qui me permet d\'accompagner des clients partout sur le territoire.' },
    },
  ],
};

const inclus = [
  { titre: 'Design sur mesure', desc: 'Une identité visuelle cohérente avec votre activité. Pas de template générique — chaque page est pensée pour vous.' },
  { titre: 'Responsive mobile', desc: 'Votre site est parfaitement lisible sur smartphone, tablette et ordinateur. Plus de 60% des visites se font sur mobile.' },
  { titre: 'SEO technique intégré', desc: 'Structure Hn claire, balises méta, vitesse de chargement optimisée, sitemap XML. Les bases pour que Google vous trouve.' },
  { titre: 'Formulaire de contact', desc: 'Un formulaire fonctionnel, sécurisé et directement relié à votre boîte mail.' },
  { titre: 'Nom de domaine & hébergement', desc: 'Je vous guide pour choisir et configurer votre nom de domaine et hébergeur, ou je le gère entièrement pour vous.' },
  { titre: 'Mise en ligne & transmission', desc: 'Je m\'occupe de la mise en ligne complète et je vous transmets tous les accès. Le paiement intervient après la mise en ligne.' },
];

const secteurs = [
  'Paysagistes & espaces verts',
  'Agriculteurs & maraîchers',
  'Artisans & créateurs',
  'Praticiens bien-être & thérapeutes',
  'Bureaux d\'études environnementaux',
  'Éco-construction & énergies renouvelables',
  'Associations écologiques',
];
---
<BaseLayout
  title="Création de site internet Drôme — Artisans & indépendants · Caelestis"
  description="Création de site internet sur mesure à Crest, Drôme. Sites professionnels pour artisans, paysagistes, agriculteurs et indépendants. Visible sur Google. À partir de 600€."
  schema={[schema, breadcrumb, faq]}
>

  <!-- ─── EN-TÊTE ─── -->
  <section class="pt-20 pb-16 px-6 md:px-10 lg:px-20 section-ambient overflow-hidden relative border-b border-cream-dark">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-20 w-[400px] h-[400px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/4 w-64 h-64"></div>

    <div class="max-w-4xl mx-auto relative">
      <nav class="flex items-center gap-2 font-body text-xs text-brun-mid/50 mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-sauge transition-colors">Accueil</a>
        <span>/</span>
        <a href="/services" class="hover:text-sauge transition-colors">Prestations</a>
        <span>/</span>
        <span class="text-brun-mid">Création de site internet</span>
      </nav>

      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Création de site internet · Drôme & France</p>
      </div>

      <h1
        class="font-display font-light text-brun leading-[1.06] tracking-tight mb-8"
        style="font-size: clamp(2.4rem, 5vw, 4rem);"
        data-reveal data-delay="1"
      >
        Un site internet qui travaille<br><span class="text-sauge">pour votre activité.</span>
      </h1>

      <p class="font-body text-lg text-brun-mid leading-relaxed max-w-2xl mb-10" data-reveal data-delay="2">
        Je crée des sites internet sur mesure pour les artisans, paysagistes, agriculteurs et indépendants de la Drôme et de toute la France.
        Des sites clairs, rapides, visibles sur Google — qui donnent envie à vos visiteurs de vous contacter.
      </p>

      <div class="flex flex-wrap gap-4" data-reveal data-delay="3">
        <Button href="/contact" variant="primary">Demander un devis gratuit →</Button>
        <Button href="/services" variant="outline">Toutes les prestations</Button>
      </div>

      <div class="flex flex-wrap gap-6 mt-10 pt-8 border-t border-cream-dark" data-reveal data-delay="4">
        {[
          { label: 'À partir de', val: '600€' },
          { label: 'Devis en', val: '48h' },
          { label: 'Mise en ligne', val: '2–4 sem.' },
          { label: 'Paiement', val: 'À la livraison' },
        ].map(({ label, val }) => (
          <div>
            <p class="font-body text-xs text-brun-mid/50 tracking-wide uppercase">{label}</p>
            <p class="font-display text-xl font-light text-brun">{val}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CONTENU PRINCIPAL ─── -->
  <section class="py-20 px-6 md:px-10 lg:px-20">
    <div class="max-w-4xl mx-auto">

      <!-- Intro SEO -->
      <div class="mb-20" data-reveal>
        <h2 class="font-display text-2xl md:text-3xl font-light text-brun mb-6 leading-[1.1]">
          Pourquoi confier votre site à Caelestis ?
        </h2>
        <div class="font-body text-base text-brun-mid leading-relaxed space-y-4 max-w-3xl">
          <p>
            Beaucoup de petites entreprises et d'indépendants en Drôme ont une activité remarquable — mais une présence en ligne quasi inexistante ou mal construite.
            Résultat : des clients potentiels qui passent à côté, ou qui choisissent un concurrent mieux référencé.
          </p>
          <p>
            Chez Caelestis, je crée des sites internet pensés pour les acteurs de terrain : artisans, paysagistes, maraîchers, praticiens.
            Des sites qui se chargent vite, qui s'affichent parfaitement sur mobile, et qui sont optimisés pour apparaître sur Google quand vos clients cherchent vos services.
          </p>
          <p>
            Basé à Crest dans la Drôme, j'accompagne des professionnels dans toute la Drôme (Valence, Romans-sur-Isère, Montélimar, Die, Bourg-lès-Valence) et partout en France, entièrement à distance.
          </p>
        </div>
      </div>

      <!-- Ce qui est inclus -->
      <div class="mb-20" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Inclus dans chaque projet</p>
        <h2 class="font-display text-2xl md:text-3xl font-light text-brun mb-10 leading-[1.1]">
          Ce que comprend votre site internet.
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {inclus.map(({ titre, desc }) => (
            <div class="border border-cream-dark rounded-xl p-6 card-lift" data-reveal>
              <div class="flex items-center gap-3 mb-3">
                <span class="w-1.5 h-1.5 rounded-full bg-sauge flex-shrink-0"></span>
                <h3 class="font-display text-lg font-light text-brun">{titre}</h3>
              </div>
              <p class="font-body text-sm text-brun-mid leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Secteurs -->
      <div class="mb-20 bg-sauge-pale rounded-2xl p-8 md:p-12 border border-cream-dark" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Secteurs d'activité</p>
        <h2 class="font-display text-2xl font-light text-brun mb-8 leading-[1.1]">
          Je travaille principalement avec :
        </h2>
        <ul class="space-y-3">
          {secteurs.map((s) => (
            <li class="flex items-center gap-3 font-body text-base text-brun-mid">
              <span class="w-1 h-1 rounded-full bg-bois-mid flex-shrink-0"></span>
              {s}
            </li>
          ))}
        </ul>
        <p class="font-body text-sm text-brun-mid/60 mt-6 leading-relaxed">
          Vous avez un autre type d'activité ? N'hésitez pas à me contacter — j'étudie tous les projets liés à l'environnement, la nature et le monde artisanal.
        </p>
      </div>

      <!-- Comment ça se passe -->
      <div class="mb-20" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4">Le déroulé</p>
        <h2 class="font-display text-2xl md:text-3xl font-light text-brun mb-10 leading-[1.1]">
          Comment se passe la création de votre site ?
        </h2>
        <div class="space-y-0 divide-y divide-cream-dark">
          {[
            { num: '01', t: 'Premier échange', d: 'On parle de votre activité, vos clients, ce que vous voulez accomplir. C\'est gratuit, sans engagement, et ça dure 20–30 min.' },
            { num: '02', t: 'Devis sous 48h', d: 'Je vous envoie un devis clair, ligne par ligne. Vous savez exactement ce que vous investissez, sans surprise.' },
            { num: '03', t: 'Conception du site', d: 'Je crée votre site par étapes, avec vos retours à chaque phase. Vous restez maître du projet du début à la fin.' },
            { num: '04', t: 'Mise en ligne & accès', d: 'Je m\'occupe de tout : hébergement, nom de domaine, SSL, Google. Vous recevez tous vos accès.' },
            { num: '05', t: 'Paiement à la livraison', d: 'Vous ne payez qu\'une fois le site en ligne et validé. Pas d\'acompte obligatoire avant le lancement.' },
          ].map(({ num, t, d }) => (
            <div class="flex items-start gap-6 py-7 group">
              <span class="font-body text-xs text-sauge/60 tabular-nums flex-shrink-0 mt-1">{num}</span>
              <div class="flex-1">
                <h3 class="font-display text-lg font-light text-brun mb-1">{t}</h3>
                <p class="font-body text-sm text-brun-mid leading-relaxed">{d}</p>
              </div>
              <span class="font-body text-sauge opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0 self-center">→</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="py-16 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth">
    <div class="max-w-3xl mx-auto">
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-4" data-reveal>Questions fréquentes</p>
      <h2 class="font-display text-2xl md:text-3xl font-light mb-12 leading-[1.1]" data-reveal data-delay="1">
        Vos questions sur la création<br>de site internet.
      </h2>
      <div id="faq-csi" data-reveal data-delay="2">
        {faq.mainEntity.map(({ name, acceptedAnswer }) => (
          <div class="faq-item border-t" style="border-color: rgba(237,227,212,0.15)">
            <button class="faq-trigger w-full flex items-center justify-between gap-6 py-6 text-left" aria-expanded="false">
              <span class="font-display text-base font-light">{name}</span>
              <span class="faq-icon font-body text-xl font-light flex-shrink-0" style="color: rgba(237,227,212,0.4)">+</span>
            </button>
            <div class="faq-body overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out">
              <p class="font-body text-sm leading-relaxed pb-6" style="color: rgba(237,227,212,0.6)">{acceptedAnswer.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="py-24 px-6 md:px-10 lg:px-20 text-center section-ambient" data-reveal>
    <div class="max-w-2xl mx-auto">
      <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-6">Prêt à vous lancer ?</p>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun leading-[1.1] mb-6">
        Votre site internet,<br><span class="text-sauge">livré en 2 à 4 semaines.</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Devis gratuit sous 48h. Paiement à la livraison. Disponible en Drôme et partout en France.
      </p>
      <Button href="/contact" variant="primary">Demander mon devis gratuit →</Button>
    </div>
  </section>

</BaseLayout>

<script>
  const FAQ_COLOR_CLOSED = 'rgba(237,227,212,0.4)';
  const FAQ_COLOR_OPEN   = '#A08060';
  document.querySelectorAll<HTMLButtonElement>('#faq-csi .faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.parentElement;
      const body = item?.querySelector<HTMLElement>('.faq-body');
      const icon = trigger.querySelector<HTMLElement>('.faq-icon');
      if (!item || !body || !icon) return;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll<HTMLButtonElement>('#faq-csi .faq-trigger').forEach((t) => {
        if (t === trigger) return;
        t.setAttribute('aria-expanded', 'false');
        const b = t.parentElement?.querySelector<HTMLElement>('.faq-body');
        const ic = t.querySelector<HTMLElement>('.faq-icon');
        if (b) b.style.maxHeight = '0';
        if (ic) { ic.textContent = '+'; ic.style.color = FAQ_COLOR_CLOSED; }
      });
      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        body.style.maxHeight = '0';
        icon.textContent = '+'; icon.style.color = FAQ_COLOR_CLOSED;
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.textContent = '–'; icon.style.color = FAQ_COLOR_OPEN;
      }
    });
  });
</script>
