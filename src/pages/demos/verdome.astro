        <div class="small">— Écrire —</div>
        <div><a href="mailto:atelier@sylv.fr">atelier@sylv.fr</a></div>
        <div><a href="tel:+33475000000">+33 4 75 00 00 00</a></div>
        <div class="rule"></div>
        <div class="small">— Atelier ouvert —</div>
        <div>Mardi au samedi</div>
        <div>10 h — 17 h</div>
        <div class="small" style="margin-top: 1.5rem;">Sur rendez-vous uniquement.</div>
      </aside>
