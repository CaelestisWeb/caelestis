    <!-- ═══════════════════ XII. COLOPHON ═══════════════════ -->
    <footer class="colophon">
      <div>
        <div class="colophon-mark">Sylv<span class="dot">·</span></div>
        Yourtes contemporaines<br/>MMXII — MMXXVI
      </div>
      <div>
        Site composé à la main<br/>
        Caractères · Fraunces · Inter Tight · JetBrains Mono
      </div>
      <div>
        Démonstration Caelestis<br/>
        Projet fictif · aucune donnée réelle
      </div>
    </footer>

  </main>

  <script>
    // ─── INTRO FADE ───
    function dismissIntro() {
      const i = document.getElementById('intro');
      if (i) i.classList.add('gone');
    }
    window.addEventListener('load', () => setTimeout(dismissIntro, 600));
    setTimeout(dismissIntro, 2100);

    // ─── QUIET REVEAL ───
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('seen'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.quiet').forEach(el => obs.observe(el));

    // ─── FOLIO TRACKER ───
    const folioNow = document.getElementById('folio-now');
    const chapters = Array.from(document.querySelectorAll('[data-folio]'));
    function syncFolio() {
      const y = window.innerHeight * 0.4;
      for (const c of chapters) {
        const r = c.getBoundingClientRect();
        if (r.top < y && r.bottom > y) {
          const t = c.getAttribute('data-folio');
          if (folioNow.textContent !== t) folioNow.textContent = t;
          return;
        }
      }
    }
    window.addEventListener('scroll', syncFolio, { passive: true });
    syncFolio();

    // ─── ANATOMIE INTERACTIVE ───
    const aSvg = document.getElementById('anatomySvg');
    const aList = document.querySelectorAll('#anatomyList li');
    aList.forEach(li => {
      li.addEventListener('mouseenter', () => {
        const part = li.dataset.part;
        aSvg.classList.add('dim');
        aList.forEach(x => x.classList.remove('active'));
        li.classList.add('active');
        aSvg.querySelectorAll('.anat-part').forEach(p => {
          p.classList.remove('lit');
          if (p.dataset.part === part) p.classList.add('lit');
        });
      });
      li.addEventListener('mouseleave', () => {
        aSvg.classList.remove('dim');
        aSvg.querySelectorAll('.anat-part').forEach(p => p.classList.remove('lit'));
        li.classList.remove('active');
      });
    });

    // ─── CONFIGURATEUR ───
    const cfState = {
      diam: 7.2,
      model: 'Khan',
      wood: 'Mélèze',
      woodColor: '#D9B47F',
      or: 'Sud',
      orDeg: 180
    };
    const cfModelInfo = {
      'Steppe': { ratio: 0.7, prixCoef: 0.7, delay: 9 },
      'Khan': { ratio: 1, prixCoef: 1, delay: 14 },
      'Nomade': { ratio: 0.55, prixCoef: 0.55, delay: 7 },
      'Khan double': { ratio: 1.35, prixCoef: 1.5, delay: 18 },
    };
    function updateCf() {
      const m = cfModelInfo[cfState.model];
      const surface = (Math.PI * Math.pow(cfState.diam / 2, 2)).toFixed(1).replace('.', ',');
      const baseLow = Math.round((30 + cfState.diam * 1.6) * m.prixCoef);
      const baseHigh = Math.round((38 + cfState.diam * 2.2) * m.prixCoef);
      const woodShort = cfState.wood.substring(0, 3).toUpperCase();
      const orShort = cfState.or === 'Sud' ? 'S' : cfState.or;

      document.getElementById('cfDiam').textContent = cfState.diam.toFixed(1).replace('.', ',') + ' m';
      document.getElementById('cfModelLabel').textContent = cfState.model;
      document.getElementById('cfWoodLabel').textContent = cfState.wood;
      document.getElementById('cfOrLabel').textContent = cfState.or;
      document.getElementById('cfSurface').textContent = surface + ' m²';
      document.getElementById('cfPrice').textContent = baseLow + ' — ' + baseHigh + ' k€';
      document.getElementById('cfDelay').textContent = m.delay + ' mois';
      document.getElementById('cfRef').textContent = 'SYL · ' + cfState.diam.toFixed(1).replace('.', ',') + ' · ' + woodShort + ' · ' + orShort;

      // SVG update
      const circle = document.getElementById('cfCircle');
      const radius = 30 + (cfState.diam - 4.8) * 12;
      circle.setAttribute('r', radius);
      circle.style.setProperty('--c', cfState.woodColor);

      document.getElementById('cfModel').textContent = cfState.model;
      document.getElementById('cfDim').textContent = 'Ø ' + cfState.diam.toFixed(1).replace('.', ',') + ' m';

      // Rotate the entrance to match orientation
      const entrance = document.getElementById('cfEntrance');
      entrance.setAttribute('transform', `rotate(${cfState.orDeg + 180} 100 100)`);
    }

    document.getElementById('cfDiamSlider').addEventListener('input', (e) => {
      cfState.diam = parseFloat(e.target.value);
      updateCf();
    });
    document.querySelectorAll('[data-cf-model]').forEach(c => c.addEventListener('click', () => {
      document.querySelectorAll('[data-cf-model]').forEach(x => x.classList.remove('on'));
      c.classList.add('on');
      cfState.model = c.dataset.cfModel;
      updateCf();
    }));
    document.querySelectorAll('[data-cf-wood]').forEach(c => c.addEventListener('click', () => {
      document.querySelectorAll('[data-cf-wood]').forEach(x => x.classList.remove('on'));
      c.classList.add('on');
      cfState.wood = c.dataset.cfWood;
      cfState.woodColor = c.dataset.cfC;
      updateCf();
    }));
    document.querySelectorAll('[data-cf-or]').forEach(c => c.addEventListener('click', () => {
      document.querySelectorAll('[data-cf-or]').forEach(x => x.classList.remove('on'));
      c.classList.add('on');
      cfState.or = c.dataset.cfOr;
      cfState.orDeg = parseInt(c.dataset.cfDeg, 10);
      updateCf();
    }));
    updateCf();

    // ─── CALENDRIER INVITATION ───
    document.querySelectorAll('.invite-date:not(.taken)').forEach(d => {
      d.addEventListener('click', () => {
        document.querySelectorAll('.invite-date').forEach(x => x.classList.remove('on'));
        d.classList.add('on');
      });
    });
  </script>

</body>
</html>
