          </g>
          <!-- entrée -->
          <path class="stroke" d="M 240 510 L 240 540 L 300 540 L 300 510" fill="var(--paper)"/>
          <text class="label" x="270" y="535" text-anchor="middle">Entrée — Sud</text>
          <!-- labels cardinaux -->
