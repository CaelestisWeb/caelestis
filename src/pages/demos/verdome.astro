    <div class="top-folio" id="folio-now">— Couverture</div>
    <a href="#atelier" class="top-cta">Écrire à l'atelier</a>
  </header>

  <div class="notice"><b>Caelestis</b> Démonstration — projet fictif</div>

  <main>

    <!-- ═══════════════════ I. COUVERTURE ═══════════════════ -->
    <section class="cover" data-folio="— Couverture">
      <div class="cover-text">
        <div class="cover-eyebrow">Sylv· — Yourtes contemporaines</div>
        <h1>
          Habiter<br/>
          <span class="roman">rond.</span>
        </h1>
        <div class="cover-tagline">
          Yourtes en bois massif, dessinées et bâties à la main dans la Drôme. <em>Une tradition mongole, un savoir-faire français.</em>
        </div>
        <div class="cover-meta">
          <div><strong>Atelier</strong><br/>Crest · Drôme</div>
          <div><strong>Depuis</strong><br/>MMXII — 12 yourtes / an</div>
        </div>
      </div>

      <!-- SVG PLAN CIRCULAIRE DE YOURTE -->
      <div class="cover-plan">
        <svg class="yurt-svg" viewBox="0 0 540 540">
          <!-- cercles concentriques (toiture vue de dessus) -->
          <circle class="stroke-mid" cx="270" cy="270" r="252"/>
          <circle class="stroke" cx="270" cy="270" r="240"/>
          <circle class="stroke-mid" cx="270" cy="270" r="200"/>
          <circle class="stroke-mid" cx="270" cy="270" r="155"/>
          <circle class="stroke-mid" cx="270" cy="270" r="105"/>
