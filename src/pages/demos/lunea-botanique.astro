---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lunéa Botanique — Bougies & Soins naturels artisanaux</title>
  <meta name="description" content="Lunéa Botanique, marque artisanale de bougies naturelles, soins botaniques et objets bien-être fabriqués à la main en France." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" />
  <link rel="stylesheet" media="print" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" id="gfonts-lunea" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" /></noscript>
  <script>var l=document.getElementById('gfonts-lunea');if(l)l.onload=function(){l.media='all'};</script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --ivory: #F7F4EF;
      --ivory-dark: #EDE8DF;
      --forest: #2C3D2A;
      --forest-light: #3D5439;
      --sage: #7A9068;
      --sand: #C8B898;
      --dark-text: #1A2018;
      --mid-text: rgba(26,32,24,0.52);
      --font: 'Plus Jakarta Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font); background: var(--ivory); color: var(--dark-text); overflow-x: hidden; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.6rem 5rem;
      transition: all 0.4s ease;
    }
    nav.scrolled {
      background: rgba(247,244,239,0.97);
      backdrop-filter: blur(12px);
      padding: 1rem 5rem;
      box-shadow: 0 1px 0 rgba(26,32,24,0.06);
    }
    .nav-logo { font-family: var(--font); font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; color: #F7F4EF; text-decoration: none; transition: color 0.4s; }
    nav.scrolled .nav-logo { color: var(--forest); }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a { font-size: 0.8rem; font-weight: 400; color: rgba(247,244,239,0.68); text-decoration: none; transition: color 0.3s; }
    nav.scrolled .nav-links a { color: var(--mid-text); }
    .nav-links a:hover { color: var(--sage) !important; }
    .nav-basket {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.8rem; font-weight: 500; color: rgba(247,244,239,0.75);
      cursor: pointer; transition: color 0.3s;
    }
    nav.scrolled .nav-basket { color: var(--dark-text); }
    .nav-basket:hover { color: var(--sage) !important; }
    .basket-count {
      width: 1.4rem; height: 1.4rem; border-radius: 50%;
      background: var(--sage); color: white;
      font-size: 0.62rem; font-weight: 600; display: flex; align-items: center; justify-content: center;
    }

    /* NOTICE FICTIF */
    .notice-fictif {
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999;
      background: var(--forest); color: rgba(247,244,239,0.55);
      padding: 0.75rem 1.1rem; font-size: 0.68rem; font-weight: 400;
      max-width: 250px; text-align: center; line-height: 1.5;
      border-left: 2px solid var(--sage);
    }
    .notice-fictif strong { color: var(--sage); display: block; margin-bottom: 0.25rem; font-size: 0.62rem; font-weight: 600; }

    /* HERO */
    .hero {
      min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr;
      position: relative; overflow: hidden;
    }
    .hero-left {
      background: var(--forest);
      display: flex; flex-direction: column; justify-content: center;
      padding: 10rem 5rem 5rem;
      position: relative; overflow: hidden;
    }
    .hero-eyebrow { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; color: var(--sage); margin-bottom: 1.8rem; display: flex; align-items: center; gap: 1rem; }
    .hero-eyebrow::before { content: ''; display: block; width: 28px; height: 1px; background: var(--sage); }
    .hero h1 { font-family: var(--font); font-weight: 600; font-size: clamp(2.6rem, 4.5vw, 4.5rem); line-height: 1.1; color: var(--ivory); letter-spacing: -0.03em; margin-bottom: 1.8rem; }
    .hero h1 span { color: var(--sage); }
    .hero-sub { font-size: 0.95rem; font-weight: 400; line-height: 1.75; color: rgba(247,244,239,0.52); max-width: 380px; margin-bottom: 3rem; }
    .hero-actions { display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
    .btn-primary-hero {
      background: var(--sage); color: white; border: none;
      padding: 1rem 2.2rem; font-family: var(--font);
      font-size: 0.82rem; font-weight: 500;
      cursor: pointer; text-decoration: none;
      transition: background 0.3s;
      display: inline-flex; align-items: center; gap: 0.7rem;
      border-radius: 2px;
    }
    .btn-primary-hero:hover { background: var(--forest-light); }
    .btn-secondary-hero {
      font-size: 0.82rem; font-weight: 400;
      color: rgba(247,244,239,0.55); text-decoration: none;
      transition: color 0.3s;
    }
    .btn-secondary-hero:hover { color: var(--ivory); }
    .hero-right { position: relative; overflow: hidden; }
    .hero-right img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .hero-badge {
      position: absolute; bottom: 2.5rem; left: 2.5rem;
      background: rgba(247,244,239,0.95); backdrop-filter: blur(8px);
      padding: 1.1rem 1.6rem;
    }
    .hero-badge-text { font-size: 0.9rem; font-weight: 500; color: var(--forest); }
    .hero-badge-sub { font-size: 0.68rem; font-weight: 400; color: var(--sage); margin-top: 0.3rem; }

    /* SECTION LABEL */
    .section-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--sage); margin-bottom: 1rem; }

    /* PRODUITS VEDETTES */
    .produits { padding: 8rem 5rem; }
    .produits-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; flex-wrap: wrap; gap: 1rem; }
    .produits h2 { font-size: clamp(1.8rem, 2.8vw, 2.8rem); font-weight: 600; color: var(--dark-text); line-height: 1.15; letter-spacing: -0.02em; }
    .voir-tout { font-size: 0.82rem; font-weight: 500; color: var(--sage); text-decoration: none; transition: opacity 0.3s; }
    .voir-tout:hover { opacity: 0.7; }
    .produits-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
    .produit-card { cursor: pointer; }
    .produit-img { position: relative; overflow: hidden; background: var(--ivory-dark); margin-bottom: 1.1rem; }
    .produit-img img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; transition: transform 0.7s ease; }
    .produit-card:hover .produit-img img { transform: scale(1.05); }
    .produit-badge {
      position: absolute; top: 0.9rem; left: 0.9rem;
      font-size: 0.6rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 0.3rem 0.7rem;
    }
    .badge-new { background: var(--forest); color: var(--ivory); }
    .badge-best { background: var(--sage); color: white; }
    .produit-quick {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: rgba(44,61,42,0.9); color: var(--ivory);
      text-align: center; padding: 0.85rem;
      font-size: 0.75rem; font-weight: 500; font-family: var(--font);
      border: none; cursor: pointer; width: 100%;
      transform: translateY(100%); transition: transform 0.32s;
    }
    .produit-card:hover .produit-quick { transform: translateY(0); }
    .produit-name { font-size: 1rem; font-weight: 600; color: var(--dark-text); margin-bottom: 0.35rem; letter-spacing: -0.01em; }
    .produit-desc { font-size: 0.78rem; font-weight: 400; color: var(--mid-text); margin-bottom: 0.6rem; line-height: 1.5; }
    .produit-footer { display: flex; justify-content: space-between; align-items: center; }
    .produit-price { font-size: 1rem; font-weight: 600; color: var(--forest); }
    .produit-stars { font-size: 0.7rem; color: var(--sage); }

    /* BRAND STORY */
    .brand-story {
      background: var(--forest); padding: 9rem 5rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 8rem; align-items: center;
    }
    .story-img-main { aspect-ratio: 4/5; overflow: hidden; }
    .story-img-main img { width: 100%; height: 100%; object-fit: cover; }
    .brand-story .section-label { color: var(--sage); }
    .brand-story h2 { font-size: clamp(1.8rem, 3vw, 3rem); font-weight: 600; color: var(--ivory); line-height: 1.15; margin-bottom: 1.8rem; letter-spacing: -0.02em; }
    .brand-story p { font-size: 0.9rem; font-weight: 400; line-height: 1.85; color: rgba(247,244,239,0.52); margin-bottom: 1.2rem; }
    .story-sign { font-size: 0.85rem; font-weight: 500; color: var(--sage); margin-top: 1.8rem; padding-top: 1.5rem; border-top: 1px solid rgba(247,244,239,0.12); }

    /* VALEURS */
    .valeurs { padding: 8rem 5rem; background: var(--ivory-dark); }
    .valeurs-header { text-align: center; margin-bottom: 5rem; }
    .valeurs h2 { font-size: clamp(1.8rem, 2.8vw, 2.8rem); font-weight: 600; color: var(--dark-text); letter-spacing: -0.02em; }
    .valeurs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(122,144,104,0.15); }
    .valeur-card { background: var(--ivory-dark); padding: 3.5rem 3rem; text-align: center; transition: background 0.3s; }
    .valeur-card:hover { background: var(--ivory); }
    .valeur-num { font-size: 2.8rem; font-weight: 300; color: rgba(122,144,104,0.25); line-height: 1; margin: 0 auto 1.8rem; }
    .valeur-card h3 { font-size: 1.05rem; font-weight: 600; color: var(--dark-text); margin-bottom: 0.9rem; letter-spacing: -0.01em; }
    .valeur-card p { font-size: 0.84rem; font-weight: 400; line-height: 1.8; color: var(--mid-text); }

    /* BESTSELLER FOCUS */
    .bestseller {
      padding: 9rem 5rem;
      display: grid; grid-template-columns: 1.2fr 1fr; gap: 7rem; align-items: center;
    }
    .bestseller-img { overflow: hidden; }
    .bestseller-img img { width: 100%; aspect-ratio: 4/5; object-fit: cover; transition: transform 0.9s; }
    .bestseller-img:hover img { transform: scale(1.04); }
    .bestseller h2 { font-size: clamp(1.8rem, 3vw, 3rem); font-weight: 600; color: var(--dark-text); line-height: 1.15; margin-bottom: 1.3rem; letter-spacing: -0.02em; }
    .bestseller p { font-size: 0.88rem; font-weight: 400; line-height: 1.85; color: var(--mid-text); margin-bottom: 1.1rem; }
    .bestseller-details { display: flex; flex-direction: column; gap: 0.75rem; margin: 2rem 0; padding: 2rem 0; border-top: 1px solid rgba(26,32,24,0.08); border-bottom: 1px solid rgba(26,32,24,0.08); }
    .b-detail { display: flex; gap: 1rem; font-size: 0.82rem; }
    .b-detail strong { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--sage); min-width: 80px; padding-top: 1px; }
    .b-detail span { font-weight: 400; color: var(--mid-text); }
    .bestseller-price { font-size: 1.8rem; font-weight: 600; color: var(--forest); margin-bottom: 1.8rem; letter-spacing: -0.02em; }
    .btn-add {
      background: var(--forest); color: var(--ivory); border: none;
      padding: 1.05rem 2.5rem; font-family: var(--font);
      font-size: 0.82rem; font-weight: 500;
      cursor: pointer; transition: background 0.3s;
      display: inline-flex; align-items: center; gap: 0.8rem;
      border-radius: 2px;
    }
    .btn-add:hover { background: var(--sage); }

    /* FABRICATION */
    .fabrication { background: var(--forest); padding: 9rem 5rem; }
    .fabrication .section-label { color: var(--sage); }
    .fabrication h2 { font-size: clamp(1.8rem, 2.8vw, 2.8rem); font-weight: 600; color: var(--ivory); margin-bottom: 5rem; max-width: 500px; line-height: 1.15; letter-spacing: -0.02em; }
    .fab-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(247,244,239,0.06); }
    .fab-step { background: var(--forest); padding: 3rem 2.5rem; transition: background 0.3s; }
    .fab-step:hover { background: rgba(247,244,239,0.04); }
    .fab-step-num { font-size: 2.5rem; font-weight: 300; color: rgba(122,144,104,0.2); line-height: 1; margin-bottom: 2rem; }
    .fab-step h3 { font-size: 1rem; font-weight: 600; color: var(--ivory); margin-bottom: 0.9rem; letter-spacing: -0.01em; }
    .fab-step p { font-size: 0.82rem; font-weight: 400; line-height: 1.8; color: rgba(247,244,239,0.42); }

    /* TEMOIGNAGES */
    .temoignages { padding: 8rem 5rem; }
    .temoignages-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; flex-wrap: wrap; gap: 1rem; }
    .temoignages h2 { font-size: clamp(1.6rem, 2.3vw, 2.3rem); font-weight: 600; color: var(--dark-text); letter-spacing: -0.02em; }
    .temoignages-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .t-card { padding: 2.2rem; border: 1px solid rgba(122,144,104,0.15); transition: border-color 0.3s, transform 0.3s; }
    .t-card:hover { border-color: var(--sage); transform: translateY(-2px); }
    .t-stars { color: var(--sage); font-size: 0.8rem; letter-spacing: 0.08em; margin-bottom: 1.4rem; }
    .t-card blockquote { font-size: 0.9rem; font-weight: 400; color: var(--dark-text); line-height: 1.75; margin-bottom: 1.8rem; }
    .t-author { display: flex; align-items: center; gap: 1rem; }
    .t-avatar { width: 2.4rem; height: 2.4rem; border-radius: 50%; background: var(--sage); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 600; color: white; flex-shrink: 0; }
    .t-name { font-size: 0.8rem; font-weight: 500; color: var(--dark-text); }
    .t-detail { font-size: 0.7rem; font-weight: 400; color: var(--mid-text); margin-top: 0.15rem; }

    /* NEWSLETTER */
    .newsletter { background: var(--ivory-dark); padding: 7rem 5rem; text-align: center; }
    .newsletter h2 { font-size: clamp(1.6rem, 2.3vw, 2.3rem); font-weight: 600; color: var(--dark-text); margin-bottom: 0.9rem; letter-spacing: -0.02em; }
    .newsletter p { font-size: 0.88rem; font-weight: 400; line-height: 1.7; color: var(--mid-text); margin-bottom: 2.5rem; max-width: 400px; margin-left: auto; margin-right: auto; }
    .newsletter-form { display: flex; max-width: 420px; margin: 0 auto; }
    .newsletter-form input {
      flex: 1; background: white; border: 1px solid rgba(122,144,104,0.22); border-right: none;
      padding: 1rem 1.4rem; font-family: var(--font);
      font-size: 0.88rem; font-weight: 400; color: var(--dark-text); outline: none;
      transition: border-color 0.3s;
    }
    .newsletter-form input:focus { border-color: var(--sage); }
    .newsletter-form button {
      background: var(--forest); color: var(--ivory); border: none;
      padding: 1rem 1.8rem; font-family: var(--font);
      font-size: 0.78rem; font-weight: 500;
      cursor: pointer; transition: background 0.3s; white-space: nowrap;
    }
    .newsletter-form button:hover { background: var(--sage); }
    .newsletter-note { font-size: 0.68rem; font-weight: 400; color: rgba(26,32,24,0.3); margin-top: 1.1rem; }

    /* FOOTER */
    footer { background: var(--forest); }
    .footer-top { display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 4rem; padding: 5rem 5rem 4rem; border-bottom: 1px solid rgba(247,244,239,0.07); }
    .footer-brand-name { font-size: 1.1rem; font-weight: 600; color: var(--ivory); margin-bottom: 1rem; letter-spacing: -0.01em; }
    .footer-brand-desc { font-size: 0.8rem; font-weight: 400; line-height: 1.7; color: rgba(247,244,239,0.32); max-width: 250px; }
    .footer-col h4 { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--sage); margin-bottom: 1.4rem; }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 0.75rem; }
    .footer-col a { font-size: 0.8rem; font-weight: 400; color: rgba(247,244,239,0.38); text-decoration: none; transition: color 0.3s; }
    .footer-col a:hover { color: var(--ivory); }
    .footer-bottom { padding: 1.5rem 5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .footer-copy { font-size: 0.7rem; font-weight: 400; color: rgba(247,244,239,0.2); }
    .footer-fictif { font-size: 0.65rem; font-weight: 400; color: rgba(247,244,239,0.16); text-align: center; }
    .footer-caelestis { font-size: 0.7rem; font-weight: 400; color: rgba(247,244,239,0.2); }
    .footer-caelestis a { color: var(--sage); text-decoration: none; }

    /* REVEAL */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    .reveal[data-d="1"] { transition-delay: 0.1s; }
    .reveal[data-d="2"] { transition-delay: 0.2s; }
    .reveal[data-d="3"] { transition-delay: 0.3s; }

    /* SCREEN-READER ONLY */
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

    /* SKIP LINK */
    .skip-link { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; background: var(--sage); color: white; padding: 0.6rem 1.2rem; font-size: 0.85rem; font-weight: 600; z-index: 9999; text-decoration: none; }
    .skip-link:focus { left: 1rem; top: 1rem; width: auto; height: auto; overflow: visible; outline: 2px solid var(--forest); outline-offset: 2px; }

    /* PREFERS-REDUCED-MOTION */
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
      .produit-img img, .bestseller-img img, .story-img-main img, .hero-right img { transition: none !important; }
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      nav { padding: 1.3rem 2.5rem; }
      nav.scrolled { padding: 0.9rem 2.5rem; }
      .produits, .valeurs, .temoignages, .newsletter, .fabrication { padding: 6rem 2.5rem; }
      .brand-story, .bestseller { padding: 6rem 2.5rem; }
      .footer-top { padding: 4rem 2.5rem 3rem; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      .footer-bottom { padding: 1.2rem 2.5rem; }
    }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-left { padding: 8rem 2rem 4rem; }
      .hero-right { height: 60vw; }
      .produits-grid { grid-template-columns: 1fr 1fr; }
      .brand-story, .bestseller { grid-template-columns: 1fr; gap: 3rem; }
      .valeurs-grid { grid-template-columns: 1fr; }
      .fab-grid { grid-template-columns: 1fr 1fr; }
      .temoignages-grid { grid-template-columns: 1fr; }
      .temoignages-header, .produits-header { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
      .footer-top { grid-template-columns: 1fr; gap: 2.5rem; }
      .footer-bottom { flex-direction: column; text-align: center; }
      .newsletter-form { flex-direction: column; }
      .newsletter-form input { border-right: 1px solid rgba(122,144,104,0.22); border-bottom: none; }
    }
  </style>
</head>
<body>

  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  <!-- NOTICE FICTIF -->
  <div class="notice-fictif">
    <strong>Projet fictif</strong>
    Démonstration des possibilités offertes par <a href="https://caelestis.fr" rel="noopener noreferrer" style="color: var(--sage); text-decoration: none;">Caelestis</a>
  </div>

  <!-- NAV -->
  <nav id="navbar" aria-label="Navigation principale">
    <a href="#" class="nav-logo">Lunéa Botanique</a>
    <ul class="nav-links">
      <li><a href="#boutique">Boutique</a></li>
      <li><a href="#histoire">Notre histoire</a></li>
      <li><a href="#fabrication">Fabrication</a></li>
      <li><a href="#contact-footer">Contact</a></li>
    </ul>
    <div class="nav-basket">
      <span>Panier</span>
      <div class="basket-count">2</div>
    </div>
  </nav>

  <main id="main-content" tabindex="-1">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow">Artisanal · Naturel · Fait en France</div>
      <h1>La nature<br><span>à l'état pur.</span></h1>
      <p class="hero-sub">Des bougies naturelles, des soins botaniques et des objets bien-être fabriqués à la main. Pour ceux qui choisissent le vivant.</p>
      <div class="hero-actions">
        <a href="#boutique" class="btn-primary-hero">Découvrir la boutique →</a>
        <a href="#histoire" class="btn-secondary-hero">Notre histoire</a>
      </div>
    </div>
    <div class="hero-right">
      <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=900&q=80" alt="Bougies naturelles Lunéa Botanique" loading="eager" />
      <div class="hero-badge">
        <div class="hero-badge-text">Fabriqué avec intention</div>
        <div class="hero-badge-sub">Depuis 2019 · Drôme, France</div>
