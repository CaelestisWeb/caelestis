---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const canonical = 'https://caelestis.fr/fiche-google-entreprise';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: "Création et optimisation de fiche Google d'établissement",
  serviceType: 'Référencement local et fiche Google Business Profile',
  description: "Création, récupération et optimisation de votre fiche Google d'établissement : catégories, photos, horaires, description et avis. Pour être trouvé sur Google et sur Maps par les clients de votre secteur.",
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://caelestis.fr/#business',
    name: 'Caelestis',
    url: 'https://caelestis.fr',
    address: { '@type': 'PostalAddress', addressLocality: 'Crest', addressRegion: 'Drôme', postalCode: '26400', addressCountry: 'FR' },
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' },
    { '@type': 'Country', name: 'France' },
  ],
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://caelestis.fr' },
    { '@type': 'ListItem', position: 2, name: 'Fiche Google', item: canonical },
  ],
};

// FAQ affichée en bas de page, le schéma reprend mot pour mot le contenu visible
const faq = [
  {
    q: "Je n'ai pas de site internet, est-ce que ça vaut le coup ?",
    a: "Oui, et c'est même souvent le moyen le plus rapide d'exister en ligne. Une fiche bien remplie affiche votre téléphone, vos horaires, vos photos et l'itinéraire vers chez vous. Beaucoup d'artisans reçoivent leurs premiers appels par là, avant d'avoir un site.",
  },
  {
    q: "Ma fiche existe déjà alors que je ne l'ai jamais créée, c'est normal ?",
    a: "Oui, cela arrive souvent : Google crée parfois une fiche automatiquement à partir d'informations publiques. Le problème, c'est qu'elle est incomplète et que personne ne la contrôle. Nous la récupérons pour vous, afin que vous en repreniez la main.",
  },
  {
    q: "En combien de temps ma fiche est-elle visible ?",
    a: "La fiche elle-même se prépare en quelques jours. Ensuite, Google demande une vérification (par courrier, téléphone ou vidéo) qui prend de quelques jours à quelques semaines. Ce délai dépend de Google, pas de nous, et nous vous accompagnons pendant toute l'étape.",
  },
  {
    q: "Pouvez-vous faire supprimer un avis négatif ?",
    a: "Non, et personne ne le peut. Un avis ne disparaît que s'il enfreint les règles de Google, auquel cas nous le signalons. La bonne réponse à un avis négatif, c'est une réponse posée et professionnelle, puis de nouveaux avis sincères qui rétablissent l'équilibre.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Ce que contient la prestation
const travaux = [
  { t: 'Création ou récupération', d: "On crée votre fiche si elle n'existe pas, ou on récupère celle que Google a générée sans vous, pour que vous en soyez officiellement propriétaire." },
  { t: 'Les bonnes catégories', d: "C'est le réglage le plus décisif : votre catégorie principale détermine sur quelles recherches vous apparaissez. On la choisit avec précision, pas au hasard." },
  { t: 'Une fiche complète', d: "Services, horaires, jours fériés, zone d'intervention, description, moyens de paiement. Google met en avant les fiches complètes et à jour." },
  { t: 'Vos vraies photos', d: "Votre lieu, vos réalisations, votre visage. Ce sont les premières choses que regardent les gens, et elles font souvent la différence avec le concurrent d'à côté." },
  { t: 'Une méthode pour les avis', d: "Comment demander un avis au bon moment, et répondre à tous, y compris aux négatifs. Jamais de faux avis : c'est interdit et cela peut faire suspendre votre fiche." },
];

// Les 3 temps de la mission
const etapes = [
  { n: '01', t: "On regarde l'existant", d: "Votre fiche actuelle si vous en avez une, celles de vos concurrents directs, et les recherches qui comptent dans votre secteur." },
  { n: '02', t: 'On construit la fiche', d: "Création ou récupération, réglages, contenus, photos. Vous validez avant la mise en ligne, comme pour un site." },
  { n: '03', t: 'On vous laisse les clés', d: "La fiche vous appartient. On vous montre comment publier et répondre aux avis, ou on continue de s'en occuper si vous préférez." },
];
---

<BaseLayout
  title="Fiche Google d'établissement, création et optimisation, Caelestis"
  description="Création, récupération et optimisation de votre fiche Google d'établissement : catégories, photos, horaires, avis. Soyez trouvé sur Google et sur Maps dans votre secteur."
  canonical={canonical}
  schema={[schema, breadcrumb, faqSchema]}
>

  <!-- ── Hero ── -->
  <section class="pt-20 pb-16 md:pt-24 px-6 md:px-10 lg:px-20 border-b border-cream-dark section-ambient overflow-hidden relative" style="isolation: isolate;">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-20 -right-24 w-[420px] h-[420px]"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute bottom-0 left-1/4 w-56 h-56"></div>

    <div class="max-w-4xl mx-auto relative text-center">
      <div class="inline-flex items-center gap-2 mb-6" data-reveal>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-sauge"></span>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge">Fiche Google d'établissement</p>
      </div>
      <h1
        class="font-display font-light text-brun leading-[1.06] tracking-tight max-w-3xl mx-auto"
        style="font-size: clamp(2.1rem, 5vw, 3.9rem);"
        data-reveal data-delay="1"
      >
        Votre fiche Google,<br class="hidden sm:block"> <span class="text-sauge">la première chose qu'on voit de vous.</span>
      </h1>
      <p class="font-body text-lg text-brun-mid mt-8 max-w-2xl leading-relaxed mx-auto" data-reveal data-delay="2">
        Avant votre site, avant votre devanture, il y a ce petit encadré qui apparaît sur Google et sur Maps. Nous le créons ou le remettons d'aplomb, pour qu'il donne envie de vous appeler.
      </p>

      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4" data-reveal data-delay="3">
        <Button href="/contact#devis" variant="primary">Faire vérifier ma fiche</Button>
        <Button href="#travaux" variant="outline">Voir ce qu'on met en place</Button>
      </div>
      <p class="font-body text-xs text-brun-mid/75 mt-6" data-reveal data-delay="3">
        Avec ou sans site internet, la fiche fonctionne seule
      </p>
    </div>
  </section>

  <!-- ── En clair ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20" style="background-color: #E8DBC4;">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">En clair</p>
        <h2 class="font-display font-light text-brun leading-[1.15] mb-6" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Ce qui s'affiche quand on cherche votre nom.
        </h2>
        <p class="font-body text-base text-brun-mid leading-relaxed max-w-2xl mx-auto">
          Quand quelqu'un tape votre nom, ou votre métier suivi de sa ville, Google affiche un encadré : vos horaires, votre téléphone, l'itinéraire, vos photos et vos avis. C'est votre fiche d'établissement. Elle est gratuite, mais elle ne sert vraiment que si elle est complète et entretenue.
        </p>
        <p class="font-body text-base text-brun-mid leading-relaxed max-w-2xl mx-auto mt-5">
          Pour un commerce ou un artisan, c'est souvent la page la plus vue de toute sa présence en ligne. Et c'est aussi l'un des cinq piliers du <a href="/referencement-naturel" class="text-[#566339] hover:text-brun underline decoration-sauge/40 underline-offset-2 transition-colors">référencement naturel</a>, celui qui donne les résultats les plus rapides en local.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Ce qu'on met en place (fond vert, blocs interactifs) ── -->
  <section id="travaux" class="py-20 px-6 md:px-10 lg:px-20 bg-brun text-cream section-dark-depth relative overflow-hidden">
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute top-24 -left-24 w-72 h-72"></div>
    <div aria-hidden="true" class="light-blob light-blob-bois pointer-events-none absolute -bottom-10 right-0 w-80 h-80"></div>

    <div class="max-w-3xl mx-auto relative">
      <div class="text-center mb-12" data-reveal>
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">La prestation</p>
        <h2 class="font-display font-light leading-[1.15] mb-5" style="font-size: clamp(1.7rem, 3vw, 2.4rem); color: rgba(237,227,212,0.94);">
          Ce qu'on met en place.
        </h2>
        <p class="font-body text-base leading-relaxed max-w-xl mx-auto" style="color: rgba(237,227,212,0.78);">
          Une fiche vraiment travaillée, pas trois champs remplis à la va-vite.
        </p>
      </div>

      <div class="anat-list max-w-lg mx-auto space-y-2.5" data-reveal data-delay="1">
        {travaux.map((s, i) => (
          <button type="button" class={`anat-block ${i === 0 ? 'is-selected' : ''}`} aria-pressed={i === 0 ? 'true' : 'false'}>
            <span class="anat-title">{s.t}</span>
            <span class="anat-desc">{s.d}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Comment ça se passe ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark">
    <div class="max-w-4xl mx-auto" data-reveal>
      <div class="text-center mb-12">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Comment ça se passe</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Simple, et vous gardez la main.
        </h2>
      </div>

      <!-- 3 temps -->
      <div class="grid sm:grid-cols-3 gap-5 lg:gap-6 mb-12" data-reveal data-delay="1">
        {etapes.map((e) => (
          <div class="text-center">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full font-display text-base text-cream mb-4" style="background: #5A653A; box-shadow: 0 6px 16px rgba(61,79,40,0.22);">{e.n}</span>
            <h3 class="font-display text-lg font-light text-brun mb-2">{e.t}</h3>
            <p class="font-body text-sm text-brun-mid leading-relaxed">{e.d}</p>
          </div>
        ))}
      </div>

      <!-- Le périmètre clair -->
      <div class="max-w-2xl mx-auto bg-cream border border-cream-dark rounded-2xl p-7 lg:p-8 text-center" data-reveal data-delay="2">
        <p class="font-display font-light text-brun leading-none" style="font-size: clamp(1.9rem, 4.5vw, 2.6rem); letter-spacing: -0.02em;">
          <span class="text-sauge">Sur devis</span>
        </p>
        <p class="font-body text-sm text-brun-mid mt-2">selon l'état de votre fiche et votre activité</p>

        <ul class="mt-7 space-y-3 text-left max-w-md mx-auto">
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>La fiche est créée à <strong class="font-semibold text-brun">votre nom</strong> et vous en gardez la propriété, même si nous cessons de travailler ensemble.</span>
          </li>
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>La vérification par Google prend de quelques jours à quelques semaines. Ce délai lui appartient, nous vous accompagnons jusqu'au bout.</span>
          </li>
          <li class="flex items-start gap-3 font-body text-sm text-brun-mid leading-relaxed">
            <span class="sup-check shrink-0 mt-0.5" aria-hidden="true"></span>
            <span>Jamais de faux avis ni de fausse adresse. C'est interdit par Google et cela peut faire suspendre votre fiche du jour au lendemain.</span>
          </li>
        </ul>

        <p class="font-body text-sm text-brun-mid/80 mt-7 pt-6 border-t border-cream-dark">
          Pas encore de site pour aller avec ? On peut commencer par une <a href="/site-une-page" class="text-[#5C6A40] hover:text-brun underline decoration-sauge/40 underline-offset-2 transition-colors">page unique dès 500 €</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="py-20 px-6 md:px-10 lg:px-20 border-t border-cream-dark section-ambient">
    <div class="max-w-2xl mx-auto" data-reveal>
      <div class="text-center mb-10">
        <p class="font-body text-xs tracking-[0.22em] uppercase text-sauge mb-3">Questions fréquentes</p>
        <h2 class="font-display font-light text-brun leading-[1.15]" style="font-size: clamp(1.7rem, 3vw, 2.4rem);">
          Ce qu'on nous demande souvent.
        </h2>
      </div>

      <div class="seo-faq">
        {faq.map((f) => (
          <details class="seo-faq-item">
            <summary class="seo-faq-q">
              <span>{f.q}</span>
              <span class="seo-faq-marque" aria-hidden="true"></span>
            </summary>
            <p class="seo-faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="relative py-20 px-6 md:px-10 lg:px-20 overflow-hidden section-ambient border-t border-cream-dark" data-reveal>
    <div aria-hidden="true" class="light-blob light-blob-sauge pointer-events-none absolute -top-12 right-1/4 w-64 h-64"></div>
    <div aria-hidden="true" class="light-blob light-blob-ocre pointer-events-none absolute -bottom-8 left-1/3 w-56 h-56"></div>

    <div class="max-w-2xl mx-auto text-center relative">
      <svg aria-hidden="true" class="mx-auto mb-6 opacity-20" width="48" height="66" viewBox="0 0 60 100" fill="none">
        <path d="M30 0 C38 16 55 36 50 58 C44 78 30 100 30 100 C30 100 16 78 10 58 C5 36 22 16 30 0Z" fill="#354024"/>
        <path d="M30 98 Q31.5 62 30 4" stroke="#889063" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M30 60 C26 54 20 52 16 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M30 60 C34 54 40 52 44 56" stroke="#4C3D19" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-brun mb-5 leading-[1.1]">
        Votre fiche est-elle<br><span class="text-sauge">à la hauteur&nbsp;?</span>
      </h2>
      <p class="font-body text-base text-brun-mid mb-10 leading-relaxed">
        Donnez-nous le nom de votre entreprise et sa ville. Nous regardons votre fiche actuelle et nous vous disons franchement ce qui mérite d'être corrigé.
      </p>
      <Button href="/contact#devis" variant="primary">Faire vérifier ma fiche</Button>
      <p class="font-body text-xs text-brun-mid/75 mt-6">
        Réponse sous 48h, sans engagement. Partout en <a href="/creation-site-internet-auvergne-rhone-alpes" class="underline decoration-sauge/40 underline-offset-2 hover:text-brun transition-colors">Auvergne-Rhône-Alpes</a>.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  /* Pastille check sauge */
  .sup-check {
    display: block;
    width: 20px;
    height: 20px;
    background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='8' cy='8' r='7.25' stroke='%23889063' stroke-width='1.5'/%3E%3Cpath d='M4.5 8.2 L6.8 10.5 L11.5 5.5' stroke='%23889063' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
  }

  /* ── Blocs sélectionnables (même langage que les autres pages service) ── */
  .anat-block {
    display: block;
    width: 100%;
    text-align: left;
    border: 0;
    border-left: 3px solid #889063;
    border-radius: 12px;
    padding: 14px 20px;
    background: #EDE3D4;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    transition: background 0.45s ease,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.45s ease,
                border-color 0.3s ease,
                border-left-width 0.25s ease;
  }
  .anat-block .anat-title {
    display: block;
    font-family: 'Lora', serif;
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: #3d4f28;
    transition: color 0.3s ease;
  }
  .anat-block .anat-desc {
    display: block;
    margin-top: 3px;
    font-family: 'DM Sans Variable', 'DM Sans', sans-serif;
    font-size: 0.75rem;
    line-height: 1.45;
    color: #6B6040;
    transition: color 0.3s ease;
  }
  .anat-block:hover:not(.is-selected) {
    border-left-width: 6px;
    transform: translateX(3px);
  }
  .anat-block.is-selected {
    background: #5A653A;
    border-left-color: transparent;
    transform: scale(1.025);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.24);
  }
  .anat-block.is-selected .anat-title { color: #EDE3D4; }
  .anat-block.is-selected .anat-desc { color: rgba(237, 227, 212, 0.95); }
  .anat-block:focus-visible {
    outline: 2px solid #EDE3D4;
    outline-offset: 3px;
  }

  /* ── FAQ : accordéons natifs, sobres ── */
  .seo-faq { border-top: 1px solid var(--color-cream-dark); }
  .seo-faq-item { border-bottom: 1px solid var(--color-cream-dark); }
  .seo-faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 4px;
    cursor: pointer;
    list-style: none;
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1.02rem;
    color: var(--color-brun);
    transition: color 0.2s ease;
  }
  .seo-faq-q::-webkit-details-marker { display: none; }
  .seo-faq-q:hover { color: var(--color-sauge-text); }
  .seo-faq-marque {
    position: relative;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }
  .seo-faq-marque::before,
  .seo-faq-marque::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--color-sauge-text);
    transition: transform 0.3s ease;
  }
  .seo-faq-marque::before { width: 14px; height: 1.5px; }
  .seo-faq-marque::after  { width: 1.5px; height: 14px; }
  .seo-faq-item[open] .seo-faq-marque::after { transform: rotate(90deg); }
  .seo-faq-a {
    padding: 0 4px 20px;
    font-family: 'DM Sans Variable', 'DM Sans', sans-serif;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-brun-mid);
    max-width: 60ch;
  }
  .seo-faq-q:focus-visible {
    outline: 2px solid var(--color-sauge-text);
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .anat-block {
      transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    }
    .anat-block:hover:not(.is-selected),
    .anat-block.is-selected { transform: none; }
    .seo-faq-marque::before,
    .seo-faq-marque::after { transition: none; }
  }
</style>

<script>
  /* Blocs : un seul sélectionné à la fois. Délégation sur document, liée une
     seule fois (survit aux View Transitions et sert toutes les pages service). */
  if (!(window as Window & { __anatBound?: boolean }).__anatBound) {
    (window as Window & { __anatBound?: boolean }).__anatBound = true;
    document.addEventListener('click', (e) => {
      const block = (e.target as HTMLElement).closest('.anat-block');
      if (!block) return;
      const list = block.closest('.anat-list');
      if (!list) return;
      list.querySelectorAll('.anat-block').forEach((x) => {
        x.classList.remove('is-selected');
        x.setAttribute('aria-pressed', 'false');
      });
      block.classList.add('is-selected');
      block.setAttribute('aria-pressed', 'true');
    });
  }
</script>
